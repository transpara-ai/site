package views

import "fmt"

// CompletedWork is a task someone finished, shown on their profile.
type CompletedWork struct {
	ID        string
	Title     string
	SpaceSlug string
	SpaceName string
	DoneAt    string // formatted
}

// UserProfile holds data for the public profile page.
type UserProfile struct {
	Name            string
	Kind            string // "human" or "agent"
	TasksDone       int
	OpCount         int
	Endorsements    int
	Endorsers       []string // names of people who endorsed this user
	HasEndorsed     bool     // whether the current viewer has endorsed this user
	ViewerLoggedIn  bool     // whether there's a logged-in viewer
	CompletedWork   []CompletedWork
	RecentOps       []ActivityItem
}

templ ProfilePage(profile UserProfile) {
	@Layout(profile.Name + " — lovyou.ai", profile.Name + "'s profile on lovyou.ai") {
		<div class="space-y-8">
			<div class="reveal flex items-center gap-4" style="--d:0">
				if profile.Kind == "agent" {
					<span class="w-16 h-16 rounded-full bg-violet-500/10 text-violet-400 text-2xl font-bold flex items-center justify-center">
						{ string([]rune(profile.Name)[:1]) }
					</span>
				} else {
					<span class="w-16 h-16 rounded-full bg-brand/10 text-brand text-2xl font-bold flex items-center justify-center">
						{ string([]rune(profile.Name)[:1]) }
					</span>
				}
				<div>
					<h1 class="text-2xl font-light text-warm">{ profile.Name }</h1>
					<div class="flex items-center gap-3 mt-1">
						if profile.Kind == "agent" {
							<span class="text-xs font-medium px-2 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
						}
						<span class="text-sm text-warm-muted">{ fmt.Sprintf("%d tasks completed", profile.TasksDone) }</span>
						<span class="text-sm text-warm-faint">{ fmt.Sprintf("%d actions", profile.OpCount) }</span>
						if profile.Endorsements > 0 {
							<span class="text-sm text-brand">{ fmt.Sprintf("%d endorsements", profile.Endorsements) }</span>
						}
					</div>
				</div>
			</div>
			<!-- Endorse section -->
			<div class="reveal flex items-center gap-4" style="--d:1">
				if profile.ViewerLoggedIn {
					if profile.HasEndorsed {
						<form method="POST" action={ templ.SafeURL("/user/" + profile.Name + "/endorse") }>
							<input type="hidden" name="action" value="unendorse"/>
							<button type="submit" class="text-xs px-4 py-2 bg-brand/15 text-brand rounded-lg hover:bg-brand/25 transition-colors font-medium">
								Endorsed
							</button>
						</form>
					} else {
						<form method="POST" action={ templ.SafeURL("/user/" + profile.Name + "/endorse") }>
							<input type="hidden" name="action" value="endorse"/>
							<button type="submit" class="text-xs px-4 py-2 bg-surface border border-edge text-warm-muted rounded-lg hover:border-brand hover:text-brand transition-colors font-medium">
								Endorse
							</button>
						</form>
					}
				}
				if len(profile.Endorsers) > 0 {
					<div class="text-xs text-warm-faint">
						Endorsed by
						for i, name := range profile.Endorsers {
							<a href={ templ.SafeURL("/user/" + name) } class="text-warm-muted hover:text-brand transition-colors">{ name }</a>
							if i < len(profile.Endorsers) - 1 {
								<span>, </span>
							}
						}
					</div>
				}
			</div>
			if len(profile.CompletedWork) > 0 {
				<div class="reveal-scroll">
					<h2 class="text-lg font-medium text-warm mb-4">Completed work</h2>
					<div class="space-y-2">
						for _, w := range profile.CompletedWork {
							<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", w.SpaceSlug, w.ID)) } class="flex items-center gap-3 p-3 bg-surface rounded-lg border border-edge hover:border-brand/40 transition-all">
								<span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
								<div class="flex-1 min-w-0">
									<span class="text-sm text-warm truncate block">{ w.Title }</span>
									<span class="text-[10px] text-warm-faint">{ w.SpaceName }</span>
								</div>
								<span class="text-[10px] text-warm-faint flex-shrink-0">{ w.DoneAt }</span>
							</a>
						}
					</div>
				</div>
			}
			if len(profile.RecentOps) > 0 {
				<div class="reveal-scroll">
					<h2 class="text-lg font-medium text-warm mb-4">Recent activity</h2>
					<div class="space-y-1">
						for _, item := range profile.RecentOps {
							@activityRow(item)
						}
					</div>
				</div>
			}
		</div>
	}
}
