package graph

import (
	"bytes"
	"encoding/json"
	"fmt"
	"time"

	"github.com/yuin/goldmark"
)

// ── Theme block (shared across app layouts) ─────────────────────

templ themeBlock() {
	<style type="text/tailwindcss">
		@theme {
			--color-brand: #e8a0b8;
			--color-brand-dark: #d4899f;
			--color-void: #09090b;
			--color-surface: #111113;
			--color-elevated: #18181b;
			--color-edge: #1e1e22;
			--color-edge-mid: #2a2a2e;
			--color-edge-strong: #3a3a3f;
			--color-warm: #f0ede8;
			--color-warm-secondary: #c8c4bc;
			--color-warm-muted: #78756e;
			--color-warm-faint: #4a4844;
		}
	</style>
	<style>
		@keyframes breathe {
			0%, 100% { opacity: 0.8; transform: scale(1); }
			50% { opacity: 1; transform: scale(1.03); }
		}
		.brand-breathe { animation: breathe 4s ease-in-out infinite; }
		@media (prefers-reduced-motion: reduce) {
			.brand-breathe { animation: none; }
		}
	</style>
}

// ── AppLayout ───────────────────────────────────────────────────
//
// Two-column layout: sidebar (spaces + lens nav) + main content.

templ appLayout(space Space, spaces []Space, activeLens string, user ViewUser) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ space.Name } — lovyou.ai</title>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			<script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
			@themeBlock()
		</head>
		<body class="bg-void text-warm-secondary h-screen flex flex-col overflow-hidden">
			<header class="border-b border-edge bg-surface flex-shrink-0">
				<nav class="px-4 md:px-6 py-3 flex items-center justify-between">
					<div class="flex items-center gap-2 md:gap-4 min-w-0">
						<a href="/" class="text-xl font-bold text-brand brand-breathe flex-shrink-0">lovyou.ai</a>
						<span class="text-warm-faint hidden md:inline">/</span>
						<a href="/app" class="text-sm font-medium hover:text-brand transition-colors text-warm-muted hidden md:inline">App</a>
						<span class="text-warm-faint">/</span>
						<span class="text-sm text-warm-secondary truncate">{ space.Name }</span>
					</div>
					<div class="hidden md:flex items-center gap-6 text-sm text-warm-muted">
						<a href="/" class="hover:text-brand transition-colors">Home</a>
						<a href="/discover" class="hover:text-brand transition-colors">Discover</a>
						<a href="/blog" class="hover:text-brand transition-colors">Blog</a>
						<a href="/reference" class="hover:text-brand transition-colors">Reference</a>
						if user.Name != "" && user.Name != "Anonymous" {
							<div class="flex items-center gap-2 ml-2 pl-4 border-l border-edge">
								if user.Picture != "" {
									<img src={ user.Picture } class="w-6 h-6 rounded-full" alt={ user.Name } referrerpolicy="no-referrer"/>
								} else {
									<span class="w-6 h-6 rounded-full bg-brand/10 text-brand text-xs font-bold flex items-center justify-center">
										{ initial(user.Name) }
									</span>
								}
								<span class="text-warm-muted text-xs">{ user.Name }</span>
								<form method="POST" action="/auth/logout">
									<button type="submit" class="text-xs text-warm-faint hover:text-red-400 transition-colors">Logout</button>
								</form>
							</div>
						}
					</div>
				</nav>
			</header>
			<!-- Mobile lens bar -->
			<nav class="md:hidden border-b border-edge bg-surface overflow-x-auto flex-shrink-0">
				<div class="flex px-2 py-1.5 gap-1">
					<a href="/app" class="px-2.5 py-1 text-[11px] rounded-md bg-elevated text-warm-faint whitespace-nowrap">My Work</a>
					@mobileLensTab(space.Slug, "board", "Board", activeLens)
					@mobileLensTab(space.Slug, "feed", "Feed", activeLens)
					@mobileLensTab(space.Slug, "threads", "Threads", activeLens)
					@mobileLensTab(space.Slug, "conversations", "Chat", activeLens)
					@mobileLensTab(space.Slug, "people", "People", activeLens)
					@mobileLensTab(space.Slug, "knowledge", "Knowledge", activeLens)
					@mobileLensTab(space.Slug, "governance", "Governance", activeLens)
					@mobileLensTab(space.Slug, "changelog", "Changelog", activeLens)
					@mobileLensTab(space.Slug, "activity", "Activity", activeLens)
					@mobileLensTab(space.Slug, "settings", "Settings", activeLens)
				</div>
			</nav>
			<div class="flex flex-1 min-h-0 overflow-hidden">
				<!-- Sidebar -->
				<aside class="w-60 border-r border-edge bg-surface flex-shrink-0 overflow-y-auto hidden md:block">
					<div class="p-4 space-y-6">
						<!-- Dashboard link -->
						<a href="/app" class="flex items-center gap-2 px-2.5 py-1.5 text-sm rounded-md hover:bg-elevated text-warm-muted transition-colors relative">
							<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
							</svg>
							My Work
							if user.UnreadCount > 0 {
								<span class="ml-auto bg-brand text-void text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0">{ fmt.Sprintf("%d", user.UnreadCount) }</span>
							}
						</a>
						<!-- Lenses -->
						<div>
							<h2 class="text-[10px] font-semibold text-warm-faint uppercase tracking-wider mb-2">Views</h2>
							<nav class="space-y-0.5">
								@lensLink(space.Slug, "board", "Board", activeLens, boardIcon())
								@lensLink(space.Slug, "feed", "Feed", activeLens, feedIcon())
								@lensLink(space.Slug, "threads", "Threads", activeLens, threadsIcon())
								@lensLink(space.Slug, "conversations", "Chat", activeLens, conversationsIcon())
								@lensLink(space.Slug, "people", "People", activeLens, peopleIcon())
								@lensLink(space.Slug, "knowledge", "Knowledge", activeLens, knowledgeIcon())
								@lensLink(space.Slug, "governance", "Governance", activeLens, governanceIcon())
								@lensLink(space.Slug, "changelog", "Changelog", activeLens, changelogIcon())
								@lensLink(space.Slug, "activity", "Activity", activeLens, activityIcon())
								@lensLink(space.Slug, "settings", "Settings", activeLens, settingsIcon())
							</nav>
						</div>
						<!-- Spaces -->
						<div>
							<h2 class="text-[10px] font-semibold text-warm-faint uppercase tracking-wider mb-2">Spaces</h2>
							<nav class="space-y-0.5">
								for _, sp := range spaces {
									<a
										href={ templ.SafeURL("/app/" + sp.Slug) }
										class={ "flex items-center gap-2 px-2.5 py-1.5 text-sm rounded-md transition-colors",
											templ.KV("bg-brand/10 text-brand font-medium", sp.ID == space.ID),
											templ.KV("hover:bg-elevated text-warm-muted", sp.ID != space.ID) }
									>
										<span class="w-1.5 h-1.5 rounded-full bg-brand flex-shrink-0"></span>
										{ sp.Name }
									</a>
								}
							</nav>
							<a
								href="/app"
								class="flex items-center gap-2 px-2.5 py-1.5 mt-1 text-sm text-warm-faint hover:text-brand rounded-md hover:bg-elevated w-full transition-colors"
							>
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
								</svg>
								New space
							</a>
						</div>
					</div>
				</aside>
				<!-- Main content -->
				<main class="flex-1 overflow-y-auto">
					{ children... }
				</main>
			</div>
		</body>
	</html>
}

templ lensLink(spaceSlug, lens, label, activeLens string, icon templ.Component) {
	<a
		href={ templ.SafeURL("/app/" + spaceSlug + "/" + lens) }
		class={ "flex items-center gap-2 px-2.5 py-1.5 text-sm rounded-md transition-colors",
			templ.KV("bg-brand/10 text-brand font-medium", lens == activeLens),
			templ.KV("hover:bg-elevated text-warm-muted", lens != activeLens) }
	>
		@icon
		{ label }
	</a>
}

templ mobileLensTab(spaceSlug, lens, label, activeLens string) {
	<a
		href={ templ.SafeURL("/app/" + spaceSlug + "/" + lens) }
		class={ "px-3 py-1.5 text-xs font-medium rounded-md whitespace-nowrap transition-colors",
			templ.KV("bg-brand/10 text-brand", lens == activeLens),
			templ.KV("text-warm-muted hover:text-warm hover:bg-elevated", lens != activeLens) }
	>
		{ label }
	</a>
}

// ── Icons ───────────────────────────────────────────────────────

templ boardIcon() {
	<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"></path>
	</svg>
}

templ feedIcon() {
	<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2"></path>
	</svg>
}

templ threadsIcon() {
	<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
	</svg>
}

templ conversationsIcon() {
	<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
	</svg>
}

templ peopleIcon() {
	<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
	</svg>
}

templ activityIcon() {
	<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
	</svg>
}

templ settingsIcon() {
	<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
	</svg>
}

templ knowledgeIcon() {
	<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
	</svg>
}

templ changelogIcon() {
	<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
	</svg>
}

templ governanceIcon() {
	<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path>
	</svg>
}

// ── Space index ─────────────────────────────────────────────────

templ Dashboard(spaces []Space, tasks []DashboardTask, convos []DashboardConversation, agentOps []DashboardOp, user ViewUser, defaultSpaceSlug string, agents []string, unreadCount int, taskFilter string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>My Work — lovyou.ai</title>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			@themeBlock()
		</head>
		<body class="bg-void text-warm-secondary min-h-screen flex flex-col">
			@simpleHeader(user)
			<main class="flex-1 max-w-5xl mx-auto px-6 py-8 w-full">
				<div class="flex items-center justify-between mb-8">
					<h1 class="text-2xl font-light text-warm">My Work</h1>
					<div class="flex items-center gap-4">
						<a href="/app/notifications" class="text-xs text-warm-muted hover:text-brand transition-colors relative">
							Notifications
							if unreadCount > 0 {
								<span class="absolute -top-1.5 -right-3 bg-brand text-void text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center">{ fmt.Sprintf("%d", unreadCount) }</span>
							}
						</a>
						<a href="/discover" class="text-xs text-warm-muted hover:text-brand transition-colors">Discover</a>
						<a href="/market" class="text-xs text-warm-muted hover:text-brand transition-colors">Market</a>
						<a href="/app/keys" class="text-xs text-warm-muted hover:text-brand transition-colors">API Keys</a>
					</div>
				</div>
				<!-- Quick chat with Mind -->
				if defaultSpaceSlug != "" && len(agents) > 0 {
					<form method="POST" action={ templ.SafeURL("/app/" + defaultSpaceSlug + "/op") } class="bg-surface border border-brand/20 rounded-lg p-4 flex gap-3 items-end">
						<input type="hidden" name="op" value="converse"/>
						<input type="hidden" name="participants" value={ agents[0] }/>
						<div class="flex-1">
							<label class="text-xs text-warm-muted mb-1 block">Chat with { agents[0] }</label>
							<input
								type="text"
								name="title"
								placeholder="Ask something, assign a task, or just say hi..."
								required
								class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent"
							/>
						</div>
						<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium flex-shrink-0">
							Start chat
						</button>
					</form>
				}
				<!-- Dashboard grid: tasks + conversations on left, agent activity + spaces on right -->
				<div class="grid gap-6 lg:grid-cols-3">
					<div class="lg:col-span-2 space-y-6">
						<!-- My Tasks -->
						<section>
							<div class="flex items-center gap-2 mb-3">
								@dashboardTaskTab("", "Open", taskFilter)
								@dashboardTaskTab("active", "Active", taskFilter)
								@dashboardTaskTab("review", "Review", taskFilter)
								@dashboardTaskTab("done", "Done", taskFilter)
								@dashboardTaskTab("all", "All", taskFilter)
							</div>
							if len(tasks) == 0 {
								<div class="bg-surface rounded-lg border border-edge p-6 text-center">
									if taskFilter == "done" {
										<p class="text-warm-faint text-sm">No completed tasks yet.</p>
									} else if taskFilter == "all" {
										<p class="text-warm-faint text-sm">No tasks yet.</p>
									} else {
										<p class="text-warm-faint text-sm">No tasks in this state.</p>
									}
									<a href="/market" class="text-xs text-brand hover:text-brand-dark mt-2 inline-block">Browse available work</a>
								</div>
							} else {
								<div class="space-y-2">
									for _, t := range tasks {
										@dashboardTaskCard(t)
									}
								</div>
							}
						</section>
						<!-- Conversations -->
						<section>
							<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Conversations</h2>
							if len(convos) == 0 {
								<div class="bg-surface rounded-lg border border-edge p-6 text-center">
									<p class="text-warm-faint text-sm">No active conversations.</p>
								</div>
							} else {
								<div class="space-y-2">
									for _, c := range convos {
										@dashboardConvoCard(c)
									}
								</div>
							}
						</section>
					</div>
					<div class="space-y-6">
						<!-- Agent Activity -->
						<section>
							<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Agent Activity</h2>
							if len(agentOps) == 0 {
								<div class="bg-surface rounded-lg border border-edge p-6 text-center">
									<p class="text-warm-faint text-sm">No agent activity yet.</p>
								</div>
							} else {
								<div class="space-y-1">
									for _, op := range agentOps {
										@dashboardAgentRow(op)
									}
								</div>
							}
						</section>
						<!-- Spaces -->
						<section>
							<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Your Spaces</h2>
							<div class="space-y-2">
								for _, sp := range spaces {
									<a href={ templ.SafeURL("/app/" + sp.Slug) } class="block p-4 bg-surface rounded-lg border border-edge hover:border-brand hover:shadow-md hover:shadow-brand/5 transition-all">
										<div class="flex items-center gap-2">
											<span class={ "text-[10px] font-medium px-2 py-0.5 rounded-full", kindBadgeClass(sp.Kind) }>
												{ sp.Kind }
											</span>
											<span class="text-sm font-medium text-warm">{ sp.Name }</span>
										</div>
									</a>
								}
								<!-- New space -->
								<details class="bg-surface rounded-lg border-2 border-dashed border-edge-mid hover:border-brand transition-all">
									<summary class="p-4 text-sm font-medium text-warm-muted cursor-pointer">+ New space</summary>
									<form action="/app/new" method="POST" class="p-4 pt-0 space-y-3">
										<input type="text" name="name" placeholder="Space name" required
											class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
										<textarea name="description" placeholder="Description (optional)" rows="2"
											class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
										<div class="flex gap-2">
											<select name="kind" class="flex-1 text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand text-warm-secondary">
												<option value="project">Project</option>
												<option value="community">Community</option>
												<option value="team">Team</option>
											</select>
											<select name="visibility" class="flex-1 text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand text-warm-secondary">
												<option value="private">Private</option>
												<option value="public">Public</option>
											</select>
										</div>
										<button type="submit" class="w-full px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
											Create
										</button>
									</form>
								</details>
							</div>
						</section>
					</div>
				</div>
			</main>
			@simpleFooter()
		</body>
	</html>
}

templ dashboardTaskTab(value, label, active string) {
	<a
		href={ templ.SafeURL("/app?tasks=" + value) }
		class={ "text-xs px-3 py-1.5 rounded-lg transition-colors font-medium",
			templ.KV("bg-brand/15 text-brand", value == active),
			templ.KV("bg-elevated text-warm-muted hover:text-warm", value != active) }
	>
		{ label }
	</a>
}

templ dashboardTaskCard(t DashboardTask) {
	<a
		href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", t.SpaceSlug, t.ID)) }
		class="flex items-center gap-3 p-3 bg-surface rounded-lg border border-edge hover:border-brand/40 hover:shadow transition-all"
	>
		<span
			class="w-2 h-2 rounded-full flex-shrink-0"
			style={ fmt.Sprintf("background-color: %s", priorityDotHex(t.Priority)) }
			title={ t.Priority }
		></span>
		<div class="flex-1 min-w-0">
			<span class="text-sm font-medium text-warm truncate block">{ t.Title }</span>
			<div class="flex items-center gap-2 mt-0.5">
				<span class="text-[10px] text-warm-faint">{ t.SpaceName }</span>
				if t.ChildCount > 0 {
					<span class="text-[10px] text-warm-faint">{ fmt.Sprintf("%d/%d subtasks", t.ChildDone, t.ChildCount) }</span>
				}
			</div>
		</div>
		<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", dashboardStateClass(t.State) }>{ t.State }</span>
	</a>
}

templ dashboardConvoCard(c DashboardConversation) {
	<a
		href={ templ.SafeURL(fmt.Sprintf("/app/%s/conversation/%s", c.SpaceSlug, c.ID)) }
		class="block p-3 bg-surface rounded-lg border border-edge hover:border-brand/40 hover:shadow transition-all"
	>
		<div class="flex items-center justify-between mb-1">
			<span class="text-sm font-medium text-warm truncate">{ c.Title }</span>
			<span class="text-[10px] text-warm-faint flex-shrink-0 ml-2">{ dashRelativeTime(c.UpdatedAt) }</span>
		</div>
		if c.LastBody != "" {
			<div class="flex items-center gap-2 text-xs text-warm-muted">
				if c.LastAuthorKind == "agent" {
					<span class="w-4 h-4 rounded-full bg-violet-500/10 text-violet-400 text-[8px] font-bold flex items-center justify-center flex-shrink-0">
						{ initial(c.LastAuthor) }
					</span>
				}
				<span class="truncate">{ truncateBody(c.LastBody, 80) }</span>
			</div>
		}
		<div class="flex items-center gap-2 mt-1">
			<span class="text-[10px] text-warm-faint">{ c.SpaceName }</span>
			if c.ChildCount > 0 {
				<span class="text-[10px] text-warm-faint">{ fmt.Sprintf("%d messages", c.ChildCount) }</span>
			}
		</div>
	</a>
}

templ dashboardAgentRow(item DashboardOp) {
	<div class="flex items-center gap-2 py-1.5 px-2 rounded hover:bg-surface transition-colors text-xs">
		<span class="w-5 h-5 rounded-full bg-violet-500/10 text-violet-400 text-[9px] font-bold flex items-center justify-center flex-shrink-0">
			{ initial(item.Actor) }
		</span>
		<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", opBadgeClass(item.Op.Op) }>{ item.Op.Op }</span>
		if item.NodeTitle != "" && item.NodeID != "" {
			<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", item.SpaceSlug, item.NodeID)) } class="text-warm-secondary hover:text-brand transition-colors truncate">{ truncate(item.NodeTitle, 30) }</a>
		} else {
			<a href={ templ.SafeURL("/app/" + item.SpaceSlug) } class="text-warm-faint hover:text-brand transition-colors truncate">{ item.SpaceName }</a>
		}
		<span class="ml-auto text-warm-faint flex-shrink-0">{ dashRelativeTime(item.CreatedAt) }</span>
	</div>
}

// ── Onboarding ──────────────────────────────────────────────────

templ SpaceOnboarding(user ViewUser) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>Get Started — lovyou.ai</title>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			@themeBlock()
		</head>
		<body class="bg-void text-warm-secondary min-h-screen flex flex-col">
			@simpleHeader(user)
			<main class="flex-1 flex items-center justify-center px-6 py-12">
				<div class="max-w-md w-full bg-surface rounded-xl border border-edge shadow-sm p-8 text-center space-y-6">
					<div>
						<div class="w-12 h-12 rounded-full bg-brand/10 flex items-center justify-center mx-auto mb-4">
							<svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
							</svg>
						</div>
						<h1 class="text-2xl font-light text-warm">Welcome</h1>
						<p class="text-warm-muted mt-2">Create your first space to get started. A space can be a project, community, or team.</p>
					</div>
					<form action="/app/new" method="POST" class="space-y-4 text-left">
						<div>
							<label for="name" class="block text-sm font-medium text-warm-muted mb-1">Space name</label>
							<input type="text" id="name" name="name" placeholder="e.g. lovyou.ai" required autofocus
								class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm placeholder-warm-faint"/>
						</div>
						<div>
							<label for="description" class="block text-sm font-medium text-warm-muted mb-1">Description</label>
							<textarea id="description" name="description" rows="2" placeholder="What is this space about?"
								class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm placeholder-warm-faint"></textarea>
						</div>
						<div>
							<label for="kind" class="block text-sm font-medium text-warm-muted mb-1">Type</label>
							<select id="kind" name="kind" class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand text-sm text-warm-secondary">
								<option value="project">Project — tasks, board, deadlines</option>
								<option value="community">Community — posts, discussions, people</option>
								<option value="team">Team — all of the above</option>
							</select>
						</div>
						<div>
							<label for="visibility" class="block text-sm font-medium text-warm-muted mb-1">Visibility</label>
							<select id="visibility" name="visibility" class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand text-sm text-warm-secondary">
								<option value="private">Private — only you can see</option>
								<option value="public">Public — anyone can view</option>
							</select>
						</div>
						<button type="submit" class="w-full px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
							Create space
						</button>
					</form>
					<div class="pt-2 border-t border-edge">
						<p class="text-sm text-warm-faint">
							Or <a href="/discover" class="text-brand hover:underline">explore existing spaces</a> to see what others are building.
						</p>
					</div>
				</div>
			</main>
			@simpleFooter()
		</body>
	</html>
}

// ── Space overview ───────────────────────────────────────────────

templ SpaceOverview(space Space, spaces []Space, pinned []Node, recentOps []Op, user ViewUser, isOwner bool, memberCount, openTasks, activeTasks, doneTasks int, members []SpaceMember, isMember bool, loggedIn bool) {
	@appLayout(space, spaces, "", user) {
		<div class="p-6 md:p-8 space-y-6 max-w-3xl mx-auto">
			<div>
				<h1 class="text-2xl font-light text-warm">{ space.Name }</h1>
				if space.Description != "" {
					<p class="text-warm-muted mt-2">{ space.Description }</p>
				}
				<div class="flex items-center gap-4 mt-3 text-xs text-warm-faint">
					<span class={ "font-medium px-2 py-0.5 rounded-full", kindBadgeClass(space.Kind) }>{ space.Kind }</span>
					<span>{ fmt.Sprintf("%d members", memberCount) }</span>
					<span>{ fmt.Sprintf("%d open · %d active · %d done", openTasks, activeTasks, doneTasks) }</span>
				</div>
				if loggedIn && !isMember && !isOwner {
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="mt-3">
						<input type="hidden" name="op" value="join"/>
						<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
							Join this space
						</button>
					</form>
				}
				if isMember && !isOwner {
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="mt-3">
						<input type="hidden" name="op" value="leave"/>
						<button type="submit" class="text-xs text-warm-faint hover:text-red-400 transition-colors">Leave this space</button>
					</form>
				}
			</div>
			<!-- Quick links to lenses -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-2">
				@overviewLensLink(space.Slug, "board", "Board", fmt.Sprintf("%d tasks", openTasks+activeTasks))
				@overviewLensLink(space.Slug, "feed", "Feed", "Posts & updates")
				@overviewLensLink(space.Slug, "conversations", "Chat", "Conversations")
				@overviewLensLink(space.Slug, "governance", "Governance", "Proposals")
			</div>
			<!-- Members -->
			if len(members) > 0 {
				<section>
					<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Members</h2>
					<div class="flex flex-wrap gap-2">
						for _, m := range members {
							<a href={ templ.SafeURL("/user/" + m.UserName) } class="flex items-center gap-1.5 px-2.5 py-1.5 bg-surface rounded-lg border border-edge hover:border-brand/40 transition-all text-xs">
								if m.Kind == "agent" {
									<span class="w-5 h-5 rounded-full bg-violet-500/10 text-violet-400 text-[9px] font-bold flex items-center justify-center">{ initial(m.UserName) }</span>
								} else {
									<span class="w-5 h-5 rounded-full bg-brand/10 text-brand text-[9px] font-bold flex items-center justify-center">{ initial(m.UserName) }</span>
								}
								<span class="text-warm">{ m.UserName }</span>
								if m.Kind == "agent" {
									<span class="text-[8px] px-1 py-0.5 rounded bg-violet-500/10 text-violet-400">agent</span>
								}
							</a>
						}
					</div>
				</section>
			}
			<!-- Pinned content -->
			if len(pinned) > 0 {
				<section>
					<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Pinned</h2>
					<div class="space-y-2">
						for _, n := range pinned {
							<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, n.ID)) } class="flex items-center gap-2 p-3 bg-surface rounded-lg border border-brand/20 hover:border-brand/40 transition-all">
								<span class="text-brand flex-shrink-0">
									<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 5a2 2 0 012-2h6a2 2 0 012 2v2a2 2 0 01-2 2H7a2 2 0 01-2-2V5zm2 10v3a1 1 0 002 0v-3h2v3a1 1 0 002 0v-3h1a1 1 0 000-2H6a1 1 0 000 2h1z"></path></svg>
								</span>
								<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", kindBadgeClass(n.Kind) }>{ n.Kind }</span>
								<span class="text-sm text-warm">{ n.Title }</span>
							</a>
						}
					</div>
				</section>
			}
			<!-- Recent activity -->
			if len(recentOps) > 0 {
				<section>
					<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Recent activity</h2>
					<div class="space-y-1">
						for _, o := range recentOps {
							<div class="flex items-center gap-2 py-1.5 px-2 text-xs text-warm-faint">
								<span class="font-medium text-warm">{ o.Actor }</span>
								<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", opBadgeClass(o.Op) }>{ o.Op }</span>
								<span class="ml-auto">{ dashRelativeTime(o.CreatedAt) }</span>
							</div>
						}
					</div>
					<a href={ templ.SafeURL("/app/" + space.Slug + "/activity") } class="text-xs text-warm-faint hover:text-brand transition-colors mt-2 inline-block">View all activity</a>
				</section>
			}
		</div>
	}
}

templ overviewLensLink(slug, lens, label, subtitle string) {
	<a href={ templ.SafeURL("/app/" + slug + "/" + lens) } class="p-3 bg-surface rounded-lg border border-edge hover:border-brand/40 hover:shadow transition-all text-center">
		<span class="text-sm font-medium text-warm block">{ label }</span>
		<span class="text-[10px] text-warm-faint">{ subtitle }</span>
	</a>
}

// ── Notifications ────────────────────────────────────────────────

templ NotificationsView(notifs []Notification, user ViewUser) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>Notifications — lovyou.ai</title>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			@themeBlock()
		</head>
		<body class="bg-void text-warm-secondary min-h-screen flex flex-col">
			@simpleHeader(user)
			<main class="flex-1 max-w-3xl mx-auto px-6 py-8 w-full">
				<div class="flex items-center justify-between mb-6">
					<h1 class="text-2xl font-light text-warm">Notifications</h1>
					<a href="/app" class="text-xs text-warm-muted hover:text-brand transition-colors">Back to dashboard</a>
				</div>
				if len(notifs) == 0 {
					<div class="text-center py-16">
						<p class="text-warm-muted">No notifications yet.</p>
						<p class="text-warm-faint text-sm mt-2">You'll see updates here when someone assigns you a task or messages you.</p>
					</div>
				} else {
					<div class="space-y-1">
						for _, n := range notifs {
							<div class={ "flex items-center gap-3 py-3 px-4 rounded-lg text-sm",
								templ.KV("bg-surface border border-brand/20", !n.Read),
								templ.KV("text-warm-muted", n.Read) }>
								if !n.Read {
									<span class="w-2 h-2 rounded-full bg-brand flex-shrink-0"></span>
								} else {
									<span class="w-2 h-2 flex-shrink-0"></span>
								}
								<span class="flex-1">{ n.Message }</span>
								if n.SpaceSlug != "" {
									<a href={ templ.SafeURL("/app/" + n.SpaceSlug) } class="text-xs text-warm-faint hover:text-brand transition-colors flex-shrink-0">{ n.SpaceName }</a>
								}
								<span class="text-xs text-warm-faint flex-shrink-0">{ dashRelativeTime(n.CreatedAt) }</span>
							</div>
						}
					</div>
				}
			</main>
			@simpleFooter()
		</body>
	</html>
}

// ── Board view (kanban) ─────────────────────────────────────────

templ BoardView(space Space, spaces []Space, columns []BoardColumn, user ViewUser, isOwner bool, agents []string, searchQuery string, assigneeFilter string) {
	@appLayout(space, spaces, "board", user) {
		<div class="p-4 md:p-6 h-full flex flex-col">
			<div class="flex items-center justify-between mb-4 md:mb-6 gap-2">
				<div class="flex items-center gap-4 min-w-0">
					<h1 class="text-lg md:text-xl font-medium text-warm truncate">{ space.Name }</h1>
					if space.Description != "" {
						<p class="text-sm text-warm-faint hidden lg:block">{ space.Description }</p>
					}
				</div>
				if user.Name != "" && user.Name != "Anonymous" {
					<button
						onclick="document.getElementById('new-task-form').classList.toggle('hidden')"
						class="flex items-center gap-1.5 px-3 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium"
					>
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
						</svg>
						New task
					</button>
				}
			</div>
			<!-- Filters -->
			<form action={ templ.SafeURL("/app/" + space.Slug + "/board") } method="GET" class="flex gap-2 mb-3 flex-shrink-0">
				<input
					type="text"
					name="q"
					value={ searchQuery }
					placeholder="Search tasks..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"
				/>
				<select name="assignee" class="px-2 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm-secondary focus:outline-none focus:ring-1 focus:ring-brand"
					onchange="this.form.submit()">
					<option value="">All assignees</option>
					for _, a := range agents {
						<option value={ a } selected?={ a == assigneeFilter }>{ a }</option>
					}
				</select>
				if searchQuery != "" || assigneeFilter != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/board") } class="px-2 py-1.5 text-xs text-warm-faint hover:text-brand transition-colors flex items-center">Clear</a>
				}
			</form>
			if boardEmpty(columns) && user.Name != "" && user.Name != "Anonymous" && searchQuery == "" && assigneeFilter == "" {
				@boardOnboarding(space.Slug, agents)
			} else {
				<div class="flex gap-4 flex-1 overflow-x-auto pb-4">
					for _, col := range columns {
						@boardColumn(space.Slug, col, user.Name != "" && user.Name != "Anonymous", agents)
					}
				</div>
			}
		</div>
	}
}

templ boardOnboarding(spaceSlug string, agents []string) {
	<div class="flex-1 flex items-center justify-center">
		<div class="max-w-md text-center space-y-6 py-12">
			<div>
				<h2 class="text-xl font-light text-warm">Welcome to your space</h2>
				<p class="text-sm text-warm-muted mt-2">Here's how to get started:</p>
			</div>
			<div class="grid gap-3 text-left">
				<div class="bg-surface border border-edge rounded-lg p-4">
					<div class="flex items-center gap-3">
						<span class="w-8 h-8 rounded-full bg-indigo-500/10 text-indigo-400 text-sm font-bold flex items-center justify-center flex-shrink-0">1</span>
						<div>
							<p class="text-sm font-medium text-warm">Create a task</p>
							<p class="text-xs text-warm-muted">Click "New task" above. Describe what you want done.</p>
						</div>
					</div>
				</div>
				if len(agents) > 0 {
					<div class="bg-surface border border-edge rounded-lg p-4">
						<div class="flex items-center gap-3">
							<span class="w-8 h-8 rounded-full bg-violet-500/10 text-violet-400 text-sm font-bold flex items-center justify-center flex-shrink-0">2</span>
							<div>
								<p class="text-sm font-medium text-warm">Assign it to { agents[0] }</p>
								<p class="text-xs text-warm-muted">The AI agent will decompose it into subtasks and work through them.</p>
							</div>
						</div>
					</div>
				}
				<div class="bg-surface border border-edge rounded-lg p-4">
					<div class="flex items-center gap-3">
						<span class="w-8 h-8 rounded-full bg-emerald-500/10 text-emerald-400 text-sm font-bold flex items-center justify-center flex-shrink-0">3</span>
						<div>
							<p class="text-sm font-medium text-warm">Watch it happen</p>
							<p class="text-xs text-warm-muted">Tasks update in real time. You'll get a notification when it's done.</p>
						</div>
					</div>
				</div>
			</div>
			<a href={ templ.SafeURL("/app/" + spaceSlug + "/conversations") } class="text-xs text-warm-faint hover:text-brand transition-colors">
				Or start a conversation with the agent instead
			</a>
		</div>
	</div>
}

templ boardColumn(spaceSlug string, col BoardColumn, canWrite bool, agents []string) {
	<div class="w-[280px] flex-shrink-0 flex flex-col">
		<div class="flex items-center gap-2 mb-3 px-1">
			<span
				class="w-2 h-2 rounded-full flex-shrink-0"
				style={ fmt.Sprintf("background-color: %s", stateColorHex(col.State)) }
			></span>
			<h2 class="text-sm font-medium text-warm-muted">{ col.Label }</h2>
			<span class="text-xs text-warm-faint bg-elevated rounded-full px-1.5 py-0.5 min-w-[1.25rem] text-center">
				{ fmt.Sprintf("%d", len(col.Nodes)) }
			</span>
		</div>
		<div
			id={ col.State + "-column" }
			class="flex-1 space-y-2 overflow-y-auto rounded-lg bg-elevated/60 p-2 min-h-[200px]"
		>
			if col.State == StateOpen && canWrite {
				@newTaskInline(spaceSlug, agents)
			}
			for _, node := range col.Nodes {
				@TaskCard(node, spaceSlug)
			}
		</div>
	</div>
}

templ newTaskInline(spaceSlug string, agents []string) {
	<div id="new-task-form" class="hidden mb-2">
		<form
			hx-post={ "/app/" + spaceSlug + "/op" }
			hx-target={ "#" + StateOpen + "-column" }
			hx-swap="afterbegin"
			hx-on::after-request="if(event.detail.successful) { this.reset(); document.getElementById('new-task-form').classList.add('hidden'); }"
			class="bg-surface rounded-lg border border-edge shadow-sm p-3 space-y-2"
		>
			<input type="hidden" name="op" value="intend"/>
			<input type="text" name="title" placeholder="Task title" required
				class="w-full text-sm px-2 py-1.5 bg-elevated border border-edge rounded-md focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
			<div>
				<input type="text" name="assignee" id="task-assignee" placeholder="Assign to..."
					class="w-full text-sm px-2 py-1.5 bg-elevated border border-edge rounded-md focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
				if len(agents) > 0 {
					<div class="flex items-center gap-1 mt-1">
						for _, agent := range agents {
							<button type="button"
								class="text-[10px] px-1.5 py-0.5 rounded-full bg-violet-500/10 text-violet-400 border border-violet-500/20 hover:bg-violet-500/20 transition-colors"
								onclick={ setAssignee(agent) }
							>{ agent }</button>
						}
					</div>
				}
			</div>
			<div class="flex items-center gap-2">
				<select name="priority" class="text-xs px-2 py-1 bg-elevated border border-edge rounded-md focus:outline-none focus:ring-2 focus:ring-brand text-warm-muted">
					<option value="medium">Medium</option>
					<option value="low">Low</option>
					<option value="high">High</option>
					<option value="urgent">Urgent</option>
				</select>
				<input type="date" name="due_date" class="text-xs px-2 py-1 bg-elevated border border-edge rounded-md focus:outline-none focus:ring-2 focus:ring-brand text-warm-muted" title="Due date (optional)"/>
				<div class="flex-1"></div>
				<button type="button" onclick="document.getElementById('new-task-form').classList.add('hidden')" class="text-xs text-warm-faint hover:text-warm-muted px-2 py-1">Cancel</button>
				<button type="submit" class="text-xs px-3 py-1 bg-brand text-void rounded-md hover:bg-brand-dark transition-colors font-medium">Create</button>
			</div>
		</form>
	</div>
}

script setAssignee(name string) {
	document.getElementById('task-assignee').value = name;
}

script toggleForm(id string) {
	var el = document.getElementById(id);
	if (!el) return;
	// Hide sibling forms first (only one open at a time).
	var parent = el.parentElement;
	parent.querySelectorAll('form[id]').forEach(function(f) {
		if (f.id !== id) f.classList.add('hidden');
	});
	el.classList.toggle('hidden');
}

templ TaskCard(node Node, spaceSlug string) {
	<a
		href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.ID)) }
		id={ "node-" + node.ID }
		class="block bg-surface rounded-lg border border-edge shadow-sm p-3 hover:border-brand/40 hover:shadow transition-all cursor-pointer"
	>
		<div class="flex items-start gap-2">
			if node.Pinned {
				<span class="text-brand mt-0.5 flex-shrink-0" title="Pinned">
					<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 5a2 2 0 012-2h6a2 2 0 012 2v2a2 2 0 01-2 2H7a2 2 0 01-2-2V5zm2 10v3a1 1 0 002 0v-3h2v3a1 1 0 002 0v-3h1a1 1 0 000-2H6a1 1 0 000 2h1z"></path></svg>
				</span>
			} else {
				<span
					class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0"
					style={ fmt.Sprintf("background-color: %s", priorityDotHex(node.Priority)) }
					title={ node.Priority }
				></span>
			}
			<span class="text-sm font-medium text-warm leading-snug">{ node.Title }</span>
		</div>
		if node.ChildCount > 0 {
			<div class="mt-2 ml-4">
				<div class="flex items-center gap-1.5 text-[10px] text-warm-faint">
					<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
					</svg>
					{ fmt.Sprintf("%d/%d", node.ChildDone, node.ChildCount) }
				</div>
				<div class="w-full bg-elevated rounded-full h-1 mt-1">
					<div class="bg-brand rounded-full h-1 transition-all" style={ childProgress(node) }></div>
				</div>
			</div>
		}
		<div class="flex items-center justify-between mt-2 ml-4">
			<div class="flex items-center gap-2">
				if node.AuthorKind == "agent" {
					<span class="w-5 h-5 rounded-full bg-violet-500/10 text-violet-400 text-[10px] font-bold flex items-center justify-center" title={ node.Author }>
						{ initial(node.Author) }
					</span>
				} else if node.Assignee == "" || node.Author != node.Assignee {
					<span class="w-5 h-5 rounded-full bg-warm-faint/20 text-warm-faint text-[10px] font-bold flex items-center justify-center" title={ node.Author }>
						{ initial(node.Author) }
					</span>
				}
				if node.Assignee != "" {
					if node.Author != node.Assignee {
						<span class="text-[10px] text-warm-faint">→</span>
					}
					<span class="w-5 h-5 rounded-full bg-brand/10 text-brand text-[10px] font-bold flex items-center justify-center" title={ node.Assignee }>
						{ initial(node.Assignee) }
					</span>
				}
				if node.DueDate != nil {
					<span class="text-[10px] text-warm-faint">{ node.DueDate.Format("Jan 2") }</span>
				}
			</div>
			if node.BlockerCount > 0 {
				<span class="text-[10px] px-1.5 py-0.5 rounded bg-red-500/10 text-red-400" title={ fmt.Sprintf("%d blocker(s)", node.BlockerCount) }>
					{ fmt.Sprintf("%d blocked", node.BlockerCount) }
				</span>
			}
		</div>
	</a>
}

// ── Feed view ───────────────────────────────────────────────────

templ FeedView(space Space, spaces []Space, posts []Node, user ViewUser, isOwner bool, hasAgent bool) {
	@appLayout(space, spaces, "feed", user) {
		<div class="max-w-2xl mx-auto p-6 space-y-6">
			<div class="flex items-center justify-between">
				<h1 class="text-xl font-medium text-warm">Feed</h1>
			</div>
			if hasAgent && user.Name != "" && user.Name != "Anonymous" {
				<a href={ templ.SafeURL("/app/" + space.Slug + "/conversations") }
					class="block p-4 bg-violet-500/5 border border-violet-500/20 rounded-lg hover:bg-violet-500/10 transition-colors">
					<div class="flex items-center gap-3">
						<span class="w-8 h-8 rounded-full bg-violet-500/10 text-violet-400 text-sm font-bold flex items-center justify-center flex-shrink-0">
							<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"></circle></svg>
						</span>
						<div>
							<p class="text-sm font-medium text-violet-300">Chat with an AI agent</p>
							<p class="text-xs text-warm-faint">Start a conversation — the Mind responds in real time</p>
						</div>
					</div>
				</a>
			}
			if user.Name != "" && user.Name != "Anonymous" {
				<!-- New post form -->
				<form
					hx-post={ "/app/" + space.Slug + "/op" }
					hx-target="#feed-items"
					hx-swap="afterbegin"
					hx-on::after-request="if(event.detail.successful) this.reset()"
					class="bg-surface rounded-lg border border-edge p-4 space-y-3"
				>
					<input type="hidden" name="op" value="express"/>
					<input type="text" name="title" placeholder="Title (optional)" class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
					<textarea name="body" placeholder="What's on your mind?" rows="3" required class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
					<div class="flex justify-end">
						<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Post</button>
					</div>
				</form>
			}
			<div id="feed-items" class="space-y-4">
				for _, post := range posts {
					@FeedCard(post, space.Slug)
				}
				if len(posts) == 0 {
					<p class="text-center text-warm-faint py-8">No posts yet. Share something!</p>
				}
			</div>
		</div>
	}
}

templ FeedCard(node Node, spaceSlug string) {
	<div class={ "bg-surface rounded-lg border p-5", templ.KV("border-brand/30", node.Pinned), templ.KV("border-edge", !node.Pinned) }>
		if node.Pinned {
			<div class="flex items-center gap-1 text-[10px] text-brand font-medium mb-2">
				<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 5a2 2 0 012-2h6a2 2 0 012 2v2a2 2 0 01-2 2H7a2 2 0 01-2-2V5zm2 10v3a1 1 0 002 0v-3h2v3a1 1 0 002 0v-3h1a1 1 0 000-2H6a1 1 0 000 2h1z"></path></svg>
				Pinned
			</div>
		}
		<div class="flex items-center gap-2 mb-3">
			if node.AuthorKind == "agent" {
				<span class="w-7 h-7 rounded-full bg-violet-500/10 text-violet-400 text-xs font-bold flex items-center justify-center" title="Agent">
					{ initial(node.Author) }
				</span>
			} else {
				<span class="w-7 h-7 rounded-full bg-brand/10 text-brand text-xs font-bold flex items-center justify-center">
					{ initial(node.Author) }
				</span>
			}
			<div class="flex items-center gap-1.5">
				<span class="text-sm font-medium text-warm">{ node.Author }</span>
				if node.AuthorKind == "agent" {
					<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
				}
				<span class="text-xs text-warm-faint ml-1">{ node.CreatedAt.Format("Jan 2, 3:04 PM") }</span>
			</div>
		</div>
		if node.Title != "" {
			<h3 class="font-medium text-warm mb-1">{ node.Title }</h3>
		}
		<div class="text-sm text-warm-secondary prose prose-invert prose-sm max-w-none">
			@renderMarkdown(node.Body)
		</div>
		<div class="mt-3 flex items-center gap-4 text-xs text-warm-faint">
			<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.ID)) } class="hover:text-brand transition-colors">
				{ fmt.Sprintf("%d replies", node.ChildCount) }
			</a>
		</div>
	</div>
}

// ── Threads view ────────────────────────────────────────────────

templ ThreadsView(space Space, spaces []Space, threads []Node, user ViewUser, isOwner bool) {
	@appLayout(space, spaces, "threads", user) {
		<div class="max-w-2xl mx-auto p-6 space-y-6">
			<div class="flex items-center justify-between">
				<h1 class="text-xl font-medium text-warm">Threads</h1>
			</div>
			if user.Name != "" && user.Name != "Anonymous" {
				<!-- New thread form -->
				<form action={ templ.SafeURL("/app/" + space.Slug + "/op") } method="POST" class="bg-surface rounded-lg border border-edge p-4 space-y-3">
					<input type="hidden" name="op" value="discuss"/>
					<input type="text" name="title" placeholder="Discussion topic" required class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
					<textarea name="body" placeholder="Start the conversation..." rows="3" class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
					<div class="flex justify-end">
						<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Start thread</button>
					</div>
				</form>
			}
			<div class="space-y-2">
				for _, thread := range threads {
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, thread.ID)) }
						class="block bg-surface rounded-lg border border-edge p-4 hover:border-brand/40 hover:shadow transition-all">
						<div class="flex items-center justify-between">
							<h3 class="font-medium text-warm">{ thread.Title }</h3>
							<span class="text-xs text-warm-faint">{ fmt.Sprintf("%d replies", thread.ChildCount) }</span>
						</div>
						if thread.Body != "" {
							<p class="text-sm text-warm-muted mt-1 line-clamp-2">{ thread.Body }</p>
						}
						<div class="flex items-center gap-2 mt-2 text-xs text-warm-faint">
							if thread.AuthorKind == "agent" {
								<span class="text-violet-400">{ thread.Author }</span>
								<span class="text-[9px] font-medium px-1 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
							} else {
								<span>{ thread.Author }</span>
							}
							<span>{ thread.CreatedAt.Format("Jan 2") }</span>
							if thread.ChildCount > 0 {
								<span class="text-warm-muted">{ fmt.Sprintf("%d replies", thread.ChildCount) }</span>
							}
						</div>
					</a>
				}
				if len(threads) == 0 {
					<p class="text-center text-warm-faint py-8">No threads yet. Start a discussion!</p>
				}
			</div>
		</div>
	}
}

// ── Conversations view ──────────────────────────────────────────

script addParticipant(name string) {
	var input = document.getElementById('participants-input');
	var current = input.value.split(',').map(function(s) { return s.trim(); }).filter(Boolean);
	if (current.indexOf(name) === -1) {
		current.push(name);
	}
	input.value = current.join(', ');
	input.focus();
}

templ ConversationsView(space Space, spaces []Space, convos []ConversationSummary, user ViewUser, agents []string, nameMap map[string]string) {
	@appLayout(space, spaces, "conversations", user) {
		<div class="max-w-2xl mx-auto p-6 space-y-6">
			<div class="flex items-center justify-between">
				<h1 class="text-xl font-medium text-warm">Conversations</h1>
			</div>
			if user.Name != "" && user.Name != "Anonymous" {
				<!-- New conversation form -->
				<form
					action={ templ.SafeURL("/app/" + space.Slug + "/op") }
					method="POST"
					class="bg-surface rounded-lg border border-edge p-4 space-y-3"
				>
					<input type="hidden" name="op" value="converse"/>
					<input type="text" name="title" placeholder="Conversation name" required class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
					<div>
						<input id="participants-input" type="text" name="participants" placeholder="Add participants by name" class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
						if len(agents) > 0 {
							<div class="flex items-center gap-2 mt-2">
								<span class="text-[10px] text-warm-faint">Add:</span>
								for _, agent := range agents {
									<button
										type="button"
										class="text-xs px-2 py-0.5 rounded-full bg-violet-500/10 text-violet-400 border border-violet-500/20 hover:bg-violet-500/20 transition-colors"
										onclick={ addParticipant(agent) }
									>
										{ agent }
									</button>
								}
							</div>
						}
					</div>
					<div class="flex justify-end">
						<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Start conversation</button>
					</div>
				</form>
			}
			<div class="space-y-2">
				for _, convo := range convos {
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/conversation/%s", space.Slug, convo.ID)) }
						class="block bg-surface rounded-lg border border-edge p-4 hover:border-brand/40 hover:shadow transition-all">
						<div class="flex items-center justify-between mb-1">
							<h3 class="font-medium text-warm">{ convo.Title }</h3>
							<span class="text-xs text-warm-faint">{ fmt.Sprintf("%d messages", convo.ChildCount) }</span>
						</div>
						if convo.LastBody != "" {
							<p class="text-sm text-warm-muted mt-1 line-clamp-1">
								if convo.LastAuthorKind == "agent" {
									<span class="text-violet-400">{ convo.LastAuthor }:</span>
								} else {
									<span class="text-warm-faint">{ convo.LastAuthor }:</span>
								}
								{ " " + truncate(convo.LastBody, 120) }
							</p>
						}
						<div class="flex items-center gap-2 text-xs text-warm-faint mt-1">
							<div class="flex items-center gap-1">
								for i, tag := range convo.Tags {
									if i > 0 {
										<span class="text-warm-faint">·</span>
									}
									<span class="text-warm-muted">{ resolveName(tag, nameMap) }</span>
								}
							</div>
							if convo.ChildCount > 0 {
								<span class="text-warm-muted ml-auto mr-2">{ fmt.Sprintf("%d msgs", convo.ChildCount) }</span>
							}
							<span class={ templ.KV("ml-auto", convo.ChildCount == 0) }>{ convo.UpdatedAt.Format("Jan 2, 3:04 PM") }</span>
						</div>
					</a>
				}
				if len(convos) == 0 {
					<p class="text-center text-warm-faint py-8">No conversations yet. Start one above!</p>
				}
			</div>
		</div>
	}
}

// ── Conversation detail view ────────────────────────────────────

templ ConversationDetailView(space Space, convo Node, messages []Node, user ViewUser, userID string, hasAgent bool, nameMap map[string]string) {
	@appLayout(space, []Space{space}, "conversations", user) {
		<div class="flex flex-col h-full">
			<!-- Conversation header -->
			<div class="border-b border-edge bg-surface px-6 py-3 flex-shrink-0">
				<div class="max-w-2xl mx-auto flex items-center justify-between">
					<div>
						<div class="flex items-center gap-2">
							<a href={ templ.SafeURL("/app/" + space.Slug + "/conversations") } class="text-warm-faint hover:text-brand transition-colors">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
								</svg>
							</a>
							<h1 class="text-lg font-medium text-warm">{ convo.Title }</h1>
						</div>
						<div class="flex items-center gap-1 mt-0.5 text-xs text-warm-faint">
							for i, tag := range convo.Tags {
								if i > 0 {
									<span>·</span>
								}
								<span class="text-warm-muted">{ resolveName(tag, nameMap) }</span>
							}
						</div>
					</div>
				</div>
			</div>

			<!-- Messages -->
			<div id="messages" class="flex-1 overflow-y-auto px-6 py-4">
				<div
					id="message-list"
					class="max-w-2xl mx-auto space-y-3"
					data-last-ts={ lastMessageTS(messages) }
					if hasAgent {
						data-has-agent="true"
					}
				>
					if len(messages) == 0 {
						<p id="empty-state" class="text-center text-warm-faint py-12">No messages yet. Start the conversation!</p>
					}
					for _, msg := range messages {
						@chatMessage(msg, userID)
					}
				</div>
				<!-- Thinking indicator (hidden by default) -->
				if hasAgent {
					<div id="thinking" class="max-w-2xl mx-auto mt-3 hidden">
						<div class="flex gap-3">
							<span class="w-8 h-8 rounded-full bg-violet-500/10 text-violet-400 text-xs font-bold flex items-center justify-center flex-shrink-0">
								<svg class="w-4 h-4 animate-pulse" fill="currentColor" viewBox="0 0 24 24"><circle cx="6" cy="12" r="2"></circle><circle cx="12" cy="12" r="2"></circle><circle cx="18" cy="12" r="2"></circle></svg>
							</span>
							<div class="bg-violet-500/5 border border-violet-500/20 rounded-lg px-4 py-2.5">
								<div class="flex items-center gap-1.5 mb-1">
									<span class="text-[9px] font-medium px-1 py-0.5 rounded-full bg-violet-500/10 text-violet-400">thinking</span>
								</div>
								<div class="flex gap-1 items-center h-5">
									<span class="w-1.5 h-1.5 rounded-full bg-violet-400/60 animate-bounce" style="animation-delay: 0s"></span>
									<span class="w-1.5 h-1.5 rounded-full bg-violet-400/60 animate-bounce" style="animation-delay: 0.15s"></span>
									<span class="w-1.5 h-1.5 rounded-full bg-violet-400/60 animate-bounce" style="animation-delay: 0.3s"></span>
								</div>
							</div>
						</div>
					</div>
				}
				<!-- Poll for new messages every 3s -->
				<div
					id="poll"
					hx-get={ "/app/" + space.Slug + "/conversation/" + convo.ID + "/messages" }
					hx-trigger="every 3s"
					hx-target="#message-list"
					hx-swap="beforeend"
					hx-vals="js:{after: document.getElementById('message-list').dataset.lastTs}"
					hx-on::after-request="var ml=document.getElementById('message-list');var last=ml.querySelector('[data-ts]:last-child');if(last){var e=document.getElementById('empty-state');if(e)e.remove();ml.dataset.lastTs=last.dataset.ts;var t=document.getElementById('thinking');if(t)t.classList.add('hidden');var m=document.getElementById('messages');if(m.scrollHeight-m.scrollTop-m.clientHeight<100)m.scrollTop=m.scrollHeight;}"
				></div>
			</div>

			<!-- Message input -->
			if user.Name != "" && user.Name != "Anonymous" {
				<div class="border-t border-edge bg-surface px-6 py-3 flex-shrink-0">
					<form
						class="max-w-2xl mx-auto flex gap-2"
						method="POST"
						action={ templ.SafeURL("/app/" + space.Slug + "/op") }
						hx-post={ "/app/" + space.Slug + "/op" }
						hx-target="#message-list"
						hx-swap="beforeend"
						hx-on::after-request="if(event.detail.successful){this.reset();var ml=document.getElementById('message-list');var e=document.getElementById('empty-state');if(e)e.remove();var last=ml.querySelector('[data-ts]:last-child');if(last)ml.dataset.lastTs=last.dataset.ts;var m=document.getElementById('messages');m.scrollTop=m.scrollHeight;if(ml.dataset.hasAgent){var t=document.getElementById('thinking');if(t){t.classList.remove('hidden');clearTimeout(window._thinkTO);window._thinkTO=setTimeout(function(){t.classList.add('hidden')},60000);}}}"
					>
						<input type="hidden" name="op" value="respond"/>
						<input type="hidden" name="parent_id" value={ convo.ID }/>
						<input
							type="text"
							name="body"
							placeholder="Write a message..."
							required
							autocomplete="off"
							class="flex-1 px-4 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm placeholder-warm-faint"
							onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();this.form.requestSubmit();}"
						/>
						<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Send</button>
					</form>
				</div>
			}
		</div>
		<!-- Scroll to bottom on load -->
		<script>
			(function(){var m=document.getElementById('messages');if(m)m.scrollTop=m.scrollHeight;})();
		</script>
	}
}

templ chatMessage(msg Node, currentUserID string) {
	<div class={ "flex gap-3", templ.KV("flex-row-reverse", msg.AuthorID == currentUserID) } data-ts={ msg.CreatedAt.Format(time.RFC3339Nano) }>
		if msg.AuthorKind == "agent" {
			<span class="w-8 h-8 rounded-full bg-violet-500/10 text-violet-400 text-xs font-bold flex items-center justify-center flex-shrink-0" title="Agent">
				{ initial(msg.Author) }
			</span>
		} else {
			<span class={ "w-8 h-8 rounded-full text-xs font-bold flex items-center justify-center flex-shrink-0",
				templ.KV("bg-brand/10 text-brand", msg.AuthorID == currentUserID),
				templ.KV("bg-elevated text-warm-muted", msg.AuthorID != currentUserID) }>
				{ initial(msg.Author) }
			</span>
		}
		<div class={ "max-w-[75%] rounded-lg px-4 py-2.5",
			templ.KV("bg-brand/10 border border-brand/20", msg.AuthorID == currentUserID),
			templ.KV("bg-surface border border-edge", msg.AuthorID != currentUserID && msg.AuthorKind != "agent"),
			templ.KV("bg-violet-500/5 border border-violet-500/20", msg.AuthorKind == "agent") }>
			<div class="flex items-center gap-1.5 mb-1">
				<span class="text-xs font-medium text-warm">{ msg.Author }</span>
				if msg.AuthorKind == "agent" {
					<span class="text-[9px] font-medium px-1 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
				}
				<span class="text-[10px] text-warm-faint ml-auto">{ msg.CreatedAt.Format("3:04 PM") }</span>
			</div>
			<div class="text-sm text-warm-secondary prose prose-invert prose-sm max-w-none">
							@renderMarkdown(msg.Body)
						</div>
		</div>
	</div>
}

// ── People view ─────────────────────────────────────────────────

templ PeopleView(space Space, spaces []Space, members []Member, user ViewUser) {
	@appLayout(space, spaces, "people", user) {
		<div class="max-w-2xl mx-auto p-6 space-y-6">
			<h1 class="text-xl font-medium text-warm">People</h1>
			<div class="bg-surface rounded-lg border border-edge overflow-hidden">
				<div class="grid grid-cols-[1fr_5rem_5rem] gap-3 px-4 py-2.5 border-b border-edge bg-elevated/80 text-[10px] font-semibold text-warm-faint uppercase tracking-wider">
					<div>Member</div>
					<div>Actions</div>
					<div>Last seen</div>
				</div>
				if len(members) == 0 {
					<div class="px-4 py-12 text-center text-sm text-warm-faint">No activity yet.</div>
				}
				for _, m := range members {
					<div class="grid grid-cols-[1fr_5rem_5rem] gap-3 px-4 py-3 border-b border-edge last:border-b-0 items-center">
						<div class="flex items-center gap-2">
							if m.Kind == "agent" {
								<span class="w-7 h-7 rounded-full bg-violet-500/10 text-violet-400 text-xs font-bold flex items-center justify-center" title="Agent">
									{ initial(m.Name) }
								</span>
							} else {
								<span class="w-7 h-7 rounded-full bg-brand/10 text-brand text-xs font-bold flex items-center justify-center">
									{ initial(m.Name) }
								</span>
							}
							<a href={ templ.SafeURL("/user/" + m.Name) } class="text-sm font-medium text-warm hover:text-brand transition-colors">{ m.Name }</a>
							if m.Kind == "agent" {
								<span class="text-[9px] font-medium px-1 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
							}
						</div>
						<div class="text-sm text-warm-muted">{ fmt.Sprintf("%d", m.OpCount) }</div>
						<div class="text-xs text-warm-faint">{ m.LastSeen }</div>
					</div>
				}
			</div>
		</div>
	}
}

// ── Activity view ───────────────────────────────────────────────

templ ActivityView(space Space, spaces []Space, ops []Op, user ViewUser) {
	@appLayout(space, spaces, "activity", user) {
		<div class="max-w-2xl mx-auto p-6 space-y-6">
			<h1 class="text-xl font-medium text-warm">Activity</h1>
			<div class="space-y-2">
				for _, o := range ops {
					@opItem(o, space.Slug)
				}
				if len(ops) == 0 {
					<p class="text-center text-warm-faint py-8">No activity yet.</p>
				}
			</div>
		</div>
	}
}

templ opItem(o Op, spaceSlug string) {
	<div class="flex items-start gap-3 bg-surface rounded-lg border border-edge px-4 py-3">
		if o.ActorKind == "agent" {
			<span class="w-6 h-6 rounded-full bg-violet-500/10 text-violet-400 text-[10px] font-bold flex items-center justify-center mt-0.5 flex-shrink-0" title="Agent">
				{ initial(o.Actor) }
			</span>
		} else {
			<span class="w-6 h-6 rounded-full bg-brand/10 text-brand text-[10px] font-bold flex items-center justify-center mt-0.5 flex-shrink-0">
				{ initial(o.Actor) }
			</span>
		}
		<div class="flex-1 min-w-0">
			<div class="text-sm">
				<span class="font-medium text-warm">{ o.Actor }</span>
				if o.ActorKind == "agent" {
					<span class="text-[9px] font-medium px-1 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
				}
				if o.NodeID != "" {
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, o.NodeID)) } class="text-warm-muted hover:text-brand transition-colors ml-1">{ o.Op }</a>
					if o.NodeTitle != "" {
						<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, o.NodeID)) } class="text-warm-secondary hover:text-brand transition-colors ml-1 truncate">{ truncate(o.NodeTitle, 60) }</a>
					}
				} else {
					<span class="text-warm-muted ml-1">{ o.Op }</span>
				}
			</div>
			<div class="text-xs text-warm-faint mt-0.5">{ o.CreatedAt.Format("Jan 2, 3:04 PM") }</div>
		</div>
		<span class={ "text-[10px] font-medium px-2 py-0.5 rounded-full flex-shrink-0", opBadgeClass(o.Op) }>
			{ o.Op }
		</span>
	</div>
}

// ── Settings ────────────────────────────────────────────────────

templ SettingsView(space Space, spaces []Space, reports []Report, user ViewUser, errMsg string, inviteToken string) {
	@appLayout(space, spaces, "settings", user) {
		<div class="max-w-xl mx-auto p-6 space-y-8">
			<h1 class="text-xl font-medium text-warm">Settings</h1>
			if errMsg != "" {
				<div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-lg px-4 py-3">
					{ errMsg }
				</div>
			}
			<!-- General settings form -->
			<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/settings") } class="space-y-5">
				<div>
					<label for="name" class="block text-sm font-medium text-warm-muted mb-1">Name</label>
					<input
						type="text"
						id="name"
						name="name"
						value={ space.Name }
						required
						class="w-full bg-elevated border border-edge rounded-lg px-3 py-2 text-sm text-warm placeholder-warm-faint focus:outline-none focus:border-brand"
					/>
				</div>
				<div>
					<label for="description" class="block text-sm font-medium text-warm-muted mb-1">Description</label>
					<textarea
						id="description"
						name="description"
						rows="3"
						class="w-full bg-elevated border border-edge rounded-lg px-3 py-2 text-sm text-warm placeholder-warm-faint focus:outline-none focus:border-brand resize-none"
					>{ space.Description }</textarea>
				</div>
				<div>
					<label for="visibility" class="block text-sm font-medium text-warm-muted mb-1">Visibility</label>
					<select
						id="visibility"
						name="visibility"
						class="w-full bg-elevated border border-edge rounded-lg px-3 py-2 text-sm text-warm focus:outline-none focus:border-brand"
					>
						<option value="private" selected?={ space.Visibility == "private" }>Private — only you can see it</option>
						<option value="public" selected?={ space.Visibility == "public" }>Public — visible on Discover and accessible by anyone</option>
					</select>
				</div>
				<button
					type="submit"
					class="bg-brand text-void text-sm font-medium px-4 py-2 rounded-lg hover:bg-brand-dark transition-colors"
				>
					Save changes
				</button>
			</form>
			<!-- Invite link -->
			<div class="bg-surface border border-edge rounded-lg p-5 space-y-3">
				<h2 class="text-sm font-medium text-warm">Invite people</h2>
				<p class="text-xs text-warm-muted">Share this link to invite someone to your space.</p>
				if inviteToken != "" {
					<div class="flex gap-2 items-center">
						<input
							type="text"
							value={ "https://lovyou.ai/join/" + inviteToken }
							readonly
							class="flex-1 px-3 py-2 bg-elevated border border-edge rounded-lg text-xs text-warm font-mono select-all focus:outline-none focus:ring-1 focus:ring-brand"
							onclick="this.select()"
						/>
					</div>
				} else {
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/invite") }>
						<button type="submit" class="px-4 py-2 bg-brand/10 text-brand rounded-lg hover:bg-brand/20 transition-colors text-sm font-medium">
							Generate invite link
						</button>
					</form>
				}
			</div>
			<!-- Reports -->
			if len(reports) > 0 {
				<div class="border border-amber-500/30 rounded-lg p-5 space-y-4">
					<h2 class="text-lg font-medium text-amber-400">Reports ({ fmt.Sprintf("%d", len(reports)) })</h2>
					<p class="text-sm text-warm-muted">Flagged content that needs your review.</p>
					<div class="space-y-3">
						for _, rpt := range reports {
							<div class="bg-elevated rounded-lg p-4 border border-edge">
								<div class="flex items-center justify-between mb-2">
									<div class="flex items-center gap-2">
										<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", kindBadgeClass(rpt.NodeKind) }>{ rpt.NodeKind }</span>
										<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, rpt.NodeID)) } class="text-sm font-medium text-warm hover:text-brand transition-colors">
											if rpt.NodeTitle != "" {
												{ rpt.NodeTitle }
											} else {
												{ rpt.NodeID }
											}
										</a>
									</div>
									<span class="text-[10px] text-warm-faint">{ dashRelativeTime(rpt.CreatedAt) }</span>
								</div>
								<p class="text-xs text-warm-muted mb-3">
									Reported by <span class="text-warm">{ rpt.Actor }</span>: { rpt.Reason }
								</p>
								<div class="flex gap-2">
									<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") }>
										<input type="hidden" name="op" value="resolve"/>
										<input type="hidden" name="node_id" value={ rpt.NodeID }/>
										<input type="hidden" name="action" value="dismiss"/>
										<button type="submit" class="text-xs px-3 py-1.5 bg-warm-faint/20 text-warm-muted rounded-lg hover:bg-warm-faint/30 transition-colors">
											Dismiss
										</button>
									</form>
									<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") }>
										<input type="hidden" name="op" value="resolve"/>
										<input type="hidden" name="node_id" value={ rpt.NodeID }/>
										<input type="hidden" name="action" value="remove"/>
										<button type="submit" class="text-xs px-3 py-1.5 bg-red-500/15 text-red-400 rounded-lg hover:bg-red-500/25 transition-colors">
											Remove content
										</button>
									</form>
								</div>
							</div>
						}
					</div>
				</div>
			}
			<!-- Danger zone -->
			<div class="border border-red-500/30 rounded-lg p-5 space-y-4">
				<h2 class="text-lg font-medium text-red-400">Danger zone</h2>
				<p class="text-sm text-warm-muted">
					Deleting a space permanently removes all its nodes, comments, and activity.
					This cannot be undone.
				</p>
				<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/delete") } class="space-y-3">
					<div>
						<label for="confirm" class="block text-sm text-warm-muted mb-1">
							Type <span class="font-medium text-warm">{ space.Name }</span> to confirm
						</label>
						<input
							type="text"
							id="confirm"
							name="confirm"
							placeholder={ space.Name }
							required
							class="w-full bg-elevated border border-edge rounded-lg px-3 py-2 text-sm text-warm placeholder-warm-faint focus:outline-none focus:border-red-500/50"
						/>
					</div>
					<button
						type="submit"
						class="bg-red-500/15 text-red-400 text-sm font-medium px-4 py-2 rounded-lg hover:bg-red-500/25 transition-colors"
					>
						Delete this space
					</button>
				</form>
			</div>
		</div>
	}
}

// ── Changelog view (Layer 5 — Build) ────────────────────────────

templ ChangelogView(space Space, spaces []Space, entries []ChangelogEntry, user ViewUser) {
	@appLayout(space, spaces, "changelog", user) {
		<div class="p-6 md:p-8 space-y-6">
			<div>
				<h1 class="text-2xl font-light text-warm">Changelog</h1>
				<p class="text-sm text-warm-muted mt-1">What was built — completed tasks with accountability</p>
			</div>
			if len(entries) == 0 {
				<div class="text-center py-12">
					<p class="text-warm-muted text-lg">Nothing shipped yet</p>
					<p class="text-warm-faint text-sm mt-2">Completed tasks will appear here as a build history</p>
				</div>
			} else {
				<div class="space-y-3">
					for _, e := range entries {
						<div class="p-4 bg-surface rounded-lg border border-edge">
							<div class="flex items-center gap-2 mb-1">
								<span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
								<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, e.ID)) } class="text-sm font-medium text-warm hover:text-brand transition-colors">
									{ e.Title }
								</a>
							</div>
							if e.Body != "" {
								<p class="text-xs text-warm-muted ml-4 line-clamp-2">{ truncate(e.Body, 200) }</p>
							}
							<div class="flex items-center gap-3 mt-2 ml-4 text-xs text-warm-faint">
								if e.CompletedByKind == "agent" {
									<span class="w-4 h-4 rounded-full bg-violet-500/10 text-violet-400 text-[8px] font-bold flex items-center justify-center">{ initial(e.CompletedBy) }</span>
								}
								<span>{ e.CompletedBy }</span>
								<span>{ e.CompletedAt.Format("Jan 2, 3:04 PM") }</span>
								if e.Assignee != "" {
									<span class="text-warm-faint">assigned to { e.Assignee }</span>
								}
							</div>
						</div>
					}
				</div>
			}
		</div>
	}
}

// ── Governance view ──────────────────────────────────────────────

templ GovernanceView(space Space, spaces []Space, proposals []ProposalWithVotes, user ViewUser, isOwner bool) {
	@appLayout(space, spaces, "governance", user) {
		<div class="p-6 md:p-8 space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="text-2xl font-light text-warm">Governance</h1>
					<p class="text-sm text-warm-muted mt-1">Propose changes, vote on decisions — transparent and accountable</p>
				</div>
			</div>
			<!-- Create proposal form -->
			<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="bg-surface border border-edge rounded-lg p-5 space-y-3">
				<input type="hidden" name="op" value="propose"/>
				<input
					type="text"
					name="title"
					placeholder="What do you propose?"
					required
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent"
				/>
				<textarea
					name="description"
					placeholder="Details and reasoning (optional)"
					rows="2"
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none"
				></textarea>
				<div class="flex items-center gap-3">
					<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
						Submit proposal
					</button>
					<div class="flex items-center gap-2">
						<label class="text-xs text-warm-faint">Deadline</label>
						<input
							type="date"
							name="deadline"
							class="px-2 py-1 bg-elevated border border-edge rounded-lg text-xs text-warm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent"
						/>
					</div>
				</div>
			</form>
			if len(proposals) == 0 {
				<div class="text-center py-12">
					<p class="text-warm-muted text-lg">No proposals yet</p>
					<p class="text-warm-faint text-sm mt-2">Be the first to propose a change in this space</p>
				</div>
			} else {
				<div class="space-y-3">
					for _, p := range proposals {
						@proposalCard(p, space.Slug, isOwner)
					}
				</div>
			}
		</div>
	}
}

templ proposalCard(p ProposalWithVotes, spaceSlug string, isOwner bool) {
	<div class="p-5 bg-surface rounded-lg border border-edge hover:border-brand/30 transition-all">
		<div class="flex items-start justify-between gap-3">
			<div class="flex-1 min-w-0">
				<div class="flex items-center gap-2 mb-1">
					@proposalStateBadge(p.State)
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, p.ID)) } class="text-sm font-medium text-warm hover:text-brand transition-colors">
						{ p.Title }
					</a>
				</div>
				if p.Body != "" {
					<p class="text-xs text-warm-muted mt-1 line-clamp-2">{ truncate(p.Body, 200) }</p>
				}
				<div class="flex items-center gap-3 mt-2 text-xs text-warm-faint">
					if p.AuthorKind == "agent" {
						<span class="w-4 h-4 rounded-full bg-violet-500/10 text-violet-400 text-[8px] font-bold flex items-center justify-center">{ initial(p.Author) }</span>
					}
					<span>{ p.Author }</span>
					<span>{ p.CreatedAt.Format("Jan 2") }</span>
					if p.DueDate != nil {
						if p.DueDate.Before(time.Now()) && p.State == ProposalOpen {
							<span class="text-red-400 font-medium">overdue { p.DueDate.Format("Jan 2") }</span>
						} else {
							<span>closes { p.DueDate.Format("Jan 2") }</span>
						}
					}
				</div>
			</div>
			<div class="flex items-center gap-2 flex-shrink-0">
				<!-- Vote counts -->
				<div class="flex items-center gap-1 text-sm">
					<span class="text-emerald-400 font-medium">{ fmt.Sprintf("%d", p.VotesYes) }</span>
					<span class="text-warm-faint">/</span>
					<span class="text-red-400 font-medium">{ fmt.Sprintf("%d", p.VotesNo) }</span>
				</div>
				if p.State == ProposalOpen {
					<!-- Vote buttons -->
					<form method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="inline">
						<input type="hidden" name="op" value="vote"/>
						<input type="hidden" name="node_id" value={ p.ID }/>
						<input type="hidden" name="vote" value="yes"/>
						<button type="submit" class="px-2 py-1 text-xs bg-emerald-500/15 text-emerald-400 rounded hover:bg-emerald-500/25 transition-colors" title="Vote yes">
							Yes
						</button>
					</form>
					<form method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="inline">
						<input type="hidden" name="op" value="vote"/>
						<input type="hidden" name="node_id" value={ p.ID }/>
						<input type="hidden" name="vote" value="no"/>
						<button type="submit" class="px-2 py-1 text-xs bg-red-500/15 text-red-400 rounded hover:bg-red-500/25 transition-colors" title="Vote no">
							No
						</button>
					</form>
					if isOwner {
						<span class="text-warm-faint mx-1">|</span>
						<form method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="inline">
							<input type="hidden" name="op" value="close_proposal"/>
							<input type="hidden" name="node_id" value={ p.ID }/>
							<input type="hidden" name="outcome" value="passed"/>
							<button type="submit" class="px-2 py-1 text-xs bg-emerald-500/15 text-emerald-400 rounded hover:bg-emerald-500/25 transition-colors" title="Close as passed">
								Pass
							</button>
						</form>
						<form method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="inline">
							<input type="hidden" name="op" value="close_proposal"/>
							<input type="hidden" name="node_id" value={ p.ID }/>
							<input type="hidden" name="outcome" value="rejected"/>
							<button type="submit" class="px-2 py-1 text-xs bg-red-500/15 text-red-400 rounded hover:bg-red-500/25 transition-colors" title="Close as rejected">
								Reject
							</button>
						</form>
					}
				}
			</div>
		</div>
	</div>
}

templ proposalStateBadge(state string) {
	switch state {
		case ProposalOpen:
			<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-sky-500/15 text-sky-400">open</span>
		case ProposalPassed:
			<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-emerald-500/15 text-emerald-400">passed</span>
		case ProposalFailed:
			<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-red-500/15 text-red-400">rejected</span>
		default:
			<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-warm-faint/20 text-warm-muted">{ state }</span>
	}
}

// ── Node detail ─────────────────────────────────────────────────

templ NodeDetailView(space Space, node Node, children []Node, ops []Op, user ViewUser, isOwner bool, parents []Node, dependencies []Node, dependents []Node, spaceTasks []Node) {
	@appLayout(space, []Space{space}, "", user) {
		<div class="max-w-3xl mx-auto p-6 space-y-8">
			<!-- Breadcrumb -->
			<div class="text-sm flex flex-wrap items-center gap-1">
				<a href={ templ.SafeURL("/app/" + space.Slug) } class="text-warm-faint hover:text-brand transition-colors">
					{ space.Name }
				</a>
				for _, p := range parents {
					<span class="text-warm-faint">/</span>
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, p.ID)) } class="text-warm-faint hover:text-brand transition-colors truncate max-w-[150px]">
						if p.Title != "" {
							{ p.Title }
						} else {
							{ p.Kind }
						}
					</a>
				}
				<span class="text-warm-faint">/</span>
				<span class="text-warm-secondary">
					if node.Title != "" {
						{ node.Title }
					} else {
						{ node.Kind }
					}
				</span>
			</div>

			<!-- Title -->
			<div>
				if node.Title != "" {
					<div class="flex items-center gap-2">
						if node.Pinned {
							<span class="text-brand" title="Pinned">
								<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.828 3.414a2 2 0 012.828 0l1.93 1.93a2 2 0 010 2.828L13 9.758l1.414 1.414L16 9.586a4 4 0 00-5.656-5.656L8.758 5.516 10.172 6.93l1.656-1.656z"></path><path d="M6.343 8.828L4.93 10.242a4 4 0 005.656 5.656l1.586-1.586-1.414-1.414-1.586 1.586a2 2 0 01-2.828-2.828l1.414-1.414L6.343 8.828z"></path></svg>
							</span>
						}
						<h1 class="text-2xl font-light leading-tight text-warm">{ node.Title }</h1>
					</div>
				}
				<div class="flex items-center gap-3 mt-2 text-xs text-warm-faint">
					<span class={ "font-medium px-2 py-0.5 rounded-full", kindBadgeClass(node.Kind) }>{ node.Kind }</span>
					if node.Pinned {
						<span class="font-medium px-2 py-0.5 rounded-full bg-brand/15 text-brand">pinned</span>
					}
					<span>by { node.Author }</span>
					<span>{ node.CreatedAt.Format("Jan 2, 2006 3:04 PM") }</span>
					if isOwner {
						if node.Pinned {
							<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="inline">
								<input type="hidden" name="op" value="unpin"/>
								<input type="hidden" name="node_id" value={ node.ID }/>
								<button type="submit" class="text-brand hover:text-brand-dark transition-colors">unpin</button>
							</form>
						} else {
							<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="inline">
								<input type="hidden" name="op" value="pin"/>
								<input type="hidden" name="node_id" value={ node.ID }/>
								<button type="submit" class="text-warm-faint hover:text-brand transition-colors">pin</button>
							</form>
						}
					}
				</div>
			</div>

			<!-- Task metadata (only for tasks) -->
			if node.Kind == KindTask {
				<div class="flex flex-wrap gap-6">
					<!-- Status buttons -->
					<div class="space-y-1.5">
						<label class="text-[10px] font-semibold text-warm-faint uppercase tracking-wider">Status</label>
						if isOwner {
							<div class="flex gap-1">
								for _, s := range []string{StateOpen, StateActive, StateReview, StateDone} {
									<form method="POST" action={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s/state", space.Slug, node.ID)) }>
										<input type="hidden" name="state" value={ s }/>
										<button type="submit" class={ "px-2 py-1 rounded-md text-xs font-medium transition-colors cursor-pointer",
											templ.KV("ring-2 ring-offset-1 ring-brand ring-offset-void", s == node.State),
											stateBgClass(s) }>
											{ stateLabel(s) }
										</button>
									</form>
								}
							</div>
						} else {
							<span class={ "px-2 py-1 rounded-md text-xs font-medium", stateBgClass(node.State) }>{ stateLabel(node.State) }</span>
						}
					</div>
					<!-- Priority -->
					<div class="space-y-1.5">
						<label class="text-[10px] font-semibold text-warm-faint uppercase tracking-wider">Priority</label>
						<div class="flex items-center gap-1.5 text-sm text-warm-secondary">
							<span class="w-2 h-2 rounded-full" style={ fmt.Sprintf("background-color: %s", priorityDotHex(node.Priority)) }></span>
							<span class="capitalize">{ node.Priority }</span>
						</div>
					</div>
					<!-- Assignee -->
					<div class="space-y-1.5">
						<label class="text-[10px] font-semibold text-warm-faint uppercase tracking-wider">Assignee</label>
						<div class="text-sm">
							if node.Assignee != "" {
								<div class="flex items-center gap-1.5 text-warm-secondary">
									<span class="w-5 h-5 rounded-full bg-brand/10 text-brand text-[10px] font-bold flex items-center justify-center">{ initial(node.Assignee) }</span>
									{ node.Assignee }
								</div>
							} else if user.Name != "" && user.Name != "Anonymous" {
								<div class="flex items-center gap-2">
									<form method="POST" action={ templ.SafeURL(fmt.Sprintf("/app/%s/op", space.Slug)) } class="inline">
										<input type="hidden" name="op" value="claim"/>
										<input type="hidden" name="node_id" value={ node.ID }/>
										<button type="submit" class="px-3 py-1 bg-brand text-void rounded-md hover:bg-brand-dark transition-colors text-sm font-medium">Claim</button>
									</form>
									<form method="POST" action={ templ.SafeURL(fmt.Sprintf("/app/%s/op", space.Slug)) } class="inline">
										<input type="hidden" name="op" value="assign"/>
										<input type="hidden" name="node_id" value={ node.ID }/>
										<input type="hidden" name="assignee" value="hive"/>
										<button type="submit" class="px-3 py-1 bg-violet-500/10 text-violet-400 border border-violet-500/20 rounded-md hover:bg-violet-500/20 transition-colors text-sm font-medium">Assign to agent</button>
									</form>
								</div>
							} else {
								<span class="text-warm-faint text-sm">Unassigned</span>
							}
						</div>
					</div>
					if node.DueDate != nil {
						<div class="space-y-1.5">
							<label class="text-[10px] font-semibold text-warm-faint uppercase tracking-wider">Due</label>
							<div class="text-sm text-warm-secondary">{ node.DueDate.Format("Jan 2, 2006") }</div>
						</div>
					}
				</div>
			}

			<!-- Dependencies -->
			if len(dependencies) > 0 || len(dependents) > 0 || len(spaceTasks) > 0 {
				<div class="space-y-3">
					if len(dependencies) > 0 {
						<div>
							<h2 class="text-xs font-semibold text-warm-faint uppercase tracking-wider mb-2">Depends on</h2>
							<div class="space-y-1">
								for _, dep := range dependencies {
									@depRow(dep, space.Slug)
								}
							</div>
						</div>
					}
					if len(dependents) > 0 {
						<div>
							<h2 class="text-xs font-semibold text-warm-faint uppercase tracking-wider mb-2">Blocking</h2>
							<div class="space-y-1">
								for _, dep := range dependents {
									@depRow(dep, space.Slug)
								}
							</div>
						</div>
					}
					if len(spaceTasks) > 0 && user.Name != "" && user.Name != "Anonymous" {
						<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="flex items-center gap-2">
							<input type="hidden" name="op" value="depend"/>
							<input type="hidden" name="node_id" value={ node.ID }/>
							<select name="depends_on" required class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-sm text-warm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent">
								<option value="" disabled selected>Add dependency...</option>
								for _, t := range spaceTasks {
									<option value={ t.ID }>{ truncate(t.Title, 60) } ({ stateLabel(t.State) })</option>
								}
							</select>
							<button type="submit" class="px-3 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium flex-shrink-0">Add</button>
						</form>
					}
				</div>
			}

			<!-- Body -->
			if node.Body != "" {
				<div class="bg-surface rounded-lg border border-edge p-4">
					<div class="text-sm text-warm-secondary prose prose-invert prose-sm max-w-none">
			@renderMarkdown(node.Body)
		</div>
				</div>
			}

			<!-- Edit form -->
			if node.Kind == KindTask && isOwner {
				<div>
					<button onclick="document.getElementById('edit-form').classList.toggle('hidden')" class="text-sm text-brand hover:underline">Edit</button>
					<form id="edit-form" method="POST" action={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s/update", space.Slug, node.ID)) } class="hidden mt-3 bg-surface rounded-lg border border-edge p-4 space-y-3">
						<div>
							<label class="block text-xs font-medium text-warm-muted mb-1">Title</label>
							<input type="text" name="title" value={ node.Title } class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm"/>
						</div>
						<div>
							<label class="block text-xs font-medium text-warm-muted mb-1">Description</label>
							<textarea name="body" rows="4" class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm">{ node.Body }</textarea>
						</div>
						<div class="grid grid-cols-2 gap-3">
							<div>
								<label class="block text-xs font-medium text-warm-muted mb-1">Priority</label>
								<select name="priority" class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand text-warm-secondary">
									<option value="low" selected?={ node.Priority == PriorityLow }>Low</option>
									<option value="medium" selected?={ node.Priority == PriorityMedium }>Medium</option>
									<option value="high" selected?={ node.Priority == PriorityHigh }>High</option>
									<option value="urgent" selected?={ node.Priority == PriorityUrgent }>Urgent</option>
								</select>
							</div>
							<div>
								<label class="block text-xs font-medium text-warm-muted mb-1">Assignee</label>
								<input type="text" name="assignee" value={ node.Assignee } class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm" placeholder="Unassigned"/>
							</div>
						</div>
						<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Save changes</button>
					</form>
				</div>
			}

			<!-- Children (subtasks / replies) -->
			if len(children) > 0 {
				<div class="space-y-3">
					<h2 class="text-sm font-medium text-warm-muted">
						if node.Kind == KindTask {
							{ fmt.Sprintf("Subtasks (%d/%d)", countDone(children), len(children)) }
						} else {
							{ fmt.Sprintf("Replies (%d)", len(children)) }
						}
					</h2>
					if node.Kind == KindTask {
						<div class="w-full bg-elevated rounded-full h-1.5">
							<div class="bg-brand rounded-full h-1.5 transition-all" style={ childProgressSlice(children) }></div>
						</div>
					}
					<div id="children" class="space-y-2"
					hx-get={ fmt.Sprintf("/app/%s/node/%s/children", space.Slug, node.ID) }
					hx-trigger="every 5s"
					hx-swap="innerHTML"
				>
						for _, child := range children {
							if child.Kind == KindComment {
								@CommentItem(child)
							} else {
								@childRow(child, space.Slug)
							}
						}
					</div>
				</div>
			}

			<!-- Add child -->
			if node.Kind == KindTask && isOwner {
				<div class="bg-elevated rounded-lg border border-edge p-4">
					<h3 class="text-xs font-semibold text-warm-faint uppercase tracking-wider mb-2">Add subtask</h3>
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="flex gap-2">
						<input type="hidden" name="op" value="decompose"/>
						<input type="hidden" name="parent_id" value={ node.ID }/>
						<input type="text" name="title" required placeholder="Subtask title..."
							class="flex-1 px-3 py-1.5 bg-surface border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm placeholder-warm-faint"/>
						<button type="submit" class="px-3 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Add</button>
					</form>
				</div>
			}

			<!-- Reply form (for posts and threads) -->
			if node.Kind == KindPost || node.Kind == KindThread {
				<div class="space-y-3">
					<h2 class="text-sm font-medium text-warm-muted">
						{ fmt.Sprintf("Replies (%d)", len(children)) }
					</h2>
					<div id="children" class="space-y-2">
						for _, child := range children {
							@CommentItem(child)
						}
					</div>
					if user.Name != "" && user.Name != "Anonymous" {
						<form
							method="POST"
							action={ templ.SafeURL("/app/" + space.Slug + "/op") }
							hx-post={ "/app/" + space.Slug + "/op" }
							hx-target="#children"
							hx-swap="beforeend"
							hx-on::after-request="if(event.detail.successful) this.reset()"
							class="space-y-2"
						>
							<input type="hidden" name="op" value="respond"/>
							<input type="hidden" name="parent_id" value={ node.ID }/>
							<textarea name="body" placeholder="Write a reply..." required rows="3"
								class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
							<div class="flex justify-end">
								<button type="submit" class="px-3 py-1.5 bg-brand text-void rounded-md hover:bg-brand-dark transition-colors text-sm font-medium">Reply</button>
							</div>
						</form>
					}
				</div>
			}

			<!-- Claim evidence actions -->
			if node.Kind == KindClaim && (node.State == ClaimClaimed || node.State == ClaimChallenged) && user.Name != "" && user.Name != "Anonymous" {
				<div class="space-y-3">
					<h2 class="text-sm font-medium text-warm-muted">Epistemic actions</h2>
					<div class="flex gap-2">
						<button type="button" onclick={ toggleForm("detail-challenge") } class="text-xs px-3 py-1.5 bg-amber-500/10 text-amber-400 rounded-lg hover:bg-amber-500/20 transition-colors">
							Challenge
						</button>
						<button type="button" onclick={ toggleForm("detail-verify") } class="text-xs px-3 py-1.5 bg-emerald-500/10 text-emerald-400 rounded-lg hover:bg-emerald-500/20 transition-colors">
							Verify
						</button>
						<button type="button" onclick={ toggleForm("detail-retract") } class="text-xs px-3 py-1.5 bg-red-500/10 text-red-400 rounded-lg hover:bg-red-500/20 transition-colors">
							Retract
						</button>
					</div>
					<form id="detail-challenge" method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="hidden bg-elevated rounded-lg border border-edge p-4 space-y-2">
						<input type="hidden" name="op" value="challenge"/>
						<input type="hidden" name="node_id" value={ node.ID }/>
						<label class="block text-xs font-medium text-amber-400">Why do you challenge this claim?</label>
						<textarea name="reason" required placeholder="Provide counter-evidence or reasoning..." rows="3"
							class="w-full px-3 py-2 bg-surface border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent resize-none"></textarea>
						<button type="submit" class="px-4 py-2 bg-amber-500/20 text-amber-400 rounded-lg hover:bg-amber-500/30 transition-colors text-sm font-medium">Submit challenge</button>
					</form>
					<form id="detail-verify" method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="hidden bg-elevated rounded-lg border border-edge p-4 space-y-2">
						<input type="hidden" name="op" value="verify"/>
						<input type="hidden" name="node_id" value={ node.ID }/>
						<label class="block text-xs font-medium text-emerald-400">Evidence supporting this claim</label>
						<textarea name="reason" placeholder="Provide supporting evidence or reasoning..." rows="3"
							class="w-full px-3 py-2 bg-surface border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent resize-none"></textarea>
						<button type="submit" class="px-4 py-2 bg-emerald-500/20 text-emerald-400 rounded-lg hover:bg-emerald-500/30 transition-colors text-sm font-medium">Confirm verification</button>
					</form>
					<form id="detail-retract" method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="hidden bg-elevated rounded-lg border border-edge p-4 space-y-2">
						<input type="hidden" name="op" value="retract"/>
						<input type="hidden" name="node_id" value={ node.ID }/>
						<label class="block text-xs font-medium text-red-400">Why is this claim being retracted?</label>
						<textarea name="reason" placeholder="Explain why this claim is no longer valid..." rows="3"
							class="w-full px-3 py-2 bg-surface border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent resize-none"></textarea>
						<button type="submit" class="px-4 py-2 bg-red-500/20 text-red-400 rounded-lg hover:bg-red-500/30 transition-colors text-sm font-medium">Confirm retraction</button>
					</form>
				</div>
			}

			<!-- Activity on this node -->
			if len(ops) > 0 {
				<div class="space-y-3">
					if node.Kind == KindClaim {
						<h2 class="text-sm font-medium text-warm-muted">Evidence trail</h2>
					} else {
						<h2 class="text-sm font-medium text-warm-muted">Activity</h2>
					}
					<div class="space-y-1">
						for _, o := range ops {
							<div class="py-1">
								<div class="flex items-center gap-2 text-xs text-warm-faint">
									<span class="font-medium text-warm-secondary">{ o.Actor }</span>
									<span class={ "font-medium px-1.5 py-0.5 rounded-full", opBadgeClass(o.Op) }>{ o.Op }</span>
									<span>{ o.CreatedAt.Format("Jan 2, 3:04 PM") }</span>
								</div>
								if isEvidenceOp(o.Op) && opReason(o.Payload) != "" && opReason(o.Payload) != "challenged" && opReason(o.Payload) != "disputed" {
									<p class="text-xs text-warm-muted mt-1 ml-4 pl-2 border-l-2 border-edge">{ opReason(o.Payload) }</p>
								}
							</div>
						}
					</div>
				</div>
			}

			<!-- Actions -->
			if user.Name != "" && user.Name != "Anonymous" && node.Kind != KindConversation && node.Kind != KindComment {
				<div class="flex gap-2 border-t border-edge pt-4">
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") }>
						<input type="hidden" name="op" value="converse"/>
						<input type="hidden" name="title" value={ "Discuss: " + node.Title }/>
						<button type="submit" class="text-xs px-3 py-1.5 bg-sky-500/10 text-sky-400 rounded-lg hover:bg-sky-500/20 transition-colors">
							Discuss this
						</button>
					</form>
				</div>
			}
			<!-- Timestamps + delete -->
			<div class="flex items-center justify-between border-t border-edge pt-4">
				<div class="flex gap-4 text-xs text-warm-faint">
					<span>Created { node.CreatedAt.Format("Jan 2, 2006 3:04 PM") }</span>
					<span>Updated { node.UpdatedAt.Format("Jan 2, 2006 3:04 PM") }</span>
				</div>
				if isOwner {
					<button type="button"
						hx-delete={ fmt.Sprintf("/app/%s/node/%s", space.Slug, node.ID) }
						hx-confirm="Delete this? This cannot be undone."
						class="text-xs text-red-400 hover:text-red-300 transition-colors">
						Delete
					</button>
				}
			</div>
		</div>
	}
}

templ childRow(node Node, spaceSlug string) {
	<a
		href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.ID)) }
		class="flex items-center gap-2 px-3 py-2 rounded-md hover:bg-elevated transition-colors"
	>
		if node.State == StateDone {
			<svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
				<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
			</svg>
		} else {
			<div class="w-4 h-4 rounded-full border-2 border-edge-strong flex-shrink-0"></div>
		}
		<span class={ "text-sm flex-1", templ.KV("line-through text-warm-faint", node.State == StateDone), templ.KV("text-warm", node.State != StateDone) }>
			{ node.Title }
		</span>
		<span class={ "text-[10px] font-medium px-2 py-0.5 rounded-full", stateBgClass(node.State) }>
			{ stateLabel(node.State) }
		</span>
	</a>
}

templ depRow(node Node, spaceSlug string) {
	<a
		href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.ID)) }
		class="flex items-center gap-2 px-3 py-2 rounded-md bg-surface border border-edge hover:border-brand/30 transition-colors"
	>
		if node.State == StateDone {
			<svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
				<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
			</svg>
		} else {
			<div class="w-4 h-4 rounded-full border-2 border-amber-500/50 flex-shrink-0"></div>
		}
		<span class={ "text-sm flex-1 truncate", templ.KV("line-through text-warm-faint", node.State == StateDone), templ.KV("text-warm", node.State != StateDone) }>
			{ node.Title }
		</span>
		<span class={ "text-[10px] font-medium px-2 py-0.5 rounded-full flex-shrink-0", stateBgClass(node.State) }>
			{ stateLabel(node.State) }
		</span>
		if node.Assignee != "" {
			<span class="text-[10px] text-warm-faint flex-shrink-0">{ node.Assignee }</span>
		}
	</a>
}

templ CommentItem(node Node) {
	<div class="bg-surface rounded-lg border border-edge p-4">
		<div class="flex items-center gap-2 mb-2">
			if node.AuthorKind == "agent" {
				<span class="w-6 h-6 rounded-full bg-violet-500/10 text-violet-400 text-xs font-bold flex items-center justify-center" title="Agent">
					{ initial(node.Author) }
				</span>
			} else {
				<span class="w-6 h-6 rounded-full bg-brand/10 text-brand text-xs font-bold flex items-center justify-center">
					{ initial(node.Author) }
				</span>
			}
			<span class="text-sm font-medium text-warm">{ node.Author }</span>
			if node.AuthorKind == "agent" {
				<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
			}
			<span class="text-xs text-warm-faint">{ node.CreatedAt.Format("Jan 2, 3:04 PM") }</span>
		</div>
		<div class="text-sm text-warm-secondary prose prose-invert prose-sm max-w-none">
			@renderMarkdown(node.Body)
		</div>
	</div>
}

// ── API Keys ─────────────────────────────────────────────────────

templ APIKeysView(keys []ViewAPIKey, user ViewUser) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>API Keys — lovyou.ai</title>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			<script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
			@themeBlock()
		</head>
		<body class="bg-void text-warm-secondary min-h-screen flex flex-col">
			@simpleHeader(user)
			<main class="flex-1 max-w-2xl mx-auto px-4 md:px-6 py-12 w-full">
				<h1 class="text-2xl font-light text-warm mb-2">API Keys</h1>
				<p class="text-sm text-warm-muted mb-8">Authenticate agents and scripts to interact with lovyou.ai programmatically.</p>
				<!-- Create new key -->
				<div class="bg-surface rounded-lg border border-edge p-6 mb-8">
					<h2 class="text-sm font-medium text-warm mb-4">Create new key</h2>
					<form hx-post="/auth/api-keys" hx-target="#key-result" hx-swap="innerHTML" class="space-y-3">
						<div class="flex gap-3">
							<input
								type="text"
								name="name"
								placeholder="Key name (e.g. hive-agent)"
								class="flex-1 text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"
							/>
							<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium whitespace-nowrap">
								Create Key
							</button>
						</div>
						<input
							type="text"
							name="agent_name"
							placeholder="Agent identity (optional — posts appear as this name)"
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"
						/>
					</form>
					<div id="key-result" class="mt-4"></div>
				</div>
				<!-- Existing keys -->
				if len(keys) > 0 {
					<div class="bg-surface rounded-lg border border-edge">
						<div class="px-6 py-4 border-b border-edge">
							<h2 class="text-sm font-medium text-warm">Your keys</h2>
						</div>
						for _, key := range keys {
							<div class="px-6 py-4 flex items-center justify-between border-b border-edge last:border-0">
								<div>
									<span class="text-sm font-medium text-warm">{ key.Name }</span>
									if key.AgentName != "" {
										<span class="text-xs text-brand ml-2">posts as { key.AgentName }</span>
									}
									<span class="text-xs text-warm-muted ml-3">Created { key.CreatedAt }</span>
								</div>
								<form method="POST" action={ templ.SafeURL("/auth/api-keys/" + key.ID + "/delete") }>
									<button type="submit" class="text-xs text-warm-faint hover:text-red-400 transition-colors">
										Revoke
									</button>
								</form>
							</div>
						}
					</div>
				} else {
					<div class="text-center py-8 text-warm-muted text-sm">
						<p>No API keys yet. Create one to get started.</p>
					</div>
				}
				<!-- Usage -->
				<div class="mt-8 bg-surface rounded-lg border border-edge p-6">
					<h2 class="text-sm font-medium text-warm mb-3">Usage</h2>
					<p class="text-sm text-warm-muted mb-3">Include your API key as a Bearer token in the Authorization header:</p>
					<pre class="text-xs bg-elevated rounded-lg p-4 text-warm-secondary overflow-x-auto"><code>curl -H "Authorization: Bearer lv_..." \
     -H "Accept: application/json" \
     https://lovyou.ai/app/your-space/feed</code></pre>
				</div>
			</main>
			@simpleFooter()
		</body>
	</html>
}

// ── Shared components ───────────────────────────────────────────

templ simpleHeader(user ViewUser) {
	<header class="border-b border-edge bg-surface">
		<nav class="max-w-4xl mx-auto px-4 md:px-6 py-4 flex items-center justify-between">
			<a href="/" class="text-xl font-bold text-brand brand-breathe">lovyou.ai</a>
			<!-- Mobile: compact links -->
			<div class="flex md:hidden items-center gap-4 text-sm text-warm-muted">
				<a href="/app" class="hover:text-brand transition-colors">App</a>
				<a href="/discover" class="hover:text-brand transition-colors">Discover</a>
				if user.Name != "" && user.Name != "Anonymous" {
					if user.Picture != "" {
						<img src={ user.Picture } class="w-6 h-6 rounded-full" alt={ user.Name } referrerpolicy="no-referrer"/>
					}
				}
			</div>
			<!-- Desktop: full links -->
			<div class="hidden md:flex items-center gap-6 text-sm text-warm-muted">
				<a href="/" class="hover:text-brand transition-colors">Home</a>
				<a href="/app" class="hover:text-brand transition-colors">App</a>
				<a href="/discover" class="hover:text-brand transition-colors">Discover</a>
				<a href="/blog" class="hover:text-brand transition-colors">Blog</a>
				<a href="/reference" class="hover:text-brand transition-colors">Reference</a>
				if user.Name != "" && user.Name != "Anonymous" {
					<div class="flex items-center gap-2 ml-2 pl-4 border-l border-edge">
						if user.Picture != "" {
							<img src={ user.Picture } class="w-6 h-6 rounded-full" alt={ user.Name } referrerpolicy="no-referrer"/>
						}
						<span class="text-warm-muted text-xs">{ user.Name }</span>
					</div>
				}
			</div>
		</nav>
	</header>
}

templ simpleFooter() {
	<footer class="border-t border-edge bg-surface">
		<div class="max-w-4xl mx-auto px-6 py-6 text-sm text-warm-muted flex items-center justify-between">
			<span>lovyou.ai — humans and agents, building together</span>
			<div class="flex gap-4 items-center">
				<a href="mailto:matt@lovyou.ai" class="hover:text-brand transition-colors">matt@lovyou.ai</a>
				<a href="https://github.com/lovyou-ai" class="hover:text-brand transition-colors" target="_blank" rel="noopener">GitHub</a>
			</div>
		</div>
	</footer>
}

// ── Helper functions ────────────────────────────────────────────

func stateLabel(state string) string {
	switch state {
	case StateOpen:
		return "Open"
	case StateActive:
		return "Active"
	case StateReview:
		return "Review"
	case StateDone:
		return "Done"
	case StateClosed:
		return "Closed"
	default:
		return state
	}
}

func stateBgClass(state string) string {
	switch state {
	case StateOpen:
		return "bg-warm-faint/20 text-warm-muted"
	case StateActive:
		return "bg-indigo-500/15 text-indigo-400"
	case StateReview:
		return "bg-amber-500/15 text-amber-400"
	case StateDone:
		return "bg-emerald-500/15 text-emerald-400"
	case StateClosed:
		return "bg-warm-faint/20 text-warm-faint"
	default:
		return "bg-warm-faint/20 text-warm-muted"
	}
}

func stateColorHex(state string) string {
	switch state {
	case StateOpen:
		return "#78756e"
	case StateActive:
		return "#818cf8"
	case StateReview:
		return "#fbbf24"
	case StateDone:
		return "#6ec89b"
	case StateClosed:
		return "#4a4844"
	default:
		return "#78756e"
	}
}

func priorityDotHex(priority string) string {
	switch priority {
	case PriorityUrgent:
		return "#e07070"
	case PriorityHigh:
		return "#fbbf24"
	case PriorityMedium:
		return "#e8a0b8"
	case PriorityLow:
		return "#78756e"
	default:
		return "#78756e"
	}
}

func boardEmpty(columns []BoardColumn) bool {
	for _, col := range columns {
		if len(col.Nodes) > 0 {
			return false
		}
	}
	return true
}

func dashboardStateClass(state string) string {
	switch state {
	case StateOpen:
		return "bg-warm-faint/20 text-warm-muted"
	case StateActive:
		return "bg-indigo-500/15 text-indigo-400"
	case StateReview:
		return "bg-amber-500/15 text-amber-400"
	default:
		return "bg-warm-faint/20 text-warm-muted"
	}
}

func dashRelativeTime(t time.Time) string {
	d := time.Since(t)
	switch {
	case d < time.Minute:
		return "now"
	case d < time.Hour:
		return fmt.Sprintf("%dm", int(d.Minutes()))
	case d < 24*time.Hour:
		return fmt.Sprintf("%dh", int(d.Hours()))
	case d < 30*24*time.Hour:
		return fmt.Sprintf("%dd", int(d.Hours()/24))
	default:
		return t.Format("Jan 2")
	}
}

func truncateBody(s string, maxLen int) string {
	if len(s) <= maxLen {
		return s
	}
	return s[:maxLen] + "..."
}

func kindBadgeClass(kind string) string {
	switch kind {
	case KindTask, SpaceProject:
		return "bg-indigo-500/15 text-indigo-400"
	case KindPost, SpaceCommunity:
		return "bg-emerald-500/15 text-emerald-400"
	case KindThread, SpaceTeam:
		return "bg-amber-500/15 text-amber-400"
	case KindComment:
		return "bg-warm-faint/20 text-warm-muted"
	default:
		return "bg-warm-faint/20 text-warm-muted"
	}
}

func opBadgeClass(op string) string {
	switch op {
	case "intend", "decompose":
		return "bg-indigo-500/15 text-indigo-400"
	case "express", "discuss":
		return "bg-emerald-500/15 text-emerald-400"
	case "respond":
		return "bg-warm-faint/20 text-warm-muted"
	case "complete":
		return "bg-emerald-500/15 text-emerald-400"
	case "claim", "assign":
		return "bg-amber-500/15 text-amber-400"
	case "prioritize":
		return "bg-purple-500/15 text-purple-400"
	case "review":
		return "bg-amber-500/15 text-amber-400"
	case "progress":
		return "bg-blue-500/15 text-blue-400"
	default:
		return "bg-warm-faint/20 text-warm-muted"
	}
}

func renderMarkdown(src string) templ.Component {
	var buf bytes.Buffer
	md := goldmark.New()
	if err := md.Convert([]byte(src), &buf); err != nil {
		return templ.Raw("<p>" + src + "</p>")
	}
	return templ.Raw(buf.String())
}

func resolveName(id string, nameMap map[string]string) string {
	if nameMap != nil {
		if name, ok := nameMap[id]; ok {
			return name
		}
	}
	return id
}

func initial(name string) string {
	if name == "" {
		return ""
	}
	runes := []rune(name)
	if len(runes) == 0 {
		return ""
	}
	return string(runes[0:1])
}

func childProgress(node Node) string {
	if node.ChildCount == 0 {
		return "width: 0%"
	}
	pct := (node.ChildDone * 100) / node.ChildCount
	return fmt.Sprintf("width: %d%%", pct)
}

func childProgressSlice(nodes []Node) string {
	if len(nodes) == 0 {
		return "width: 0%"
	}
	done := countDone(nodes)
	pct := (done * 100) / len(nodes)
	return fmt.Sprintf("width: %d%%", pct)
}

func countDone(nodes []Node) int {
	n := 0
	for _, nd := range nodes {
		if nd.State == StateDone {
			n++
		}
	}
	return n
}

func truncate(s string, max int) string {
	if len(s) <= max {
		return s
	}
	return s[:max] + "…"
}

func lastMessageTS(messages []Node) string {
	if len(messages) == 0 {
		return time.Now().UTC().Format(time.RFC3339Nano)
	}
	return messages[len(messages)-1].CreatedAt.Format(time.RFC3339Nano)
}

// ── Knowledge lens (Layer 6) ────────────────────────────────────

templ KnowledgeView(space Space, spaces []Space, claims []Node, challengeCounts map[string]int, user ViewUser) {
	@appLayout(space, spaces, "knowledge", user) {
		<div class="p-6 md:p-8 space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="text-2xl font-light text-warm">Knowledge</h1>
					<p class="text-sm text-warm-muted mt-1">Claims with epistemic status — assert what you know, challenge what you doubt</p>
				</div>
			</div>
			<!-- Create claim form -->
			<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="bg-surface border border-edge rounded-lg p-5 space-y-3">
				<input type="hidden" name="op" value="assert"/>
				<input
					type="text"
					name="title"
					placeholder="State a claim..."
					required
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent"
				/>
				<textarea
					name="body"
					placeholder="Evidence or reasoning (optional)"
					rows="2"
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none"
				></textarea>
				<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
					Assert claim
				</button>
			</form>
			if len(claims) == 0 {
				<div class="text-center py-12">
					<p class="text-warm-muted text-lg">No claims yet</p>
					<p class="text-warm-faint text-sm mt-2">Be the first to assert a knowledge claim in this space</p>
				</div>
			} else {
				<div class="space-y-3">
					for _, c := range claims {
						@KnowledgeCard(c, space.Slug, challengeCounts[c.ID])
					}
				</div>
			}
		</div>
	}
}

templ KnowledgeCard(node Node, spaceSlug string, challenges int) {
	<div class="p-5 bg-surface rounded-lg border border-edge hover:border-brand/30 transition-all">
		<div class="flex items-center gap-2 mb-1">
			@claimStatusBadge(node.State)
			<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.ID)) } class="text-sm font-medium text-warm hover:text-brand transition-colors">
				{ node.Title }
			</a>
		</div>
		if node.Body != "" {
			<p class="text-xs text-warm-muted mt-1 line-clamp-2">{ truncate(node.Body, 200) }</p>
		}
		<div class="flex items-center gap-3 mt-2 text-xs text-warm-faint">
			if node.AuthorKind == "agent" {
				<span class="text-violet-400">{ node.Author }</span>
			} else {
				<span>{ node.Author }</span>
			}
			<span>{ node.CreatedAt.Format("Jan 2, 2006") }</span>
			if challenges > 0 {
				<span class="text-amber-400">{ fmt.Sprintf("%d challenge", challenges) }{ pluralS(challenges) }</span>
			}
		</div>
		if node.State == ClaimClaimed || node.State == ClaimChallenged {
			<div class="flex gap-1 mt-3">
				<button type="button" onclick={ toggleForm("challenge-" + node.ID) } class="text-xs px-2 py-1 bg-amber-500/10 text-amber-400 rounded hover:bg-amber-500/20 transition-colors">
					Challenge
				</button>
				<button type="button" onclick={ toggleForm("verify-" + node.ID) } class="text-xs px-2 py-1 bg-emerald-500/10 text-emerald-400 rounded hover:bg-emerald-500/20 transition-colors">
					Verify
				</button>
				<button type="button" onclick={ toggleForm("retract-" + node.ID) } class="text-xs px-2 py-1 bg-red-500/10 text-red-400 rounded hover:bg-red-500/20 transition-colors">
					Retract
				</button>
			</div>
			<form id={ "challenge-" + node.ID } method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="hidden mt-2 space-y-2">
				<input type="hidden" name="op" value="challenge"/>
				<input type="hidden" name="node_id" value={ node.ID }/>
				<textarea name="reason" required placeholder="Why do you challenge this claim?" rows="2"
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent resize-none"></textarea>
				<button type="submit" class="text-xs px-3 py-1.5 bg-amber-500/20 text-amber-400 rounded hover:bg-amber-500/30 transition-colors font-medium">
					Submit challenge
				</button>
			</form>
			<form id={ "verify-" + node.ID } method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="hidden mt-2 space-y-2">
				<input type="hidden" name="op" value="verify"/>
				<input type="hidden" name="node_id" value={ node.ID }/>
				<textarea name="reason" placeholder="Evidence or reasoning for verification (optional)" rows="2"
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent resize-none"></textarea>
				<button type="submit" class="text-xs px-3 py-1.5 bg-emerald-500/20 text-emerald-400 rounded hover:bg-emerald-500/30 transition-colors font-medium">
					Confirm verification
				</button>
			</form>
			<form id={ "retract-" + node.ID } method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="hidden mt-2 space-y-2">
				<input type="hidden" name="op" value="retract"/>
				<input type="hidden" name="node_id" value={ node.ID }/>
				<textarea name="reason" placeholder="Why is this claim being retracted?" rows="2"
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent resize-none"></textarea>
				<button type="submit" class="text-xs px-3 py-1.5 bg-red-500/20 text-red-400 rounded hover:bg-red-500/30 transition-colors font-medium">
					Confirm retraction
				</button>
			</form>
		}
	</div>
}

templ claimStatusBadge(state string) {
	switch state {
		case "claimed":
			<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-sky-500/15 text-sky-400">claimed</span>
		case "challenged":
			<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-400">challenged</span>
		case "verified":
			<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-emerald-500/15 text-emerald-400">verified</span>
		case "retracted":
			<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-red-500/15 text-red-400">retracted</span>
		default:
			<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-warm-faint/20 text-warm-muted">{ state }</span>
	}
}

func pluralS(n int) string {
	if n == 1 {
		return ""
	}
	return "s"
}

// opReason extracts the "reason" field from an op's JSON payload.
func opReason(payload json.RawMessage) string {
	if len(payload) == 0 {
		return ""
	}
	var m map[string]string
	if err := json.Unmarshal(payload, &m); err != nil {
		return ""
	}
	return m["reason"]
}

// isEvidenceOp returns true if the op is a knowledge evidence operation.
func isEvidenceOp(op string) bool {
	return op == "challenge" || op == "verify" || op == "retract"
}
