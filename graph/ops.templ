package graph

import (
	"fmt"
	"strings"

	"github.com/transpara-ai/site/profile"
)

templ OpsPage(data OpsPageData, user ViewUser, p *profile.Profile) {
	<!DOCTYPE html>
	<html lang="en" data-profile={ p.GetSlug() } style={ "--accent: " + p.GetAccentColor() }>
		<head>
			@metaTags(data.Title, data.Description, p)
			@themeBlock()
		</head>
		<body class="bg-void text-warm-secondary min-h-screen flex flex-col">
			@simpleHeader(user, p)
			<main class="flex-1 max-w-6xl mx-auto px-4 md:px-6 py-8 md:py-10 w-full space-y-6">
				<section class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
					<div class="space-y-2 max-w-3xl">
						<p class="text-xs font-medium text-brand uppercase tracking-widest">Operator shell</p>
						<h1 class="text-3xl md:text-4xl font-display font-normal text-warm">{ data.Title }</h1>
						<p class="text-sm md:text-base text-warm-muted leading-relaxed">{ data.Description }</p>
					</div>
					<a href="/app" class="inline-flex items-center justify-center px-3 py-2 rounded-md bg-elevated text-warm-muted hover:text-brand transition-colors text-sm">
						My Work
					</a>
				</section>
				<nav class="grid gap-3 md:grid-cols-3 lg:grid-cols-6" aria-label="Operator surfaces">
					for _, surface := range data.Surfaces {
						<a
							href={ templ.SafeURL(surface.Href) }
							class={ "group border rounded-lg p-4 transition-colors min-h-[9rem] flex flex-col",
								templ.KV("border-brand/40 bg-brand/10", surface.ID == data.Active),
								templ.KV("border-edge bg-surface hover:border-brand/30 hover:bg-elevated/60", surface.ID != data.Active) }
						>
							<div class="flex min-w-0 flex-wrap items-start justify-between gap-2">
								<h2 class="min-w-0 text-base font-medium text-warm break-words group-hover:text-brand transition-colors">{ surface.Label }</h2>
								<span class={ "shrink-0 text-[10px] px-2 py-1 rounded-full border whitespace-nowrap",
									templ.KV("border-brand/30 text-brand bg-brand/10", surface.ID == data.Active),
									templ.KV("border-edge text-warm-faint bg-void/30", surface.ID != data.Active) }
								>
									{ surface.Status }
								</span>
							</div>
							<p class="text-xs text-warm-muted leading-relaxed mt-3 flex-1">{ surface.Description }</p>
							<p class="text-[11px] text-warm-faint mt-3">{ surface.Owner }</p>
						</a>
					}
				</nav>
				if data.Civilization != nil {
					@opsCivilizationAssembly(data.Civilization)
				} else if data.GitHubCanonical != nil {
					@opsGitHubCanonical(data.GitHubCanonical)
				} else if data.Observatory != nil {
					@opsObservatorySummary(data.Observatory)
				} else if data.Telemetry != nil {
					@opsTelemetrySummary(data.Telemetry)
				} else if data.Work != nil {
					@opsWorkSummary(data.Work)
				} else if data.Hive != nil {
					@opsHiveSummary(data.Hive, data.LegacyURL)
				} else if data.HiveShell != nil {
					@opsHiveShell(data.HiveShell)
				} else if data.Evidence != nil {
					if data.View == "forensic" {
						@opsEvidenceSummary(data.Evidence)
					} else {
						@opsRoleTimeline(data.Evidence)
					}
				} else if data.Decision != nil {
					@opsDecisionSurface(data.Decision)
				} else if data.Approvals != nil {
					@opsApprovalsQueue(data.Approvals)
				} else if data.EmbedURL != "" {
					<section class="border border-edge bg-surface rounded-lg overflow-hidden">
						<div class="px-4 py-3 border-b border-edge flex items-center justify-between gap-3">
							<div class="min-w-0">
								<h2 class="text-sm font-medium text-warm">{ data.EmbedLabel }</h2>
								<p class="text-xs text-warm-faint truncate">{ data.EmbedURL }</p>
							</div>
							<a href={ templ.SafeURL(data.EmbedURL) } class="text-xs px-3 py-1.5 rounded-md bg-elevated text-warm-muted hover:text-brand transition-colors" target="_blank" rel="noopener">
								Open
							</a>
						</div>
						<iframe
							src={ templ.SafeURL(data.EmbedURL) }
							title={ data.EmbedLabel }
							class="w-full h-[72vh] bg-void"
							loading="lazy"
						></iframe>
					</section>
				} else {
					<section class="grid gap-3 md:grid-cols-2">
						for _, surface := range data.Surfaces {
							<div class="border border-edge bg-surface rounded-lg p-4">
								<div class="flex items-start justify-between gap-3">
									<h2 class="text-sm font-medium text-warm">{ surface.Label }</h2>
									<a href={ templ.SafeURL(surface.Href) } class="text-xs text-brand hover:text-brand/80 transition-colors">Open</a>
								</div>
								<p class="text-sm text-warm-muted mt-2 leading-relaxed">{ surface.Description }</p>
								<dl class="grid grid-cols-[5.5rem_1fr] gap-x-3 gap-y-1 mt-4 text-xs">
									<dt class="text-warm-faint">Owner</dt>
									<dd class="text-warm-muted">{ surface.Owner }</dd>
									<dt class="text-warm-faint">Target</dt>
									<dd class="text-warm-muted break-all">{ surface.Target }</dd>
									<dt class="text-warm-faint">Status</dt>
									<dd class="text-warm-muted">{ surface.Status }</dd>
								</dl>
							</div>
						}
					</section>
				}
			</main>
			@simpleFooter(p)
		</body>
	</html>
}

templ opsGitHubCanonical(data *OpsGitHubCanonicalData) {
	<section class="space-y-4" data-github-canonical-migration="read-only">
		<section class="border border-edge bg-surface rounded-lg overflow-hidden">
			<header class="px-4 py-3 border-b border-edge flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
				<div>
					<h2 class="text-base font-medium text-warm">GitHub-canonical migration</h2>
					<p class="text-sm text-warm-muted mt-2 leading-relaxed">GitHub Issues are the live source-of-intent target; legacy markdown is background evidence only until the cutover criteria in docs#197 are complete.</p>
					<p class="text-xs text-warm-faint mt-2">Parent: <a href={ templ.SafeURL(data.Parent.URL) } class="text-brand hover:underline" target="_blank" rel="noopener">{ githubCanonicalIssueLabel(data.Parent) }</a> · { data.Parent.Title }</p>
				</div>
				<div class="flex flex-col items-start md:items-end gap-2">
					<span class="text-[10px] px-2 py-1 rounded-full border border-brand/30 text-brand bg-brand/10 whitespace-nowrap">{ data.Status }</span>
					<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-faint bg-void/30 whitespace-nowrap">effect = none</span>
				</div>
			</header>
			<dl class="grid gap-x-3 gap-y-2 p-4 text-xs md:grid-cols-[10rem_1fr]">
				<dt class="text-warm-faint">projection state</dt>
				<dd class="text-warm-muted">{ data.ProjectionState }</dd>
				<dt class="text-warm-faint">rendered_at</dt>
				<dd class="text-warm-muted">{ data.GeneratedAt }</dd>
				<dt class="text-warm-faint">scanner_snapshot_at</dt>
				<dd class="text-warm-muted">{ data.ScannerSnapshotAt }</dd>
				<dt class="text-warm-faint">source_mode</dt>
				<dd class="text-warm-muted">{ data.ProjectionSource }</dd>
				<dt class="text-warm-faint">boundary</dt>
				<dd class="text-warm-muted">read-only static scanner-evidence transcription; no Hive wake, GitHub mutation, EventGraph write, runtime start, approval, merge, deploy, or autonomy increase</dd>
			</dl>
		</section>
		<section class="border border-edge bg-surface rounded-lg overflow-hidden" data-github-canonical-progress="read-only">
			<header class="px-4 py-3 border-b border-edge flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
				<div>
					<h2 class="text-sm font-medium text-warm">Progress accounting</h2>
					<p class="text-xs text-warm-faint mt-1">Recent issue closeouts and the parked-frontier reason are shown together so activity and closure state are not confused.</p>
				</div>
				<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", githubCanonicalStateClass(data.Progress.Recommendation) }>{ data.Progress.Recommendation }</span>
			</header>
			<div class="p-4 space-y-4">
				<p class="text-sm text-warm-muted leading-relaxed">{ data.Progress.Summary }</p>
				<div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
					<dl class="border border-edge bg-void/20 rounded-md p-3 text-[11px] grid grid-cols-[10.5rem_1fr] gap-x-2 gap-y-1">
						<dt class="text-warm-faint">closure_window</dt><dd class="text-warm-muted break-all">{ data.Progress.ClosureWindow }</dd>
						<dt class="text-warm-faint">closed_intake_issue_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.Progress.ClosedIssueCount) }</dd>
						<dt class="text-warm-faint">merged_pr_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.Progress.MergedPRCount) }</dd>
					</dl>
					<dl class="border border-edge bg-void/20 rounded-md p-3 text-[11px] grid grid-cols-[10.5rem_1fr] gap-x-2 gap-y-1">
						<dt class="text-warm-faint">recent_closeouts_shown</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.Progress.RecentCloseoutsShown) }</dd>
						<dt class="text-warm-faint">parked_open_issue_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.Progress.ParkedOpenIssueCount) }</dd>
					</dl>
					<dl class="border border-edge bg-void/20 rounded-md p-3 text-[11px] grid grid-cols-[10.5rem_1fr] gap-x-2 gap-y-1">
						<dt class="text-warm-faint">pr_ready_issue_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.Progress.PRReadyIssueCount) }</dd>
						<dt class="text-warm-faint">candidate_bundle_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.Progress.CandidateBundleCount) }</dd>
						<dt class="text-warm-faint">candidate_singleton_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.Progress.CandidateSingletonCount) }</dd>
					</dl>
					<div class="border border-edge bg-void/20 rounded-md p-3">
						<p class="text-[11px] text-warm-faint leading-relaxed">{ data.Progress.Boundary }</p>
					</div>
				</div>
				<div class="grid gap-4 xl:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
					<section class="border border-edge bg-void/20 rounded-md overflow-hidden">
						<header class="px-3 py-2 border-b border-edge flex items-center justify-between gap-3">
							<h3 class="text-xs font-medium text-warm uppercase tracking-widest">Recent closeouts</h3>
							<span class="text-[10px] text-warm-faint tabular-nums">{ fmt.Sprintf("%d", len(data.Progress.RecentCloseouts)) }</span>
						</header>
						<div class="divide-y divide-edge">
							for _, item := range data.Progress.RecentCloseouts {
								<article class="px-3 py-3">
									<div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
										<div>
											<a href={ templ.SafeURL(item.Issue.URL) } class="text-sm font-medium text-brand hover:underline break-all" target="_blank" rel="noopener">{ githubCanonicalIssueLabel(item.Issue) }</a>
											<p class="text-[11px] text-warm-faint mt-1 break-words">{ item.Issue.Title }</p>
										</div>
										<a href={ templ.SafeURL(item.PRURL) } class="text-[11px] text-brand hover:underline whitespace-nowrap" target="_blank" rel="noopener">{ item.PRRef }</a>
									</div>
									<dl class="grid gap-x-2 gap-y-1 mt-3 text-[11px] md:grid-cols-[6.5rem_1fr]">
										<dt class="text-warm-faint">closed_at</dt><dd class="text-warm-muted break-all">{ item.ClosedAt }</dd>
										<dt class="text-warm-faint">merged_at</dt><dd class="text-warm-muted break-all">{ item.MergedAt }</dd>
										<dt class="text-warm-faint">merge</dt><dd class="text-warm-muted break-all">{ item.MergeCommit }</dd>
										<dt class="text-warm-faint">reviewed_head</dt><dd class="text-warm-muted break-all">{ item.ReviewedHead }</dd>
										<dt class="text-warm-faint">note</dt><dd class="text-warm-faint break-words">{ item.Note }</dd>
									</dl>
								</article>
							}
						</div>
					</section>
					<section class="border border-edge bg-void/20 rounded-md overflow-hidden">
						<header class="px-3 py-2 border-b border-edge">
							<h3 class="text-xs font-medium text-warm uppercase tracking-widest">Parked reasons</h3>
						</header>
						<div class="divide-y divide-edge">
							for _, group := range data.Progress.ParkedGroups {
								<article class="px-3 py-3">
									<div class="flex items-start justify-between gap-3">
										<h4 class="text-sm font-medium text-warm">{ group.Label }</h4>
										<span class="text-[10px] text-warm-faint tabular-nums">{ fmt.Sprintf("%d", group.Count) }</span>
									</div>
									<p class="text-[11px] text-warm-muted mt-2 leading-relaxed">{ group.RequiredNext }</p>
									<p class="text-[11px] text-warm-faint mt-2 break-all">{ opsCivilizationJoin(group.Refs, "none") }</p>
								</article>
							}
						</div>
						<div class="px-3 py-3 border-t border-edge">
							<p class="text-[11px] text-warm-faint break-all">evidence_refs: { opsCivilizationJoin(data.Progress.EvidenceRefs, "none") }</p>
						</div>
					</section>
				</div>
			</div>
		</section>
		<section class="border border-edge bg-surface rounded-lg overflow-hidden" data-github-canonical-source-counts="read-only">
			<header class="px-4 py-3 border-b border-edge flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
				<div>
					<h2 class="text-sm font-medium text-warm">Scanner source counts</h2>
					<p class="text-xs text-warm-faint mt-1">Typed per-source counts from the platform scanner; zero-count repos are shown explicitly so clear lanes do not look unscanned.</p>
				</div>
				<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-faint bg-void/30 whitespace-nowrap">display only</span>
			</header>
			<div class="grid gap-3 p-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
				for _, source := range data.SourceSummaries {
					<article class="border border-edge bg-void/20 rounded-md p-3 min-h-[8rem]">
						<div class="flex items-start justify-between gap-3">
							<h3 class="text-sm font-medium text-warm break-all">{ source.Repo }</h3>
							<span class={ "text-[10px] px-2 py-1 rounded-full border tabular-nums whitespace-nowrap", templ.KV("border-emerald-400/40 text-emerald-300 bg-emerald-400/10", source.IssueCount == 0), templ.KV("border-amber-300/40 text-amber-300 bg-amber-300/10", source.IssueCount > 0) }>{ fmt.Sprintf("%d", source.IssueCount) }</span>
						</div>
						<dl class="grid grid-cols-[4.25rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
							<dt class="text-warm-faint">source</dt><dd class="text-warm-muted break-all">{ source.Source }</dd>
							<dt class="text-warm-faint">kind</dt><dd class="text-warm-muted">{ source.Kind }</dd>
							<dt class="text-warm-faint">labels</dt><dd class="text-warm-muted break-all">{ opsCivilizationJoin(source.Labels, "none") }</dd>
							if source.Error != "" {
								<dt class="text-warm-faint">error</dt><dd class="text-amber-300 break-all">{ source.Error }</dd>
							}
						</dl>
					</article>
				}
			</div>
		</section>
		<section class="border border-edge bg-surface rounded-lg overflow-hidden" data-github-canonical-authority-actions="read-only">
			<header class="px-4 py-3 border-b border-edge flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
				<div>
					<h2 class="text-sm font-medium text-warm">Authority action queue</h2>
					<p class="text-xs text-warm-faint mt-1">Human-scope decisions required before the parked blocker refs can become PR-ready work.</p>
				</div>
				<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-faint bg-void/30 whitespace-nowrap">display only</span>
			</header>
			<div class="grid gap-3 p-4 lg:grid-cols-2">
				for _, action := range data.AuthorityActions {
					<article class="border border-edge bg-void/20 rounded-md p-3">
						<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
							<div>
								<h3 class="text-sm font-medium text-warm">{ action.Label }</h3>
								<p class="text-[11px] text-warm-faint mt-1 break-all">{ opsCivilizationJoin(action.BlockerRefs, "none") }</p>
							</div>
							<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", githubCanonicalStateClass(action.State) }>{ action.State }</span>
						</div>
						<dl class="grid gap-x-2 gap-y-2 mt-3 text-[11px] md:grid-cols-[8.75rem_1fr]">
							<dt class="text-warm-faint">required_decision</dt><dd class="text-warm-muted leading-relaxed">{ action.RequiredDecision }</dd>
							<dt class="text-warm-faint">unlocks</dt><dd class="text-warm-muted leading-relaxed">{ action.Unlocks }</dd>
							<dt class="text-warm-faint">evidence_expectation</dt><dd class="text-warm-faint leading-relaxed">{ action.EvidenceExpectation }</dd>
							<dt class="text-warm-faint">forbidden_actions</dt><dd class="text-warm-faint break-words">{ opsCivilizationJoin(action.ForbiddenActions, "; ") }</dd>
						</dl>
					</article>
				}
			</div>
		</section>
		<section class="grid gap-3 md:grid-cols-2 lg:grid-cols-4">
			for _, repo := range data.RepoSummaries {
				<article class="border border-edge bg-surface rounded-lg p-4 min-h-[10rem]">
					<div class="flex items-start justify-between gap-3">
						<h3 class="text-sm font-medium text-warm break-all">{ repo.Repo }</h3>
						<span class="text-[10px] text-warm-faint tabular-nums">{ fmt.Sprintf("%d", repo.Total) }</span>
					</div>
					<dl class="grid grid-cols-[6.5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
						<dt class="text-warm-faint">completed</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", repo.Completed) }</dd>
						<dt class="text-warm-faint">ready</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", repo.Ready) }</dd>
						<dt class="text-warm-faint">deferred</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", repo.Deferred) }</dd>
						<dt class="text-warm-faint">human scope</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", repo.HumanScope) }</dd>
						<dt class="text-warm-faint">protected</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", repo.Protected) }</dd>
						<dt class="text-warm-faint">legacy only</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", repo.LegacyOnly) }</dd>
					</dl>
					if repo.BlockedReason != "" {
						<p class="text-[11px] text-warm-faint mt-3 leading-relaxed">{ repo.BlockedReason }</p>
					}
				</article>
			}
		</section>
		<section class="border border-edge bg-surface rounded-lg overflow-hidden" data-github-canonical-autonomy-frontier="read-only">
			<header class="px-4 py-3 border-b border-edge flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
				<div>
					<h2 class="text-sm font-medium text-warm">Autonomy frontier</h2>
					<p class="text-xs text-warm-faint mt-1">Typed scanner frontier for parking or candidate-work posture; recommendation is evidence only, not authority.</p>
				</div>
				<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", githubCanonicalStateClass(data.AutonomyFrontier.Recommendation) }>{ data.AutonomyFrontier.Recommendation }</span>
			</header>
			<div class="grid gap-3 p-4 xl:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
				<div class="grid gap-2 sm:grid-cols-2">
					<dl class="border border-edge bg-void/20 rounded-md p-3 text-[11px] grid grid-cols-[9.75rem_1fr] gap-x-2 gap-y-1">
						<dt class="text-warm-faint">total_issue_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.AutonomyFrontier.TotalIssueCount) }</dd>
						<dt class="text-warm-faint">candidate_bundle_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.AutonomyFrontier.CandidateBundleCount) }</dd>
						<dt class="text-warm-faint">candidate_singleton_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.AutonomyFrontier.CandidateSingletonCount) }</dd>
						<dt class="text-warm-faint">review_group_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.AutonomyFrontier.ReviewGroupCount) }</dd>
						<dt class="text-warm-faint">singleton_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.AutonomyFrontier.SingletonCount) }</dd>
						<dt class="text-warm-faint">issue_shape_warning_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.AutonomyFrontier.IssueShapeWarningCount) }</dd>
					</dl>
					<dl class="border border-edge bg-void/20 rounded-md p-3 text-[11px] grid grid-cols-[11.75rem_1fr] gap-x-2 gap-y-1">
						<dt class="text-warm-faint">pr_ready_issue_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.AutonomyFrontier.PRReadyIssueCount) }</dd>
						<dt class="text-warm-faint">autonomous_pr_ready_issue_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.AutonomyFrontier.AutonomousPRReadyIssueCount) }</dd>
						<dt class="text-warm-faint">needs_human_scope_issue_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.AutonomyFrontier.NeedsHumanScopeIssueCount) }</dd>
						<dt class="text-warm-faint">protected_action_issue_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.AutonomyFrontier.ProtectedActionIssueCount) }</dd>
						<dt class="text-warm-faint">deferred_issue_count</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", data.AutonomyFrontier.DeferredIssueCount) }</dd>
					</dl>
				</div>
				<div class="border border-edge bg-void/20 rounded-md p-3">
					<dl class="grid grid-cols-[6.5rem_1fr] gap-x-2 gap-y-2 text-[11px]">
						<dt class="text-warm-faint">blocker_refs</dt><dd class="text-warm-muted break-all">{ opsCivilizationJoin(data.AutonomyFrontier.BlockerRefs, "none") }</dd>
						<dt class="text-warm-faint">evidence_refs</dt><dd class="text-warm-faint break-all">{ opsCivilizationJoin(data.AutonomyFrontier.EvidenceRefs, "none") }</dd>
					</dl>
					<p class="text-[11px] text-warm-faint mt-3 leading-relaxed">{ data.AutonomyFrontier.Boundary }</p>
				</div>
			</div>
		</section>
		<section class="border border-edge bg-surface rounded-lg overflow-hidden" data-github-canonical-issue-shape-warnings="read-only">
			<header class="px-4 py-3 border-b border-edge flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
				<div>
					<h2 class="text-sm font-medium text-warm">Issue shape warnings</h2>
					<p class="text-xs text-warm-faint mt-1">Scanner warning state for repair or human-scope triage only; absence does not authorize issue closure, PR-ready state, Hive wake, GitHub mutation, or Test 001 GREEN.</p>
				</div>
				<span class="text-[10px] px-2 py-1 rounded-full border border-amber-300/40 text-amber-300 bg-amber-300/10 whitespace-nowrap">warning projection</span>
			</header>
			if len(data.IssueWarnings) == 0 {
				<p class="p-4 text-sm text-warm-faint">No issue-shape warnings projected.</p>
			} else {
				<div class="grid gap-3 p-4 lg:grid-cols-2">
					for _, warning := range data.IssueWarnings {
						<article class="border border-edge bg-void/20 rounded-md p-3">
							<div class="flex items-start justify-between gap-3">
								<div>
									if warning.Issue.URL != "" {
										<a href={ templ.SafeURL(warning.Issue.URL) } class="text-sm font-medium text-brand hover:underline break-all" target="_blank" rel="noopener">{ githubCanonicalIssueLabel(warning.Issue) }</a>
									} else {
										<h3 class="text-sm font-medium text-warm break-all">{ githubCanonicalIssueLabel(warning.Issue) }</h3>
									}
									<p class="text-[11px] text-warm-faint mt-1 break-words">{ warning.Issue.Title }</p>
								</div>
								<span class="text-[10px] px-2 py-1 rounded-full border border-amber-300/40 text-amber-300 bg-amber-300/10 whitespace-nowrap">shape warning</span>
							</div>
							<dl class="grid grid-cols-[8.75rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
								<dt class="text-warm-faint">missing_fields</dt><dd class="text-warm-muted break-words">{ opsCivilizationJoin(warning.MissingFields, "none") }</dd>
								<dt class="text-warm-faint">recommendation</dt><dd class="text-warm-muted break-all">{ warning.Recommendation }</dd>
								<dt class="text-warm-faint">evidence_refs</dt><dd class="text-warm-faint break-all">{ opsCivilizationJoin(warning.EvidenceRefs, "none") }</dd>
							</dl>
							<p class="text-[11px] text-warm-faint mt-3 leading-relaxed">{ warning.Boundary }</p>
						</article>
					}
				</div>
			}
		</section>
		<section class="border border-edge bg-surface rounded-lg overflow-hidden" data-github-canonical-evidence-records="read-only">
			<header class="px-4 py-3 border-b border-edge flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
				<div>
					<h2 class="text-sm font-medium text-warm">Typed evidence records</h2>
					<p class="text-xs text-warm-faint mt-1">Projection-shaped EventGraph evidence for display only; not a live gate, Test 001 GREEN claim, EventGraph write, or Hive wake.</p>
				</div>
				<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-faint bg-void/30 whitespace-nowrap">display contract</span>
			</header>
			<div class="grid gap-3 p-4 xl:grid-cols-3">
				for _, record := range data.EvidenceRecords {
					<article class="border border-edge bg-void/20 rounded-md p-3">
						<div class="flex items-start justify-between gap-3">
							<div>
								<h3 class="text-sm font-medium text-warm">{ record.Name }</h3>
								<p class="text-[11px] text-brand mt-1 break-all">{ record.EventType }</p>
							</div>
							<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", githubCanonicalStateClass(record.Outcome) }>{ record.Outcome }</span>
						</div>
						<dl class="grid grid-cols-[8.75rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
							<dt class="text-warm-faint">schema</dt><dd class="text-warm-muted break-all">{ record.Schema }</dd>
							<dt class="text-warm-faint">source_issue_refs</dt><dd class="text-warm-muted break-all">{ opsCivilizationJoin(record.SourceIssueRefs, "none") }</dd>
							<dt class="text-warm-faint">pr_refs</dt><dd class="text-warm-muted break-all">{ opsCivilizationJoin(record.PRRefs, "none") }</dd>
							<dt class="text-warm-faint">validation_refs</dt><dd class="text-warm-muted break-all">{ opsCivilizationJoin(record.ValidationRefs, "none") }</dd>
							<dt class="text-warm-faint">cfar_refs</dt><dd class="text-warm-muted break-all">{ opsCivilizationJoin(record.CFARRefs, "none") }</dd>
							<dt class="text-warm-faint">authority_boundary_refs</dt><dd class="text-warm-muted break-all">{ opsCivilizationJoin(record.AuthorityBoundaryRefs, "none") }</dd>
							<dt class="text-warm-faint">residual_risk_refs</dt><dd class="text-warm-muted break-all">{ opsCivilizationJoin(record.ResidualRiskRefs, "none") }</dd>
							<dt class="text-warm-faint">provenance_refs</dt><dd class="text-warm-muted break-all">{ opsCivilizationJoin(record.ProvenanceRefs, "none") }</dd>
							<dt class="text-warm-faint">trace_score_basis_points</dt><dd class="text-warm-muted tabular-nums">{ fmt.Sprintf("%d", record.TraceScoreBasisPoints) }</dd>
						</dl>
						<p class="text-[11px] text-warm-faint mt-3 leading-relaxed">{ record.ProjectionReadinessNote }</p>
					</article>
				}
			</div>
		</section>
		<section class="border border-edge bg-surface rounded-lg overflow-hidden">
			<header class="px-4 py-3 border-b border-edge flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
				<div>
					<h2 class="text-sm font-medium text-warm">Canonical issue lanes</h2>
					<p class="text-xs text-warm-faint mt-1">One typed row per migration lane; markdown refs are historical evidence, not executable work.</p>
				</div>
				<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-faint bg-void/30 whitespace-nowrap">source-of-intent only</span>
			</header>
			<div class="overflow-x-auto" data-github-canonical-wide-table="lanes">
				<table class="w-full min-w-[94rem] text-left text-xs">
					<thead class="text-warm-faint border-b border-edge">
						<tr>
							<th class="py-2 px-3 font-medium min-w-[16rem]">Issue</th>
							<th class="py-2 px-3 font-medium">Repo</th>
							<th class="py-2 px-3 font-medium">State</th>
							<th class="py-2 px-3 font-medium">Substrate</th>
							<th class="py-2 px-3 font-medium">Readiness</th>
							<th class="py-2 px-3 font-medium">Blocked reason</th>
							<th class="py-2 px-3 font-medium">Labels</th>
							<th class="py-2 px-3 font-medium">Evidence refs</th>
							<th class="py-2 px-3 font-medium">Legacy refs</th>
						</tr>
					</thead>
					<tbody>
						for _, lane := range data.Lanes {
							<tr class="border-b border-edge/50 align-top">
								<td class="py-2 px-3 text-warm min-w-[16rem]">
									if lane.Issue.URL != "" && strings.HasPrefix(lane.Issue.URL, "https://") {
										<a href={ templ.SafeURL(lane.Issue.URL) } class="text-brand hover:underline break-all" target="_blank" rel="noopener">{ githubCanonicalIssueLabel(lane.Issue) }</a>
									} else {
										<p class="break-all">{ githubCanonicalIssueLabel(lane.Issue) }</p>
									}
									<p class="text-[10px] text-warm-faint mt-1 break-words">{ lane.Issue.Title }</p>
									<p class="text-[10px] text-warm-faint mt-1">parent: { lane.ParentRef }</p>
								</td>
								<td class="py-2 px-3 text-warm-muted break-all">{ lane.Issue.Repo }</td>
								<td class="py-2 px-3">
									<span class={ "inline-flex text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", githubCanonicalStateClass(lane.State) }>{ lane.State }</span>
									<p class="text-[10px] text-warm-faint mt-1">{ lane.Risk }</p>
								</td>
								<td class="py-2 px-3 text-warm-muted break-words">{ lane.Substrate }</td>
								<td class="py-2 px-3 text-warm-muted break-words">{ lane.Readiness }</td>
								<td class="py-2 px-3 text-warm-faint break-words">{ opsCivilizationValue(lane.BlockedReason, "none") }</td>
								<td class="py-2 px-3 text-warm-faint break-words">{ opsCivilizationJoin(lane.Labels, "none") }</td>
								<td class="py-2 px-3 text-warm-faint break-all">{ opsCivilizationJoin(lane.EvidenceRefs, "none") }</td>
								<td class="py-2 px-3 text-warm-faint break-all">{ opsCivilizationJoin(lane.LegacyRefs, "none") }</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</section>
		<section class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
			<section class="border border-edge bg-surface rounded-lg overflow-hidden">
				<header class="px-4 py-3 border-b border-edge">
					<h2 class="text-sm font-medium text-warm">Cutover checks</h2>
				</header>
				<div class="divide-y divide-edge">
					for _, check := range data.CutoverChecks {
						<div class="px-4 py-3">
							<div class="flex items-start justify-between gap-3">
								<h3 class="text-sm font-medium text-warm">{ check.Label }</h3>
								<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", githubCanonicalStateClass(check.State) }>{ check.State }</span>
							</div>
							<p class="text-xs text-warm-muted mt-2 leading-relaxed">{ check.Evidence }</p>
							if check.Blocker != "" {
								<p class="text-[11px] text-warm-faint mt-1 leading-relaxed">blocker: { check.Blocker }</p>
							}
						</div>
					}
				</div>
			</section>
			<section class="border border-edge bg-surface rounded-lg overflow-hidden">
				<header class="px-4 py-3 border-b border-edge">
					<h2 class="text-sm font-medium text-warm">Boundaries</h2>
				</header>
				<div class="p-4 space-y-4">
					<ul class="space-y-2">
						for _, boundary := range data.Boundaries {
							<li class="text-sm text-warm-muted leading-relaxed">{ boundary }</li>
						}
					</ul>
					<div class="border border-edge bg-void/20 rounded-md p-3">
						<h3 class="text-xs font-medium text-warm uppercase tracking-widest">Legacy evidence</h3>
						for _, item := range data.LegacyEvidence {
							<div class="mt-3">
								<p class="text-xs text-warm break-all">{ item.Ref }</p>
								<p class="text-[11px] text-warm-faint mt-1">{ item.State } · { item.Disposition }</p>
							</div>
						}
					</div>
				</div>
			</section>
		</section>
	</section>
}

templ opsDecisionSurface(d *OpsDecisionData) {
	<section class="space-y-4">
		<section class="border border-edge bg-surface rounded-lg overflow-hidden">
			<header class="px-4 py-3 border-b border-edge flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
				<div>
					<h2 class="text-base font-medium text-warm">Gate E decision surface</h2>
					<p class="text-sm text-warm-muted mt-2 leading-relaxed">Site is non-executing. It remains projection and governed decision console only.</p>
					<p class="text-xs text-warm-faint mt-2">Authorization: { d.AuthorizationSource }</p>
				</div>
				<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap self-start", opsDecisionStatusClass(d.Status) }>{ d.Status }</span>
			</header>
			<div class="p-4 space-y-3">
				<p class="text-sm text-warm-muted leading-relaxed">Site does not directly execute work, produce protected side effects, rely on policy-adapter decisions, run runner/worktree protected execution, or grant production autonomy.</p>
				<p class="text-sm text-warm-muted leading-relaxed">It also does not produce ExecutionReceipt production output or rely on policy-bundle evidence.</p>
				<form method="post" action="/ops/decision" class="grid gap-3 md:grid-cols-3">
					<input type="hidden" name="request_id" value={ d.RequestID }/>
					<div class="md:col-span-3 grid gap-3">
						<label class="block">
							<span class="text-xs text-warm-faint">Decision reason</span>
							<textarea name="reason" required rows="3" class="mt-1 w-full rounded-md border border-edge bg-void/40 px-3 py-2 text-sm text-warm placeholder:text-warm-faint" placeholder="Explain the operator-visible rationale.">{ d.DecisionReason }</textarea>
						</label>
						<p class="text-[11px] text-warm-faint">Approver attribution is assigned by Hive's configured decision writer; Site does not accept operator-entered actor IDs.</p>
					</div>
					for _, action := range d.Actions {
						<div class={ "border rounded-lg p-3 min-h-[8rem] flex flex-col",
							templ.KV("border-brand/40 bg-brand/10", action.WireValue == d.RequestedAction),
							templ.KV("border-edge bg-void/20", action.WireValue != d.RequestedAction) }
						>
							<div class="flex items-start justify-between gap-3">
								<h3 class="text-sm font-medium text-warm">{ action.Label }</h3>
								<span class="text-[10px] px-2 py-1 rounded-full border border-brand/30 text-brand bg-brand/10 whitespace-nowrap">effect = none</span>
							</div>
							<p class="text-xs text-warm-muted mt-3 leading-relaxed flex-1">{ action.Description }</p>
							<p class="text-[11px] text-warm-faint mt-2">requested_action: { action.WireValue }</p>
							<button name="decision" value={ action.WireValue } formnovalidate?={ action.WireValue == opsDecisionMoreEvidence } class="mt-3 w-full text-xs px-3 py-2 rounded-md border border-brand/40 bg-brand/10 text-brand hover:bg-brand/20 transition-colors">{ action.Label }</button>
						</div>
					}
				</form>
			</div>
		</section>
		<div class="grid gap-4 lg:grid-cols-[1fr_1fr]">
			<section class="border border-edge bg-surface rounded-lg overflow-hidden">
				<header class="px-4 py-3 border-b border-edge">
					<h2 class="text-sm font-medium text-warm">Request envelope</h2>
					<p class="text-xs text-warm-faint mt-1">Displayed locally by Site; not submitted to an executor.</p>
				</header>
				<dl class="grid grid-cols-[8.5rem_1fr] gap-x-3 gap-y-2 p-4 text-xs">
					<dt class="text-warm-faint">correlation_id</dt><dd class="text-warm-muted break-all">{ d.CorrelationID }</dd>
					<dt class="text-warm-faint">trace_id</dt><dd class="text-warm-muted break-all">{ d.TraceID }</dd>
					<dt class="text-warm-faint">requested_action</dt><dd class="text-warm-muted break-all">{ d.RequestedAction }</dd>
					<dt class="text-warm-faint">decision_reason</dt><dd class="text-warm-muted break-all">{ opsValueOr(d.DecisionReason, "missing") }</dd>
					<dt class="text-warm-faint">target_type</dt><dd class="text-warm-muted break-all">{ d.TargetType }</dd>
					<dt class="text-warm-faint">repo</dt><dd class="text-warm-muted break-all">{ d.Repo }</dd>
					<dt class="text-warm-faint">target_ref</dt><dd class="text-warm-muted break-all">{ opsValueOr(d.TargetRef, "missing") }</dd>
					<dt class="text-warm-faint">governance_scope</dt><dd class="text-warm-muted break-all">non-executing Site projection; effect = none; excluded scopes visible below</dd>
				</dl>
			</section>
			<section class="border border-edge bg-surface rounded-lg overflow-hidden">
				<header class="px-4 py-3 border-b border-edge">
					<h2 class="text-sm font-medium text-warm">Response and trace</h2>
					<p class="text-xs text-warm-faint mt-1">Acceptance means review display only, never downstream execution.</p>
				</header>
				<dl class="grid grid-cols-[8.5rem_1fr] gap-x-3 gap-y-2 p-4 text-xs">
					<dt class="text-warm-faint">correlation_id</dt><dd class="text-warm-muted break-all">{ d.CorrelationID }</dd>
					<dt class="text-warm-faint">trace_id</dt><dd class="text-warm-muted break-all">{ d.TraceID }</dd>
					<dt class="text-warm-faint">status</dt><dd class="text-warm-muted break-all">{ d.Status }</dd>
					<dt class="text-warm-faint">effect</dt><dd class="text-warm-muted break-all">effect = { d.Effect }</dd>
					<dt class="text-warm-faint">summary</dt><dd class="text-warm-muted break-all">{ d.OperatorSummary }</dd>
					if len(d.BlockedReasons) > 0 {
						<dt class="text-warm-faint">blocked_reason</dt>
						<dd class="text-amber-300 break-all">
							<ul class="space-y-1">
								for _, reason := range d.BlockedReasons {
									<li>{ reason }</li>
								}
							</ul>
						</dd>
					}
					if len(d.RequiredEvidence) > 0 {
						<dt class="text-warm-faint">required_evidence</dt>
						<dd class="text-warm-muted break-all">
							<ul class="space-y-1">
								for _, item := range d.RequiredEvidence {
									<li>{ item }</li>
								}
							</ul>
						</dd>
					}
				</dl>
			</section>
		</div>
		<section class="border border-edge bg-surface rounded-lg overflow-hidden">
			<header class="px-4 py-3 border-b border-edge">
				<h2 class="text-sm font-medium text-warm">Governance posture</h2>
				<p class="text-xs text-warm-faint mt-1">Excluded scopes are visible and fail closed before execution.</p>
			</header>
			<div class="grid gap-3 p-4 md:grid-cols-2 lg:grid-cols-4">
				for _, item := range d.GovernancePosture {
					@opsDecisionPostureCard(item)
				}
			</div>
		</section>
		<section class="grid gap-4 lg:grid-cols-[1fr_1fr]">
			<div class="border border-edge bg-surface rounded-lg overflow-hidden">
				<header class="px-4 py-3 border-b border-edge">
					<h2 class="text-sm font-medium text-warm">Fail-closed evidence</h2>
				</header>
				if len(d.BlockedReasons) == 0 {
					<p class="px-4 py-6 text-sm text-warm-faint">No blocked reasons for this displayed envelope.</p>
				} else {
					<div class="divide-y divide-edge">
						for _, reason := range d.BlockedReasons {
							<p class="px-4 py-3 text-sm text-amber-300">{ reason }</p>
						}
					</div>
				}
				if len(d.RequiredEvidence) > 0 {
					<div class="border-t border-edge px-4 py-3">
						<h3 class="text-xs font-medium text-warm uppercase tracking-widest">Required evidence</h3>
						<ul class="mt-2 space-y-1">
							for _, item := range d.RequiredEvidence {
								<li class="text-xs text-warm-muted">{ item }</li>
							}
						</ul>
					</div>
				}
			</div>
			<div class="border border-edge bg-surface rounded-lg overflow-hidden">
				<header class="px-4 py-3 border-b border-edge">
					<h2 class="text-sm font-medium text-warm">Residual-risk boundary</h2>
				</header>
				<div class="grid gap-3 p-4">
					for _, item := range d.BoundaryChecks {
						@opsDecisionPostureCard(item)
					}
				</div>
			</div>
		</section>
	</section>
}

templ opsApprovalsQueue(a *OpsApprovalsData) {
	<section class="space-y-4">
		<section class="border border-edge bg-surface rounded-lg overflow-hidden">
			<header class="px-4 py-3 border-b border-edge flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
				<div>
					<h2 class="text-base font-medium text-warm">Authority approval queue</h2>
					<p class="text-sm text-warm-muted mt-2 leading-relaxed">Pending requests, recent decisions, and audit refs are projected from Hive. Site forwards supported approve/deny decisions to Hive; EventGraph remains truth.</p>
					if a.ProjectionSource != "" || a.GeneratedAt != "" {
						<p class="text-xs text-warm-faint mt-2">{ opsValueOr(a.ProjectionSource, "projection") } · { opsValueOr(a.GeneratedAt, "time unknown") }</p>
					}
				</div>
				<span class="text-[10px] px-2 py-1 rounded-full border border-brand/30 text-brand bg-brand/10 whitespace-nowrap self-start">effect = none</span>
			</header>
			if a.ProjectionError != "" {
				<p class="px-4 py-4 text-sm text-amber-300">{ a.ProjectionError }</p>
			} else {
				if a.ProjectionWarning != "" {
					<p class="px-4 pt-4 text-sm text-amber-300">{ a.ProjectionWarning }</p>
				}
				<div class="grid gap-3 p-4 md:grid-cols-3">
					@opsMetric("Pending", fmt.Sprintf("%d", len(a.PendingApprovals)), "authority requests")
					@opsMetric("Decisions", fmt.Sprintf("%d", len(a.AuthorityDecisions)), "recent records")
					@opsMetric("Audit refs", fmt.Sprintf("%d", len(a.KeyAuditTraces)), "key/audit traces")
				</div>
			}
		</section>
		if a.ProjectionError == "" {
			<section class="border border-edge bg-surface rounded-lg overflow-hidden">
				<header class="px-4 py-3 border-b border-edge">
					<h2 class="text-sm font-medium text-warm">Pending approvals</h2>
					<p class="text-xs text-warm-faint mt-1">Each row includes the causal request id and source event id used for audit.</p>
				</header>
				if len(a.PendingApprovals) == 0 {
					<p class="px-4 py-6 text-sm text-warm-faint">No pending authority requests projected.</p>
				} else {
					<div class="divide-y divide-edge">
						for _, item := range a.PendingApprovals {
							<div class="px-4 py-4 grid gap-3 lg:grid-cols-[1fr_auto]">
								<div class="min-w-0">
									<div class="flex flex-wrap items-center gap-2">
										<h3 class="text-sm font-medium text-warm break-all">{ opsValueOr(item.ActionName, "authority request") }</h3>
										<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsDecisionStatusClass(item.ResolveStatus) }>{ item.ResolveStatus }</span>
									</div>
									<p class="text-xs text-warm-muted mt-2 leading-relaxed">{ opsValueOr(item.Justification, "no justification projected") }</p>
									<dl class="grid grid-cols-[7.5rem_1fr] gap-x-3 gap-y-1 mt-3 text-xs">
										<dt class="text-warm-faint">request_id</dt><dd class="text-warm-muted break-all">{ item.RequestID }</dd>
										<dt class="text-warm-faint">event_id</dt><dd class="text-warm-muted break-all">{ opsValueOr(item.EventID, "missing") }</dd>
										<dt class="text-warm-faint">actor</dt><dd class="text-warm-muted break-all">{ opsValueOr(item.RequestingActor, "unknown") }</dd>
										<dt class="text-warm-faint">target</dt><dd class="text-warm-muted break-all">{ opsValueOr(item.Target, "missing") }</dd>
										<dt class="text-warm-faint">environment</dt><dd class="text-warm-muted break-all">{ opsValueOr(item.Environment, "unspecified") }</dd>
										if item.RiskSummary != "" {
											<dt class="text-warm-faint">risk</dt><dd class="text-warm-muted break-all">{ item.RiskSummary }</dd>
										}
										if item.ProposedOperation != "" {
											<dt class="text-warm-faint">operation</dt><dd class="text-warm-muted break-all">{ item.ProposedOperation }</dd>
										}
										<dt class="text-warm-faint">created</dt><dd class="text-warm-muted break-all">{ formatOpsTime(item.CreatedAt) }</dd>
									</dl>
								</div>
								<div class="lg:w-44">
									if item.ResolveEnabled {
										<a href={ templ.SafeURL(item.DecisionHref) } class="inline-flex w-full items-center justify-center rounded-md border border-brand/40 bg-brand/10 px-3 py-2 text-xs text-brand hover:bg-brand/20 transition-colors">Review decision</a>
									} else {
										<p class="rounded-md border border-edge bg-void/20 px-3 py-2 text-xs text-warm-faint">Hive decision POST currently resolves draft-PR requests only; this item is audit-visible but not actionable here.</p>
									}
								</div>
							</div>
						}
					</div>
				}
			</section>
			<section class="grid gap-4 lg:grid-cols-[1fr_1fr]">
				<section class="border border-edge bg-surface rounded-lg overflow-hidden">
					<header class="px-4 py-3 border-b border-edge">
						<h2 class="text-sm font-medium text-warm">Recent authority decisions</h2>
					</header>
					if len(a.AuthorityDecisions) == 0 {
						<p class="px-4 py-6 text-sm text-warm-faint">No authority decisions projected.</p>
					} else {
						<div class="divide-y divide-edge">
							for _, d := range a.AuthorityDecisions {
								<div class="px-4 py-3">
									<div class="flex items-start justify-between gap-3">
										<h3 class="text-sm font-medium text-warm break-all">{ opsValueOr(d.Outcome, "decision") }</h3>
										<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsDecisionStatusClass(d.Outcome) }>{ opsValueOr(d.Outcome, "recorded") }</span>
									</div>
									<dl class="grid grid-cols-[7.5rem_1fr] gap-x-3 gap-y-1 mt-3 text-xs">
										<dt class="text-warm-faint">decision_id</dt><dd class="text-warm-muted break-all">{ opsValueOr(d.DecisionID, d.EventID) }</dd>
										<dt class="text-warm-faint">request_id</dt><dd class="text-warm-muted break-all">{ d.RequestID }</dd>
										<dt class="text-warm-faint">approver</dt><dd class="text-warm-muted break-all">{ opsValueOr(d.ApproverActor, "unknown") }</dd>
										<dt class="text-warm-faint">action</dt><dd class="text-warm-muted break-all">{ opsValueOr(d.ApprovedAction, d.RequestedAction) }</dd>
										<dt class="text-warm-faint">target</dt><dd class="text-warm-muted break-all">{ opsValueOr(d.ApprovedTarget, d.RequestedTarget) }</dd>
										<dt class="text-warm-faint">reason</dt><dd class="text-warm-muted break-all">{ opsValueOr(d.Rationale, "missing") }</dd>
									</dl>
								</div>
							}
						</div>
					}
				</section>
				<section class="border border-edge bg-surface rounded-lg overflow-hidden">
					<header class="px-4 py-3 border-b border-edge">
						<h2 class="text-sm font-medium text-warm">Guardian audit refs</h2>
					</header>
					if len(a.KeyAuditTraces) == 0 {
						<p class="px-4 py-6 text-sm text-warm-faint">No key or audit traces projected.</p>
					} else {
						<div class="divide-y divide-edge">
							for _, trace := range a.KeyAuditTraces {
								<div class="px-4 py-3">
									<h3 class="text-sm font-medium text-warm break-all">{ opsValueOr(trace.EventType, "audit event") }</h3>
									<dl class="grid grid-cols-[7.5rem_1fr] gap-x-3 gap-y-1 mt-3 text-xs">
										<dt class="text-warm-faint">event_id</dt><dd class="text-warm-muted break-all">{ trace.EventID }</dd>
										<dt class="text-warm-faint">actor</dt><dd class="text-warm-muted break-all">{ opsValueOr(trace.ActorID, trace.SubjectActorID) }</dd>
										<dt class="text-warm-faint">request</dt><dd class="text-warm-muted break-all">{ opsValueOr(trace.AuthorityRequest, "none") }</dd>
										<dt class="text-warm-faint">decision</dt><dd class="text-warm-muted break-all">{ opsValueOr(trace.DecisionEvent, "none") }</dd>
										<dt class="text-warm-faint">created</dt><dd class="text-warm-muted break-all">{ formatOpsTime(trace.CreatedAt) }</dd>
									</dl>
								</div>
							}
						</div>
					}
				</section>
			</section>
		}
	</section>
}

templ opsDecisionPostureCard(item OpsDecisionPosture) {
	<div class="border border-edge bg-void/20 rounded-lg p-3 min-h-[7rem]">
		<div class="flex items-start justify-between gap-2">
			<h3 class="text-sm font-medium text-warm">{ item.Label }</h3>
			<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsDecisionStatusClass(item.Status) }>{ item.Status }</span>
		</div>
		<p class="text-[11px] text-warm-faint mt-2 break-all">{ item.Field }</p>
		<p class="text-xs text-warm-muted mt-2 break-all">{ item.Value }</p>
	</div>
}

templ opsTelemetrySummary(t *OpsTelemetryData) {
	<section class="space-y-4">
		<div class="border border-edge bg-surface rounded-lg p-4">
			<div>
				<h2 class="text-base font-medium text-warm">Telemetry summary</h2>
				if t.GeneratedAt != "" {
					<p class="text-xs text-warm-faint mt-1">Projected at { t.GeneratedAt }</p>
				}
				if t.Error != "" {
					<p class="text-sm text-red-300 mt-2">{ t.Error }</p>
				}
			</div>
		</div>
		if t.Error == "" {
			<div class="grid gap-3 md:grid-cols-4">
				@opsMetric("Actors", fmt.Sprintf("%d", t.ActorCount), "registered identities")
				@opsMetric("Agents", fmt.Sprintf("%d", t.AgentCount), "reported by Work")
				@opsMetric("Active", fmt.Sprintf("%d", t.ActiveAgentCount), "non-idle or processing")
				@opsMetric("Processing", fmt.Sprintf("%d", t.ProcessingAgentCount), "currently working")
			</div>
			@opsPipelineReport(t)
			<div class="grid gap-3 lg:grid-cols-[1fr_1fr]">
				<section class="border border-edge bg-surface rounded-lg overflow-hidden">
					<header class="px-4 py-3 border-b border-edge flex items-center justify-between gap-3">
						<div>
							<h2 class="text-sm font-medium text-warm">Agent status</h2>
							if t.PhaseLabel != "" {
								<p class="text-xs text-warm-faint mt-1">{ t.PhaseLabel } / { t.PhaseStatus }</p>
							}
						</div>
					</header>
					<div class="divide-y divide-edge">
						for _, agent := range t.RecentAgents {
							<div class="px-4 py-3">
								<div class="flex items-start justify-between gap-3">
									<div class="min-w-0">
										<h3 class="text-sm font-medium text-warm truncate">{ agent.Role }</h3>
										<p class="text-xs text-warm-faint mt-1 truncate">{ agent.Model }</p>
									</div>
									<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsAgentStateClass(agent.State) }>{ agent.State }</span>
								</div>
								if agent.LastMessage != "" {
									<p class="text-xs text-warm-muted mt-2 leading-relaxed line-clamp-2">{ agent.LastMessage }</p>
								}
							</div>
						}
					</div>
				</section>
				<section class="border border-edge bg-surface rounded-lg overflow-hidden">
					<header class="px-4 py-3 border-b border-edge">
						<h2 class="text-sm font-medium text-warm">Recent events</h2>
					</header>
					<div class="divide-y divide-edge">
						for _, event := range t.RecentEvents {
							<div class="px-4 py-3">
								<div class="flex items-start justify-between gap-3">
									<div class="min-w-0">
										<h3 class="text-sm font-medium text-warm truncate">{ event.Summary }</h3>
										<p class="text-xs text-warm-faint mt-1">{ event.ActorRole } / { event.EventType }</p>
									</div>
									<span class="text-[10px] text-warm-faint whitespace-nowrap">{ formatOpsTime(event.At) }</span>
								</div>
							</div>
						}
					</div>
				</section>
			</div>
		}
	</section>
}

templ opsPipelineReport(t *OpsTelemetryData) {
	<section class="border border-edge bg-surface rounded-lg overflow-hidden">
		<header class="px-4 py-3 border-b border-edge flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
			<div>
				<h2 class="text-sm font-medium text-warm">Pipeline report</h2>
				if t.Pipeline != nil && t.Pipeline.CycleID != "" {
					<p class="text-xs text-warm-faint mt-1">{ t.Pipeline.CycleID }</p>
				} else {
					<p class="text-xs text-warm-faint mt-1">{ t.PipelineURL }</p>
				}
				if t.PipelineError != "" {
					<p class="text-xs text-amber-300 mt-2">{ t.PipelineError }</p>
				}
			</div>
			if t.Pipeline != nil {
				<span class="text-[10px] px-2 py-1 rounded-full border border-brand/30 text-brand bg-brand/10 whitespace-nowrap">{ opsValueOr(t.Pipeline.Status, "unknown") }</span>
			}
		</header>
		if t.Pipeline == nil {
			<p class="px-4 py-6 text-sm text-warm-faint">No pipeline report returned.</p>
		} else {
			<div class="p-4 space-y-4">
				if t.Pipeline.HumanStatus != "" {
					<p class="text-sm text-warm-muted leading-relaxed">{ t.Pipeline.HumanStatus }</p>
				}
				<div class="grid gap-3 md:grid-cols-4">
					@opsMetric("Stage", opsValueOr(t.Pipeline.CurrentStage, "unknown"), opsValueOr(t.Pipeline.CurrentPhase, "phase unknown"))
					@opsMetric("Board open", fmt.Sprintf("%d", t.Pipeline.OpenBoardItems), "items still open")
					@opsMetric("Cost", fmt.Sprintf("$%.4f", t.Pipeline.TotalCostUSD), "cycle total")
					@opsMetric("Tokens", fmt.Sprintf("%d", t.Pipeline.TotalTokens), "input plus output")
				</div>
				<div class="grid gap-3 md:grid-cols-3">
					@opsMetric("Duration", formatOpsDuration(t.Pipeline.DurationSecs), "cycle elapsed")
					@opsMetric("Revisions", fmt.Sprintf("%d", t.Pipeline.ReviseCount), "revise loops")
					@opsMetric("Updated", formatOpsTime(t.Pipeline.UpdatedAt), "latest phase")
				</div>
				<div class="grid gap-3 lg:grid-cols-5">
					for _, phase := range t.Pipeline.Phases {
						<div class="border border-edge bg-void/20 rounded-lg p-3 min-h-[8.5rem]">
							<div class="flex items-start justify-between gap-2">
								<div class="min-w-0">
									<h3 class="text-sm font-medium text-warm truncate">{ opsValueOr(phase.WorkflowStage, phase.Phase) }</h3>
									<p class="text-[11px] text-warm-faint mt-1 truncate">{ opsValueOr(phase.Phase, "phase") }</p>
								</div>
								<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsPipelineOutcomeClass(phase.Outcome) }>{ opsValueOr(phase.Outcome, "unknown") }</span>
							</div>
							if phase.Summary != "" {
								<p class="text-xs text-warm-muted leading-relaxed mt-3 line-clamp-3">{ phase.Summary }</p>
							}
							<p class="text-[11px] text-warm-faint mt-3">{ formatOpsDuration(phase.DurationSecs) } / { fmt.Sprintf("$%.4f", phase.CostUSD) }</p>
						</div>
					}
				</div>
			</div>
		}
	</section>
}

templ opsHiveSummary(h *OpsHiveData, publicURL string) {
	<section class="space-y-4">
		@opsHiveSubnav("overview")
		<div class="border border-edge bg-surface rounded-lg p-4 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
			<div>
				<h2 class="text-base font-medium text-warm">Hive summary</h2>
				if h.GeneratedAt != "" {
					<p class="text-xs text-warm-faint mt-1">Projected at { h.GeneratedAt }</p>
				}
				if h.Error != "" {
					<p class="text-sm text-red-300 mt-2">{ h.Error }</p>
				}
			</div>
			<a href={ templ.SafeURL(publicURL) } class="inline-flex items-center justify-center px-3 py-2 rounded-md bg-elevated text-warm-muted hover:text-brand transition-colors text-sm" target="_blank" rel="noopener">
				Public live build
			</a>
		</div>
		if h.Error == "" {
			<div class="grid gap-3 md:grid-cols-4">
				@opsMetric("Iteration", fmt.Sprintf("%d", h.Iteration), "highest observed run")
				@opsMetric("Phase", opsValueOr(h.Phase, "unknown"), "current runtime signal")
				@opsMetric("Ops", fmt.Sprintf("%d", h.TotalOps), "recorded agent operations")
				@opsMetric("Diagnostics", fmt.Sprintf("%d", h.DiagnosticCount), "recent phase events")
			</div>
			<div class="grid gap-3 md:grid-cols-4">
				@opsMetric("Builds", fmt.Sprintf("%d", h.VerifiedBuilds), "cost-tagged outputs")
				@opsMetric("Cost", fmt.Sprintf("$%.2f", h.TotalCost), "verified build spend")
				@opsMetric("Average", fmt.Sprintf("$%.2f", h.AverageCost), "per verified build")
				@opsMetric("Last active", opsValueOr(h.LastActive, "none"), "latest recorded operation")
			</div>
			@opsHiveAuthorityProjection(h)
			<div class="grid gap-3 lg:grid-cols-[1fr_1fr]">
				<section class="border border-edge bg-surface rounded-lg overflow-hidden">
					<header class="px-4 py-3 border-b border-edge">
						<h2 class="text-sm font-medium text-warm">Runtime signal</h2>
						if h.BuildTitle != "" {
							<p class="text-xs text-warm-faint mt-1">{ h.BuildTitle }</p>
						}
					</header>
					<div class="divide-y divide-edge">
						if len(h.RecentEvents) == 0 {
							<p class="px-4 py-6 text-sm text-warm-faint">No diagnostic events reported.</p>
						}
						for _, event := range h.RecentEvents {
							<div class="px-4 py-3">
								<div class="flex items-start justify-between gap-3">
									<div class="min-w-0">
										<h3 class="text-sm font-medium text-warm truncate">{ opsValueOr(event.Phase, "unknown phase") }</h3>
										<p class="text-xs text-warm-faint mt-1">{ opsValueOr(event.Outcome, "ok") }</p>
									</div>
									if !event.Timestamp.IsZero() {
										<span class="text-[10px] text-warm-faint whitespace-nowrap">{ event.Timestamp.Format("2006-01-02 15:04") }</span>
									}
								</div>
							</div>
						}
					</div>
				</section>
				<section class="border border-edge bg-surface rounded-lg overflow-hidden">
					<header class="px-4 py-3 border-b border-edge">
						<h2 class="text-sm font-medium text-warm">Recent commits</h2>
						<p class="text-xs text-warm-faint mt-1">Build repository activity when a loop directory is configured.</p>
					</header>
					<div class="divide-y divide-edge">
						if len(h.RecentCommits) == 0 {
							<p class="px-4 py-6 text-sm text-warm-faint">No local commit feed available.</p>
						}
						for _, commit := range h.RecentCommits {
							<div class="px-4 py-3 flex items-start gap-3 min-w-0">
								<span class="font-mono text-xs text-warm-faint shrink-0">{ commit.Hash }</span>
								<span class="font-mono text-xs text-warm truncate">{ commit.Subject }</span>
							</div>
						}
					</div>
				</section>
			</div>
		}
	</section>
}

templ opsHiveSubnav(active string) {
	<nav class="grid gap-3 md:grid-cols-5" aria-label="Hive operator views">
		for _, card := range opsHiveShellCards() {
			<a
				href={ templ.SafeURL(card.Href) }
				class={ "border rounded-lg p-3 min-h-[7.5rem] transition-colors flex flex-col",
					templ.KV("border-brand/40 bg-brand/10", card.ID == active),
					templ.KV("border-edge bg-surface hover:border-brand/30 hover:bg-elevated/60", card.ID != active) }
			>
				<div class="flex items-start justify-between gap-2">
					<h2 class="text-sm font-medium text-warm">{ card.Label }</h2>
					<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsHiveShellStatusClass(card.Status) }>{ card.Status }</span>
				</div>
				<p class="text-xs text-warm-muted leading-relaxed mt-2 flex-1">{ card.Description }</p>
			</a>
		}
	</nav>
}

templ opsHiveShell(shell *OpsHiveShellData) {
	<section class="space-y-4">
		@opsHiveSubnav(shell.Active)
		<section class="border border-edge bg-surface rounded-lg overflow-hidden">
			<header class="px-4 py-3 border-b border-edge flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
				<div>
					<h2 class="text-base font-medium text-warm">Hive control room</h2>
					<p class="text-sm text-warm-muted mt-2 leading-relaxed">Site-owned operator shell. Intake can queue governed Hive launch intent; runtime start remains separate evidence.</p>
				</div>
				<span class="text-[10px] px-2 py-1 rounded-full border border-brand/30 text-brand bg-brand/10 whitespace-nowrap self-start">queued launch boundary</span>
			</header>
			if shell.Active == "intake" {
				@opsHiveIntakeShell(shell.Intake, shell.Profile)
			} else if shell.Active == "runs" {
				@opsHiveRunsShell(shell.Runs, shell.Launches)
			} else if shell.Active == "agents" {
				@opsHiveAgentsShell(shell.Agents)
			} else if shell.Active == "resources" {
				@opsHiveResourcesShell(shell.Resources)
			}
		</section>
	</section>
}

templ opsHiveIntakeShell(intake OpsHiveIntakeView, profileSlug string) {
	<div class="grid gap-4 p-4 lg:grid-cols-[1.05fr_.95fr]">
		<section class="border border-edge bg-void/20 rounded-lg overflow-hidden">
			<header class="px-4 py-3 border-b border-edge">
				<h3 class="text-sm font-medium text-warm">Source input</h3>
				<p class="text-xs text-warm-faint mt-1">Persisted source cards for draft brief assembly and governed queued launch requests.</p>
				if intake.StorageStatus != "" {
					<p class="text-[11px] text-warm-faint mt-1">Storage: { intake.StorageStatus }</p>
				}
			</header>
			<div class="p-4 space-y-3">
				<form method="post" action="/ops/hive/intake/sources" class="border border-brand/30 bg-brand/5 rounded-lg p-4 space-y-3">
					if profileSlug != "" {
						<input type="hidden" name="profile" value={ profileSlug }/>
					}
					<div class="grid gap-3 md:grid-cols-[9rem_1fr]">
						<label class="block text-[11px] text-warm-faint">
							Type
							<select name="source_kind" class="mt-1 w-full px-2 py-2 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand">
								<option value="text">Text</option>
								<option value="url">URL</option>
								<option value="repo">Repo</option>
							</select>
						</label>
						<label class="block text-[11px] text-warm-faint">
							Title
							<input name="title" maxlength="72" placeholder="Optional title" class="mt-1 w-full px-2 py-2 bg-elevated border border-edge rounded-md text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
						</label>
					</div>
					<label class="block text-[11px] text-warm-faint">
						Source
						<textarea name="content" required maxlength="20000" rows="4" placeholder="Paste PRD/spec/plan text, a URL, or owner/repo context" class="mt-1 w-full px-3 py-2 bg-elevated border border-edge rounded-md text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand resize-y"></textarea>
					</label>
					<button type="submit" class="inline-flex items-center justify-center px-3 py-2 rounded-md bg-brand text-void text-xs font-medium hover:bg-brand-dark transition-colors">Add source</button>
				</form>
				if intake.Error != "" {
					<p class="text-xs text-red-300">{ intake.Error }</p>
				}
				<div class="grid gap-3">
					if len(intake.Sources) == 0 {
						<div class="border border-edge bg-surface rounded-lg p-4">
							<p class="text-sm text-warm-faint">No intake sources saved yet.</p>
						</div>
					}
					for _, source := range intake.Sources {
						<div class="border border-edge bg-surface rounded-lg p-3">
							<div class="flex items-start justify-between gap-3">
								<div class="min-w-0">
									<h4 class="text-sm font-medium text-warm truncate">{ source.Title }</h4>
									<p class="text-xs text-warm-faint mt-1">{ source.Kind } / { source.CreatedAt }</p>
								</div>
								<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsHiveShellStatusClass(source.Status) }>{ source.Status }</span>
							</div>
							<p class="text-xs text-warm-muted mt-2 leading-relaxed">{ source.Detail }</p>
							if source.Content != "" {
								<p class="text-[11px] text-warm-faint mt-2 leading-relaxed line-clamp-2">{ source.Content }</p>
							}
						</div>
					}
				</div>
			</div>
		</section>
		<section class="border border-edge bg-void/20 rounded-lg overflow-hidden">
			<header class="px-4 py-3 border-b border-edge">
				<h3 class="text-sm font-medium text-warm">Live interpretation</h3>
				<p class="text-xs text-warm-faint mt-1">Sample derived brief readiness for the initial shell.</p>
			</header>
			<div class="p-4 space-y-4">
				<div class="grid gap-3 sm:grid-cols-2">
					@opsMetric("Status", intake.Status, "launch readiness")
					@opsMetric("Confidence", intake.Confidence, "classification score")
					@opsMetric("Mode", intake.SuggestedMode, "suggested pipeline")
					@opsMetric("Budget", intake.EstimatedBudget, "operator cap")
				</div>
				<div class="border border-edge bg-surface rounded-lg p-3 space-y-3">
					<div class="flex items-start justify-between gap-3">
						<h4 class="text-xs font-medium text-warm uppercase tracking-widest">Factory brief</h4>
						<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsHiveShellStatusClass(intake.Status) }>{ intake.Status }</span>
					</div>
					<label class="block text-[11px] text-warm-faint">
						Title
						<input maxlength="72" value={ intake.Brief.Title } class="mt-1 w-full px-2 py-2 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand"/>
					</label>
					<label class="block text-[11px] text-warm-faint">
						Objective
						<textarea rows="3" class="mt-1 w-full px-3 py-2 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand resize-y">{ intake.Brief.Objective }</textarea>
					</label>
					<div class="grid gap-3 md:grid-cols-2">
						<label class="block text-[11px] text-warm-faint">
							Scope
							<textarea rows="4" class="mt-1 w-full px-3 py-2 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand resize-y">{ intake.Brief.Scope }</textarea>
						</label>
						<label class="block text-[11px] text-warm-faint">
							Acceptance
							<textarea rows="4" class="mt-1 w-full px-3 py-2 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand resize-y">{ intake.Brief.Acceptance }</textarea>
						</label>
					</div>
					<label class="block text-[11px] text-warm-faint">
						Risks
						<textarea rows="3" class="mt-1 w-full px-3 py-2 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand resize-y">{ intake.Brief.Risks }</textarea>
					</label>
					<div class="flex flex-wrap gap-2">
						for _, field := range intake.Brief.Missing {
							<span class={ "text-[10px] px-2 py-1 rounded-full border", opsHiveShellStatusClass(field.Status) }>{ field.Label }: { field.Status }</span>
						}
					</div>
					<p class="text-xs text-warm-muted">Readiness: { intake.Brief.Readiness }</p>
				</div>
				<div>
					<h4 class="text-xs font-medium text-warm uppercase tracking-widest">Missing info</h4>
					<div class="mt-3 grid gap-2">
						for _, field := range intake.MissingFields {
							<div class="flex items-start justify-between gap-3 border border-edge bg-surface rounded-lg p-3">
								<div class="min-w-0">
									<p class="text-sm text-warm">{ field.Label }</p>
									<p class="text-xs text-warm-muted mt-1 leading-relaxed">{ field.Detail }</p>
								</div>
								<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsHiveShellStatusClass(field.Status) }>{ field.Status }</span>
							</div>
						}
					</div>
				</div>
				<div class="border border-edge bg-surface rounded-lg p-3">
					<p class="text-xs text-warm-faint">Authority level</p>
					<p class="text-sm text-warm mt-1">{ intake.AuthorityLevel }</p>
					<p class="text-xs text-warm-muted mt-2">Queueing records launch intent in Hive. Runtime start remains separate evidence.</p>
					if intake.LaunchError != "" {
						<p class="text-xs text-red-300 mt-2">{ intake.LaunchError }</p>
					}
					if len(intake.Sources) == 0 {
						<p class="text-xs text-warm-faint mt-3">Add at least one source before queueing a Hive run request.</p>
					} else {
						<form method="post" action="/ops/hive/intake/launch" class="mt-3 grid gap-3">
							if profileSlug != "" {
								<input type="hidden" name="profile" value={ profileSlug }/>
							}
							<label class="block text-[11px] text-warm-faint">
								Target repos
								<input name="target_repos" required value="transpara-ai/hive" class="mt-1 w-full px-2 py-2 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand"/>
							</label>
							<div class="grid gap-3 md:grid-cols-2">
								<label class="block text-[11px] text-warm-faint">
									Max iterations
									<input name="max_iterations" required type="number" min="1" value="4" class="mt-1 w-full px-2 py-2 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand"/>
								</label>
								<label class="block text-[11px] text-warm-faint">
									Max cost USD
									<input name="max_cost_usd" required type="number" min="0" step="0.01" value="12.50" class="mt-1 w-full px-2 py-2 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand"/>
								</label>
							</div>
							<button type="submit" class="inline-flex items-center justify-center px-3 py-2 rounded-md bg-brand text-void text-xs font-medium hover:bg-brand-dark transition-colors">Queue Hive run request</button>
						</form>
					}
				</div>
			</div>
		</section>
	</div>
}

templ opsHiveRunsShell(runs []OpsHiveRunView, launches []OpsHiveRunLaunchView) {
	<div class="p-4 space-y-4">
		<div class="grid gap-3 md:grid-cols-3">
			@opsMetric("Runs", fmt.Sprintf("%d", len(runs)), "sample run records")
			@opsMetric("Pipeline", "Research -> Integrate", "visible stages")
			@opsMetric("Approvals", "sample queue", "read-only count")
		</div>
		if len(launches) > 0 {
			<section class="border border-edge bg-surface rounded-lg overflow-hidden">
				<header class="px-4 py-3 border-b border-edge">
					<h3 class="text-sm font-medium text-warm">Queued Hive run requests</h3>
					<p class="text-xs text-warm-faint mt-1">Stored Site proof of Hive-accepted queued launch intent. This is not runtime-start evidence.</p>
				</header>
				<div class="grid gap-3 p-4">
					for _, launch := range launches {
						<article class={ templ.KV("border border-brand/40 bg-brand/10 rounded-lg p-3", launch.Selected), templ.KV("border border-edge bg-void/20 rounded-lg p-3", !launch.Selected) }>
							<div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
								<div class="min-w-0">
									<h4 class="text-sm font-medium text-warm">{ launch.Title }</h4>
									<p class="text-[11px] text-warm-faint mt-1 font-mono break-all">{ launch.RunID }</p>
								</div>
								<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap self-start", opsHiveShellStatusClass(launch.Status) }>{ launch.Status }</span>
							</div>
							<div class="grid gap-3 mt-3 md:grid-cols-5">
								@opsMetric("Targets", launch.TargetRepos, "declared repos")
								@opsMetric("Operator", launch.OperatorID, "Site actor")
								@opsMetric("Budget", launch.Budget, "operator cap")
								@opsMetric("First event", launch.FirstEventID, "Hive source event")
								@opsMetric("Queued", launch.CreatedAt, "Site stored")
							</div>
						</article>
					}
				</div>
			</section>
		}
		<div class="grid gap-3">
			for _, run := range runs {
				<article class="border border-edge bg-void/20 rounded-lg p-4">
					<div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
						<div class="min-w-0">
							<h3 class="text-base font-medium text-warm">{ run.Title }</h3>
							<p class="text-xs text-warm-faint mt-1 font-mono">{ run.ID } - updated { run.UpdatedAt }</p>
						</div>
						<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap self-start", opsHiveShellStatusClass(run.Status) }>{ run.Status }</span>
					</div>
					<div class="grid gap-3 mt-4 md:grid-cols-5">
						@opsMetric("Phase", run.Phase, "pipeline")
						@opsMetric("Guardian", run.Guardian, "risk state")
						@opsMetric("Budget", run.Budget, "operator cap")
						@opsMetric("Approvals", fmt.Sprintf("%d", run.Approvals), "pending")
						@opsMetric("Artifacts", fmt.Sprintf("%d", run.Artifacts), "collected")
					</div>
				</article>
			}
		</div>
	</div>
}

templ opsHiveAgentsShell(agents []OpsHiveAgentView) {
	<div class="p-4 space-y-4">
		<div class="border border-edge bg-void/20 rounded-lg p-4">
			<h3 class="text-sm font-medium text-warm">Agent topology</h3>
			<p class="text-xs text-warm-muted mt-2">Guardian -> Architect -> Builder -> Tester. Static topology only; live lifecycle events land in later Hive projection work.</p>
		</div>
		<div class="grid gap-3 md:grid-cols-2">
			for _, agent := range agents {
				<article class="border border-edge bg-void/20 rounded-lg p-4">
					<div class="flex items-start justify-between gap-3">
						<div class="min-w-0">
							<h3 class="text-base font-medium text-warm">{ agent.Name }</h3>
							<p class="text-xs text-warm-faint mt-1">{ agent.Role }</p>
						</div>
						<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsHiveShellStatusClass(agent.State) }>{ agent.State }</span>
					</div>
					<dl class="grid grid-cols-[6rem_1fr] gap-x-3 gap-y-2 mt-4 text-xs">
						<dt class="text-warm-faint">Budget</dt><dd class="text-warm-muted">{ agent.Budget }</dd>
						<dt class="text-warm-faint">Last event</dt><dd class="text-warm-muted">{ agent.LastEvent }</dd>
					</dl>
				</article>
			}
		</div>
	</div>
}

templ opsHiveResourcesShell(resources []OpsHiveResourceView) {
	<div class="p-4 space-y-4">
		<div class="grid gap-3 md:grid-cols-4">
			for _, resource := range resources {
				<article class="border border-edge bg-void/20 rounded-lg p-4 min-h-[10rem]">
					<div class="flex items-start justify-between gap-3">
						<h3 class="text-sm font-medium text-warm">{ resource.Label }</h3>
						<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsHiveShellStatusClass(resource.Status) }>{ resource.Status }</span>
					</div>
					<p class="text-2xl font-display text-warm mt-4">{ resource.Used }</p>
					<p class="text-xs text-warm-faint mt-1">limit: { resource.Limit }</p>
					<p class="text-xs text-warm-muted mt-3 leading-relaxed">{ resource.Detail }</p>
				</article>
			}
		</div>
		<div class="border border-edge bg-surface rounded-lg p-4">
			<h3 class="text-sm font-medium text-warm">Read-only mode</h3>
			<p class="text-sm text-warm-muted mt-2 leading-relaxed">All resource signals are sample projections. The shell does not resize budgets, launch agents, or call Hive.</p>
		</div>
	</div>
}

templ opsHiveAuthorityProjection(h *OpsHiveData) {
	<section class="border border-edge bg-surface rounded-lg overflow-hidden">
		<header class="px-4 py-3 border-b border-edge">
			<h2 class="text-sm font-medium text-warm">Authority projection</h2>
			if h.ProjectionSource != "" {
				<p class="text-xs text-warm-faint mt-1">Source: { h.ProjectionSource }</p>
			}
			if h.ProjectionError != "" {
				<p class="text-xs text-amber-300 mt-2">{ h.ProjectionError }</p>
			}
		</header>
		<div class="grid gap-3 p-4 lg:grid-cols-2">
			@opsHiveRuntimeEvidence(h.RuntimeEvidence)
			@opsHivePendingApprovals(h.PendingApprovals)
			@opsHiveAuthorityDecisions(h.AuthorityDecisions)
			@opsHiveLifecycle(h.Lifecycle)
			@opsHiveKeyAudit(h.KeyAuditTraces)
			@opsHiveModelSelection(h.ModelSelection)
		</div>
	</section>
}

templ opsHiveRuntimeEvidence(e OpsHiveRuntimeEvidence) {
	<section class="border border-edge bg-void/20 rounded-lg overflow-hidden lg:col-span-2">
		<header class="px-3 py-2 border-b border-edge">
			<div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
				<div>
					<h3 class="text-sm font-medium text-warm">Runtime evidence</h3>
					if e.Source != "" {
						<p class="text-xs text-warm-faint mt-1">Source: { e.Source }</p>
					}
				</div>
				if e.Status != "" {
					<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsHiveShellStatusClass(e.Status) }>{ e.Status }</span>
				}
			</div>
		</header>
		if opsHiveRuntimeEvidenceEmpty(e) {
			<p class="px-3 py-5 text-sm text-warm-faint">No runtime evidence projection returned.</p>
		} else {
			<div class="p-3 space-y-3">
				<div class="grid gap-2 md:grid-cols-4">
					@opsMetric("Status", opsValueOr(e.Status, "unknown"), "latest run")
					@opsMetric("Active", fmt.Sprintf("%d", e.AgentEvents.ObservedActive), "bounded window")
					@opsMetric("Spawned", fmt.Sprintf("%d", e.AgentEvents.Spawned), opsValueOr(e.AgentEvents.Scope, "events"))
					@opsMetric("Stopped", fmt.Sprintf("%d", e.AgentEvents.Stopped), "bounded tally")
				</div>
				<div class="grid gap-3 lg:grid-cols-2">
					<section class="border border-edge bg-surface rounded-lg p-3">
						<h4 class="text-xs font-medium text-warm uppercase tracking-widest">Observed run</h4>
						if e.LastRun == nil {
							<p class="text-sm text-warm-faint mt-3">No hive.run.started event observed.</p>
						} else {
							<div class="mt-3 space-y-2">
								<p class="text-sm text-warm break-all">{ opsValueOr(e.LastRun.SeedIdea, "runtime run") }</p>
								<dl class="grid grid-cols-[7rem_1fr] gap-x-2 gap-y-1 text-[11px]">
									<dt class="text-warm-faint">Conversation</dt>
									<dd class="text-warm-muted truncate">{ e.LastRun.ConversationID }</dd>
									<dt class="text-warm-faint">Started</dt>
									<dd class="text-warm-muted">{ opsValueOr(formatOpsTime(e.LastRun.StartedAt), "not observed") }</dd>
									<dt class="text-warm-faint">Completed</dt>
									<dd class="text-warm-muted">{ opsValueOr(formatOpsTime(e.LastRun.CompletedAt), "not observed") }</dd>
									<dt class="text-warm-faint">Agents</dt>
									<dd class="text-warm-muted">{ opsHiveOptionalInt(e.LastRun.AgentCount, "not observed") }</dd>
									<dt class="text-warm-faint">Duration</dt>
									<dd class="text-warm-muted">{ opsHiveOptionalDurationMs(e.LastRun.DurationMs, "not observed") }</dd>
									<dt class="text-warm-faint">Cost</dt>
									<dd class="text-warm-muted">{ opsHiveOptionalFloatUSD(e.LastRun.TotalCost, "not observed") }</dd>
									<dt class="text-warm-faint">Repo</dt>
									<dd class="text-warm-muted truncate">{ opsValueOr(e.LastRun.RepoPath, "not projected") }</dd>
								</dl>
							</div>
						}
					</section>
					<section class="border border-edge bg-surface rounded-lg p-3">
						<h4 class="text-xs font-medium text-warm uppercase tracking-widest">Queued launch intent</h4>
						if e.LastQueuedRunRequest == nil {
							<p class="text-sm text-warm-faint mt-3">No queued run request projected.</p>
						} else {
							<div class="mt-3 space-y-2">
								<p class="text-sm text-warm break-all">{ opsValueOr(e.LastQueuedRunRequest.Title, e.LastQueuedRunRequest.RunID) }</p>
								<dl class="grid grid-cols-[7rem_1fr] gap-x-2 gap-y-1 text-[11px]">
									<dt class="text-warm-faint">Run</dt>
									<dd class="text-warm-muted truncate">{ e.LastQueuedRunRequest.RunID }</dd>
									<dt class="text-warm-faint">Evidence</dt>
									<dd class="text-warm-muted truncate">{ opsValueOr(e.LastQueuedRunRequest.EvidenceKind, "queued request") }</dd>
									<dt class="text-warm-faint">Authority</dt>
									<dd class="text-warm-muted truncate">{ opsValueOr(e.LastQueuedRunRequest.AuthorityInitialLevel, "unknown") }</dd>
									<dt class="text-warm-faint">Budget</dt>
									<dd class="text-warm-muted">{ opsHiveOptionalInt(e.LastQueuedRunRequest.BudgetMaxIterations, "?") } iter / { opsHiveOptionalFloatUSD(e.LastQueuedRunRequest.BudgetMaxCostUSD, "?") }</dd>
									<dt class="text-warm-faint">Targets</dt>
									<dd class="text-warm-muted truncate">{ opsEvidenceJoin(e.LastQueuedRunRequest.TargetRepos) }</dd>
									<dt class="text-warm-faint">Created</dt>
									<dd class="text-warm-muted">{ opsValueOr(formatOpsTime(e.LastQueuedRunRequest.CreatedAt), "not observed") }</dd>
								</dl>
								@opsHiveQueuedRunLifecycle(e.LastQueuedRunRequest)
							</div>
						}
					</section>
				</div>
				if len(e.AgentEvents.ActiveAgents) > 0 {
					<div class="grid gap-2 md:grid-cols-2">
						for _, agent := range e.AgentEvents.ActiveAgents {
							<div class="border border-edge bg-surface rounded-lg p-3">
								<div class="flex items-start justify-between gap-3">
									<div class="min-w-0">
										<h4 class="text-sm font-medium text-warm truncate">{ opsValueOr(agent.Name, "agent") }</h4>
										<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(agent.Role, "role") }</p>
									</div>
									<span class="text-[10px] px-2 py-1 rounded-full border border-brand/30 text-brand bg-brand/10 whitespace-nowrap">active</span>
								</div>
								<dl class="grid grid-cols-[5.5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
									<dt class="text-warm-faint">Actor</dt>
									<dd class="text-warm-muted truncate">{ agent.ActorID }</dd>
									<dt class="text-warm-faint">Model</dt>
									<dd class="text-warm-muted truncate">{ agent.Model }</dd>
									<dt class="text-warm-faint">Spawned</dt>
									<dd class="text-warm-muted">{ opsValueOr(formatOpsTime(agent.SpawnedAt), "not observed") }</dd>
								</dl>
							</div>
						}
					</div>
				}
				@opsHiveRuntimeArtifacts(e.Artifacts)
				@opsHiveRuntimeCausalGraph(e.CausalGraph)
				@opsHiveRuntimeEventInspector(e.RunEvents)
				if len(e.Limitations) > 0 {
					<div class="border border-amber-400/30 bg-amber-400/10 rounded-lg p-3">
						<p class="text-xs font-medium text-amber-300">Evidence boundaries</p>
						<ul class="mt-2 space-y-1 text-xs text-amber-100/80">
							for _, item := range e.Limitations {
								<li>{ item }</li>
							}
						</ul>
					</div>
				}
			</div>
		}
	</section>
}

templ opsHiveQueuedRunLifecycle(q *OpsHiveQueuedRunRequest) {
	if q != nil && (q.BriefKind != "" || q.LifecycleVersion != "" || q.LifecycleEvidenceKind != "" || q.SelectionPolicy != nil || len(q.DevelopmentLifecycle) > 0 || len(q.AgentExecutionPlan) > 0) {
		<div class="min-w-0 mt-3 border-t border-edge pt-3 space-y-3">
			<div>
				<h5 class="text-[11px] font-medium text-warm-muted uppercase tracking-widest">Issue-scan lifecycle</h5>
				<p class="text-[11px] text-warm-faint mt-1">Projected plan from the Hive brief. These stages are expected evidence, not runtime progress.</p>
				<dl class="grid grid-cols-[minmax(0,7rem)_minmax(0,1fr)] gap-x-2 gap-y-1 mt-2 text-[11px]">
					<dt class="text-warm-faint">Brief</dt>
					<dd class="min-w-0 text-warm-muted truncate">{ opsValueOr(q.BriefKind, "not projected") }</dd>
					<dt class="text-warm-faint">Version</dt>
					<dd class="min-w-0 text-warm-muted truncate">{ opsValueOr(q.LifecycleVersion, "not projected") }</dd>
					<dt class="text-warm-faint">Evidence</dt>
					<dd class="min-w-0 text-warm-muted truncate">{ opsValueOr(q.LifecycleEvidenceKind, "not projected") }</dd>
				</dl>
			</div>
			if q.SelectionPolicy != nil {
				<div class="min-w-0 border border-edge bg-void/20 rounded-md p-3">
					<h5 class="text-[11px] font-medium text-warm-muted uppercase tracking-widest">Issue selection</h5>
					<dl class="grid grid-cols-[minmax(0,7rem)_minmax(0,1fr)] gap-x-2 gap-y-1 mt-2 text-[11px]">
						<dt class="text-warm-faint">Policy</dt>
						<dd class="min-w-0 text-warm-muted break-all">{ opsValueOr(q.SelectionPolicy.PolicyID, "not projected") }</dd>
						<dt class="text-warm-faint">Rank</dt>
						<dd class="min-w-0 text-warm-muted">{ opsHiveIntValue(q.SelectionPolicy.SelectedRank, "?") } / { opsHiveIntValue(q.SelectionPolicy.CandidateCount, "?") }</dd>
						<dt class="text-warm-faint">Inputs</dt>
						<dd class="min-w-0 text-warm-muted break-words">{ opsEvidenceJoin(q.SelectionPolicy.RankingInputs) }</dd>
						<dt class="text-warm-faint">Rationale</dt>
						<dd class="min-w-0 text-warm-muted break-words">{ opsValueOr(q.SelectionPolicy.Rationale, "not projected") }</dd>
					</dl>
				</div>
			}
			if len(q.DevelopmentLifecycle) > 0 {
				<div class="border border-edge bg-void/20 rounded-md overflow-x-auto">
					<table class="min-w-[34rem] w-full text-[11px]">
						<thead>
							<tr class="text-left text-warm-faint border-b border-edge">
								<th class="py-2 px-2 font-medium">Stage</th>
								<th class="py-2 px-2 font-medium">Roles</th>
								<th class="py-2 px-2 font-medium">Gate</th>
								<th class="py-2 px-2 font-medium">Status</th>
							</tr>
						</thead>
						<tbody>
							for _, stage := range q.DevelopmentLifecycle {
								<tr class="border-b border-edge/50 align-top">
									<td class="py-2 px-2 text-warm">
										<p>{ opsValueOr(stage.Name, stage.ID) }</p>
										<p class="text-[10px] text-warm-faint truncate">{ stage.ID }</p>
									</td>
									<td class="py-2 px-2 text-warm-muted">{ opsEvidenceJoin(stage.RequiredRoles) }</td>
									<td class="py-2 px-2 text-warm-muted">
										<p class="break-words">{ opsValueOr(stage.CompletionGate, "not projected") }</p>
										<p class="text-[10px] text-warm-faint mt-1 break-words">{ opsValueOr(stage.AuthorityBoundary, "boundary not projected") }</p>
									</td>
									<td class="py-2 px-2 text-warm-muted">{ opsCivilizationEvidenceStatusValue(stage.EvidenceStatus, "expected") }</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			} else if q.LifecycleVersion != "" {
				<p class="text-[11px] text-warm-faint">No lifecycle stages were projected for this brief.</p>
			}
			if len(q.AgentExecutionPlan) > 0 {
				<div class="min-w-0">
					<h5 class="text-[11px] font-medium text-warm-muted uppercase tracking-widest">Agent execution plan</h5>
					<div class="grid gap-2 mt-2 md:grid-cols-2">
						for _, step := range q.AgentExecutionPlan {
							<article class="border border-edge bg-void/20 rounded-md p-2 min-w-0">
								<div class="flex items-start justify-between gap-2">
									<div class="min-w-0">
										<p class="text-xs text-warm truncate">{ opsValueOr(step.Role, "role not projected") }</p>
										<p class="text-[10px] text-warm-faint truncate">{ opsValueOr(step.StageID, "stage not projected") }</p>
									</div>
									if step.CanOperate {
										<span class="text-[10px] px-2 py-1 rounded-full border border-emerald-400/30 text-emerald-300 bg-emerald-400/10 whitespace-nowrap">operate</span>
									} else {
										<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-faint bg-void/30 whitespace-nowrap">review</span>
									}
								</div>
								<p class="text-[11px] text-warm-muted mt-2 leading-relaxed break-words">{ opsValueOr(step.Objective, "objective not projected") }</p>
								<dl class="grid grid-cols-[minmax(0,4.5rem)_minmax(0,1fr)] gap-x-2 gap-y-1 mt-2 text-[10px]">
									<dt class="text-warm-faint">Outputs</dt>
									<dd class="min-w-0 text-warm-muted break-words">{ opsEvidenceJoin(step.RequiredOutputs) }</dd>
									<dt class="text-warm-faint">Boundary</dt>
									<dd class="min-w-0 text-warm-muted break-words">{ opsValueOr(step.AuthorityBoundary, "boundary not projected") }</dd>
									<dt class="text-warm-faint">Gate</dt>
									<dd class="min-w-0 text-warm-muted break-words">{ opsValueOr(step.CompletionGate, "not projected") }</dd>
									<dt class="text-warm-faint">Status</dt>
									<dd class="min-w-0 text-warm-muted">{ opsCivilizationEvidenceStatusValue(step.EvidenceStatus, "expected") }</dd>
								</dl>
							</article>
						}
					</div>
				</div>
			}
		</div>
	}
}

templ opsHiveRuntimeArtifacts(items []OpsHiveRuntimeArtifact) {
	<section class="border border-edge bg-surface rounded-lg p-3">
		<div class="flex items-start justify-between gap-3">
			<div>
				<h4 class="text-xs font-medium text-warm uppercase tracking-widest">Artifacts</h4>
				<p class="text-[11px] text-warm-faint mt-1">Read-only factory.artifact.created projection.</p>
			</div>
			<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-muted bg-void/30 whitespace-nowrap">{ fmt.Sprintf("%d", len(items)) }</span>
		</div>
		if len(items) == 0 {
			<p class="text-sm text-warm-faint mt-3">No factory artifacts projected.</p>
		} else {
			<div class="grid gap-2 mt-3 md:grid-cols-2">
				for _, artifact := range items {
					<article class="border border-edge bg-void/20 rounded-lg p-3 min-w-0">
						<div class="flex items-start justify-between gap-3">
							<div class="min-w-0">
								<h5 class="text-sm font-medium text-warm truncate">{ opsHiveArtifactLabel(artifact) }</h5>
								<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(artifact.MediaType, "media type unknown") }</p>
							</div>
							<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsHiveShellStatusClass(artifact.CauseStatus) }>{ opsValueOr(artifact.CauseStatus, "cause") }</span>
						</div>
						if artifact.Summary != "" {
							<p class="text-xs text-warm-muted mt-2 leading-relaxed line-clamp-2">{ artifact.Summary }</p>
						}
						<dl class="grid grid-cols-[5.5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
							<dt class="text-warm-faint">Artifact</dt>
							<dd class="text-warm-muted truncate">{ artifact.ArtifactID }</dd>
							<dt class="text-warm-faint">Event</dt>
							<dd class="text-warm-muted truncate">{ artifact.EventID }</dd>
							<dt class="text-warm-faint">Run</dt>
							<dd class="text-warm-muted truncate">{ artifact.RunID }</dd>
							<dt class="text-warm-faint">Created</dt>
							<dd class="text-warm-muted">{ opsValueOr(formatOpsTime(artifact.CreatedAt), "not observed") }</dd>
							<dt class="text-warm-faint">URI</dt>
							<dd class="text-warm-muted truncate">{ opsValueOr(artifact.URI, "not projected") }</dd>
						</dl>
						<div class="mt-3 border-t border-edge pt-2">
							<p class="text-[11px] font-medium text-warm-muted">Causes</p>
							if len(artifact.Causes) == 0 {
								<p class="text-[11px] text-warm-faint mt-1">No causes projected.</p>
							}
							for _, cause := range artifact.Causes {
								<p class="text-[11px] text-warm-muted mt-1 truncate">{ cause.EventID } <span class="text-warm-faint">({ opsValueOr(cause.Scope, "scope unknown") })</span></p>
							}
						</div>
					</article>
				}
			</div>
		}
	</section>
}

templ opsHiveRuntimeCausalGraph(graph OpsHiveCausalGraph) {
	<section class="border border-edge bg-surface rounded-lg p-3">
		<div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
			<div>
				<h4 class="text-xs font-medium text-warm uppercase tracking-widest">Run-local causal graph</h4>
				<p class="text-[11px] text-warm-faint mt-1">EventGraph causes in the latest run conversation.</p>
			</div>
			<div class="flex flex-wrap gap-2">
				<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-muted bg-void/30">nodes { fmt.Sprintf("%d", len(graph.Nodes)) }</span>
				<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-muted bg-void/30">edges { fmt.Sprintf("%d", len(graph.Edges)) }</span>
				if graph.Truncated {
					<span class="text-[10px] px-2 py-1 rounded-full border border-amber-400/30 text-amber-300 bg-amber-400/10">truncated</span>
				}
			</div>
		</div>
		if graph.Scope != "" || graph.ConversationID != "" {
			<dl class="grid grid-cols-[7rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
				<dt class="text-warm-faint">Scope</dt>
				<dd class="text-warm-muted truncate">{ opsValueOr(graph.Scope, "unknown") }</dd>
				<dt class="text-warm-faint">Conversation</dt>
				<dd class="text-warm-muted truncate">{ opsValueOr(graph.ConversationID, "not projected") }</dd>
				<dt class="text-warm-faint">Limit</dt>
				<dd class="text-warm-muted">{ fmt.Sprintf("%d", graph.Limit) }</dd>
			</dl>
		}
		if len(graph.Nodes) == 0 && len(graph.Edges) == 0 {
			<p class="text-sm text-warm-faint mt-3">No run-local graph nodes projected.</p>
		} else {
			<div class="grid gap-3 mt-3 lg:grid-cols-2">
				<div class="border border-edge bg-void/20 rounded-lg p-3 min-w-0">
					<p class="text-[11px] font-medium text-warm-muted uppercase tracking-widest">Nodes</p>
					<div class="mt-2 space-y-2">
						for _, node := range graph.Nodes {
							<div class="border-l-2 border-brand/40 pl-2 min-w-0">
								<p class="text-xs text-warm truncate">{ opsValueOr(node.Label, node.EventType) }</p>
								<p class="text-[11px] text-warm-faint truncate">{ node.EventID }</p>
								<p class="text-[10px] text-warm-faint truncate">{ opsValueOr(node.Scope, "scope unknown") }</p>
							</div>
						}
					</div>
				</div>
				<div class="border border-edge bg-void/20 rounded-lg p-3 min-w-0">
					<p class="text-[11px] font-medium text-warm-muted uppercase tracking-widest">Edges</p>
					if len(graph.Edges) == 0 {
						<p class="text-xs text-warm-faint mt-2">No causal edges projected.</p>
					}
					<div class="mt-2 space-y-2">
						for _, edge := range graph.Edges {
							<div class="text-[11px] text-warm-muted min-w-0">
								<p class="truncate">{ edge.FromEventID }</p>
								<p class="text-warm-faint">-&gt; <span class="text-warm-muted">{ edge.ToEventID }</span></p>
								<p class="text-[10px] text-warm-faint truncate">{ opsValueOr(edge.Scope, "scope unknown") }</p>
							</div>
						}
					</div>
				</div>
			</div>
		}
	</section>
}

templ opsHiveRuntimeEventInspector(items []OpsHiveRuntimeEvent) {
	<section class="border border-edge bg-surface rounded-lg p-3">
		<div class="flex items-start justify-between gap-3">
			<div>
				<h4 class="text-xs font-medium text-warm uppercase tracking-widest">Event inspector</h4>
				<p class="text-[11px] text-warm-faint mt-1">Curated payloads only; non-allowlisted event content remains omitted.</p>
			</div>
			<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-muted bg-void/30 whitespace-nowrap">{ fmt.Sprintf("%d", len(items)) }</span>
		</div>
		if len(items) == 0 {
			<p class="text-sm text-warm-faint mt-3">No run events projected.</p>
		} else {
			<div class="mt-3 divide-y divide-edge border border-edge rounded-lg overflow-hidden">
				for _, event := range items {
					<details class="bg-void/20 open:bg-void/30">
						<summary class="cursor-pointer px-3 py-2">
							<span class="text-xs font-medium text-warm">{ opsValueOr(event.EventType, "event") }</span>
							<span class="block text-[11px] text-warm-faint truncate mt-1">{ event.EventID }</span>
						</summary>
						<div class="px-3 pb-3 space-y-2">
							<dl class="grid grid-cols-[6rem_1fr] gap-x-2 gap-y-1 text-[11px]">
								<dt class="text-warm-faint">Kind</dt>
								<dd class="text-warm-muted truncate">{ opsValueOr(event.InspectorKind, "eventgraph_event") }</dd>
								<dt class="text-warm-faint">At</dt>
								<dd class="text-warm-muted">{ opsValueOr(formatOpsTime(event.CreatedAt), "not observed") }</dd>
								<dt class="text-warm-faint">Causes</dt>
								<dd class="text-warm-muted truncate">{ opsEvidenceJoin(event.Causes) }</dd>
							</dl>
							if event.ContentError != "" {
								<p class="text-xs text-amber-200 bg-amber-400/10 border border-amber-400/30 rounded-md p-2">{ event.ContentError }</p>
							} else if opsHiveEventContentText(event.Content) != "" {
								<pre class="max-h-48 overflow-auto text-[11px] text-warm-muted bg-void border border-edge rounded-md p-2 whitespace-pre-wrap">{ opsHiveEventContentText(event.Content) }</pre>
							}
						</div>
					</details>
				}
			</div>
		}
	</section>
}

templ opsHivePendingApprovals(items []OpsHiveApproval) {
	<section class="border border-edge bg-void/20 rounded-lg overflow-hidden">
		<header class="px-3 py-2 border-b border-edge">
			<h3 class="text-sm font-medium text-warm">Pending approvals</h3>
		</header>
		<div class="divide-y divide-edge">
			if len(items) == 0 {
				<p class="px-3 py-5 text-sm text-warm-faint">No pending authority requests.</p>
			}
			for _, item := range items {
				<div class="px-3 py-3">
					<div class="flex items-start justify-between gap-3">
						<div class="min-w-0">
							<h4 class="text-sm font-medium text-warm truncate">{ opsValueOr(item.ActionName, "protected action") }</h4>
							<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(item.Target, "target unknown") }</p>
						</div>
						<span class="text-[10px] px-2 py-1 rounded-full border border-amber-400/30 text-amber-300 bg-amber-400/10 whitespace-nowrap">{ opsValueOr(item.Environment, "env") }</span>
					</div>
					if item.Justification != "" {
						<p class="text-xs text-warm-muted mt-2 leading-relaxed line-clamp-2">{ item.Justification }</p>
					}
					<dl class="grid grid-cols-[5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
						<dt class="text-warm-faint">Request</dt>
						<dd class="text-warm-muted truncate">{ item.RequestID }</dd>
						<dt class="text-warm-faint">Actor</dt>
						<dd class="text-warm-muted truncate">{ item.RequestingActor }</dd>
						<dt class="text-warm-faint">At</dt>
						<dd class="text-warm-muted">{ formatOpsTime(item.CreatedAt) }</dd>
					</dl>
				</div>
			}
		</div>
	</section>
}

templ opsHiveAuthorityDecisions(items []OpsHiveDecision) {
	<section class="border border-edge bg-void/20 rounded-lg overflow-hidden">
		<header class="px-3 py-2 border-b border-edge">
			<h3 class="text-sm font-medium text-warm">Authority decisions</h3>
		</header>
		<div class="divide-y divide-edge">
			if len(items) == 0 {
				<p class="px-3 py-5 text-sm text-warm-faint">No authority decisions projected.</p>
			}
			for _, item := range items {
				<div class="px-3 py-3">
					<div class="flex items-start justify-between gap-3">
						<div class="min-w-0">
							<h4 class="text-sm font-medium text-warm truncate">{ opsValueOr(item.ApprovedAction, item.RequestedAction) }</h4>
							<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(item.ApprovedTarget, item.RequestedTarget) }</p>
						</div>
						<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsPhaseGateStatusClass(item.Outcome) }>{ opsValueOr(item.Outcome, "recorded") }</span>
					</div>
					if item.Rationale != "" {
						<p class="text-xs text-warm-muted mt-2 leading-relaxed line-clamp-2">{ item.Rationale }</p>
					}
					<dl class="grid grid-cols-[5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
						<dt class="text-warm-faint">Request</dt>
						<dd class="text-warm-muted truncate">{ item.RequestID }</dd>
						<dt class="text-warm-faint">Approver</dt>
						<dd class="text-warm-muted truncate">{ item.ApproverActor }</dd>
						<dt class="text-warm-faint">At</dt>
						<dd class="text-warm-muted">{ formatOpsTime(item.CreatedAt) }</dd>
					</dl>
				</div>
			}
		</div>
	</section>
}

templ opsHiveLifecycle(items []OpsHiveLifecycle) {
	<section class="border border-edge bg-void/20 rounded-lg overflow-hidden">
		<header class="px-3 py-2 border-b border-edge">
			<h3 class="text-sm font-medium text-warm">Lifecycle state</h3>
		</header>
		<div class="divide-y divide-edge">
			if len(items) == 0 {
				<p class="px-3 py-5 text-sm text-warm-faint">No lifecycle state projected.</p>
			}
			for _, item := range items {
				<div class="px-3 py-3">
					<div class="flex items-start justify-between gap-3">
						<div class="min-w-0">
							<h4 class="text-sm font-medium text-warm truncate">{ opsValueOr(item.DisplayName, item.ActorID) }</h4>
							<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(item.Role, item.ActorID) }</p>
						</div>
						<span class="text-[10px] px-2 py-1 rounded-full border border-brand/30 text-brand bg-brand/10 whitespace-nowrap">{ opsValueOr(item.LifecycleStatus, "unknown") }</span>
					</div>
					<dl class="grid grid-cols-[5.5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
						<dt class="text-warm-faint">Scope</dt>
						<dd class="text-warm-muted truncate">{ opsValueOr(item.AuthorityScope, "none") }</dd>
						<dt class="text-warm-faint">Key</dt>
						<dd class="text-warm-muted truncate">{ opsValueOr(item.KeyProvenance, "unknown") }</dd>
						<dt class="text-warm-faint">Updated</dt>
						<dd class="text-warm-muted">{ formatOpsTime(item.UpdatedAt) }</dd>
					</dl>
				</div>
			}
		</div>
	</section>
}

templ opsHiveKeyAudit(items []OpsHiveKeyAuditTrace) {
	<section class="border border-edge bg-void/20 rounded-lg overflow-hidden">
		<header class="px-3 py-2 border-b border-edge">
			<h3 class="text-sm font-medium text-warm">Key provenance</h3>
		</header>
		<div class="divide-y divide-edge">
			if len(items) == 0 {
				<p class="px-3 py-5 text-sm text-warm-faint">No key or audit traces projected.</p>
			}
			for _, item := range items {
				<div class="px-3 py-3">
					<div class="flex items-start justify-between gap-3">
						<div class="min-w-0">
							<h4 class="text-sm font-medium text-warm truncate">{ opsValueOr(item.EventType, "audit event") }</h4>
							<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(item.ActorID, item.SubjectActorID) }</p>
						</div>
						if item.KeyProvenance != "" {
							<span class="text-[10px] px-2 py-1 rounded-full border border-brand/30 text-brand bg-brand/10 whitespace-nowrap">{ item.KeyProvenance }</span>
						}
					</div>
					if item.Reason != "" {
						<p class="text-xs text-warm-muted mt-2 leading-relaxed line-clamp-2">{ item.Reason }</p>
					} else if item.Rationale != "" {
						<p class="text-xs text-warm-muted mt-2 leading-relaxed line-clamp-2">{ item.Rationale }</p>
					}
					<dl class="grid grid-cols-[5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
						<dt class="text-warm-faint">Event</dt>
						<dd class="text-warm-muted truncate">{ item.EventID }</dd>
						<dt class="text-warm-faint">Public</dt>
						<dd class="text-warm-muted truncate">{ opsValueOr(item.PublicKey, item.NewPublicKey) }</dd>
						<dt class="text-warm-faint">At</dt>
						<dd class="text-warm-muted">{ formatOpsTime(item.CreatedAt) }</dd>
					</dl>
				</div>
			}
		</div>
	</section>
}

templ opsHiveModelSelection(selection OpsHiveModelSelection) {
	<section class="border border-edge bg-void/20 rounded-lg overflow-hidden lg:col-span-2">
		<header class="px-3 py-2 border-b border-edge">
			<div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
				<div>
					<h3 class="text-sm font-medium text-warm">Model selection</h3>
					if selection.CatalogSource != "" {
						<p class="text-xs text-warm-faint mt-1 break-all">Catalog: { selection.CatalogSource }</p>
					}
				</div>
				if selection.ReloadMode != "" {
					<span class="text-[10px] px-2 py-1 rounded-full border border-brand/30 text-brand bg-brand/10 whitespace-nowrap">{ selection.ReloadMode }</span>
				}
			</div>
		</header>
		<div class="px-3 py-3 border-b border-edge">
			<div class="border border-edge bg-surface rounded-lg p-3 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
				<div>
					<p class="text-xs font-medium text-warm">Global Model Selection Mode</p>
					<p class="text-[11px] text-warm-faint mt-1">Projected by Hive when present; inferred as Auto for selector-backed projections.</p>
					<p class="text-[10px] text-warm-faint mt-1 uppercase tracking-widest">provenance: { obsHiveProjectionModelModeProvenance(selection) }</p>
				</div>
				@obsModelModeToggle(obsHiveProjectionModelMode(selection))
			</div>
		</div>
		if selection.Source == "" && len(selection.Assignments) == 0 && len(selection.Models) == 0 {
			<p class="px-3 py-5 text-sm text-warm-faint">No model-selection projection returned.</p>
		} else {
			<div class="p-3 space-y-3">
				<div class="grid gap-2 md:grid-cols-4">
					@opsMetric("Models", fmt.Sprintf("%d", len(selection.Models)), "catalog")
					@opsMetric("Roles", fmt.Sprintf("%d", len(selection.Assignments)), "assignments")
					@opsMetric("Hot reload", fmt.Sprintf("%t", selection.HotReload), "Hive-owned")
					@opsMetric("Loaded", formatOpsTime(selection.LoadedAt), "catalog")
				</div>
				if selection.LastReloadAt != "" {
					<p class="text-[11px] text-warm-faint">Last reload: { formatOpsTime(selection.LastReloadAt) }</p>
				}
				if len(selection.Errors) > 0 {
					<div class="border border-amber-400/30 bg-amber-400/10 rounded-lg p-3">
						<p class="text-xs font-medium text-amber-300">Projection errors</p>
						<ul class="mt-2 space-y-1 text-xs text-amber-100/80">
							for _, err := range selection.Errors {
								<li>{ err }</li>
							}
						</ul>
					</div>
				}
				<div class="grid gap-2 md:grid-cols-2">
					for _, item := range selection.Assignments {
						<div class="border border-edge bg-surface rounded-lg p-3">
							<div class="flex items-start justify-between gap-3">
								<div class="min-w-0">
									<h4 class="text-sm font-medium text-warm truncate">{ opsValueOr(item.Role, "role") }</h4>
									<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(item.Model, item.PolicyModel) }</p>
								</div>
								<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-faint bg-void/30 whitespace-nowrap">{ opsValueOr(item.AuthMode, "auth") }</span>
							</div>
							<dl class="grid grid-cols-[5.5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
								<dt class="text-warm-faint">Provider</dt>
								<dd class="text-warm-muted truncate">{ opsValueOr(item.Provider, item.PolicyProvider) }</dd>
								<dt class="text-warm-faint">Tier</dt>
								<dd class="text-warm-muted truncate">{ opsValueOr(item.PreferredTier, item.Tier) }</dd>
								<dt class="text-warm-faint">Operate</dt>
								<dd class="text-warm-muted">{ fmt.Sprintf("%t", item.CanOperate) }</dd>
								<dt class="text-warm-faint">Mode</dt>
								<dd class="text-warm-muted">
									@obsModelModeToggle(obsAssignmentModelMode(selection, item))
									<p class="text-[10px] text-warm-faint mt-1">{ obsAssignmentModelModeProvenance(selection, item) }</p>
								</dd>
								if len(item.RequiredCapabilities) > 0 {
									<dt class="text-warm-faint">Caps</dt>
									<dd class="text-warm-muted truncate">{ strings.Join(item.RequiredCapabilities, ", ") }</dd>
								}
							</dl>
							if item.Error != "" {
								<p class="text-xs text-amber-300 mt-2 leading-relaxed">{ item.Error }</p>
							}
							if len(selection.Models) > 0 {
								<form method="post" action="/ops/hive/model-policy" class="mt-3 pt-3 border-t border-edge space-y-2">
									<input type="hidden" name="role" value={ item.Role }/>
									<input type="hidden" name="operator_id" value="site-ops"/>
									<input type="hidden" name="preferred_tier" value={ item.PreferredTier }/>
									if opsHiveMaxCostValue(item.MaxCostPerCallUSD) != "" {
										<input type="hidden" name="max_cost_per_call_usd" value={ opsHiveMaxCostValue(item.MaxCostPerCallUSD) }/>
									}
									for _, cap := range item.RequiredCapabilities {
										<input type="hidden" name="required_capability" value={ cap }/>
									}
									<label class="block text-[11px] text-warm-faint">
										Model
										<select name="model" class="mt-1 w-full px-2 py-1.5 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand">
											for _, model := range selection.Models {
												<option value={ model.ID } selected?={ model.ID == item.Model || model.ID == item.PolicyModel }>{ model.ID } - { model.Provider }/{ model.AuthMode }</option>
											}
										</select>
									</label>
									<div class="grid grid-cols-2 gap-2">
										<label class="block text-[11px] text-warm-faint">
											Auth
											<select name="auth_mode" class="mt-1 w-full px-2 py-1.5 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand">
												<option value="subscription" selected?={ item.AuthMode == "subscription" }>subscription</option>
												<option value="api-key" selected?={ item.AuthMode == "api-key" }>api-key</option>
												<option value="local" selected?={ item.AuthMode == "local" }>local</option>
											</select>
										</label>
										<label class="block text-[11px] text-warm-faint">
											Profile
											<input name="profile" value={ item.Profile } class="mt-1 w-full px-2 py-1.5 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand"/>
										</label>
									</div>
									<input name="reason" value="Site /ops/hive model policy update" class="w-full px-2 py-1.5 bg-elevated border border-edge rounded-md text-xs text-warm focus:outline-none focus:ring-1 focus:ring-brand"/>
									<button type="submit" class="inline-flex items-center justify-center px-3 py-1.5 rounded-md bg-brand text-void text-xs font-medium hover:bg-brand-dark transition-colors">Apply</button>
								</form>
							}
						</div>
					}
				</div>
				<p class="text-[11px] text-warm-faint leading-relaxed">Hive-owned policy. Site forwards changes to Hive and does not persist selections.</p>
			</div>
		}
	</section>
}

templ opsWorkSummary(w *OpsWorkData) {
	<section class="space-y-4">
		<div class="border border-edge bg-surface rounded-lg p-4">
			<div>
				<h2 class="text-base font-medium text-warm">Work summary</h2>
				if w.GeneratedAt != "" {
					<p class="text-xs text-warm-faint mt-1">Projected at { w.GeneratedAt }</p>
				}
				if w.Error != "" {
					<p class="text-sm text-red-300 mt-2">{ w.Error }</p>
				}
			</div>
		</div>
		if w.Error == "" {
			<div class="grid gap-3 md:grid-cols-4">
				@opsMetric("Total", fmt.Sprintf("%d", w.Total), "tasks returned by Work")
				@opsMetric("Open", fmt.Sprintf("%d", w.Open), "not completed")
				@opsMetric("Blocked", fmt.Sprintf("%d", w.Blocked), "needs operator attention")
				@opsMetric("Evidence", fmt.Sprintf("%d", w.EvidenceCount), "attached artifacts")
			</div>
			<div class="grid gap-3 md:grid-cols-4">
				@opsMetric("Active", fmt.Sprintf("%d", w.Active), "assigned or in progress")
				@opsMetric("Completed", fmt.Sprintf("%d", w.Completed), "closed out")
				@opsMetric("Ready", fmt.Sprintf("%d", w.Ready), "gates satisfied")
				@opsMetric("Unassigned", fmt.Sprintf("%d", w.Unassigned), "needs owner")
			</div>
			@opsPhaseGates(w.PhaseGates)
			<div class="grid gap-3 lg:grid-cols-[1fr_1fr]">
				<section class="border border-edge bg-surface rounded-lg overflow-hidden">
					<header class="px-4 py-3 border-b border-edge">
						<h2 class="text-sm font-medium text-warm">Active queue</h2>
						<p class="text-xs text-warm-faint mt-1">{ w.WorkURL }</p>
					</header>
					<div class="divide-y divide-edge">
						if len(w.RecentTasks) == 0 {
							<p class="px-4 py-6 text-sm text-warm-faint">No tasks returned.</p>
						}
						for _, task := range w.RecentTasks {
							@opsWorkTaskRow(task)
						}
					</div>
				</section>
				<section class="border border-edge bg-surface rounded-lg overflow-hidden">
					<header class="px-4 py-3 border-b border-edge">
						<h2 class="text-sm font-medium text-warm">Blocked</h2>
						<p class="text-xs text-warm-faint mt-1">Tasks that need unblock action or dependency evidence.</p>
					</header>
					<div class="divide-y divide-edge">
						if len(w.BlockedTasks) == 0 {
							<p class="px-4 py-6 text-sm text-warm-faint">No blocked tasks.</p>
						}
						for _, task := range w.BlockedTasks {
							@opsWorkTaskRow(task)
						}
					</div>
				</section>
			</div>
		}
	</section>
}

templ opsPhaseGates(gates []OpsPhaseGate) {
	<section class="border border-edge bg-surface rounded-lg overflow-hidden">
		<header class="px-4 py-3 border-b border-edge">
			<h2 class="text-sm font-medium text-warm">Phase gates</h2>
			<p class="text-xs text-warm-faint mt-1">Audited approval records from Work.</p>
		</header>
		if len(gates) == 0 {
			<p class="px-4 py-6 text-sm text-warm-faint">No phase gates declared.</p>
		} else {
			<div class="grid gap-3 p-4 md:grid-cols-2 lg:grid-cols-3">
				for _, gate := range gates {
					<div class="border border-edge bg-void/20 rounded-lg p-3 min-h-[9rem]">
						<div class="flex items-start justify-between gap-3">
							<div class="min-w-0">
								<h3 class="text-sm font-medium text-warm truncate">{ gate.Title }</h3>
								<p class="text-[11px] text-warm-faint mt-1 truncate">{ gate.Phase }</p>
							</div>
							<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsPhaseGateStatusClass(gate.Status) }>{ opsValueOr(gate.Status, "pending") }</span>
						</div>
						if len(gate.Criteria) > 0 {
							<p class="text-xs text-warm-muted mt-3">{ fmt.Sprintf("%d criteria", len(gate.Criteria)) }</p>
						}
						if gate.Summary != "" {
							<p class="text-xs text-warm-muted mt-2 leading-relaxed line-clamp-2">{ gate.Summary }</p>
						} else if gate.Reason != "" {
							<p class="text-xs text-warm-muted mt-2 leading-relaxed line-clamp-2">{ gate.Reason }</p>
						}
						if gate.UpdatedAt != "" {
							<p class="text-[11px] text-warm-faint mt-3">{ formatOpsTime(gate.UpdatedAt) }</p>
						}
					</div>
				}
			</div>
		}
	</section>
}

templ opsWorkTaskRow(task OpsWorkTask) {
	<div class="px-4 py-3">
		<div class="flex items-start justify-between gap-3">
			<div class="min-w-0">
				<h3 class="text-sm font-medium text-warm truncate">{ task.Title }</h3>
				if task.Description != "" {
					<p class="text-xs text-warm-muted mt-1 leading-relaxed line-clamp-2">{ task.Description }</p>
				}
				<p class="text-[11px] text-warm-faint mt-2">
					{ task.ID }
					if task.Workspace != "" {
						<span> / { task.Workspace }</span>
					}
				</p>
			</div>
			<div class="shrink-0 flex flex-col items-end gap-1">
				<span class="text-[10px] px-2 py-1 rounded-full border border-brand/30 text-brand bg-brand/10 whitespace-nowrap">{ task.Status }</span>
				if task.Blocked {
					<span class="text-[10px] px-2 py-1 rounded-full border border-amber-400/30 text-amber-300 bg-amber-400/10 whitespace-nowrap">blocked</span>
				}
				if task.Ready {
					<span class="text-[10px] px-2 py-1 rounded-full border border-emerald-400/30 text-emerald-300 bg-emerald-400/10 whitespace-nowrap">ready</span>
				} else if len(task.MissingGates) > 0 {
					<span class="text-[10px] px-2 py-1 rounded-full border border-amber-400/30 text-amber-300 bg-amber-400/10 whitespace-nowrap">gates missing</span>
				}
			</div>
		</div>
		<dl class="grid grid-cols-[5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
			<dt class="text-warm-faint">Priority</dt>
			<dd class="text-warm-muted">{ task.Priority }</dd>
			<dt class="text-warm-faint">Owner</dt>
			if task.Assignee != "" {
				<dd class="text-warm-muted truncate">{ task.Assignee }</dd>
			} else {
				<dd class="text-warm-faint">Unassigned</dd>
			}
			<dt class="text-warm-faint">Evidence</dt>
			<dd class="text-warm-muted">{ fmt.Sprintf("%d", task.ArtifactCount) }</dd>
			if len(task.MissingGates) > 0 {
				<dt class="text-warm-faint">Missing</dt>
				<dd class="text-warm-muted">{ strings.Join(task.MissingGates, ", ") }</dd>
			}
		</dl>
	</div>
}

// opsRoleTimeline renders the "order built by the society" view — the default
// evidence panel.  It groups the run by civic role in canonical order:
//
//	strategist → planner → implementer → reviewer → guardian → human (Site approval) → draft PR
//
// Sourced entirely from the hive operator projection Lifecycle + AuthorityDecisions.
// Read-only; no mutation controls; EventGraph is truth.
templ opsRoleTimeline(e *OpsEvidenceData) {
	<section class="space-y-4">
		<div class="border border-edge bg-surface rounded-lg p-4">
			<div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
				<div>
					<h2 class="text-base font-medium text-warm">Society view</h2>
					<p class="text-xs text-warm-faint mt-1">Order built by the civic roles — read-only projection; EventGraph is truth.</p>
					if e.GeneratedAt != "" {
						<p class="text-xs text-warm-faint mt-1">Projected at { e.GeneratedAt }</p>
					}
				</div>
				<div class="flex flex-col items-end gap-2">
					<span class="text-[10px] px-2 py-1 rounded-full border border-edge text-warm-faint bg-void/30 whitespace-nowrap">effect = none</span>
					<a href="/ops/evidence?view=forensic" class="text-[10px] text-warm-faint hover:text-brand transition-colors">Forensic tiers →</a>
				</div>
			</div>
		</div>
		<section class="border border-edge bg-surface rounded-lg overflow-hidden">
			<header class="px-4 py-3 border-b border-edge">
				<h2 class="text-sm font-medium text-warm">Role timeline</h2>
				<p class="text-xs text-warm-faint mt-1">Canonical civic order. Advisory only — Site cannot certify or execute work.</p>
			</header>
			if len(e.RoleTimeline) == 0 {
				<p class="px-4 py-6 text-sm text-warm-faint">No role timeline data available. Configure HIVE_OPS_API_BASE_URL to source from the hive operator projection.</p>
			} else {
				<ol class="divide-y divide-edge">
					for i, row := range e.RoleTimeline {
						<li class="flex items-start gap-4 px-4 py-3">
							<span class="flex-none w-6 h-6 rounded-full border border-edge bg-void/40 text-[10px] text-warm-faint flex items-center justify-center mt-0.5">{ fmt.Sprintf("%d", i+1) }</span>
							<div class="flex-1 min-w-0">
								<div class="flex flex-wrap items-center gap-2">
									<span class="text-sm font-medium text-warm">{ row.Role }</span>
									if row.Status != "" {
										<span class={ "text-[10px] px-2 py-0.5 rounded-full border whitespace-nowrap",
											templ.KV("border-green-700/40 text-green-400 bg-green-900/20", row.Status == "active" || row.Status == "approved"),
											templ.KV("border-amber-700/40 text-amber-400 bg-amber-900/20", row.Status == "retired" || row.Status == "pending"),
											templ.KV("border-edge text-warm-faint bg-void/30", row.Status != "active" && row.Status != "approved" && row.Status != "retired" && row.Status != "pending") }>{ row.Status }</span>
									}
								</div>
								if row.Actors != "" {
									<p class="text-xs text-warm-muted mt-1">{ row.Actors }</p>
								}
								if row.Notes != "" {
									<p class="text-[11px] text-warm-faint mt-1 break-all">{ row.Notes }</p>
								}
							</div>
						</li>
					}
				</ol>
			}
		</section>
		<section class="border border-edge bg-surface rounded-lg p-4">
			<h2 class="text-xs font-medium text-warm uppercase tracking-widest">Evidence-surface guardrails</h2>
			<ul class="mt-3 space-y-1.5 text-xs text-warm-muted leading-relaxed">
				<li>Read-only projection surface — Site does not write the graph or call GitHub.</li>
				<li>effect = none — this console has no downstream execution authority.</li>
				<li>EventGraph is truth — roles and decisions sourced from the hive operator projection only.</li>
				<li>Bounded scope — advisory display; Site cannot certify, reject, or repair work.</li>
			</ul>
		</section>
	</section>
}

templ opsEvidenceSummary(e *OpsEvidenceData) {
	<section class="space-y-4">
		<div class="border border-edge bg-surface rounded-lg p-4">
			<div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
				<div>
					<h2 class="text-base font-medium text-warm">Evidence projection</h2>
					if e.GeneratedAt != "" {
						<p class="text-xs text-warm-faint mt-1">Projected at { e.GeneratedAt }</p>
					}
					if e.Source != "" {
						<p class="text-xs text-warm-faint mt-1">Source: { e.Source }</p>
					}
					if e.ProjectionError != "" {
						<p class="text-sm text-amber-300 mt-2">{ e.ProjectionError }</p>
					}
				</div>
				<div class="text-xs text-warm-faint md:text-right space-y-1">
					<p>FactoryOrder: { opsValueOr(e.FactoryOrderID, "none") }</p>
					<p>ReleaseCandidate: { opsValueOr(e.ReleaseCandidateID, "none") }</p>
				</div>
			</div>
		</div>
		if e.ProjectionError != "" && e.FactoryOrder == nil && len(e.Timeline) == 0 && len(e.GateEvidence) == 0 && e.AuditReport == nil {
			<section class="border border-edge bg-surface rounded-lg p-4">
				<h2 class="text-sm font-medium text-warm">Projection unavailable</h2>
				<p class="text-sm text-warm-muted mt-2 leading-relaxed">No read-only evidence projection is available for this operator view.</p>
			</section>
		} else {
			@opsEvidenceIdentity(e)
			@opsProofOfWorkPacket(e.ProofOfWorkPacket)
			@opsEvidenceTimeline(e.Timeline)
			<div class="grid gap-3 lg:grid-cols-[1fr_1fr]">
				@opsEvidenceGates(e.GateEvidence)
				@opsEvidenceRelease(e)
			</div>
			<div class="grid gap-3 lg:grid-cols-[1fr_1fr]">
				@opsEvidenceFailures(e.FailuresRepairs)
				@opsEvidenceAudit(e.AuditReport)
			</div>
			@opsEvidenceMissing(e.MissingProvenance)
		}
	</section>
}

templ opsEvidenceIdentity(e *OpsEvidenceData) {
	<section class="grid gap-3 md:grid-cols-2">
		<div class="border border-edge bg-surface rounded-lg p-4">
			<h2 class="text-sm font-medium text-warm">FactoryOrder</h2>
			if e.FactoryOrder == nil {
				<p class="text-sm text-warm-faint mt-3">No FactoryOrder projection returned.</p>
			} else {
				<dl class="grid grid-cols-[7rem_1fr] gap-x-3 gap-y-1 mt-3 text-xs">
					<dt class="text-warm-faint">ID</dt><dd class="text-warm-muted break-all">{ e.FactoryOrder.ID }</dd>
					<dt class="text-warm-faint">Status</dt><dd class="text-warm-muted">{ opsValueOr(e.FactoryOrder.Status, "unknown") }</dd>
					<dt class="text-warm-faint">Version</dt><dd class="text-warm-muted">{ fmt.Sprintf("%d", e.FactoryOrder.Version) }</dd>
					<dt class="text-warm-faint">Risk</dt><dd class="text-warm-muted">{ opsValueOr(e.FactoryOrder.RiskClass, "unknown") }</dd>
					<dt class="text-warm-faint">Policy</dt><dd class="text-warm-muted break-all">{ opsValueOr(e.FactoryOrder.ReleasePolicy, "unknown") }</dd>
					<dt class="text-warm-faint">Intent</dt><dd class="text-warm-muted break-all">{ opsValueOr(e.FactoryOrder.SourceIntentRef, "none") }</dd>
				</dl>
			}
		</div>
		<div class="border border-edge bg-surface rounded-lg p-4">
			<h2 class="text-sm font-medium text-warm">ReleaseCandidate</h2>
			if e.ReleaseCandidate == nil {
				<p class="text-sm text-warm-faint mt-3">No ReleaseCandidate projection returned.</p>
			} else {
				<dl class="grid grid-cols-[7rem_1fr] gap-x-3 gap-y-1 mt-3 text-xs">
					<dt class="text-warm-faint">ID</dt><dd class="text-warm-muted break-all">{ e.ReleaseCandidate.ID }</dd>
					<dt class="text-warm-faint">Status</dt><dd class="text-warm-muted">{ opsValueOr(e.ReleaseCandidate.Status, "unknown") }</dd>
					<dt class="text-warm-faint">Factory</dt><dd class="text-warm-muted break-all">{ opsValueOr(e.ReleaseCandidate.FactoryOrderID, "none") }</dd>
					<dt class="text-warm-faint">Runtime</dt><dd class="text-warm-muted break-all">{ opsValueOr(e.ReleaseCandidate.FactoryRuntimeVersionID, "none") }</dd>
					<dt class="text-warm-faint">Artifacts</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(e.ReleaseCandidate.ArtifactRefs) }</dd>
				</dl>
			}
		</div>
	</section>
}

templ opsProofOfWorkPacket(packet *OpsProofOfWorkPacket) {
	<section class="border border-edge bg-surface rounded-lg overflow-hidden">
		<header class="px-4 py-3 border-b border-edge">
			<div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
				<div>
					<h2 class="text-sm font-medium text-warm">Proof-of-work packet</h2>
					<p class="text-xs text-warm-faint mt-1">Read-only evidence package; authority and certification records remain external sources of truth.</p>
				</div>
				if packet != nil && packet.Status != "" {
					<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap self-start", opsPipelineOutcomeClass(packet.Status) }>{ packet.Status }</span>
				}
			</div>
		</header>
		if packet == nil {
			<p class="px-4 py-6 text-sm text-warm-faint">No proof-of-work packet returned.</p>
		} else {
			<div class="p-4 space-y-4">
				<div class="grid gap-2 md:grid-cols-2 text-xs">
					<div>
						<p class="text-warm-faint">Packet</p>
						<p class="text-warm-muted break-all mt-1">{ opsValueOr(packet.ID, "unknown") }</p>
					</div>
					<div>
						<p class="text-warm-faint">EventGraph refs</p>
						<p class="text-warm-muted break-all mt-1">{ opsEvidenceJoin(packet.EventGraphRefs) }</p>
					</div>
				</div>
				if packet.Summary != "" {
					<p class="text-sm text-warm-muted leading-relaxed">{ packet.Summary }</p>
				}
				<div class="grid gap-3 lg:grid-cols-2">
					@opsProofOfWorkSingle("Work item", packet.WorkItem)
					@opsProofOfWorkSingle("Runtime invocation", packet.RuntimeInvocation)
					@opsProofOfWorkList("Changed files", packet.ChangedFiles)
					@opsProofOfWorkList("Tests run", packet.TestsRun)
					@opsProofOfWorkSingle("CI status", packet.CIStatus)
					@opsProofOfWorkList("Review feedback", packet.ReviewFeedback)
					@opsProofOfWorkList("Security scan results", packet.SecurityScanResults)
					@opsProofOfWorkList("Screenshots and walkthrough artifacts", packet.ScreenshotsWalkthrough)
					@opsProofOfWorkList("Known failures", packet.KnownFailures)
					@opsProofOfWorkSingle("Operator decision", packet.OperatorDecision)
				</div>
			</div>
		}
	</section>
}

templ opsProofOfWorkSingle(title string, item *OpsProofOfWorkItem) {
	<div class="border border-edge bg-void/30 rounded-lg p-3">
		<h3 class="text-xs font-medium text-warm uppercase tracking-widest">{ title }</h3>
		if item == nil {
			<p class="text-xs text-warm-faint mt-3">No evidence returned.</p>
		} else {
			@opsProofOfWorkItem(item)
		}
	</div>
}

templ opsProofOfWorkList(title string, items []OpsProofOfWorkItem) {
	<div class="border border-edge bg-void/30 rounded-lg p-3">
		<h3 class="text-xs font-medium text-warm uppercase tracking-widest">{ title }</h3>
		if len(items) == 0 {
			<p class="text-xs text-warm-faint mt-3">No evidence returned.</p>
		}
		<div class="divide-y divide-edge">
			for _, item := range items {
				<div class="py-3 first:pt-3 last:pb-0">
					@opsProofOfWorkItem(&item)
				</div>
			}
		</div>
	</div>
}

templ opsProofOfWorkItem(item *OpsProofOfWorkItem) {
	<div class="space-y-2">
		<div class="flex items-start justify-between gap-3">
			<div class="min-w-0">
				<p class="text-sm font-medium text-warm truncate">{ opsValueOr(item.Label, "evidence item") }</p>
				if item.ArtifactRef != "" {
					<p class="text-[11px] text-warm-faint mt-1 break-all">{ item.ArtifactRef }</p>
				}
			</div>
			if item.Status != "" {
				<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsPipelineOutcomeClass(item.Status) }>{ item.Status }</span>
			}
		</div>
		if item.Summary != "" {
			<p class="text-xs text-warm-muted leading-relaxed">{ item.Summary }</p>
		}
		<p class="text-[11px] text-warm-faint break-all">EventGraph refs: { opsEvidenceJoin(item.EventGraphRefs) }</p>
	</div>
}

templ opsEvidenceTimeline(items []OpsEvidenceTimelineEvent) {
	<section class="border border-edge bg-surface rounded-lg overflow-hidden">
		<header class="px-4 py-3 border-b border-edge">
			<h2 class="text-sm font-medium text-warm">FactoryOrder timeline</h2>
		</header>
		<div class="divide-y divide-edge">
			if len(items) == 0 {
				<p class="px-4 py-6 text-sm text-warm-faint">No timeline events returned.</p>
			}
			for _, item := range items {
				<div class="px-4 py-3 flex items-start justify-between gap-3">
					<div class="min-w-0">
						<h3 class="text-sm font-medium text-warm truncate">{ opsValueOr(item.Label, item.Kind) }</h3>
						<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(item.NodeID, "node unknown") } / { opsValueOr(item.Kind, "event") }</p>
						if item.Summary != "" {
							<p class="text-xs text-warm-muted mt-2 leading-relaxed line-clamp-2">{ item.Summary }</p>
						}
					</div>
					<div class="shrink-0 text-right">
						<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsPipelineOutcomeClass(item.Status) }>{ opsValueOr(item.Status, "recorded") }</span>
						<p class="text-[11px] text-warm-faint mt-2">{ formatOpsTime(item.CreatedAt) }</p>
					</div>
				</div>
			}
		</div>
	</section>
}

templ opsEvidenceGates(items []OpsEvidenceGate) {
	<section class="border border-edge bg-surface rounded-lg overflow-hidden">
		<header class="px-4 py-3 border-b border-edge">
			<h2 class="text-sm font-medium text-warm">Gate evidence</h2>
		</header>
		<div class="divide-y divide-edge">
			if len(items) == 0 {
				<p class="px-4 py-6 text-sm text-warm-faint">No gate evidence returned.</p>
			}
			for _, item := range items {
				<div class="px-4 py-3">
					<div class="flex items-start justify-between gap-3">
						<div class="min-w-0">
							<h3 class="text-sm font-medium text-warm truncate">{ opsValueOr(item.GateName, "gate") }</h3>
							<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(item.GateResultID, "gate result unknown") }</p>
						</div>
						<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsPhaseGateStatusClass(item.Status) }>{ opsValueOr(item.Status, "unknown") }</span>
					</div>
					<dl class="grid grid-cols-[5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
						<dt class="text-warm-faint">Evidence</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(item.EvidenceRefs) }</dd>
						<dt class="text-warm-faint">Waiver</dt><dd class="text-warm-muted break-all">{ opsValueOr(item.WaiverRef, "none") }</dd>
						<dt class="text-warm-faint">Missing</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(item.MissingRefs) }</dd>
					</dl>
				</div>
			}
		</div>
	</section>
}

templ opsEvidenceRelease(e *OpsEvidenceData) {
	<section class="border border-edge bg-surface rounded-lg overflow-hidden">
		<header class="px-4 py-3 border-b border-edge">
			<h2 class="text-sm font-medium text-warm">Release evidence</h2>
		</header>
		<div class="divide-y divide-edge">
			if len(e.ReleaseEvidence) == 0 && e.Decision == nil {
				<p class="px-4 py-6 text-sm text-warm-faint">No release evidence returned.</p>
			}
			for _, item := range e.ReleaseEvidence {
				<div class="px-4 py-3">
					<div class="flex items-start justify-between gap-3">
						<h3 class="text-sm font-medium text-warm truncate">{ opsValueOr(item.Label, "release path") }</h3>
						<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsPipelineOutcomeClass(item.Status) }>{ opsValueOr(item.Status, "unknown") }</span>
					</div>
					<dl class="grid grid-cols-[5.5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
						<dt class="text-warm-faint">Artifacts</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(item.ArtifactRefs) }</dd>
						<dt class="text-warm-faint">Runtime</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(item.RuntimeRefs) }</dd>
						<dt class="text-warm-faint">BOM</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(item.BOMRefs) }</dd>
						<dt class="text-warm-faint">Paths</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(item.RequiredPathRefs) }</dd>
						<dt class="text-warm-faint">Missing</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(item.MissingRefs) }</dd>
					</dl>
				</div>
			}
			if e.Decision != nil {
				<div class="px-4 py-3">
					<div class="flex items-start justify-between gap-3">
						<div class="min-w-0">
							<h3 class="text-sm font-medium text-warm truncate">{ opsValueOr(e.Decision.Kind, "decision") }</h3>
							<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(e.Decision.ID, "decision unknown") } / { opsValueOr(e.Decision.ActorID, "actor unknown") }</p>
						</div>
						<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsPipelineOutcomeClass(e.Decision.Status) }>{ opsValueOr(e.Decision.Status, "recorded") }</span>
					</div>
					if e.Decision.Reason != "" {
						<p class="text-xs text-warm-muted mt-2 leading-relaxed">{ e.Decision.Reason }</p>
					}
					<p class="text-[11px] text-warm-faint mt-2 break-all">Evidence: { opsEvidenceJoin(e.Decision.EvidenceRefs) }</p>
				</div>
			}
		</div>
	</section>
}

templ opsEvidenceFailures(items []OpsEvidenceFailureRepair) {
	<section class="border border-edge bg-surface rounded-lg overflow-hidden">
		<header class="px-4 py-3 border-b border-edge">
			<h2 class="text-sm font-medium text-warm">Failures and repairs</h2>
		</header>
		<div class="divide-y divide-edge">
			if len(items) == 0 {
				<p class="px-4 py-6 text-sm text-warm-faint">No failures or repairs returned.</p>
			}
			for _, item := range items {
				<div class="px-4 py-3">
					<div class="flex items-start justify-between gap-3">
						<div class="min-w-0">
							<h3 class="text-sm font-medium text-warm truncate">{ opsValueOr(item.FailureClass, "failure") }</h3>
							<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(item.FailureID, "failure unknown") }</p>
						</div>
						<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsPipelineOutcomeClass(item.Severity) }>{ opsValueOr(item.Severity, "unknown") }</span>
					</div>
					if item.Summary != "" {
						<p class="text-xs text-warm-muted mt-2 leading-relaxed">{ item.Summary }</p>
					}
					<dl class="grid grid-cols-[5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
						<dt class="text-warm-faint">Task</dt><dd class="text-warm-muted break-all">{ opsValueOr(item.TaskID, "none") }</dd>
						<dt class="text-warm-faint">Gate</dt><dd class="text-warm-muted break-all">{ opsValueOr(item.GateResultID, "none") }</dd>
						<dt class="text-warm-faint">Repair</dt><dd class="text-warm-muted break-all">{ opsValueOr(item.RepairID, "none") } / { opsValueOr(item.RepairStatus, "unknown") }</dd>
					</dl>
				</div>
			}
		</div>
	</section>
}

templ opsEvidenceAudit(a *OpsEvidenceAuditReport) {
	<section class="border border-edge bg-surface rounded-lg overflow-hidden">
		<header class="px-4 py-3 border-b border-edge">
			<h2 class="text-sm font-medium text-warm">Audit evidence</h2>
		</header>
		if a == nil {
			<p class="px-4 py-6 text-sm text-warm-faint">No audit report returned.</p>
		} else {
			<div class="p-4">
				<div class="flex items-start justify-between gap-3">
					<div class="min-w-0">
						<h3 class="text-sm font-medium text-warm truncate">{ opsValueOr(a.ID, "audit report") }</h3>
						<p class="text-xs text-warm-faint mt-1 truncate">{ opsValueOr(a.TargetType, "target") } / { opsValueOr(a.TargetID, "unknown") }</p>
					</div>
					<span class={ "text-[10px] px-2 py-1 rounded-full border whitespace-nowrap", opsPipelineOutcomeClass(a.Status) }>{ opsValueOr(a.Status, "unknown") }</span>
				</div>
				<dl class="grid grid-cols-[5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
					<dt class="text-warm-faint">Score</dt><dd class="text-warm-muted">{ fmt.Sprintf("%.2f", a.TraceScore) }</dd>
					<dt class="text-warm-faint">Missing</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(a.MissingLinks) }</dd>
				</dl>
			</div>
		}
	</section>
}

templ opsEvidenceMissing(items []OpsEvidenceMissingProvenance) {
	<section class="border border-edge bg-surface rounded-lg overflow-hidden">
		<header class="px-4 py-3 border-b border-edge">
			<h2 class="text-sm font-medium text-warm">Missing provenance</h2>
		</header>
		<div class="divide-y divide-edge">
			if len(items) == 0 {
				<p class="px-4 py-6 text-sm text-warm-faint">No missing provenance returned.</p>
			}
			for _, item := range items {
				<div class="px-4 py-3">
					<div class="flex items-start justify-between gap-3">
						<h3 class="text-sm font-medium text-warm truncate">{ opsValueOr(item.PathName, "required path") }</h3>
						if item.Completed {
							<span class="text-[10px] px-2 py-1 rounded-full border border-emerald-400/30 text-emerald-300 bg-emerald-400/10 whitespace-nowrap">complete</span>
						} else {
							<span class="text-[10px] px-2 py-1 rounded-full border border-amber-400/30 text-amber-300 bg-amber-400/10 whitespace-nowrap">missing</span>
						}
					</div>
					<dl class="grid grid-cols-[5rem_1fr] gap-x-2 gap-y-1 mt-3 text-[11px]">
						<dt class="text-warm-faint">Nodes</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(item.NodeIDs) }</dd>
						<dt class="text-warm-faint">Edges</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(item.EdgeIDs) }</dd>
						<dt class="text-warm-faint">Missing</dt><dd class="text-warm-muted break-all">{ opsEvidenceJoin(item.Missing) }</dd>
					</dl>
				</div>
			}
		</div>
	</section>
}

templ opsMetric(label, value, hint string) {
	<div class="border border-edge bg-surface rounded-lg p-4">
		<p class="text-xs text-warm-faint uppercase tracking-widest">{ label }</p>
		<p class="text-3xl font-light text-warm mt-2">{ value }</p>
		<p class="text-xs text-warm-muted mt-1">{ hint }</p>
	</div>
}

func opsValueOr(value, fallback string) string {
	if value == "" {
		return fallback
	}
	return value
}

func opsEvidenceJoin(values []string) string {
	if len(values) == 0 {
		return "none"
	}
	return strings.Join(values, ", ")
}
