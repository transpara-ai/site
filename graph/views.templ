// ── Welcome (new users with no spaces) ──────────────────────────

templ Welcome(user ViewUser) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>Welcome — lovyou.ai</title>
			@themeBlock()
		</head>
		<body class="bg-void text-warm min-h-screen">
			<div class="max-w-xl mx-auto px-6 py-20 space-y-10">
				<!-- Welcome message -->
				<div class="text-center space-y-4">
					<div class="text-5xl">✦</div>
					<h1 class="font-display text-3xl font-light text-warm">
						Welcome, { user.Name }.
					</h1>
					<p class="text-warm-muted leading-relaxed">
						You're in. Let's set up your first space — a place where you and an AI agent
						work together. Takes 30 seconds.
					</p>
				</div>

				<!-- Create space form — simple, prominent -->
				<form method="POST" action="/app/new" class="bg-surface rounded-lg border border-edge p-6 space-y-4">
					<div>
						<label for="name" class="block text-sm font-medium text-warm mb-1.5">Name your space</label>
						<input type="text" id="name" name="name" placeholder="My Project" required autofocus
							class="w-full text-lg px-4 py-3 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
						<p class="text-xs text-warm-faint mt-1.5">A project, a team, a community — whatever you're working on.</p>
					</div>
					<div>
						<label for="description" class="block text-sm font-medium text-warm mb-1.5">What's it for? <span class="text-warm-faint font-normal">(optional)</span></label>
						<input type="text" id="description" name="description" placeholder="Building a REST API for our app"
							class="w-full px-4 py-2.5 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint text-sm"/>
					</div>
					<input type="hidden" name="visibility" value="public"/>
					<button type="submit" class="w-full py-3 bg-brand text-void rounded-lg hover:bg-brand-dark transition-all font-medium text-lg hover:shadow-lg hover:shadow-brand/20">
						Create space
					</button>
				</form>

				<!-- What happens next -->
				<div class="text-center space-y-3 text-sm text-warm-muted">
					<p>After you create a space, you can:</p>
					<div class="grid grid-cols-3 gap-4 text-center">
						<div>
							<div class="text-brand text-lg mb-1">✎</div>
							<p>Create tasks and assign them to an AI agent</p>
						</div>
						<div>
							<div class="text-brand text-lg mb-1">💬</div>
							<p>Chat with the agent directly</p>
						</div>
						<div>
							<div class="text-brand text-lg mb-1">◉</div>
							<p>See everything on one board</p>
						</div>
					</div>
				</div>

				<!-- Or explore -->
				<div class="text-center">
					<a href="/discover" class="text-sm text-warm-faint hover:text-brand transition-colors">
						or browse what others have built &rarr;
					</a>
				</div>
			</div>
		</body>
	</html>
}

// ── Space index ─────────────────────────────────────────────────

templ Dashboard(spaces []Space, tasks []DashboardTask, convos []DashboardConversation, agentOps []DashboardOp, user ViewUser, defaultSpaceSlug string, agents []string, unreadCount int, taskFilter string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>My Work — lovyou.ai</title>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			@themeBlock()
		</head>
		<body class="bg-void text-warm-secondary min-h-screen flex flex-col">
			@simpleHeader(user)
			<main class="flex-1 max-w-5xl mx-auto px-6 py-8 w-full">
				<div class="flex items-center justify-between mb-8">
					<h1 class="font-display text-3xl font-light text-warm">My Work</h1>
					<div class="flex items-center gap-4">
						<a href="/app/notifications" class="text-xs text-warm-muted hover:text-brand transition-colors relative">
							Notifications
							if unreadCount > 0 {
								<span class="absolute -top-1.5 -right-3 bg-brand text-void text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center">{ fmt.Sprintf("%d", unreadCount) }</span>
							}
						</a>
						<a href="/discover" class="text-xs text-warm-muted hover:text-brand transition-colors">Discover</a>
						<a href="/market" class="text-xs text-warm-muted hover:text-brand transition-colors">Market</a>
						<a href="/app/keys" class="text-xs text-warm-muted hover:text-brand transition-colors">API Keys</a>
					</div>
				</div>
				<!-- Quick chat with Mind -->
				if defaultSpaceSlug != "" && len(agents) > 0 {
					<form method="POST" action={ templ.SafeURL("/app/" + defaultSpaceSlug + "/op") } class="bg-surface border border-brand/20 rounded-lg p-4 flex gap-3 items-end">
						<input type="hidden" name="op" value="converse"/>
						<input type="hidden" name="participants" value={ agents[0] }/>
						<div class="flex-1">
							<label class="text-xs text-warm-muted mb-1 block">Chat with { agents[0] }</label>
							<input
								type="text"
								name="title"
								placeholder="Ask something, assign a task, or just say hi..."
								required
								class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent"
							/>
						</div>
						<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium flex-shrink-0">
							Start chat
						</button>
					</form>
				}
				<!-- Dashboard grid: tasks + conversations on left, agent activity + spaces on right -->
				<div class="grid gap-6 lg:grid-cols-3">
					<div class="lg:col-span-2 space-y-6">
						<!-- My Tasks -->
						<section>
							<div class="flex items-center gap-2 mb-3">
								@dashboardTaskTab("", "Open", taskFilter)
								@dashboardTaskTab("active", "Active", taskFilter)
								@dashboardTaskTab("review", "Review", taskFilter)
								@dashboardTaskTab("done", "Done", taskFilter)
								@dashboardTaskTab("all", "All", taskFilter)
							</div>
							if len(tasks) == 0 {
								<div class="bg-surface rounded-lg border border-edge p-6 text-center">
									if taskFilter == "done" {
										<p class="text-warm-faint text-sm">No completed tasks yet.</p>
									} else if taskFilter == "all" {
										<p class="text-warm-faint text-sm">No tasks yet.</p>
									} else {
										<p class="text-warm-faint text-sm">No tasks in this state.</p>
									}
									<a href="/market" class="text-xs text-brand hover:text-brand-dark mt-2 inline-block">Browse available work</a>
								</div>
							} else {
								<div class="space-y-2">
									for _, t := range tasks {
										@dashboardTaskCard(t)
									}
								</div>
							}
						</section>
						<!-- Conversations -->
						<section>
							<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Conversations</h2>
							if len(convos) == 0 {
								<div class="bg-surface rounded-lg border border-edge p-6 text-center">
									<p class="text-warm-faint text-sm">No active conversations.</p>
								</div>
							} else {
								<div class="space-y-2">
									for _, c := range convos {
										@dashboardConvoCard(c)
									}
								</div>
							}
						</section>
					</div>
					<div class="space-y-6">
						<!-- Agent Activity -->
						<section>
							<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Agent Activity</h2>
							if len(agentOps) == 0 {
								<div class="bg-surface rounded-lg border border-edge p-6 text-center">
									<p class="text-warm-faint text-sm">No agent activity yet.</p>
								</div>
							} else {
								<div class="space-y-1">
									for _, op := range agentOps {
										@dashboardAgentRow(op)
									}
								</div>
							}
						</section>
						<!-- Spaces -->
						<section>
							<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Your Spaces</h2>
							<div class="space-y-2">
								for _, sp := range spaces {
									<a href={ templ.SafeURL("/app/" + sp.Slug) } class="block p-4 bg-surface rounded-lg border border-edge hover:border-brand/50 hover:shadow-lg hover:shadow-brand/10 hover:-translate-y-0.5 transition-all duration-200">
										<div class="flex items-center gap-2">
											<span class={ "text-[10px] font-medium px-2 py-0.5 rounded-full", kindBadgeClass(sp.Kind) }>
												{ sp.Kind }
											</span>
											<span class="text-sm font-medium text-warm">{ sp.Name }</span>
										</div>
									</a>
								}
								<!-- New space -->
								<details class="bg-surface rounded-lg border-2 border-dashed border-edge-mid hover:border-brand transition-all">
									<summary class="p-4 text-sm font-medium text-warm-muted cursor-pointer">+ New space</summary>
									<form action="/app/new" method="POST" class="p-4 pt-0 space-y-3">
										<input type="text" name="name" placeholder="Space name" required
											class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
										<textarea name="description" placeholder="Description (optional)" rows="2"
											class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
										<div class="flex gap-2">
											<select name="kind" class="flex-1 text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand text-warm-secondary">
												<option value="project">Project</option>
												<option value="community">Community</option>
												<option value="team">Team</option>
											</select>
											<select name="visibility" class="flex-1 text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand text-warm-secondary">
												<option value="private">Private</option>
												<option value="public">Public</option>
											</select>
										</div>
										<button type="submit" class="w-full px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
											Create
										</button>
									</form>
								</details>
							</div>
						</section>
					</div>
				</div>
			</main>
			@simpleFooter()
			@commandPalette()
		</body>
	</html>
}

templ dashboardTaskTab(value, label, active string) {
	<a
		href={ templ.SafeURL("/app?tasks=" + value) }
		class={ "text-xs px-3 py-1.5 rounded-lg transition-colors font-medium",
			templ.KV("bg-brand/15 text-brand", value == active),
			templ.KV("bg-elevated text-warm-muted hover:text-warm", value != active) }
	>
		{ label }
	</a>
}

templ dashboardTaskCard(t DashboardTask) {
	<a
		href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", t.SpaceSlug, t.ID)) }
		class="flex items-center gap-3 p-3 bg-surface rounded-lg border border-edge hover:border-brand/40 hover:shadow-lg hover:shadow-brand/5 hover:-translate-y-0.5 transition-all duration-200"
	>
		<span
			class="w-2 h-2 rounded-full flex-shrink-0"
			style={ fmt.Sprintf("background-color: %s", priorityDotHex(t.Priority)) }
			title={ t.Priority }
		></span>
		<div class="flex-1 min-w-0">
			<span class="text-sm font-medium text-warm truncate block">{ t.Title }</span>
			<div class="flex items-center gap-2 mt-0.5">
				<span class="text-[10px] text-warm-faint">{ t.SpaceName }</span>
				if t.ChildCount > 0 {
					<span class="text-[10px] text-warm-faint">{ fmt.Sprintf("%d/%d subtasks", t.ChildDone, t.ChildCount) }</span>
				}
				if t.DueDate != nil {
					if t.DueDate.Before(time.Now()) && t.State != StateDone {
						<span class="text-[10px] text-red-400 font-medium">overdue { t.DueDate.Format("Jan 2") }</span>
					} else {
						<span class="text-[10px] text-warm-faint">due { t.DueDate.Format("Jan 2") }</span>
					}
				}
				if t.BlockerCount > 0 {
					<span class="text-[10px] px-1.5 py-0.5 rounded bg-red-500/10 text-red-400">{ fmt.Sprintf("%d blocked", t.BlockerCount) }</span>
				}
			</div>
		</div>
		<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", dashboardStateClass(t.State) }>{ t.State }</span>
	</a>
}

templ dashboardConvoCard(c DashboardConversation) {
	<a
		href={ templ.SafeURL(fmt.Sprintf("/app/%s/conversation/%s", c.SpaceSlug, c.ID)) }
		class="block p-3 bg-surface rounded-lg border border-edge hover:border-brand/40 hover:shadow-lg hover:shadow-brand/5 hover:-translate-y-0.5 transition-all duration-200"
	>
		<div class="flex items-center justify-between mb-1">
			<span class="text-sm font-medium text-warm truncate">{ c.Title }</span>
			<span class="text-[10px] text-warm-faint flex-shrink-0 ml-2">{ dashRelativeTime(c.UpdatedAt) }</span>
		</div>
		if c.LastBody != "" {
			<div class="flex items-center gap-2 text-xs text-warm-muted">
				if c.LastAuthorKind == "agent" {
					<span class="w-4 h-4 rounded-full bg-violet-500/10 text-violet-400 text-[8px] font-bold flex items-center justify-center flex-shrink-0">
						{ initial(c.LastAuthor) }
					</span>
				}
				<span class="truncate">{ truncateBody(c.LastBody, 80) }</span>
			</div>
		}
		<div class="flex items-center gap-2 mt-1">
			<span class="text-[10px] text-warm-faint">{ c.SpaceName }</span>
			if c.ChildCount > 0 {
				<span class="text-[10px] text-warm-faint">{ fmt.Sprintf("%d messages", c.ChildCount) }</span>
			}
		</div>
	</a>
}

templ dashboardAgentRow(item DashboardOp) {
	<div class="flex items-center gap-2 py-1.5 px-2 rounded hover:bg-surface transition-colors text-xs">
		<span class="w-5 h-5 rounded-full bg-violet-500/10 text-violet-400 text-[9px] font-bold flex items-center justify-center flex-shrink-0">
			{ initial(item.Actor) }
		</span>
		<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", opBadgeClass(item.Op.Op) }>{ item.Op.Op }</span>
		if item.NodeTitle != "" && item.NodeID != "" {
			<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", item.SpaceSlug, item.NodeID)) } class="text-warm-secondary hover:text-brand transition-colors truncate">{ truncate(item.NodeTitle, 30) }</a>
		} else {
			<a href={ templ.SafeURL("/app/" + item.SpaceSlug) } class="text-warm-faint hover:text-brand transition-colors truncate">{ item.SpaceName }</a>
		}
		<span class="ml-auto text-warm-faint flex-shrink-0">{ dashRelativeTime(item.CreatedAt) }</span>
	</div>
}

// ── Onboarding ──────────────────────────────────────────────────

templ SpaceOnboarding(user ViewUser) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>Get Started — lovyou.ai</title>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			@themeBlock()
		</head>
		<body class="bg-void text-warm-secondary min-h-screen flex flex-col">
			@simpleHeader(user)
			<main class="flex-1 flex items-center justify-center px-6 py-12">
				<div class="max-w-md w-full bg-surface rounded-xl border border-edge shadow-sm p-8 text-center space-y-6">
					<div>
						<div class="w-12 h-12 rounded-full bg-brand/10 flex items-center justify-center mx-auto mb-4">
							<svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
							</svg>
						</div>
						<h1 class="font-display text-2xl font-light text-warm">Welcome</h1>
						<p class="text-warm-muted mt-2">Create your first space to get started. A space can be a project, community, or team.</p>
					</div>
					<form action="/app/new" method="POST" class="space-y-4 text-left">
						<div>
							<label for="name" class="block text-sm font-medium text-warm-muted mb-1">Space name</label>
							<input type="text" id="name" name="name" placeholder="e.g. lovyou.ai" required autofocus
								class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm placeholder-warm-faint"/>
						</div>
						<div>
							<label for="description" class="block text-sm font-medium text-warm-muted mb-1">Description</label>
							<textarea id="description" name="description" rows="2" placeholder="What is this space about?"
								class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm placeholder-warm-faint"></textarea>
						</div>
						<div>
							<label for="kind" class="block text-sm font-medium text-warm-muted mb-1">Type</label>
							<select id="kind" name="kind" class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand text-sm text-warm-secondary">
								<option value="project">Project — tasks, board, deadlines</option>
								<option value="community">Community — posts, discussions, people</option>
								<option value="team">Team — all of the above</option>
							</select>
						</div>
						<div>
							<label for="visibility" class="block text-sm font-medium text-warm-muted mb-1">Visibility</label>
							<select id="visibility" name="visibility" class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand text-sm text-warm-secondary">
								<option value="private">Private — only you can see</option>
								<option value="public">Public — anyone can view</option>
							</select>
						</div>
						<button type="submit" class="w-full px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
							Create space
						</button>
					</form>
					<div class="pt-2 border-t border-edge">
						<p class="text-sm text-warm-faint">
							Or <a href="/discover" class="text-brand hover:underline">explore existing spaces</a> to see what others are building.
						</p>
					</div>
				</div>
			</main>
			@simpleFooter()
			@commandPalette()
		</body>
	</html>
}

// ── Space overview ───────────────────────────────────────────────

templ SpaceOverview(space Space, spaces []Space, pinned []Node, recentOps []Op, user ViewUser, isOwner bool, memberCount, openTasks, activeTasks, doneTasks int, members []SpaceMember, isMember bool, loggedIn bool) {
	@appLayout(space, spaces, "", user) {
		<div class="p-6 md:p-8 space-y-6 max-w-3xl mx-auto">
			<div>
				<h1 class="font-display text-2xl font-light text-warm">{ space.Name }</h1>
				if space.Description != "" {
					<p class="text-warm-muted mt-2">{ space.Description }</p>
				}
				<div class="flex items-center gap-4 mt-3 text-xs text-warm-faint">
					<span class={ "font-medium px-2 py-0.5 rounded-full", kindBadgeClass(space.Kind) }>{ space.Kind }</span>
					<span>{ fmt.Sprintf("%d members", memberCount) }</span>
					<span>{ fmt.Sprintf("%d open · %d active · %d done", openTasks, activeTasks, doneTasks) }</span>
				</div>
				if loggedIn && !isMember && !isOwner {
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="mt-3">
						<input type="hidden" name="op" value="join"/>
						<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
							Join this space
						</button>
					</form>
				}
				if isMember && !isOwner {
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="mt-3">
						<input type="hidden" name="op" value="leave"/>
						<button type="submit" class="text-xs text-warm-faint hover:text-red-400 transition-colors">Leave this space</button>
					</form>
				}
			</div>
			<!-- Quick links to lenses -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-2">
				@overviewLensLink(space.Slug, "board", "Board", fmt.Sprintf("%d tasks", openTasks+activeTasks))
				@overviewLensLink(space.Slug, "feed", "Feed", "Posts & updates")
				@overviewLensLink(space.Slug, "conversations", "Chat", "Conversations")
				@overviewLensLink(space.Slug, "governance", "Governance", "Proposals")
			</div>
			<!-- Members -->
			if len(members) > 0 {
				<section>
					<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Members</h2>
					<div class="flex flex-wrap gap-2">
						for _, m := range members {
							<a href={ templ.SafeURL("/user/" + m.UserName) } class="flex items-center gap-1.5 px-2.5 py-1.5 bg-surface rounded-lg border border-edge hover:border-brand/40 transition-all text-xs">
								if m.Kind == "agent" {
									<span class="w-5 h-5 rounded-full bg-violet-500/10 text-violet-400 text-[9px] font-bold flex items-center justify-center">{ initial(m.UserName) }</span>
								} else {
									<span class="w-5 h-5 rounded-full bg-brand/10 text-brand text-[9px] font-bold flex items-center justify-center">{ initial(m.UserName) }</span>
								}
								<span class="text-warm">{ m.UserName }</span>
								if m.Kind == "agent" {
									<span class="text-[8px] px-1 py-0.5 rounded bg-violet-500/10 text-violet-400">agent</span>
								}
							</a>
						}
					</div>
				</section>
			}
			<!-- Pinned content -->
			if len(pinned) > 0 {
				<section>
					<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Pinned</h2>
					<div class="space-y-2">
						for _, n := range pinned {
							<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, n.ID)) } class="flex items-center gap-2 p-3 bg-surface rounded-lg border border-brand/20 hover:border-brand/40 transition-all">
								<span class="text-brand flex-shrink-0">
									<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 5a2 2 0 012-2h6a2 2 0 012 2v2a2 2 0 01-2 2H7a2 2 0 01-2-2V5zm2 10v3a1 1 0 002 0v-3h2v3a1 1 0 002 0v-3h1a1 1 0 000-2H6a1 1 0 000 2h1z"></path></svg>
								</span>
								<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", kindBadgeClass(n.Kind) }>{ n.Kind }</span>
								<span class="text-sm text-warm">{ n.Title }</span>
							</a>
						}
					</div>
				</section>
			}
			<!-- Recent activity -->
			if len(recentOps) > 0 {
				<section>
					<h2 class="text-sm font-medium text-warm-muted uppercase tracking-wide mb-3">Recent activity</h2>
					<div class="space-y-1">
						for _, o := range recentOps {
							<div class="flex items-center gap-2 py-1.5 px-2 text-xs text-warm-faint">
								<span class="font-medium text-warm">{ o.Actor }</span>
								<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", opBadgeClass(o.Op) }>{ o.Op }</span>
								if o.NodeTitle != "" && o.NodeID != "" {
									<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, o.NodeID)) } class="text-warm-secondary hover:text-brand transition-colors truncate max-w-[150px]">{ truncate(o.NodeTitle, 40) }</a>
								}
								<span class="ml-auto flex-shrink-0">{ dashRelativeTime(o.CreatedAt) }</span>
							</div>
						}
					</div>
					<a href={ templ.SafeURL("/app/" + space.Slug + "/activity") } class="text-xs text-warm-faint hover:text-brand transition-colors mt-2 inline-block">View all activity</a>
				</section>
			}
		</div>
	}
}

templ overviewLensLink(slug, lens, label, subtitle string) {
	<a href={ templ.SafeURL("/app/" + slug + "/" + lens) } class="p-3 bg-surface rounded-lg border border-edge hover:border-brand/40 hover:shadow transition-all text-center">
		<span class="text-sm font-medium text-warm block">{ label }</span>
		<span class="text-[10px] text-warm-faint">{ subtitle }</span>
	</a>
}

// ── Notifications ────────────────────────────────────────────────

templ NotificationsView(notifs []Notification, user ViewUser) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>Notifications — lovyou.ai</title>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			@themeBlock()
		</head>
		<body class="bg-void text-warm-secondary min-h-screen flex flex-col">
			@simpleHeader(user)
			<main class="flex-1 max-w-3xl mx-auto px-6 py-8 w-full">
				<div class="flex items-center justify-between mb-6">
					<h1 class="font-display text-2xl font-light text-warm">Notifications</h1>
					<a href="/app" class="text-xs text-warm-muted hover:text-brand transition-colors">Back to dashboard</a>
				</div>
				if len(notifs) == 0 {
					<div class="text-center py-16">
						<p class="text-warm-muted">No notifications yet.</p>
						<p class="text-warm-faint text-sm mt-2">You'll see updates here when someone assigns you a task or messages you.</p>
					</div>
				} else {
					<div class="space-y-1">
						for _, n := range notifs {
							<div class={ "flex items-center gap-3 py-3 px-4 rounded-lg text-sm",
								templ.KV("bg-surface border border-brand/20", !n.Read),
								templ.KV("text-warm-muted", n.Read) }>
								if !n.Read {
									<span class="w-2 h-2 rounded-full bg-brand flex-shrink-0"></span>
								} else {
									<span class="w-2 h-2 flex-shrink-0"></span>
								}
								if n.NodeID != "" && n.SpaceSlug != "" {
									<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", n.SpaceSlug, n.NodeID)) } class="flex-1 hover:text-brand transition-colors">{ n.Message }</a>
								} else {
									<span class="flex-1">{ n.Message }</span>
								}
								if n.SpaceSlug != "" {
									<a href={ templ.SafeURL("/app/" + n.SpaceSlug) } class="text-xs text-warm-faint hover:text-brand transition-colors flex-shrink-0">{ n.SpaceName }</a>
								}
								<span class="text-xs text-warm-faint flex-shrink-0">{ dashRelativeTime(n.CreatedAt) }</span>
							</div>
						}
					</div>
				}
			</main>
			@simpleFooter()
			@commandPalette()
		</body>
	</html>
}

// ── Board view (kanban) ─────────────────────────────────────────

templ gettingStartedChecklist(spaceSlug string, hasTask bool, hasAgentTask bool, hasCompletion bool) {
	<div
		id="getting-started-checklist"
		class="fixed top-4 right-4 z-40 w-72 bg-elevated border border-edge rounded-xl shadow-lg shadow-black/20 p-4"
	>
		<div class="flex items-center justify-between mb-3">
			<div class="flex items-center gap-2">
				<h3 class="text-sm font-semibold text-warm">Getting Started</h3>
				<span
					id="checklist-badge"
					class="text-[11px] font-medium px-1.5 py-0.5 rounded-full bg-brand/15 text-brand"
					data-server-done={ fmt.Sprintf("%d", checklistDoneCount(hasTask, hasAgentTask, hasCompletion)) }
				>{ fmt.Sprintf("%d/4", checklistDoneCount(hasTask, hasAgentTask, hasCompletion)) }</span>
			</div>
			<form method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/checklist/dismiss") }>
				<button type="submit" class="text-warm-faint hover:text-warm transition-colors" aria-label="Dismiss">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
					</svg>
				</button>
			</form>
		</div>
		<ul class="space-y-2.5 mb-4">
			<li class="flex items-start gap-2.5">
				if hasTask {
					<svg class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
					</svg>
					<span class="text-xs text-warm-muted line-through">Create your first task</span>
				} else {
					<svg class="w-4 h-4 text-warm-faint flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<circle cx="12" cy="12" r="9" stroke-width="2"></circle>
					</svg>
					<span class="text-xs text-warm">
						<button
							onclick="var f=document.getElementById('new-task-form');if(f){f.classList.remove('hidden');f.querySelector('input[name=title]').focus()}"
							class="text-brand hover:underline font-medium"
						>Create your first task</button>
					</span>
				}
			</li>
			<li class="flex items-start gap-2.5">
				if hasAgentTask {
					<svg class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
					</svg>
					<span class="text-xs text-warm-muted line-through">Assign it to your AI colleague</span>
				} else {
					<svg class="w-4 h-4 text-warm-faint flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<circle cx="12" cy="12" r="9" stroke-width="2"></circle>
					</svg>
					<span class="text-xs text-warm">Assign it to your AI colleague</span>
				}
			</li>
			<li class="flex items-start gap-2.5">
				if hasCompletion {
					<svg class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
					</svg>
					<span class="text-xs text-warm-muted line-through">See their response</span>
				} else {
					<svg class="w-4 h-4 text-warm-faint flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<circle cx="12" cy="12" r="9" stroke-width="2"></circle>
					</svg>
					<span class="text-xs text-warm">
						<a href={ templ.SafeURL("/app/" + spaceSlug + "/conversations") } class="text-brand hover:underline font-medium">Check Chat</a>
						<span class="text-warm-muted"> to see their response</span>
					</span>
				}
			</li>
			<li class="flex items-start gap-2.5" id="checklist-step-invite">
				<svg class="w-4 h-4 text-warm-faint flex-shrink-0 mt-0.5 step-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<circle cx="12" cy="12" r="9" stroke-width="2"></circle>
				</svg>
				<span class="text-xs text-warm step-label">
					<a href={ templ.SafeURL("/app/" + spaceSlug + "/people") } class="text-brand hover:underline font-medium">Invite your team</a>
				</span>
			</li>
		</ul>
		<script>
		(function() {
			var slug = location.pathname.split('/')[2];
			var badge = document.getElementById('checklist-badge');
			var serverDone = parseInt(badge.dataset.serverDone, 10);
			var inviteKey = 'checklist_invite_' + slug;
			var inviteDone = !!localStorage.getItem(inviteKey);

			function markInviteDone() {
				var step = document.getElementById('checklist-step-invite');
				if (step) {
					step.querySelector('.step-icon').outerHTML = '<svg class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
					step.querySelector('.step-label').classList.add('line-through', 'text-warm-muted');
					step.querySelector('.step-label').classList.remove('text-warm');
				}
				badge.textContent = (serverDone + 1) + '/4';
			}

			if (inviteDone) {
				markInviteDone();
			} else {
				badge.textContent = serverDone + '/4';
			}

			var inviteLink = document.querySelector('#checklist-step-invite a');
			if (inviteLink) {
				inviteLink.addEventListener('click', function() {
					if (!localStorage.getItem(inviteKey)) {
						localStorage.setItem(inviteKey, '1');
						markInviteDone();
					}
				});
			}
		})();
		</script>
	</div>
}

templ whatsNextModal(spaceSlug string) {
	<div
		id="whats-next-modal"
		class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm"
	>
		<div class="w-full max-w-sm bg-elevated border border-edge rounded-2xl shadow-2xl shadow-black/40 p-6 mx-4">
			<div class="flex items-start justify-between mb-1">
				<div class="flex items-center gap-2">
					<svg class="w-5 h-5 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
					</svg>
					<h2 class="text-sm font-semibold text-warm">You're set up. What's next?</h2>
				</div>
				<button
					onclick="dismissWhatsNext()"
					class="text-warm-faint hover:text-warm transition-colors ml-2 flex-shrink-0"
					aria-label="Dismiss"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
					</svg>
				</button>
			</div>
			<p class="text-xs text-warm-muted mb-4 ml-7">Pick a template — your AI teammate will get started.</p>
			<div class="space-y-2">
				<button
					onclick="pickNextTemplate('Plan a feature with your agent')"
					class="w-full text-left px-3 py-2.5 bg-surface hover:bg-brand/10 border border-edge hover:border-brand/30 rounded-lg transition-colors group"
				>
					<div class="text-xs font-medium text-warm group-hover:text-brand transition-colors">Plan a feature</div>
					<div class="text-[11px] text-warm-muted mt-0.5">Break it into tasks with your AI teammate</div>
				</button>
				<button
					onclick="pickNextTemplate('Bug: ')"
					class="w-full text-left px-3 py-2.5 bg-surface hover:bg-brand/10 border border-edge hover:border-brand/30 rounded-lg transition-colors group"
				>
					<div class="text-xs font-medium text-warm group-hover:text-brand transition-colors">Track a bug</div>
					<div class="text-[11px] text-warm-muted mt-0.5">Log and assign it for investigation</div>
				</button>
				<button
					onclick="pickNextTemplate('Decision: ')"
					class="w-full text-left px-3 py-2.5 bg-surface hover:bg-brand/10 border border-edge hover:border-brand/30 rounded-lg transition-colors group"
				>
					<div class="text-xs font-medium text-warm group-hover:text-brand transition-colors">Write a decision</div>
					<div class="text-[11px] text-warm-muted mt-0.5">Document a choice and the reasoning behind it</div>
				</button>
				<button
					onclick="pickNextTemplate('Goal: ')"
					class="w-full text-left px-3 py-2.5 bg-surface hover:bg-brand/10 border border-edge hover:border-brand/30 rounded-lg transition-colors group"
				>
					<div class="text-xs font-medium text-warm group-hover:text-brand transition-colors">Set a team goal</div>
					<div class="text-[11px] text-warm-muted mt-0.5">Define what you're working toward this sprint</div>
				</button>
			</div>
			<button
				onclick="dismissWhatsNext()"
				class="mt-4 w-full text-xs text-warm-faint hover:text-warm transition-colors py-1"
			>Not now</button>
		</div>
	</div>
	<script>
	function dismissWhatsNext() {
		var modal = document.getElementById('whats-next-modal');
		if (modal) modal.remove();
		localStorage.setItem('whats_next_seen_' + location.pathname.split('/')[2], '1');
	}
	function pickNextTemplate(title) {
		dismissWhatsNext();
		var form = document.getElementById('new-task-form');
		if (form) {
			form.classList.remove('hidden');
			var input = form.querySelector('input[name=title]');
			if (input) { input.value = title; input.focus(); input.select(); }
		}
	}
	(function() {
		var key = 'whats_next_seen_' + location.pathname.split('/')[2];
		if (localStorage.getItem(key)) {
			var modal = document.getElementById('whats-next-modal');
			if (modal) modal.remove();
		}
	})();
	</script>
}

templ firstCompletionToast(spaceSlug string) {
	<div
		id="first-completion-toast"
		class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-3 px-4 py-3 bg-elevated border border-brand/30 rounded-xl shadow-xl shadow-brand/10 text-sm"
	>
		<svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
		</svg>
		<span class="text-warm">Your AI teammate just helped!</span>
		<a href={ templ.SafeURL("/app/" + spaceSlug + "/conversations") } class="text-brand hover:text-brand-dark font-medium transition-colors whitespace-nowrap">Try Chat →</a>
		<button
			onclick="document.getElementById('first-completion-toast').remove()"
			class="text-warm-faint hover:text-warm transition-colors ml-1"
			aria-label="Dismiss"
		>
			<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
			</svg>
		</button>
		<script>
			setTimeout(function() {
				var t = document.getElementById('first-completion-toast');
				if (t) t.remove();
			}, 8000);
		</script>
	</div>
}

templ BoardView(space Space, spaces []Space, columns []BoardColumn, user ViewUser, isOwner bool, agents []string, searchQuery string, assigneeFilter string, projects []Node, projectFilter string, showFirstCompletionToast bool, showChecklist bool, hasTask bool, hasAgentTask bool, hasCompletion bool) {
	@appLayout(space, spaces, "board", user) {
		if showFirstCompletionToast {
			@firstCompletionToast(space.Slug)
		}
		if showChecklist {
			@gettingStartedChecklist(space.Slug, hasTask, hasAgentTask, hasCompletion)
		}
		if showChecklist && hasTask && hasAgentTask && hasCompletion {
			@whatsNextModal(space.Slug)
		}
		<div class="p-4 md:p-6 h-full flex flex-col">
			<div class="flex items-center justify-between mb-4 md:mb-6 gap-2">
				<div class="min-w-0">
					<h1 class="font-display text-xl md:text-2xl font-light text-warm truncate">{ space.Name }</h1>
					<p class="text-sm text-warm-muted mt-0.5">Organize tasks in columns by status</p>
				</div>
				if user.Name != "" && user.Name != "Anonymous" {
					<button
						onclick="var f=document.getElementById('new-task-form');if(f)f.classList.toggle('hidden')"
						class="flex items-center gap-1.5 px-3 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium"
					>
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
						</svg>
						New task
					</button>
				}
			</div>
			<!-- View toggle -->
			<div class="flex gap-2 mb-3">
				<a href={ templ.SafeURL("/app/" + space.Slug + "/board") }
					class="text-xs px-3 py-1 rounded-full border bg-brand/10 border-brand/30 text-warm">Board</a>
				<a href={ templ.SafeURL("/app/" + space.Slug + "/board?view=list") }
					class="text-xs px-3 py-1 rounded-full border border-edge text-warm-muted hover:border-brand/30">List</a>
			</div>
			<!-- Filters -->
			<form action={ templ.SafeURL("/app/" + space.Slug + "/board") } method="GET" class="flex gap-2 mb-3 flex-shrink-0">
				<input
					type="text"
					name="q"
					value={ searchQuery }
					placeholder="Search tasks..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"
				/>
				if len(projects) > 0 {
					<select name="project" class="px-2 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm-secondary focus:outline-none focus:ring-1 focus:ring-brand"
						onchange="this.form.submit()">
						<option value="">All projects</option>
						for _, p := range projects {
							<option value={ p.ID } selected?={ p.ID == projectFilter }>{ p.Title }</option>
						}
					</select>
				}
				<select name="assignee" class="px-2 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm-secondary focus:outline-none focus:ring-1 focus:ring-brand"
					onchange="this.form.submit()">
					<option value="">All assignees</option>
					for _, a := range agents {
						<option value={ a } selected?={ a == assigneeFilter }>{ a }</option>
					}
				</select>
				if searchQuery != "" || assigneeFilter != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/board") } class="px-2 py-1.5 text-xs text-warm-faint hover:text-brand transition-colors flex items-center">Clear</a>
				}
			</form>
			if boardEmpty(columns) && user.Name != "" && user.Name != "Anonymous" && searchQuery == "" && assigneeFilter == "" {
				@boardOnboarding(space.Slug, agents)
			} else {
				<div class="flex gap-4 flex-1 overflow-x-auto pb-4">
					for _, col := range columns {
						@boardColumn(space.Slug, col, user.Name != "" && user.Name != "Anonymous", agents)
					}
				</div>
			}
			<script>
			function boardDrop(e,col){
				e.preventDefault();
				var nodeId=e.dataTransfer.getData('text/plain');
				if(!nodeId)return;
				var state=col.dataset.state;
				var slug=col.dataset.spaceSlug;
				fetch('/app/'+slug+'/node/'+nodeId+'/state',{
					method:'POST',
					headers:{'Content-Type':'application/x-www-form-urlencoded'},
					body:'state='+encodeURIComponent(state)
				}).then(function(){window.location.reload()});
			}
			</script>
		</div>
	}
}

templ boardOnboarding(spaceSlug string, agents []string) {
	<div class="flex-1 flex items-center justify-center py-12">
		<div class="max-w-sm w-full space-y-5">
			<div class="text-center">
				<div class="w-12 h-12 rounded-xl bg-brand/10 flex items-center justify-center mx-auto mb-4">
					<svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7l2 2 4-4"></path>
					</svg>
				</div>
				<h2 class="text-xl font-light text-warm">Create your first task</h2>
				if len(agents) > 0 {
					<p class="text-sm text-warm-muted mt-1">{ agents[0] } will help you break it down and get it done.</p>
				} else {
					<p class="text-sm text-warm-muted mt-1">Describe what needs doing. Track it here.</p>
				}
			</div>
			<form action={ templ.SafeURL("/app/" + spaceSlug + "/op") } method="POST" class="bg-surface rounded-lg border border-edge p-4 space-y-3">
				<input type="hidden" name="op" value="intend"/>
				<input type="text" name="title" placeholder="Task title" required
					class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
				if len(agents) > 0 {
					<select name="assignee" class="w-full text-sm px-3 py-1.5 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm-secondary">
						<option value="">Assign to... (optional)</option>
						for _, a := range agents {
							<option value={ a }>{ a }</option>
						}
					</select>
				}
				<div class="flex justify-end">
					<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Create task</button>
				</div>
			</form>
			if len(agents) > 0 {
				<p class="text-center text-xs text-warm-faint">
					or <a href={ templ.SafeURL("/app/" + spaceSlug + "/conversations") } class="text-brand hover:underline">chat with { agents[0] }</a> to get started conversationally
				</p>
			}
		</div>
	</div>
}

templ boardColumn(spaceSlug string, col BoardColumn, canWrite bool, agents []string) {
	<div class="w-[280px] flex-shrink-0 flex flex-col">
		<div class="flex items-center gap-2 mb-3 px-2">
			<span
				class="w-1.5 h-5 rounded-full flex-shrink-0"
				style={ fmt.Sprintf("background-color: %s", stateColorHex(col.State)) }
			></span>
			<h2 class="text-xs font-semibold text-warm-muted uppercase tracking-wider">{ col.Label }</h2>
			<span class="text-[10px] text-warm-faint bg-elevated rounded-full px-1.5 py-0.5 min-w-[1.25rem] text-center">
				{ fmt.Sprintf("%d", len(col.Nodes)) }
			</span>
		</div>
		<div
			id={ col.State + "-column" }
			data-state={ col.State }
			data-space-slug={ spaceSlug }
			class="flex-1 space-y-2 overflow-y-auto rounded-xl bg-elevated/40 p-2 min-h-[200px] transition-colors duration-150"
			ondragover="event.preventDefault();event.dataTransfer.dropEffect='move';this.classList.add('bg-brand/10','border','border-brand/30')"
			ondragleave="this.classList.remove('bg-brand/10','border','border-brand/30')"
			ondrop="this.classList.remove('bg-brand/10','border','border-brand/30');boardDrop(event,this)"
		>
			if col.State == StateOpen && canWrite {
				@newTaskInline(spaceSlug, agents)
			}
			for _, node := range col.Nodes {
				@TaskCard(node, spaceSlug)
			}
		</div>
	</div>
}

templ newTaskInline(spaceSlug string, agents []string) {
	<div id="new-task-form" class="hidden mb-2">
		<form
			hx-post={ "/app/" + spaceSlug + "/op" }
			hx-target={ "#" + StateOpen + "-column" }
			hx-swap="afterbegin"
			hx-on::after-request="if(event.detail.successful) { this.reset(); document.getElementById('new-task-form').classList.add('hidden'); }"
			class="bg-surface rounded-lg border border-edge shadow-sm p-3 space-y-2"
		>
			<input type="hidden" name="op" value="intend"/>
			<input type="text" name="title" placeholder="Task title" required
				class="w-full text-sm px-2 py-1.5 bg-elevated border border-edge rounded-md focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
			<textarea name="description" placeholder="Description (optional — helps agents understand the task)" rows="2"
				class="w-full text-sm px-2 py-1.5 bg-elevated border border-edge rounded-md focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint resize-none"></textarea>
			if len(agents) > 0 {
				<div class="flex items-center gap-2 px-2 py-1.5 bg-brand/5 border border-brand/20 rounded-md">
					<input type="checkbox" id="assign-to-agent" checked
						class="w-3.5 h-3.5 accent-brand cursor-pointer flex-shrink-0"
						onchange={ toggleAgentAssign(agents[0]) }/>
					<label for="assign-to-agent" class="text-xs text-warm-secondary cursor-pointer flex-1 select-none">Let your AI colleague help?</label>
					if len(agents) == 1 {
						<span class="text-[10px] px-1.5 py-0.5 rounded-full bg-violet-500/10 text-violet-400 border border-violet-500/20">{ agents[0] }</span>
					} else {
						<select id="agent-select" class="text-[10px] px-1.5 py-0.5 bg-elevated border border-violet-500/20 rounded-full text-violet-400 focus:outline-none" onchange={ pickAgent() }>
							for _, agent := range agents {
								<option value={ agent }>{ agent }</option>
							}
						</select>
					}
					<input type="text" name="assignee" id="task-assignee" value={ agents[0] } class="hidden"/>
				</div>
			} else {
				<input type="text" name="assignee" id="task-assignee" placeholder="Assign to..."
					class="w-full text-sm px-2 py-1.5 bg-elevated border border-edge rounded-md focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
			}
			<div class="flex items-center gap-2">
				<select name="priority" class="text-xs px-2 py-1 bg-elevated border border-edge rounded-md focus:outline-none focus:ring-2 focus:ring-brand text-warm-muted">
					<option value="medium">Medium</option>
					<option value="low">Low</option>
					<option value="high">High</option>
					<option value="urgent">Urgent</option>
				</select>
				<input type="date" name="due_date" class="text-xs px-2 py-1 bg-elevated border border-edge rounded-md focus:outline-none focus:ring-2 focus:ring-brand text-warm-muted" title="Due date (optional)"/>
				<div class="flex-1"></div>
				<button type="button" onclick="document.getElementById('new-task-form').classList.add('hidden')" class="text-xs text-warm-faint hover:text-warm-muted px-2 py-1">Cancel</button>
				<button type="submit" class="text-xs px-3 py-1 bg-brand text-void rounded-md hover:bg-brand-dark transition-colors font-medium">Create</button>
			</div>
		</form>
	</div>
}

script inlineStateChange(spaceSlug string, nodeID string) {
	var sel = event.target;
	fetch('/app/' + spaceSlug + '/node/' + nodeID + '/state', {
		method: 'POST',
		headers: {'Content-Type': 'application/x-www-form-urlencoded'},
		body: 'state=' + encodeURIComponent(sel.value)
	}).then(function() { window.location.reload(); });
}

script setAssignee(name string) {
	document.getElementById('task-assignee').value = name;
}

script toggleAgentAssign(defaultAgent string) {
	var cb = document.getElementById('assign-to-agent');
	var input = document.getElementById('task-assignee');
	if (input) { input.value = cb.checked ? defaultAgent : ''; }
}

script pickAgent() {
	var sel = document.getElementById('agent-select');
	var input = document.getElementById('task-assignee');
	var cb = document.getElementById('assign-to-agent');
	if (input && sel) { input.value = (cb && cb.checked) ? sel.value : ''; }
}


script replyTo(msgID string, author string, text string) {
	var bar = document.getElementById('reply-bar');
	var barText = document.getElementById('reply-bar-text');
	var hiddenInput = document.getElementById('reply-to-id');
	if (bar && barText) {
		barText.textContent = author + ': ' + text;
		bar.classList.remove('hidden');
		bar.dataset.author = author;
		bar.dataset.text = text;
		if (hiddenInput) hiddenInput.value = msgID;
		// Focus the textarea
		var ta = document.querySelector('textarea[name="body"]');
		if (ta) ta.focus();
	}
}

script editMessage(msgID string, currentBody string) {
	event.stopPropagation();
	event.preventDefault();
	var newBody = prompt('Edit message:', currentBody);
	if (newBody !== null && newBody !== currentBody) {
		var form = new FormData();
		form.append('op', 'edit');
		form.append('node_id', msgID);
		form.append('body', newBody);
		// Find the closest form's action URL
		var action = document.querySelector('form[hx-post]');
		if (action) {
			fetch(action.getAttribute('hx-post') || action.getAttribute('action'), {
				method: 'POST',
				body: form
			}).then(function(resp) {
				if (resp.ok) {
					var el = document.getElementById('msg-body-' + msgID);
					if (el) el.textContent = newBody;
				}
			});
		}
	}
}

script toggleForm(id string) {
	var el = document.getElementById(id);
	if (!el) return;
	// Hide sibling forms first (only one open at a time).
	var parent = el.parentElement;
	parent.querySelectorAll('form[id]').forEach(function(f) {
		if (f.id !== id) f.classList.add('hidden');
	});
	el.classList.toggle('hidden');
}

templ TaskCard(node Node, spaceSlug string) {
	<div class="relative group">
		<!-- Hover action bar -->
		<div class="absolute -top-3 right-2 z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-150 flex gap-1">
			if node.AssigneeID == "" && node.State == StateOpen {
				<form method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="inline">
					<input type="hidden" name="op" value="claim"/>
					<input type="hidden" name="node_id" value={ node.ID }/>
					<button type="submit" class="h-6 px-1.5 rounded-md bg-surface border border-edge hover:border-brand/50 hover:bg-brand/10 flex items-center justify-center transition-colors text-[10px] text-warm-muted hover:text-brand font-medium" title="Claim this task" onclick="event.stopPropagation()">
						Claim
					</button>
				</form>
			}
			if node.State != StateDone {
				<form method="POST" action={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s/state", spaceSlug, node.ID)) } class="inline">
					<input type="hidden" name="state" value={ StateDone }/>
					<button type="submit" class="w-6 h-6 rounded-md bg-surface border border-edge hover:border-emerald-500/50 hover:bg-emerald-500/10 flex items-center justify-center transition-colors" title="Complete" onclick="event.stopPropagation()">
						<svg class="w-3 h-3 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
					</button>
				</form>
			}
			<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.ID)) } class="w-6 h-6 rounded-md bg-surface border border-edge hover:border-brand/50 hover:bg-brand/10 flex items-center justify-center transition-colors" title="Open" onclick="event.stopPropagation()">
				<svg class="w-3 h-3 text-warm-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
			</a>
		</div>
	<a
		href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.ID)) }
		id={ "node-" + node.ID }
		draggable="true"
		data-node-id={ node.ID }
		data-space-slug={ spaceSlug }
		class={ "block bg-surface rounded-lg border shadow-sm p-3 transition-all duration-200 cursor-pointer",
			templ.KV("border-edge hover:border-brand/30 hover:shadow-lg hover:shadow-brand/10 hover:-translate-y-0.5", node.State != StateDone),
			templ.KV("border-emerald-500/20 opacity-75", node.State == StateDone),
		}
		ondragstart="event.dataTransfer.setData('text/plain',this.dataset.nodeId);event.dataTransfer.effectAllowed='move';this.style.opacity='0.4'"
		ondragend="this.style.opacity='1'"
	>
		<div class="flex items-start gap-2">
			if node.Pinned {
				<span class="text-brand mt-0.5 flex-shrink-0" title="Pinned">
					<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 5a2 2 0 012-2h6a2 2 0 012 2v2a2 2 0 01-2 2H7a2 2 0 01-2-2V5zm2 10v3a1 1 0 002 0v-3h2v3a1 1 0 002 0v-3h1a1 1 0 000-2H6a1 1 0 000 2h1z"></path></svg>
				</span>
			} else if node.State == StateDone {
				<svg class="w-3 h-3 text-emerald-400 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
			} else {
				<span
					class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0"
					style={ fmt.Sprintf("background-color: %s", priorityDotHex(node.Priority)) }
					title={ node.Priority }
				></span>
			}
			<span class={ "text-sm font-medium leading-snug", templ.KV("text-warm", node.State != StateDone), templ.KV("line-through text-warm-muted", node.State == StateDone) }>{ node.Title }</span>
		</div>
		if node.Body != "" {
			<p class="text-[11px] text-warm-faint mt-1 ml-4 leading-relaxed line-clamp-2">{ truncate(node.Body, 120) }</p>
		}
		if node.ChildCount > 0 {
			<div class="mt-2 ml-4">
				<div class="flex items-center gap-1.5 text-[10px] text-warm-faint">
					<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
					</svg>
					{ fmt.Sprintf("%d/%d", node.ChildDone, node.ChildCount) }
				</div>
				<div class="w-full bg-elevated rounded-full h-1 mt-1">
					<div class="bg-brand rounded-full h-1 transition-all" style={ childProgress(node) }></div>
				</div>
			</div>
		}
		<div class="flex items-center justify-between mt-2 ml-4">
			<div class="flex items-center gap-2">
				if node.AuthorKind == "agent" {
					<span class="w-5 h-5 rounded-full bg-violet-500/10 text-violet-400 text-[10px] font-bold flex items-center justify-center" title={ node.Author }>
						{ initial(node.Author) }
					</span>
				} else if node.Assignee == "" || node.Author != node.Assignee {
					<span class="w-5 h-5 rounded-full bg-warm-faint/20 text-warm-faint text-[10px] font-bold flex items-center justify-center" title={ node.Author }>
						{ initial(node.Author) }
					</span>
				}
				if node.Assignee != "" {
					if node.Author != node.Assignee {
						<span class="text-[10px] text-warm-faint">→</span>
					}
					<span class="w-5 h-5 rounded-full bg-brand/10 text-brand text-[10px] font-bold flex items-center justify-center" title={ node.Assignee }>
						{ initial(node.Assignee) }
					</span>
				}
				if node.DueDate != nil {
					if node.DueDate.Before(time.Now()) && node.State != StateDone {
						<span class="text-[10px] text-red-400 font-medium">overdue { node.DueDate.Format("Jan 2") }</span>
					} else {
						<span class="text-[10px] text-warm-faint">{ node.DueDate.Format("Jan 2") }</span>
					}
				}
			</div>
			if node.AssigneeKind == "agent" {
				if node.State == StateDone {
					<span class="flex items-center gap-1 text-[9px] text-emerald-400/80 font-medium">
						<svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
						Agent done
					</span>
				} else {
					<span class="flex items-center gap-1 text-[9px] text-violet-400/80 font-medium">
						Thinking
						<span class="w-1 h-1 rounded-full bg-violet-400/60 animate-bounce" style="animation-delay: 0s"></span>
						<span class="w-1 h-1 rounded-full bg-violet-400/60 animate-bounce" style="animation-delay: 0.15s"></span>
						<span class="w-1 h-1 rounded-full bg-violet-400/60 animate-bounce" style="animation-delay: 0.3s"></span>
					</span>
				}
			}
			if node.BlockerCount > 0 {
				<span class="text-[10px] px-1.5 py-0.5 rounded bg-red-500/10 text-red-400" title={ fmt.Sprintf("%d blocker(s)", node.BlockerCount) }>
					{ fmt.Sprintf("%d blocked", node.BlockerCount) }
				</span>
			}
			<select
				class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full border-0 cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity ml-auto", stateBgClass(node.State) }
				onclick="event.preventDefault();event.stopPropagation()"
				onchange={ inlineStateChange(spaceSlug, node.ID) }
			>
				<option value={ StateOpen } selected?={ node.State == StateOpen }>Open</option>
				<option value={ StateActive } selected?={ node.State == StateActive }>Active</option>
				<option value={ StateReview } selected?={ node.State == StateReview }>Review</option>
				<option value={ StateDone } selected?={ node.State == StateDone }>Done</option>
			</select>
		</div>
	</a>
	</div>
}

// ── Goals view ──────────────────────────────────────────────────

templ GoalsView(space Space, spaces []Space, goals []GoalWithProjects, user ViewUser, isOwner bool, searchQuery string) {
	@appLayout(space, spaces, "goals", user) {
		<div class="max-w-3xl mx-auto p-6 space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="font-display text-xl font-normal text-warm">Goals</h1>
					<p class="text-sm text-warm-muted mt-0.5">Project roadmap and objectives</p>
				</div>
				if user.Name != "" && user.Name != "Anonymous" {
					<button onclick="document.getElementById('new-goal-form').classList.toggle('hidden')"
						class="flex items-center gap-1.5 px-3 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
						</svg>
						New goal
					</button>
				}
			</div>
			<form action={ templ.SafeURL("/app/" + space.Slug + "/goals") } method="GET" class="flex gap-2">
				<input type="text" name="q" value={ searchQuery } placeholder="Search goals..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/goals") } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			if user.Name != "" && user.Name != "Anonymous" {
				<div id="new-goal-form" class="hidden">
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") }
						class="bg-surface rounded-lg border border-edge p-4 space-y-3">
						<input type="hidden" name="op" value="intend"/>
						<input type="hidden" name="kind" value="goal"/>
						<input type="text" name="title" placeholder="What do you want to achieve?" required
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
						<textarea name="description" placeholder="How will you measure success? (optional)" rows="2"
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
						<div class="flex justify-end">
							<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Set goal</button>
						</div>
					</form>
				</div>
			}
			<div class="space-y-4">
				for _, gp := range goals {
					<div class="bg-surface rounded-lg border border-edge overflow-hidden">
						<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, gp.Goal.ID)) }
							class="flex items-start justify-between p-4 hover:bg-elevated transition-colors">
							<div class="flex items-start gap-2 min-w-0">
								<svg class="w-4 h-4 text-brand flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5"></path>
								</svg>
								<div class="min-w-0">
									<h3 class="font-medium text-warm">{ gp.Goal.Title }</h3>
									if gp.Goal.Body != "" {
										<p class="text-sm text-warm-muted line-clamp-1 mt-0.5">{ truncate(gp.Goal.Body, 120) }</p>
									}
								</div>
							</div>
							<div class="flex items-center gap-2 flex-shrink-0 ml-3">
								if len(gp.Projects) > 0 {
									<span class="text-xs text-warm-faint">{ fmt.Sprintf("%d project", len(gp.Projects)) }
										if len(gp.Projects) != 1 {
											s
										}
									</span>
								}
								<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", stateBgClass(gp.Goal.State) }>{ stateLabel(gp.Goal.State) }</span>
							</div>
						</a>
						if len(gp.Projects) > 0 {
							<div class="border-t border-edge divide-y divide-edge/50">
								for _, proj := range gp.Projects {
									<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, proj.ID)) }
										class="flex items-center gap-3 px-4 py-2.5 hover:bg-elevated transition-colors">
										<svg class="w-3.5 h-3.5 text-warm-faint flex-shrink-0 ml-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
											<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z"></path>
										</svg>
										<span class="text-sm text-warm-secondary flex-1 truncate">{ proj.Title }</span>
										<div class="flex items-center gap-2 flex-shrink-0">
											if proj.ChildCount > 0 {
												<span class="text-xs text-warm-faint">{ fmt.Sprintf("%d/%d", proj.ChildDone, proj.ChildCount) }</span>
												<div class="w-16 bg-elevated rounded-full h-1">
													<div class="bg-brand rounded-full h-1 transition-all" style={ childProgress(proj) }></div>
												</div>
											} else {
												<span class="text-xs text-warm-faint">No tasks</span>
											}
											<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", stateBgClass(proj.State) }>{ stateLabel(proj.State) }</span>
										</div>
									</a>
								}
							</div>
						}
					</div>
				}
				if len(goals) == 0 {
					<div class="text-center py-12 space-y-3">
						<svg class="w-12 h-12 mx-auto text-warm-faint/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5"></path></svg>
						<p class="text-warm-faint text-sm">No goals yet</p>
						<p class="text-warm-faint/60 text-xs">Set a goal to give your work direction.</p>
					</div>
				}
			</div>
		</div>
	}
}

// ── Projects view ───────────────────────────────────────────────

templ ProjectsView(space Space, spaces []Space, projects []Node, user ViewUser, isOwner bool, searchQuery string) {
	@appLayout(space, spaces, "projects", user) {
		<div class="max-w-3xl mx-auto p-6 space-y-6">
			<div class="flex items-center justify-between">
				<h1 class="font-display text-xl font-normal text-warm">Projects</h1>
				if user.Name != "" && user.Name != "Anonymous" {
					<button onclick="document.getElementById('new-project-form').classList.toggle('hidden')"
						class="flex items-center gap-1.5 px-3 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
						</svg>
						New project
					</button>
				}
			</div>
			<form action={ templ.SafeURL("/app/" + space.Slug + "/projects") } method="GET" class="flex gap-2">
				<input type="text" name="q" value={ searchQuery } placeholder="Search projects..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/projects") } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			if user.Name != "" && user.Name != "Anonymous" {
				<div id="new-project-form" class="hidden">
					<form
						method="POST"
						action={ templ.SafeURL("/app/" + space.Slug + "/op") }
						class="bg-surface rounded-lg border border-edge p-4 space-y-3"
					>
						<input type="hidden" name="op" value="intend"/>
						<input type="hidden" name="kind" value="project"/>
						<input type="text" name="title" placeholder="Project name" required
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
						<textarea name="description" placeholder="Description (optional)" rows="2"
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
						<div class="flex justify-end">
							<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Create project</button>
						</div>
					</form>
				</div>
			}
			<div class="space-y-3">
				for _, proj := range projects {
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, proj.ID)) }
						class="block bg-surface rounded-lg border border-edge p-4 hover:border-brand/40 hover:shadow-lg hover:shadow-brand/5 hover:-translate-y-0.5 transition-all duration-200">
						<div class="flex items-center justify-between mb-1">
							<h3 class="font-medium text-warm">{ proj.Title }</h3>
							<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", stateBgClass(proj.State) }>{ stateLabel(proj.State) }</span>
						</div>
						if proj.Body != "" {
							<p class="text-sm text-warm-muted line-clamp-2 mb-2">{ truncate(proj.Body, 150) }</p>
						}
						<div class="flex items-center gap-3 text-xs text-warm-faint">
							if proj.ChildCount > 0 {
								<span>{ fmt.Sprintf("%d/%d tasks done", proj.ChildDone, proj.ChildCount) }</span>
								<div class="flex-1 max-w-[120px] bg-elevated rounded-full h-1.5">
									<div class="bg-brand rounded-full h-1.5 transition-all" style={ childProgress(proj) }></div>
								</div>
							} else {
								<span>No tasks yet</span>
							}
							<span class="ml-auto">{ proj.CreatedAt.Format("Jan 2") }</span>
						</div>
					</a>
				}
				if len(projects) == 0 {
					<div class="text-center py-12 space-y-3">
						<svg class="w-12 h-12 mx-auto text-warm-faint/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z"></path></svg>
						<p class="text-warm-faint text-sm">No projects yet</p>
						<p class="text-warm-faint/60 text-xs">Create a project to group related tasks together.</p>
					</div>
				}
			</div>
		</div>
	}
}

// ── Roles view ───────────────────────────────────────────────

templ RolesView(space Space, spaces []Space, roles []Node, user ViewUser, isOwner bool, searchQuery string) {
	@appLayout(space, spaces, "roles", user) {
		<div class="max-w-3xl mx-auto p-6 space-y-6">
			<div class="flex items-center justify-between">
				<h1 class="font-display text-xl font-normal text-warm">Roles</h1>
				if user.Name != "" && user.Name != "Anonymous" {
					<button onclick="document.getElementById('new-role-form').classList.toggle('hidden')"
						class="flex items-center gap-1.5 px-3 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
						</svg>
						New role
					</button>
				}
			</div>
			<form action={ templ.SafeURL("/app/" + space.Slug + "/roles") } method="GET" class="flex gap-2">
				<input type="text" name="q" value={ searchQuery } placeholder="Search roles..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/roles") } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			if user.Name != "" && user.Name != "Anonymous" {
				<div id="new-role-form" class="hidden">
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") }
						class="bg-surface rounded-lg border border-edge p-4 space-y-3">
						<input type="hidden" name="op" value="intend"/>
						<input type="hidden" name="kind" value="role"/>
						<input type="text" name="title" placeholder="Role name (e.g. Engineer, Moderator)" required
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
						<textarea name="description" placeholder="Responsibilities and capabilities (optional)" rows="2"
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
						<div class="flex justify-end">
							<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Create role</button>
						</div>
					</form>
				</div>
			}
			<div class="space-y-3">
				for _, role := range roles {
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, role.ID)) }
						class="block bg-surface rounded-lg border border-edge p-4 hover:border-brand/40 hover:shadow-lg hover:shadow-brand/5 hover:-translate-y-0.5 transition-all duration-200">
						<div class="flex items-center justify-between mb-1">
							<div class="flex items-center gap-2">
								<svg class="w-4 h-4 text-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"></path>
								</svg>
								<h3 class="font-medium text-warm">{ role.Title }</h3>
							</div>
						</div>
						if role.Body != "" {
							<p class="text-sm text-warm-muted line-clamp-2 mb-2 ml-6">{ truncate(role.Body, 150) }</p>
						}
						<div class="flex items-center gap-3 text-xs text-warm-faint ml-6">
							<span>{ role.Author }</span>
							<span class="ml-auto">{ role.CreatedAt.Format("Jan 2") }</span>
						</div>
					</a>
				}
				if len(roles) == 0 {
					<div class="text-center py-12 space-y-3">
						<svg class="w-12 h-12 mx-auto text-warm-faint/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"></path></svg>
						<p class="text-warm-faint text-sm">No roles yet</p>
						<p class="text-warm-faint/60 text-xs">Define roles to organize capability and responsibility.</p>
					</div>
				}
			</div>
		</div>
	}
}

// ── Teams view ──────────────────────────────────────────────────

templ TeamsView(space Space, spaces []Space, teams []Node, user ViewUser, isOwner bool, searchQuery string) {
	@appLayout(space, spaces, "teams", user) {
		<div class="max-w-3xl mx-auto p-6 space-y-6">
			<div class="flex items-center justify-between">
				<h1 class="font-display text-xl font-normal text-warm">Teams</h1>
				if user.Name != "" && user.Name != "Anonymous" {
					<button onclick="document.getElementById('new-team-form').classList.toggle('hidden')"
						class="flex items-center gap-1.5 px-3 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
						</svg>
						New team
					</button>
				}
			</div>
			<form action={ templ.SafeURL("/app/" + space.Slug + "/teams") } method="GET" class="flex gap-2">
				<input type="text" name="q" value={ searchQuery } placeholder="Search teams..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/teams") } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			if user.Name != "" && user.Name != "Anonymous" {
				<div id="new-team-form" class="hidden">
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") }
						class="bg-surface rounded-lg border border-edge p-4 space-y-3">
						<input type="hidden" name="op" value="intend"/>
						<input type="hidden" name="kind" value="team"/>
						<input type="text" name="title" placeholder="Team name (e.g. Engineering, Design, Growth)" required
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
						<textarea name="description" placeholder="Team purpose and focus (optional)" rows="2"
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
						<div class="flex justify-end">
							<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Create team</button>
						</div>
					</form>
				</div>
			}
			<div class="space-y-3">
				for _, team := range teams {
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, team.ID)) }
						class="block bg-surface rounded-lg border border-edge p-4 hover:border-brand/40 hover:shadow-lg hover:shadow-brand/5 hover:-translate-y-0.5 transition-all duration-200">
						<div class="flex items-center justify-between mb-1">
							<div class="flex items-center gap-2">
								<svg class="w-4 h-4 text-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"></path>
								</svg>
								<h3 class="font-medium text-warm">{ team.Title }</h3>
							</div>
						</div>
						if team.Body != "" {
							<p class="text-sm text-warm-muted line-clamp-2 mb-2 ml-6">{ truncate(team.Body, 150) }</p>
						}
						<div class="flex items-center gap-3 text-xs text-warm-faint ml-6">
							<span>{ team.Author }</span>
							<span class="ml-auto">{ team.CreatedAt.Format("Jan 2") }</span>
						</div>
					</a>
				}
				if len(teams) == 0 {
					<div class="text-center py-12 space-y-3">
						<svg class="w-12 h-12 mx-auto text-warm-faint/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"></path></svg>
						<p class="text-warm-faint text-sm">No teams yet</p>
						<p class="text-warm-faint/60 text-xs">Create teams to organize people into functional groups.</p>
					</div>
				}
			</div>
		</div>
	}
}

// ── Policies view ───────────────────────────────────────────────

templ PoliciesView(space Space, spaces []Space, policies []Node, user ViewUser, isOwner bool, searchQuery string) {
	@appLayout(space, spaces, "policies", user) {
		<div class="max-w-3xl mx-auto p-6 space-y-6">
			<div class="flex items-center justify-between">
				<h1 class="font-display text-xl font-normal text-warm">Policies</h1>
				if user.Name != "" && user.Name != "Anonymous" {
					<button onclick="document.getElementById('new-policy-form').classList.toggle('hidden')"
						class="flex items-center gap-1.5 px-3 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
						</svg>
						New policy
					</button>
				}
			</div>
			<form action={ templ.SafeURL("/app/" + space.Slug + "/policies") } method="GET" class="flex gap-2">
				<input type="text" name="q" value={ searchQuery } placeholder="Search policies..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/policies") } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			if user.Name != "" && user.Name != "Anonymous" {
				<div id="new-policy-form" class="hidden">
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") }
						class="bg-surface rounded-lg border border-edge p-4 space-y-3">
						<input type="hidden" name="op" value="intend"/>
						<input type="hidden" name="kind" value="policy"/>
						<input type="text" name="title" placeholder="Policy name (e.g. Code of Conduct, Privacy Policy)" required
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
						<textarea name="description" placeholder="Policy description and scope (optional)" rows="2"
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
						<div class="flex justify-end">
							<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Create policy</button>
						</div>
					</form>
				</div>
			}
			<div class="space-y-3">
				for _, policy := range policies {
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, policy.ID)) }
						class="block bg-surface rounded-lg border border-edge p-4 hover:border-brand/40 hover:shadow-lg hover:shadow-brand/5 hover:-translate-y-0.5 transition-all duration-200">
						<div class="flex items-center justify-between mb-1">
							<div class="flex items-center gap-2">
								<svg class="w-4 h-4 text-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
								</svg>
								<h3 class="font-medium text-warm">{ policy.Title }</h3>
							</div>
						</div>
						if policy.Body != "" {
							<p class="text-sm text-warm-muted line-clamp-2 mb-2 ml-6">{ truncate(policy.Body, 150) }</p>
						}
						<div class="flex items-center gap-3 text-xs text-warm-faint ml-6">
							<span>{ policy.Author }</span>
							<span class="ml-auto">{ policy.CreatedAt.Format("Jan 2") }</span>
						</div>
					</a>
				}
				if len(policies) == 0 {
					<div class="text-center py-12 space-y-3">
						<svg class="w-12 h-12 mx-auto text-warm-faint/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
						<p class="text-warm-faint text-sm">No policies yet</p>
						<p class="text-warm-faint/60 text-xs">Define policies to codify rules and standards for the space.</p>
					</div>
				}
			</div>
		</div>
	}
}

// ── List view (table) ───────────────────────────────────────────

templ ListView(space Space, spaces []Space, tasks []Node, user ViewUser, isOwner bool, agents []string, searchQuery string, assigneeFilter string, sortBy string, projects []Node, projectFilter string) {
	@appLayout(space, spaces, "board", user) {
		<div class="p-4 md:p-6 h-full flex flex-col">
			<div class="flex items-center justify-between mb-4 gap-2">
				<h1 class="font-display text-xl font-light text-warm truncate">{ space.Name }</h1>
			</div>
			<!-- View toggle -->
			<div class="flex gap-2 mb-3">
				<a href={ templ.SafeURL("/app/" + space.Slug + "/board") }
					class="text-xs px-3 py-1 rounded-full border border-edge text-warm-muted hover:border-brand/30">Board</a>
				<a href={ templ.SafeURL("/app/" + space.Slug + "/board?view=list") }
					class="text-xs px-3 py-1 rounded-full border bg-brand/10 border-brand/30 text-warm">List</a>
			</div>
			<!-- Filters -->
			<form action={ templ.SafeURL("/app/" + space.Slug + "/board") } method="GET" class="flex gap-2 mb-3 flex-shrink-0">
				<input type="hidden" name="view" value="list"/>
				<input type="text" name="q" value={ searchQuery } placeholder="Search tasks..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if len(projects) > 0 {
					<select name="project" class="px-2 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm-secondary focus:outline-none focus:ring-1 focus:ring-brand"
						onchange="this.form.submit()">
						<option value="">All projects</option>
						for _, p := range projects {
							<option value={ p.ID } selected?={ p.ID == projectFilter }>{ p.Title }</option>
						}
					</select>
				}
				if searchQuery != "" || assigneeFilter != "" || projectFilter != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/board?view=list") } class="px-2 py-1.5 text-xs text-warm-faint hover:text-brand transition-colors flex items-center">Clear</a>
				}
			</form>
			<!-- Table -->
			<div class="flex-1 overflow-auto">
				<table class="w-full text-sm">
					<thead>
						<tr class="text-[10px] uppercase tracking-wider text-warm-faint border-b border-edge">
							<th class="text-left py-2 px-3 font-semibold">
								<a href={ templ.SafeURL("/app/" + space.Slug + "/board?view=list&sort=state") } class="hover:text-brand">State</a>
							</th>
							<th class="text-left py-2 px-3 font-semibold">
								<a href={ templ.SafeURL("/app/" + space.Slug + "/board?view=list&sort=priority") } class="hover:text-brand">Pri</a>
							</th>
							<th class="text-left py-2 px-3 font-semibold">Title</th>
							<th class="text-left py-2 px-3 font-semibold">
								<a href={ templ.SafeURL("/app/" + space.Slug + "/board?view=list&sort=assignee") } class="hover:text-brand">Assignee</a>
							</th>
							<th class="text-left py-2 px-3 font-semibold">
								<a href={ templ.SafeURL("/app/" + space.Slug + "/board?view=list&sort=due") } class="hover:text-brand">Due</a>
							</th>
							<th class="text-right py-2 px-3 font-semibold">Sub</th>
						</tr>
					</thead>
					<tbody>
						for _, task := range tasks {
							<tr class="border-b border-edge/50 hover:bg-elevated/50 transition-colors">
								<td class="py-2 px-3">
									<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", stateBgClass(task.State) }>{ stateLabel(task.State) }</span>
								</td>
								<td class="py-2 px-3">
									<span class="w-2 h-2 rounded-full inline-block" style={ fmt.Sprintf("background-color: %s", priorityDotHex(task.Priority)) } title={ task.Priority }></span>
								</td>
								<td class="py-2 px-3">
									<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, task.ID)) } class="text-warm hover:text-brand transition-colors">
										{ task.Title }
									</a>
									if task.BlockerCount > 0 {
										<span class="text-[10px] px-1 py-0.5 rounded bg-red-500/10 text-red-400 ml-1">blocked</span>
									}
								</td>
								<td class="py-2 px-3 text-warm-muted">
									if task.Assignee != "" {
										<span class="flex items-center gap-1">
											<span class="w-4 h-4 rounded-full bg-brand/10 text-brand text-[9px] font-bold flex items-center justify-center">{ initial(task.Assignee) }</span>
											<span class="text-xs">{ task.Assignee }</span>
										</span>
									} else if task.State == StateOpen {
										<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="inline">
											<input type="hidden" name="op" value="claim"/>
											<input type="hidden" name="node_id" value={ task.ID }/>
											<button type="submit" class="text-[10px] px-2 py-0.5 rounded border border-edge text-warm-faint hover:text-brand hover:border-brand/30 transition-colors">Claim</button>
										</form>
									}
								</td>
								<td class="py-2 px-3 text-xs">
									if task.DueDate != nil {
										if task.DueDate.Before(time.Now()) && task.State != StateDone {
											<span class="text-red-400 font-medium">{ task.DueDate.Format("Jan 2") }</span>
										} else {
											<span class="text-warm-faint">{ task.DueDate.Format("Jan 2") }</span>
										}
									}
								</td>
								<td class="py-2 px-3 text-right text-xs text-warm-faint">
									if task.ChildCount > 0 {
										{ fmt.Sprintf("%d/%d", task.ChildDone, task.ChildCount) }
									}
								</td>
							</tr>
						}
					</tbody>
				</table>
				if len(tasks) == 0 {
					<div class="text-center py-12 text-warm-faint text-sm">No tasks match your filters</div>
				}
			</div>
		</div>
	}
}

// ── Feed view ───────────────────────────────────────────────────

templ FeedView(space Space, spaces []Space, posts []Node, user ViewUser, isOwner bool, hasAgent bool, searchQuery string, feedTab string, endorseCounts map[string]int, userEndorsed map[string]bool, repostCounts map[string]int, userReposted map[string]bool, repostedBy map[string]string, quotePost *Node) {
	@appLayout(space, spaces, "feed", user) {
		<div class="max-w-2xl mx-auto p-6 space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="font-display text-xl font-normal text-warm">Feed</h1>
					<p class="text-sm text-warm-muted mt-0.5">Activity stream of posts and updates</p>
				</div>
			</div>
			<!-- Feed tabs -->
			if user.Name != "" && user.Name != "Anonymous" {
				<div class="flex gap-2">
					<a href={ templ.SafeURL("/app/" + space.Slug + "/feed") }
						class={ "text-xs px-3 py-1 rounded-full border transition-colors",
							templ.KV("bg-brand/10 border-brand/30 text-warm", feedTab == ""),
							templ.KV("border-edge text-warm-muted hover:border-brand/30", feedTab != "") }>All</a>
					<a href={ templ.SafeURL("/app/" + space.Slug + "/feed?tab=following") }
						class={ "text-xs px-3 py-1 rounded-full border transition-colors",
							templ.KV("bg-brand/10 border-brand/30 text-warm", feedTab == "following"),
							templ.KV("border-edge text-warm-muted hover:border-brand/30", feedTab != "following") }>Following</a>
					<a href={ templ.SafeURL("/app/" + space.Slug + "/feed?tab=foryou") }
						class={ "text-xs px-3 py-1 rounded-full border transition-colors",
							templ.KV("bg-brand/10 border-brand/30 text-warm", feedTab == "foryou"),
							templ.KV("border-edge text-warm-muted hover:border-brand/30", feedTab != "foryou") }>For You</a>
					<a href={ templ.SafeURL("/app/" + space.Slug + "/feed?tab=trending") }
						class={ "text-xs px-3 py-1 rounded-full border transition-colors",
							templ.KV("bg-brand/10 border-brand/30 text-warm", feedTab == "trending"),
							templ.KV("border-edge text-warm-muted hover:border-brand/30", feedTab != "trending") }>Trending</a>
				</div>
			}
			<form action={ templ.SafeURL("/app/" + space.Slug + "/feed") } method="GET" class="flex gap-2">
				if feedTab != "" {
					<input type="hidden" name="tab" value={ feedTab }/>
				}
				<input type="text" name="q" value={ searchQuery } placeholder="Search posts..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/feed") } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			if hasAgent && user.Name != "" && user.Name != "Anonymous" {
				<a href={ templ.SafeURL("/app/" + space.Slug + "/conversations") }
					class="block p-4 bg-violet-500/5 border border-violet-500/20 rounded-lg hover:bg-violet-500/10 transition-colors">
					<div class="flex items-center gap-3">
						<span class="w-8 h-8 rounded-full bg-violet-500/10 text-violet-400 text-sm font-bold flex items-center justify-center flex-shrink-0">
							<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"></circle></svg>
						</span>
						<div>
							<p class="text-sm font-medium text-violet-300">Chat with an AI agent</p>
							<p class="text-xs text-warm-faint">Start a conversation — the Mind responds in real time</p>
						</div>
					</div>
				</a>
			}
			if user.Name != "" && user.Name != "Anonymous" {
				<!-- New post form -->
				<form
					hx-post={ "/app/" + space.Slug + "/op" }
					hx-target="#feed-items"
					hx-swap="afterbegin"
					hx-on::after-request="if(event.detail.successful) this.reset()"
					class="bg-surface rounded-lg border border-edge p-4 space-y-3"
				>
					<input type="hidden" name="op" value="express"/>
					if quotePost != nil {
						<input type="hidden" name="quote_of_id" value={ quotePost.ID }/>
						<div class="rounded-lg border border-brand/30 p-3 bg-brand/5">
							<div class="flex items-center gap-1 mb-1">
								<span class="text-xs font-medium text-warm-muted">Quoting { quotePost.Author }</span>
								if quotePost.Title != "" {
									<span class="text-xs text-warm-faint">· { quotePost.Title }</span>
								}
							</div>
							<p class="text-xs text-warm-faint line-clamp-2">{ truncate(quotePost.Body, 120) }</p>
						</div>
					}
					<input type="text" name="title" placeholder="Title (optional)" class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
					<textarea name="body" placeholder={ quotePostPlaceholder(quotePost) } rows="3" required class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
					<div class="flex justify-end">
						<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Post</button>
					</div>
				</form>
			}
			<div id="feed-items" class="space-y-4">
				for _, post := range posts {
					@FeedCard(post, space.Slug, endorseCounts[post.ID], userEndorsed[post.ID], repostCounts[post.ID], userReposted[post.ID], repostedBy[post.ID])
				}
				if len(posts) == 0 {
					<div class="text-center py-12 space-y-4">
						<div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center mx-auto">
							<svg class="w-5 h-5 text-brand/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
						</div>
						if feedTab == "following" {
							<p class="text-warm text-sm font-medium">No posts from people you follow</p>
							<p class="text-warm-faint/80 text-xs">Follow users from their profile page to see their posts here.</p>
						} else if user.Name != "" && user.Name != "Anonymous" {
							<p class="text-warm text-sm font-medium">Share your first post</p>
							<p class="text-warm-faint/80 text-xs">Use the form above to share an update, an idea, or a progress note.</p>
						} else {
							<p class="text-warm text-sm font-medium">Nothing posted yet</p>
							<p class="text-warm-faint/80 text-xs">Sign in to share the first post in this space.</p>
						}
					</div>
				}
			</div>
		</div>
	}
}

templ FeedCard(node Node, spaceSlug string, endorseCount int, endorsed bool, repostCount int, reposted bool, repostedByName string) {
	<div class={ "bg-surface rounded-lg border p-5", templ.KV("border-brand/30", node.Pinned), templ.KV("border-edge", !node.Pinned) }>
		if repostedByName != "" {
			<div class="flex items-center gap-1.5 text-[10px] text-warm-faint mb-2">
				<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3-3 3"></path>
				</svg>
				<span>{ repostedByName } reposted</span>
			</div>
		}
		if node.Pinned {
			<div class="flex items-center gap-1 text-[10px] text-brand font-medium mb-2">
				<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 5a2 2 0 012-2h6a2 2 0 012 2v2a2 2 0 01-2 2H7a2 2 0 01-2-2V5zm2 10v3a1 1 0 002 0v-3h2v3a1 1 0 002 0v-3h1a1 1 0 000-2H6a1 1 0 000 2h1z"></path></svg>
				Pinned
			</div>
		}
		<div class="flex items-center gap-2 mb-3">
			if node.AuthorKind == "agent" {
				<span class="w-7 h-7 rounded-full bg-violet-500/10 text-violet-400 text-xs font-bold flex items-center justify-center" title="Agent">
					{ initial(node.Author) }
				</span>
			} else {
				<span class="w-7 h-7 rounded-full bg-brand/10 text-brand text-xs font-bold flex items-center justify-center">
					{ initial(node.Author) }
				</span>
			}
			<div class="flex items-center gap-1.5">
				<span class="text-sm font-medium text-warm">{ node.Author }</span>
				if node.AuthorKind == "agent" {
					<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
				}
				<span class="text-xs text-warm-faint ml-1">{ node.CreatedAt.Format("Jan 2, 3:04 PM") }</span>
			</div>
		</div>
		if node.Title != "" {
			<h3 class="font-medium text-warm mb-1">{ node.Title }</h3>
		}
		if node.QuoteOfID != "" {
			<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.QuoteOfID)) }
				class="block mt-2 mb-1 rounded-lg border border-edge p-3 hover:border-brand/30 transition-colors">
				<div class="flex items-center gap-1 mb-1">
					<span class="text-xs font-medium text-warm-muted">{ node.QuoteOfAuthor }</span>
					if node.QuoteOfTitle != "" {
						<span class="text-xs text-warm-faint">· { node.QuoteOfTitle }</span>
					}
				</div>
				<p class="text-xs text-warm-faint line-clamp-2">{ node.QuoteOfBody }</p>
			</a>
		}
		<div class="text-sm text-warm-secondary prose prose-invert prose-sm max-w-none">
			@renderMarkdown(node.Body)
		</div>
		<div class="mt-3 flex items-center gap-4 text-xs text-warm-faint">
			<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.ID)) } class="hover:text-brand transition-colors">
				{ fmt.Sprintf("%d replies", node.ChildCount) }
			</a>
			<div id={ "repost-" + node.ID }>
				@repostButton(node.ID, spaceSlug, repostCount, reposted)
			</div>
			<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/feed?quote=%s", spaceSlug, node.ID)) } class="hover:text-brand transition-colors">
				quote
			</a>
			<div id={ "endorse-" + node.ID }>
				@endorseButton(node.ID, spaceSlug, endorseCount, endorsed)
			</div>
		</div>
	</div>
}

templ endorseButton(nodeID string, spaceSlug string, count int, endorsed bool) {
	<button
		class={ "flex items-center gap-1 transition-colors cursor-pointer",
			templ.KV("text-brand font-medium", endorsed),
			templ.KV("text-warm-faint hover:text-brand", !endorsed) }
		hx-post={ "/app/" + spaceSlug + "/op" }
		hx-vals={ `{"op":"endorse","node_id":"` + nodeID + `"}` }
		hx-target={ "#endorse-" + nodeID }
		hx-swap="innerHTML"
	>
		if endorsed {
			<svg class="w-3.5 h-3.5" fill="currentColor" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.25c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 0 1 2.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 0 0 .322-1.672V2.75a.75.75 0 0 1 .75-.75 2.25 2.25 0 0 1 2.25 2.25c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282m0 0h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 0 1-2.649 7.521c-.388.482-.987.729-1.605.729H13.48c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 0 0-1.423-.23H5.904m10.598-9.75H14.25M5.904 18.5c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12 12 0 0 1-.521-3.507c0-1.553.295-3.036.831-4.398C3.387 9.953 4.167 9.5 5 9.5h1.053c.472 0 .745.556.5.96a8.958 8.958 0 0 0-1.302 4.665c0 1.194.232 2.333.654 3.375Z"></path>
			</svg>
		} else {
			<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.25c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 0 1 2.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 0 0 .322-1.672V2.75a.75.75 0 0 1 .75-.75 2.25 2.25 0 0 1 2.25 2.25c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282m0 0h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 0 1-2.649 7.521c-.388.482-.987.729-1.605.729H13.48c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 0 0-1.423-.23H5.904m10.598-9.75H14.25M5.904 18.5c.083.205.173.405.27.602.197.4-.078.898-.523.898h-.908c-.889 0-1.713-.518-1.972-1.368a12 12 0 0 1-.521-3.507c0-1.553.295-3.036.831-4.398C3.387 9.953 4.167 9.5 5 9.5h1.053c.472 0 .745.556.5.96a8.958 8.958 0 0 0-1.302 4.665c0 1.194.232 2.333.654 3.375Z"></path>
			</svg>
		}
		if count > 0 {
			{ fmt.Sprintf("%d", count) }
		}
	</button>
}

templ repostButton(nodeID string, spaceSlug string, count int, reposted bool) {
	<button
		class={ "flex items-center gap-1 transition-colors cursor-pointer",
			templ.KV("text-emerald-400 font-medium", reposted),
			templ.KV("text-warm-faint hover:text-emerald-400", !reposted) }
		hx-post={ "/app/" + spaceSlug + "/op" }
		hx-vals={ `{"op":"repost","node_id":"` + nodeID + `"}` }
		hx-target={ "#repost-" + nodeID }
		hx-swap="innerHTML"
	>
		<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
			<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3-3 3"></path>
		</svg>
		if count > 0 {
			{ fmt.Sprintf("%d", count) }
		}
	</button>
}

// ── Threads view ────────────────────────────────────────────────

templ ThreadsView(space Space, spaces []Space, threads []Node, user ViewUser, isOwner bool, searchQuery string) {
	@appLayout(space, spaces, "threads", user) {
		<div class="max-w-2xl mx-auto p-6 space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="font-display text-xl font-normal text-warm">Threads</h1>
					<p class="text-sm text-warm-muted mt-0.5">Topic discussions and ongoing conversations</p>
				</div>
			</div>
			<form action={ templ.SafeURL("/app/" + space.Slug + "/threads") } method="GET" class="flex gap-2">
				<input type="text" name="q" value={ searchQuery } placeholder="Search threads..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/threads") } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			if user.Name != "" && user.Name != "Anonymous" {
				<!-- New thread form -->
				<form action={ templ.SafeURL("/app/" + space.Slug + "/op") } method="POST" class="bg-surface rounded-lg border border-edge p-4 space-y-3">
					<input type="hidden" name="op" value="discuss"/>
					<input type="text" name="title" placeholder="Discussion topic" required class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
					<textarea name="body" placeholder="Start the conversation..." rows="3" class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
					<div class="flex justify-end">
						<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Start thread</button>
					</div>
				</form>
			}
			<div class="space-y-2">
				for _, thread := range threads {
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, thread.ID)) }
						class="block bg-surface rounded-lg border border-edge p-4 hover:border-brand/40 hover:shadow-lg hover:shadow-brand/5 hover:-translate-y-0.5 transition-all duration-200">
						<div class="flex items-center justify-between">
							<h3 class="font-medium text-warm">{ thread.Title }</h3>
							<span class="text-xs text-warm-faint">{ fmt.Sprintf("%d replies", thread.ChildCount) }</span>
						</div>
						if thread.Body != "" {
							<p class="text-sm text-warm-muted mt-1 line-clamp-2">{ thread.Body }</p>
						}
						<div class="flex items-center gap-2 mt-2 text-xs text-warm-faint">
							if thread.AuthorKind == "agent" {
								<span class="text-violet-400">{ thread.Author }</span>
								<span class="text-[9px] font-medium px-1 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
							} else {
								<span>{ thread.Author }</span>
							}
							<span>{ thread.CreatedAt.Format("Jan 2") }</span>
							if thread.ChildCount > 0 {
								<span class="text-warm-muted">{ fmt.Sprintf("%d replies", thread.ChildCount) }</span>
							}
						</div>
					</a>
				}
				if len(threads) == 0 {
					<div class="text-center py-12 space-y-3">
						<svg class="w-12 h-12 mx-auto text-warm-faint/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a2 2 0 01-2-2v-1m0-3V6a2 2 0 012-2h8a2 2 0 012 2v5a2 2 0 01-2 2h-2l-4 4V13H9a2 2 0 01-2-2z"></path></svg>
						<p class="text-warm-faint text-sm">No threads yet</p>
						<p class="text-warm-faint/60 text-xs">Start a discussion topic for the community.</p>
					</div>
				}
			</div>
		</div>
	}
}

// ── Conversations view ──────────────────────────────────────────

script addParticipant(name string) {
	var input = document.getElementById('participants-input');
	var current = input.value.split(',').map(function(s) { return s.trim(); }).filter(Boolean);
	if (current.indexOf(name) === -1) {
		current.push(name);
	}
	input.value = current.join(', ');
	input.focus();
}

templ ConversationsView(space Space, spaces []Space, convos []ConversationSummary, user ViewUser, agents []string, nameMap map[string]string, searchQuery string, isDMFilter bool, isGroupFilter bool, msgResults []MessageSearchResult) {
	@appLayout(space, spaces, "conversations", user) {
		<div class="max-w-2xl mx-auto p-6 space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="font-display text-xl font-normal text-warm">Chat</h1>
					<p class="text-sm text-warm-muted mt-0.5">Direct conversations with teammates and agents</p>
				</div>
			</div>
			<!-- DM / Group filter -->
			<div class="flex gap-2">
				<a href={ templ.SafeURL("/app/" + space.Slug + "/conversations") } class={ "text-xs px-3 py-1 rounded-full border transition-colors", templ.KV("bg-brand/10 border-brand/30 text-warm", searchQuery == "" && !isDMFilter && !isGroupFilter), templ.KV("border-edge text-warm-muted hover:border-brand/30", searchQuery != "" || isDMFilter || isGroupFilter) }>All</a>
				<a href={ templ.SafeURL("/app/" + space.Slug + "/conversations?filter=dm") } class={ "text-xs px-3 py-1 rounded-full border transition-colors", templ.KV("bg-brand/10 border-brand/30 text-warm", isDMFilter), templ.KV("border-edge text-warm-muted hover:border-brand/30", !isDMFilter) }>DMs</a>
				<a href={ templ.SafeURL("/app/" + space.Slug + "/conversations?filter=group") } class={ "text-xs px-3 py-1 rounded-full border transition-colors", templ.KV("bg-brand/10 border-brand/30 text-warm", isGroupFilter), templ.KV("border-edge text-warm-muted hover:border-brand/30", !isGroupFilter) }>Groups</a>
			</div>
			<form action={ templ.SafeURL("/app/" + space.Slug + "/conversations") } method="GET" class="flex gap-2">
				<input type="text" name="q" value={ searchQuery } placeholder="Search messages... (from:name)"
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/conversations") } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			if user.Name != "" && user.Name != "Anonymous" {
				<!-- New conversation form -->
				<form
					action={ templ.SafeURL("/app/" + space.Slug + "/op") }
					method="POST"
					class="bg-surface rounded-lg border border-edge p-4 space-y-3"
				>
					<input type="hidden" name="op" value="converse"/>
					<input type="text" name="title" placeholder="Conversation name" required class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
					<div>
						<input id="participants-input" type="text" name="participants" placeholder="Add participants by name" class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"/>
						if len(agents) > 0 {
							<div class="flex items-center gap-2 mt-2">
								<span class="text-[10px] text-warm-faint">Add:</span>
								for _, agent := range agents {
									<button
										type="button"
										class="text-xs px-2 py-0.5 rounded-full bg-violet-500/10 text-violet-400 border border-violet-500/20 hover:bg-violet-500/20 transition-colors"
										onclick={ addParticipant(agent) }
									>
										{ agent }
									</button>
								}
							</div>
						}
					</div>
					<div class="flex justify-end">
						<button type="submit" class="px-4 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Start conversation</button>
					</div>
				</form>
			}
			<div class="space-y-2">
				for _, convo := range convos {
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/conversation/%s", space.Slug, convo.ID)) }
						class="block bg-surface rounded-lg border border-edge p-4 hover:border-brand/40 hover:shadow-lg hover:shadow-brand/5 hover:-translate-y-0.5 transition-all duration-200">
						<div class="flex items-center justify-between mb-1">
							<h3 class={ "font-medium", templ.KV("text-warm", convo.UnreadCount > 0), templ.KV("text-warm-muted", convo.UnreadCount == 0) }>{ convo.Title }</h3>
							<div class="flex items-center gap-2">
								if convo.UnreadCount > 0 {
									<span class="text-[10px] font-bold bg-brand text-void px-1.5 py-0.5 rounded-full">{ fmt.Sprintf("%d", convo.UnreadCount) }</span>
								}
								<span class="text-xs text-warm-faint">{ fmt.Sprintf("%d msgs", convo.ChildCount) }</span>
							</div>
						</div>
						if convo.LastBody != "" {
							<p class="text-sm text-warm-muted mt-1 line-clamp-1">
								if convo.LastAuthorKind == "agent" {
									<span class="text-violet-400">{ convo.LastAuthor }:</span>
								} else {
									<span class="text-warm-faint">{ convo.LastAuthor }:</span>
								}
								{ " " + truncate(convo.LastBody, 120) }
							</p>
						}
						<div class="flex items-center gap-2 text-xs text-warm-faint mt-1">
							<div class="flex items-center gap-1">
								for i, tag := range convo.Tags {
									if i > 0 {
										<span class="text-warm-faint">·</span>
									}
									<span class="text-warm-muted">{ resolveName(tag, nameMap) }</span>
								}
							</div>
							if convo.ChildCount > 0 {
								<span class="text-warm-muted ml-auto mr-2">{ fmt.Sprintf("%d msgs", convo.ChildCount) }</span>
							}
							<span class={ templ.KV("ml-auto", convo.ChildCount == 0) }>{ convo.UpdatedAt.Format("Jan 2, 3:04 PM") }</span>
						</div>
					</a>
				}
				if len(convos) == 0 && len(msgResults) == 0 {
					<div class="text-center py-12 space-y-3">
						<div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center mx-auto">
							<svg class="w-5 h-5 text-brand/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
						</div>
						<p class="text-warm text-sm font-medium">Start a conversation</p>
						if len(agents) > 0 {
							<p class="text-warm-faint/80 text-xs max-w-xs mx-auto">Use the form above to chat with your team or with { agents[0] }. Conversations appear here.</p>
						} else {
							<p class="text-warm-faint/80 text-xs max-w-xs mx-auto">Use the form above to start a conversation with your team. It will appear here.</p>
						}
					</div>
				}
			</div>
			if len(msgResults) > 0 {
				<div class="space-y-2">
					<h2 class="text-sm font-medium text-warm-muted">Messages ({ fmt.Sprintf("%d", len(msgResults)) })</h2>
					for _, msg := range msgResults {
						<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/conversation/%s", space.Slug, msg.ConvoID)) }
							class="block bg-surface rounded-lg border border-edge p-3 hover:border-brand/40 transition-colors">
							<div class="flex items-center gap-2 mb-1">
								<span class={ "text-xs font-medium", templ.KV("text-violet-400", msg.AuthorKind == "agent"), templ.KV("text-warm", msg.AuthorKind != "agent") }>{ msg.Author }</span>
								<span class="text-[10px] text-warm-faint">in { msg.ConvoTitle }</span>
								<span class="text-[10px] text-warm-faint ml-auto">{ msg.CreatedAt.Format("Jan 2, 3:04 PM") }</span>
							</div>
							<p class="text-sm text-warm-secondary line-clamp-2">{ truncate(msg.Body, 200) }</p>
						</a>
					}
				</div>
			}
		</div>
	}
}

// ── Conversation detail view ────────────────────────────────────

templ ConversationDetailView(space Space, convo Node, messages []Node, user ViewUser, userID string, hasAgent bool, nameMap map[string]string, rxnMap map[string][]Reaction) {
	@appLayout(space, []Space{space}, "conversations", user) {
		<div class="flex flex-col h-full">
			<!-- Conversation header -->
			<div class="border-b border-edge bg-surface px-6 py-3 flex-shrink-0">
				<div class="max-w-2xl mx-auto flex items-center justify-between">
					<div>
						<div class="flex items-center gap-2">
							<a href={ templ.SafeURL("/app/" + space.Slug + "/conversations") } class="text-warm-faint hover:text-brand transition-colors">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
								</svg>
							</a>
							<h1 class="text-lg font-medium text-warm">{ convo.Title }</h1>
						</div>
						<div class="flex items-center gap-1 mt-0.5 text-xs text-warm-faint">
							for i, tag := range convo.Tags {
								if i > 0 {
									<span>·</span>
								}
								<span class="text-warm-muted">{ resolveName(tag, nameMap) }</span>
							}
						</div>
					</div>
				</div>
			</div>

			<!-- Messages -->
			<div id="messages" class="flex-1 overflow-y-auto px-6 py-4">
				<div
					id="message-list"
					class="max-w-2xl mx-auto space-y-3"
					data-last-ts={ lastMessageTS(messages) }
					if hasAgent {
						data-has-agent="true"
					}
				>
					if len(messages) == 0 {
						<p id="empty-state" class="text-center text-warm-faint py-12">No messages yet. Start the conversation!</p>
					}
					for i, msg := range messages {
						if i > 0 && messages[i-1].AuthorID == msg.AuthorID && msg.CreatedAt.Sub(messages[i-1].CreatedAt) < 5*time.Minute {
							@chatMessageCompact(msg, userID, space.Slug, rxnMap[msg.ID])
						} else {
							@chatMessage(msg, userID, space.Slug, rxnMap[msg.ID])
						}
					}
				</div>
				<!-- Thinking indicator (hidden by default) -->
				if hasAgent {
					<div id="thinking" class="max-w-2xl mx-auto mt-3 hidden">
						<div class="flex gap-3">
							<span class="w-8 h-8 rounded-full bg-violet-500/10 text-violet-400 text-xs font-bold flex items-center justify-center flex-shrink-0">
								<svg class="w-4 h-4 animate-pulse" fill="currentColor" viewBox="0 0 24 24"><circle cx="6" cy="12" r="2"></circle><circle cx="12" cy="12" r="2"></circle><circle cx="18" cy="12" r="2"></circle></svg>
							</span>
							<div class="bg-violet-500/5 border border-violet-500/20 rounded-lg px-4 py-2.5">
								<div class="flex items-center gap-1.5 mb-1">
									<span class="text-[9px] font-medium px-1 py-0.5 rounded-full bg-violet-500/10 text-violet-400">thinking</span>
								</div>
								<div class="flex gap-1 items-center h-5">
									<span class="w-1.5 h-1.5 rounded-full bg-violet-400/60 animate-bounce" style="animation-delay: 0s"></span>
									<span class="w-1.5 h-1.5 rounded-full bg-violet-400/60 animate-bounce" style="animation-delay: 0.15s"></span>
									<span class="w-1.5 h-1.5 rounded-full bg-violet-400/60 animate-bounce" style="animation-delay: 0.3s"></span>
								</div>
							</div>
						</div>
					</div>
				}
				<!-- Poll for new messages every 3s -->
				<div
					id="poll"
					hx-get={ "/app/" + space.Slug + "/conversation/" + convo.ID + "/messages" }
					hx-trigger="every 3s"
					hx-target="#message-list"
					hx-swap="beforeend"
					hx-vals="js:{after: document.getElementById('message-list').dataset.lastTs}"
					hx-on::after-request="var ml=document.getElementById('message-list');var last=ml.querySelector('[data-ts]:last-child');if(last){var e=document.getElementById('empty-state');if(e)e.remove();ml.dataset.lastTs=last.dataset.ts;var t=document.getElementById('thinking');if(t)t.classList.add('hidden');var m=document.getElementById('messages');if(m.scrollHeight-m.scrollTop-m.clientHeight<100)m.scrollTop=m.scrollHeight;}"
				></div>
			</div>

			<!-- Message input -->
			if user.Name != "" && user.Name != "Anonymous" {
				<div class="border-t border-edge bg-surface px-6 py-3 flex-shrink-0">
					<form
						class="max-w-2xl mx-auto flex gap-2"
						method="POST"
						action={ templ.SafeURL("/app/" + space.Slug + "/op") }
						hx-post={ "/app/" + space.Slug + "/op" }
						hx-target="#message-list"
						hx-swap="beforeend"
						hx-on::before-request="var ta=this.querySelector('textarea[name=body]');if(ta&&ta.value.trim()){var ml=document.getElementById('message-list');var d=document.createElement('div');d.className='flex gap-3 flex-row-reverse';d.id='optimistic-msg';d.innerHTML='<span class=\\'w-8 h-8 rounded-full bg-brand/10 text-brand text-xs font-bold flex items-center justify-center flex-shrink-0\\'>...</span><div class=\\'max-w-[75%] rounded-lg px-4 py-2.5 bg-brand/10 border border-brand/20 opacity-60\\'><div class=\\'text-sm text-warm-secondary\\'>'+ta.value.replace(/</g,'&lt;')+'</div></div>';ml.appendChild(d);var m=document.getElementById('messages');m.scrollTop=m.scrollHeight}"
						hx-on::after-request="var opt=document.getElementById('optimistic-msg');if(opt)opt.remove();if(event.detail.successful){this.reset();clearReplyAfterSend();var ta=this.querySelector('textarea[name=body]');if(ta){ta.style.height='auto'};var ml=document.getElementById('message-list');var e=document.getElementById('empty-state');if(e)e.remove();var last=ml.querySelector('[data-ts]:last-child');if(last)ml.dataset.lastTs=last.dataset.ts;var m=document.getElementById('messages');m.scrollTop=m.scrollHeight;if(ml.dataset.hasAgent){var t=document.getElementById('thinking');if(t){t.classList.remove('hidden');clearTimeout(window._thinkTO);window._thinkTO=setTimeout(function(){t.classList.add('hidden')},60000);}}}"
					>
						<input type="hidden" name="op" value="respond"/>
						<input type="hidden" name="parent_id" value={ convo.ID }/>
						<input type="hidden" name="reply_to_id" id="reply-to-id" value=""/>
						<textarea
							id="chat-body"
							name="body"
							placeholder="Write a message... (Shift+Enter for new line)"
							required
							autocomplete="off"
							rows="1"
							class="flex-1 px-4 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm placeholder-warm-faint resize-none overflow-hidden"
							onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();this.form.requestSubmit();}"
							oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,144)+'px'"
						></textarea>
						<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Send</button>
					</form>
				</div>
			}
		</div>
		<!-- Reply preview bar -->
			<div id="reply-bar" class="hidden border-t border-brand/20 bg-brand/5 px-6 py-2 flex items-center gap-2 text-xs text-warm-muted flex-shrink-0">
				<span class="text-brand">Replying to</span>
				<span id="reply-bar-text" class="truncate"></span>
				<button type="button" onclick="cancelReply()" class="ml-auto text-warm-faint hover:text-warm cursor-pointer">✕</button>
			</div>
			<!-- Scroll to bottom + reply helpers -->
			<script>
			(function(){var m=document.getElementById('messages');if(m)m.scrollTop=m.scrollHeight;})();
			function cancelReply(){var b=document.getElementById('reply-bar');var h=document.getElementById('reply-to-id');if(b){b.classList.add('hidden');b.dataset.author='';b.dataset.text=''}if(h)h.value=''}
			function clearReplyAfterSend(){var h=document.getElementById('reply-to-id');if(h)h.value='';cancelReply()}
			</script>
	}
}

templ chatMessage(msg Node, currentUserID string, spaceSlug string, reactions []Reaction) {
	<div class={ "group flex gap-3", templ.KV("flex-row-reverse", msg.AuthorID == currentUserID) } data-ts={ msg.CreatedAt.Format(time.RFC3339Nano) }>
		if msg.AuthorKind == "agent" {
			<span class="w-8 h-8 rounded-full bg-violet-500/10 text-violet-400 text-xs font-bold flex items-center justify-center flex-shrink-0" title="Agent">
				{ initial(msg.Author) }
			</span>
		} else {
			<span class={ "w-8 h-8 rounded-full text-xs font-bold flex items-center justify-center flex-shrink-0",
				templ.KV("bg-brand/10 text-brand", msg.AuthorID == currentUserID),
				templ.KV("bg-elevated text-warm-muted", msg.AuthorID != currentUserID) }>
				{ initial(msg.Author) }
			</span>
		}
		<div class="max-w-[75%]">
			<div class={ "rounded-lg px-4 py-2.5 relative",
				templ.KV("bg-brand/10 border border-brand/20", msg.AuthorID == currentUserID),
				templ.KV("bg-surface border border-edge", msg.AuthorID != currentUserID && msg.AuthorKind != "agent"),
				templ.KV("bg-violet-500/5 border border-violet-500/20", msg.AuthorKind == "agent") }>
				<div class="flex items-center gap-1.5 mb-1">
					<span class="text-xs font-medium text-warm">{ msg.Author }</span>
					if msg.AuthorKind == "agent" {
						<span class="text-[9px] font-medium px-1 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
					}
					<span class="text-[10px] text-warm-faint ml-auto">{ msg.CreatedAt.Format("3:04 PM") }</span>
					<!-- Hover actions: reply + react + edit/delete -->
					<div class="opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-0.5 ml-1">
						<button type="button" class="text-[10px] text-warm-faint hover:text-brand cursor-pointer"
							onclick={ replyTo(msg.ID, msg.Author, truncate(msg.Body, 80)) }>reply</button>
						@quickReactButtons(msg.ID, spaceSlug)
						if msg.AuthorID == currentUserID && msg.Body != "[deleted]" {
							<button type="button" class="text-[10px] text-warm-faint hover:text-brand cursor-pointer"
								onclick={ editMessage(msg.ID, msg.Body) }>edit</button>
							<button type="button" class="text-[10px] text-warm-faint hover:text-red-400 cursor-pointer"
								hx-post={ "/app/" + spaceSlug + "/op" }
								hx-vals={ `{"op":"delete","node_id":"` + msg.ID + `"}` }
								hx-confirm="Delete this message?"
								>del</button>
						}
					</div>
				</div>
				if msg.ReplyToID != "" {
					<div class="text-xs border-l-2 border-brand/30 pl-2 py-0.5 mb-1 text-warm-faint truncate">
						<span class="font-medium text-warm-muted">{ msg.ReplyToAuthor }</span>
						<span>: { truncate(msg.ReplyToBody, 60) }</span>
					</div>
				}
				if msg.Body == "[deleted]" {
					<div class="text-sm text-warm-faint italic">message deleted</div>
				} else {
					<div id={ "msg-body-" + msg.ID } class="text-sm text-warm-secondary prose prose-invert prose-sm max-w-none">
									@renderMarkdown(msg.Body)
								</div>
				}
			</div>
			if len(reactions) > 0 {
				<div id={ "rxn-" + msg.ID }>
					@reactionBar(msg.ID, spaceSlug, reactions, currentUserID)
				</div>
			} else {
				<div id={ "rxn-" + msg.ID }></div>
			}
		</div>
	</div>
}

templ chatMessageCompact(msg Node, currentUserID string, spaceSlug string, reactions []Reaction) {
	<div class={ "group flex gap-3", templ.KV("flex-row-reverse", msg.AuthorID == currentUserID) } data-ts={ msg.CreatedAt.Format(time.RFC3339Nano) }>
		<div class="w-8 flex-shrink-0"></div>
		<div class="max-w-[75%]">
			<div class={ "rounded-lg px-4 py-1 relative",
				templ.KV("bg-brand/10 border border-brand/20", msg.AuthorID == currentUserID),
				templ.KV("bg-surface border border-edge", msg.AuthorID != currentUserID && msg.AuthorKind != "agent"),
				templ.KV("bg-violet-500/5 border border-violet-500/20", msg.AuthorKind == "agent") }>
				<!-- Hover actions -->
				<div class="absolute -top-2.5 right-2 opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-0.5 bg-elevated border border-edge rounded px-1 py-0.5 shadow-sm">
					<button type="button" class="text-[10px] text-warm-faint hover:text-brand cursor-pointer"
						onclick={ replyTo(msg.ID, msg.Author, truncate(msg.Body, 80)) }>reply</button>
					@quickReactButtons(msg.ID, spaceSlug)
				</div>
				<div class="text-sm text-warm-secondary prose prose-invert prose-sm max-w-none">
								@renderMarkdown(msg.Body)
							</div>
			</div>
			if len(reactions) > 0 {
				<div id={ "rxn-" + msg.ID }>
					@reactionBar(msg.ID, spaceSlug, reactions, currentUserID)
				</div>
			} else {
				<div id={ "rxn-" + msg.ID }></div>
			}
		</div>
	</div>
}

// ── Reaction components ─────────────────────────────────────────

// quickReactButtons renders the 6 quick emoji reaction buttons on hover.
templ quickReactButtons(nodeID string, spaceSlug string) {
	for _, emoji := range []string{"👍", "❤️", "🔥", "👀", "✅", "😂"} {
		<button
			type="button"
			class="text-xs hover:scale-125 transition-transform cursor-pointer px-0.5 leading-none"
			hx-post={ "/app/" + spaceSlug + "/op" }
			hx-vals={ `{"op":"react","node_id":"` + nodeID + `","emoji":"` + emoji + `"}` }
			hx-target={ "#rxn-" + nodeID }
			hx-swap="innerHTML"
		>
			{ emoji }
		</button>
	}
}

// reactionBar renders the aggregated reaction badges below a message.
templ reactionBar(nodeID string, spaceSlug string, reactions []Reaction, currentUserID string) {
	<div class="flex flex-wrap gap-1 mt-1">
		for _, r := range reactions {
			<button
				type="button"
				class={ "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs transition-colors cursor-pointer border",
					templ.KV("bg-brand/10 border-brand/30 text-warm", containsStr(r.Users, currentUserID)),
					templ.KV("bg-elevated border-edge text-warm-muted hover:border-brand/30", !containsStr(r.Users, currentUserID)) }
				hx-post={ "/app/" + spaceSlug + "/op" }
				hx-vals={ `{"op":"react","node_id":"` + nodeID + `","emoji":"` + r.Emoji + `"}` }
				hx-target={ "#rxn-" + nodeID }
				hx-swap="innerHTML"
			>
				<span>{ r.Emoji }</span>
				<span>{ fmt.Sprintf("%d", r.Count) }</span>
			</button>
		}
	</div>
}

// ── People view ─────────────────────────────────────────────────

templ PeopleView(space Space, spaces []Space, members []Member, user ViewUser, searchQuery string) {
	@appLayout(space, spaces, "people", user) {
		<div class="max-w-2xl mx-auto p-6 space-y-6">
			<div>
				<h1 class="font-display text-xl font-normal text-warm">People</h1>
				<p class="text-sm text-warm-muted mt-0.5">Team members and collaborators</p>
			</div>
			<form action={ templ.SafeURL("/app/" + space.Slug + "/people") } method="GET" class="flex gap-2">
				<input type="text" name="q" value={ searchQuery } placeholder="Search people..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/people") } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			<div class="bg-surface rounded-lg border border-edge overflow-hidden">
				<div class="grid grid-cols-[1fr_5rem_5rem] gap-3 px-4 py-2.5 border-b border-edge bg-elevated/80 text-[10px] font-semibold text-warm-faint uppercase tracking-wider">
					<div>Member</div>
					<div>Actions</div>
					<div>Last seen</div>
				</div>
				if len(members) == 0 {
					<div class="px-4 py-12 text-center space-y-2">
						<p class="text-sm font-medium text-warm">No one here yet</p>
						<p class="text-xs text-warm-faint">Invite people to this space to start collaborating.</p>
					</div>
				}
				for _, m := range members {
					<div class="grid grid-cols-[1fr_5rem_5rem] gap-3 px-4 py-3 border-b border-edge last:border-b-0 items-center">
						<div class="flex items-center gap-2">
							if m.Kind == "agent" {
								<span class="w-7 h-7 rounded-full bg-violet-500/10 text-violet-400 text-xs font-bold flex items-center justify-center" title="Agent">
									{ initial(m.Name) }
								</span>
							} else {
								<span class="w-7 h-7 rounded-full bg-brand/10 text-brand text-xs font-bold flex items-center justify-center">
									{ initial(m.Name) }
								</span>
							}
							<a href={ templ.SafeURL("/user/" + m.Name) } class="text-sm font-medium text-warm hover:text-brand transition-colors">{ m.Name }</a>
							if m.Kind == "agent" {
								<span class="text-[9px] font-medium px-1 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
							}
						</div>
						<div class="text-sm text-warm-muted">{ fmt.Sprintf("%d", m.OpCount) }</div>
						<div class="text-xs text-warm-faint">{ m.LastSeen }</div>
					</div>
				}
			</div>
		</div>
	}
}

// ── Activity view ───────────────────────────────────────────────

templ ActivityView(space Space, spaces []Space, ops []Op, user ViewUser, opFilter string) {
	@appLayout(space, spaces, "activity", user) {
		<div class="max-w-2xl mx-auto p-6 space-y-6">
			<div>
				<h1 class="font-display text-xl font-normal text-warm">Activity</h1>
				<p class="text-sm text-warm-muted mt-0.5">Everything that happened in this space</p>
			</div>
			<div class="flex flex-wrap gap-1">
				@activityOpTab(space.Slug, "", "All", opFilter)
				@activityOpTab(space.Slug, "intend", "Tasks", opFilter)
				@activityOpTab(space.Slug, "complete", "Completions", opFilter)
				@activityOpTab(space.Slug, "respond", "Messages", opFilter)
				@activityOpTab(space.Slug, "assert", "Claims", opFilter)
				@activityOpTab(space.Slug, "vote", "Votes", opFilter)
			</div>
			<div class="space-y-2">
				for i, o := range ops {
					if i > 0 && ops[i-1].ActorID == o.ActorID && ops[i-1].NodeID == o.NodeID && o.NodeID != "" && ops[i-1].CreatedAt.Sub(o.CreatedAt) < 5*time.Minute {
						<!-- Grouped: skip (shown as count on the first item) -->
					} else {
						@opItem(o, space.Slug)
					}
				}
				if len(ops) == 0 {
					<div class="text-center py-12 space-y-3">
						<svg class="w-12 h-12 mx-auto text-warm-faint/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
						<p class="text-warm-faint text-sm">No activity yet</p>
					</div>
				}
			</div>
		</div>
	}
}

templ activityOpTab(spaceSlug, value, label, active string) {
	<a
		href={ templ.SafeURL("/app/" + spaceSlug + "/activity?op=" + value) }
		class={ "text-xs px-2.5 py-1 rounded-lg transition-colors font-medium",
			templ.KV("bg-brand/15 text-brand", value == active),
			templ.KV("bg-elevated text-warm-muted hover:text-warm", value != active) }
	>
		{ label }
	</a>
}

templ opItem(o Op, spaceSlug string) {
	<div class="flex items-start gap-3 bg-surface rounded-lg border border-edge px-4 py-3">
		if o.ActorKind == "agent" {
			<span class="w-6 h-6 rounded-full bg-violet-500/10 text-violet-400 text-[10px] font-bold flex items-center justify-center mt-0.5 flex-shrink-0" title="Agent">
				{ initial(o.Actor) }
			</span>
		} else {
			<span class="w-6 h-6 rounded-full bg-brand/10 text-brand text-[10px] font-bold flex items-center justify-center mt-0.5 flex-shrink-0">
				{ initial(o.Actor) }
			</span>
		}
		<div class="flex-1 min-w-0">
			<div class="text-sm">
				<span class="font-medium text-warm">{ o.Actor }</span>
				if o.ActorKind == "agent" {
					<span class="text-[9px] font-medium px-1 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
				}
				if o.NodeID != "" {
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, o.NodeID)) } class="text-warm-muted hover:text-brand transition-colors ml-1">{ o.Op }</a>
					if o.NodeTitle != "" {
						<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, o.NodeID)) } class="text-warm-secondary hover:text-brand transition-colors ml-1 truncate">{ truncate(o.NodeTitle, 60) }</a>
					}
				} else {
					<span class="text-warm-muted ml-1">{ o.Op }</span>
				}
			</div>
			<div class="text-xs text-warm-faint mt-0.5">{ o.CreatedAt.Format("Jan 2, 3:04 PM") }</div>
		</div>
		<span class={ "text-[10px] font-medium px-2 py-0.5 rounded-full flex-shrink-0", opBadgeClass(o.Op) }>
			{ o.Op }
		</span>
	</div>
}

// ── Settings ────────────────────────────────────────────────────

templ SettingsView(space Space, spaces []Space, reports []Report, user ViewUser, errMsg string, inviteToken string, members []SpaceMember) {
	@appLayout(space, spaces, "settings", user) {
		<div class="max-w-xl mx-auto p-6 space-y-8">
			<h1 class="font-display text-xl font-normal text-warm">Settings</h1>
			if errMsg != "" {
				<div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-lg px-4 py-3">
					{ errMsg }
				</div>
			}
			<!-- General settings form -->
			<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/settings") } class="space-y-5">
				<div>
					<label for="name" class="block text-sm font-medium text-warm-muted mb-1">Name</label>
					<input
						type="text"
						id="name"
						name="name"
						value={ space.Name }
						required
						class="w-full bg-elevated border border-edge rounded-lg px-3 py-2 text-sm text-warm placeholder-warm-faint focus:outline-none focus:border-brand"
					/>
				</div>
				<div>
					<label for="description" class="block text-sm font-medium text-warm-muted mb-1">Description</label>
					<textarea
						id="description"
						name="description"
						rows="3"
						class="w-full bg-elevated border border-edge rounded-lg px-3 py-2 text-sm text-warm placeholder-warm-faint focus:outline-none focus:border-brand resize-none"
					>{ space.Description }</textarea>
				</div>
				<div>
					<label for="visibility" class="block text-sm font-medium text-warm-muted mb-1">Visibility</label>
					<select
						id="visibility"
						name="visibility"
						class="w-full bg-elevated border border-edge rounded-lg px-3 py-2 text-sm text-warm focus:outline-none focus:border-brand"
					>
						<option value="private" selected?={ space.Visibility == "private" }>Private — only you can see it</option>
						<option value="public" selected?={ space.Visibility == "public" }>Public — visible on Discover and accessible by anyone</option>
					</select>
				</div>
				<button
					type="submit"
					class="bg-brand text-void text-sm font-medium px-4 py-2 rounded-lg hover:bg-brand-dark transition-colors"
				>
					Save changes
				</button>
			</form>
			<!-- Invite link -->
			<div class="bg-surface border border-edge rounded-lg p-5 space-y-3">
				<h2 class="text-sm font-medium text-warm">Invite people</h2>
				<p class="text-xs text-warm-muted">Share this link to invite someone to your space.</p>
				if inviteToken != "" {
					<div class="flex gap-2 items-center">
						<input
							type="text"
							value={ "https://lovyou.ai/join/" + inviteToken }
							readonly
							class="flex-1 px-3 py-2 bg-elevated border border-edge rounded-lg text-xs text-warm font-mono select-all focus:outline-none focus:ring-1 focus:ring-brand"
							onclick="this.select()"
						/>
					</div>
				} else {
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/invite") }>
						<button type="submit" class="px-4 py-2 bg-brand/10 text-brand rounded-lg hover:bg-brand/20 transition-colors text-sm font-medium">
							Generate invite link
						</button>
					</form>
				}
			</div>
			<!-- Reports -->
			if len(reports) > 0 {
				<div class="border border-amber-500/30 rounded-lg p-5 space-y-4">
					<h2 class="text-lg font-medium text-amber-400">Reports ({ fmt.Sprintf("%d", len(reports)) })</h2>
					<p class="text-sm text-warm-muted">Flagged content that needs your review.</p>
					<div class="space-y-3">
						for _, rpt := range reports {
							<div class="bg-elevated rounded-lg p-4 border border-edge">
								<div class="flex items-center justify-between mb-2">
									<div class="flex items-center gap-2">
										<span class={ "text-[10px] font-medium px-1.5 py-0.5 rounded-full", kindBadgeClass(rpt.NodeKind) }>{ rpt.NodeKind }</span>
										<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, rpt.NodeID)) } class="text-sm font-medium text-warm hover:text-brand transition-colors">
											if rpt.NodeTitle != "" {
												{ rpt.NodeTitle }
											} else {
												{ rpt.NodeID }
											}
										</a>
									</div>
									<span class="text-[10px] text-warm-faint">{ dashRelativeTime(rpt.CreatedAt) }</span>
								</div>
								<p class="text-xs text-warm-muted mb-3">
									Reported by <span class="text-warm">{ rpt.Actor }</span>: { rpt.Reason }
								</p>
								<div class="flex gap-2">
									<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") }>
										<input type="hidden" name="op" value="resolve"/>
										<input type="hidden" name="node_id" value={ rpt.NodeID }/>
										<input type="hidden" name="action" value="dismiss"/>
										<button type="submit" class="text-xs px-3 py-1.5 bg-warm-faint/20 text-warm-muted rounded-lg hover:bg-warm-faint/30 transition-colors">
											Dismiss
										</button>
									</form>
									<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") }>
										<input type="hidden" name="op" value="resolve"/>
										<input type="hidden" name="node_id" value={ rpt.NodeID }/>
										<input type="hidden" name="action" value="remove"/>
										<button type="submit" class="text-xs px-3 py-1.5 bg-red-500/15 text-red-400 rounded-lg hover:bg-red-500/25 transition-colors">
											Remove content
										</button>
									</form>
								</div>
							</div>
						}
					</div>
				</div>
			}
			<!-- Members -->
			if len(members) > 0 {
				<div class="bg-surface border border-edge rounded-lg p-5 space-y-3">
					<h2 class="text-sm font-medium text-warm">Members ({ fmt.Sprintf("%d", len(members)) })</h2>
					<div class="space-y-1">
						for _, m := range members {
							<div class="flex items-center justify-between py-2 px-2 rounded hover:bg-elevated transition-colors">
								<div class="flex items-center gap-2">
									if m.Kind == "agent" {
										<span class="w-6 h-6 rounded-full bg-violet-500/10 text-violet-400 text-[10px] font-bold flex items-center justify-center">{ initial(m.UserName) }</span>
									} else {
										<span class="w-6 h-6 rounded-full bg-brand/10 text-brand text-[10px] font-bold flex items-center justify-center">{ initial(m.UserName) }</span>
									}
									<a href={ templ.SafeURL("/user/" + m.UserName) } class="text-sm text-warm hover:text-brand transition-colors">{ m.UserName }</a>
									if m.Kind == "agent" {
										<span class="text-[9px] px-1 py-0.5 rounded bg-violet-500/10 text-violet-400">agent</span>
									}
								</div>
								if m.UserID != space.OwnerID {
									<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") }>
										<input type="hidden" name="op" value="kick"/>
										<input type="hidden" name="member_id" value={ m.UserID }/>
										<button type="submit" class="text-[10px] text-warm-faint hover:text-red-400 transition-colors px-2 py-1">Remove</button>
									</form>
								} else {
									<span class="text-[10px] text-warm-faint px-2 py-1">owner</span>
								}
							</div>
						}
					</div>
				</div>
			}
			<!-- Danger zone -->
			<div class="border border-red-500/30 rounded-lg p-5 space-y-4">
				<h2 class="text-lg font-medium text-red-400">Danger zone</h2>
				<p class="text-sm text-warm-muted">
					Deleting a space permanently removes all its nodes, comments, and activity.
					This cannot be undone.
				</p>
				<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/delete") } class="space-y-3">
					<div>
						<label for="confirm" class="block text-sm text-warm-muted mb-1">
							Type <span class="font-medium text-warm">{ space.Name }</span> to confirm
						</label>
						<input
							type="text"
							id="confirm"
							name="confirm"
							placeholder={ space.Name }
							required
							class="w-full bg-elevated border border-edge rounded-lg px-3 py-2 text-sm text-warm placeholder-warm-faint focus:outline-none focus:border-red-500/50"
						/>
					</div>
					<button
						type="submit"
						class="bg-red-500/15 text-red-400 text-sm font-medium px-4 py-2 rounded-lg hover:bg-red-500/25 transition-colors"
					>
						Delete this space
					</button>
				</form>
			</div>
		</div>
	}
}

// ── Changelog view (Layer 5 — Build) ────────────────────────────

templ ChangelogView(space Space, spaces []Space, entries []ChangelogEntry, user ViewUser, searchQuery string) {
	@appLayout(space, spaces, "changelog", user) {
		<div class="p-6 md:p-8 space-y-6">
			<div>
				<h1 class="font-display text-2xl font-light text-warm">Changelog</h1>
				<p class="text-sm text-warm-muted mt-1">What was built — completed tasks with accountability</p>
			</div>
			<form action={ templ.SafeURL("/app/" + space.Slug + "/changelog") } method="GET" class="flex gap-2">
				<input type="text" name="q" value={ searchQuery } placeholder="Search changelog..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/changelog") } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			if len(entries) == 0 {
				<div class="text-center py-12">
					<p class="text-warm-muted text-lg">Nothing shipped yet</p>
					<p class="text-warm-faint text-sm mt-2">Completed tasks will appear here as a build history</p>
				</div>
			} else {
				<div class="space-y-3">
					for _, e := range entries {
						<div class="p-4 bg-surface rounded-lg border border-edge">
							<div class="flex items-center gap-2 mb-1">
								<span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
								<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, e.ID)) } class="text-sm font-medium text-warm hover:text-brand transition-colors">
									{ e.Title }
								</a>
							</div>
							if e.Body != "" {
								<p class="text-xs text-warm-muted ml-4 line-clamp-2">{ truncate(e.Body, 200) }</p>
							}
							<div class="flex items-center gap-3 mt-2 ml-4 text-xs text-warm-faint">
								if e.CompletedByKind == "agent" {
									<span class="w-4 h-4 rounded-full bg-violet-500/10 text-violet-400 text-[8px] font-bold flex items-center justify-center">{ initial(e.CompletedBy) }</span>
								}
								<span>{ e.CompletedBy }</span>
								<span>{ e.CompletedAt.Format("Jan 2, 3:04 PM") }</span>
								if e.Assignee != "" {
									<span class="text-warm-faint">assigned to { e.Assignee }</span>
								}
							</div>
						</div>
					}
				</div>
			}
		</div>
	}
}

// ── Governance view ──────────────────────────────────────────────

templ GovernanceView(space Space, spaces []Space, proposals []ProposalWithVotes, user ViewUser, isOwner bool, stateFilter string, searchQuery string) {
	@appLayout(space, spaces, "governance", user) {
		<div class="p-6 md:p-8 space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="font-display text-2xl font-light text-warm">Governance</h1>
					<p class="text-sm text-warm-muted mt-1">Propose changes, vote on decisions — transparent and accountable</p>
				</div>
			</div>
			<form action={ templ.SafeURL("/app/" + space.Slug + "/governance") } method="GET" class="flex gap-2">
				<input type="text" name="q" value={ searchQuery } placeholder="Search proposals..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if stateFilter != "" {
					<input type="hidden" name="state" value={ stateFilter }/>
				}
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/governance?state=" + stateFilter) } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			<div class="flex gap-2">
				@govStateTab(space.Slug, "", "All", stateFilter)
				@govStateTab(space.Slug, "open", "Open", stateFilter)
				@govStateTab(space.Slug, "done", "Passed", stateFilter)
				@govStateTab(space.Slug, "closed", "Rejected", stateFilter)
			</div>
			<!-- Create proposal form -->
			<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="bg-surface border border-edge rounded-lg p-5 space-y-3">
				<input type="hidden" name="op" value="propose"/>
				<input
					type="text"
					name="title"
					placeholder="What do you propose?"
					required
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent"
				/>
				<textarea
					name="description"
					placeholder="Details and reasoning (optional)"
					rows="2"
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none"
				></textarea>
				<div class="flex items-center gap-3">
					<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
						Submit proposal
					</button>
					<div class="flex items-center gap-2">
						<label class="text-xs text-warm-faint">Deadline</label>
						<input
							type="date"
							name="deadline"
							class="px-2 py-1 bg-elevated border border-edge rounded-lg text-xs text-warm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent"
						/>
					</div>
				</div>
			</form>
			if len(proposals) == 0 {
				<div class="text-center py-12">
					<p class="text-warm-muted text-lg">No proposals yet</p>
					<p class="text-warm-faint text-sm mt-2">Be the first to propose a change in this space</p>
				</div>
			} else {
				<div class="space-y-3">
					for _, p := range proposals {
						@proposalCard(p, space.Slug, isOwner)
					}
				</div>
			}
		</div>
	}
}

templ proposalCard(p ProposalWithVotes, spaceSlug string, isOwner bool) {
	<div class="p-5 bg-surface rounded-lg border border-edge hover:border-brand/30 transition-all">
		<div class="flex items-start justify-between gap-3">
			<div class="flex-1 min-w-0">
				<div class="flex items-center gap-2 mb-1">
					@proposalStateBadge(p.State)
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, p.ID)) } class="text-sm font-medium text-warm hover:text-brand transition-colors">
						{ p.Title }
					</a>
				</div>
				if p.Body != "" {
					<p class="text-xs text-warm-muted mt-1 line-clamp-2">{ truncate(p.Body, 200) }</p>
				}
				<div class="flex items-center gap-3 mt-2 text-xs text-warm-faint">
					if p.AuthorKind == "agent" {
						<span class="w-4 h-4 rounded-full bg-violet-500/10 text-violet-400 text-[8px] font-bold flex items-center justify-center">{ initial(p.Author) }</span>
					}
					<span>{ p.Author }</span>
					<span>{ p.CreatedAt.Format("Jan 2") }</span>
					if p.DueDate != nil {
						if p.DueDate.Before(time.Now()) && p.State == ProposalOpen {
							<span class="text-red-400 font-medium">overdue { p.DueDate.Format("Jan 2") }</span>
						} else {
							<span>closes { p.DueDate.Format("Jan 2") }</span>
						}
					}
				</div>
			</div>
			<div class="flex items-center gap-2 flex-shrink-0">
				<!-- Vote counts -->
				<div class="flex items-center gap-1 text-sm">
					<span class="text-emerald-400 font-medium">{ fmt.Sprintf("%d", p.VotesYes) }</span>
					<span class="text-warm-faint">/</span>
					<span class="text-red-400 font-medium">{ fmt.Sprintf("%d", p.VotesNo) }</span>
				</div>
				if p.State == ProposalOpen {
					<!-- Vote buttons -->
					<form method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="inline">
						<input type="hidden" name="op" value="vote"/>
						<input type="hidden" name="node_id" value={ p.ID }/>
						<input type="hidden" name="vote" value="yes"/>
						<button type="submit" class="px-2 py-1 text-xs bg-emerald-500/15 text-emerald-400 rounded hover:bg-emerald-500/25 transition-colors" title="Vote yes">
							Yes
						</button>
					</form>
					<form method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="inline">
						<input type="hidden" name="op" value="vote"/>
						<input type="hidden" name="node_id" value={ p.ID }/>
						<input type="hidden" name="vote" value="no"/>
						<button type="submit" class="px-2 py-1 text-xs bg-red-500/15 text-red-400 rounded hover:bg-red-500/25 transition-colors" title="Vote no">
							No
						</button>
					</form>
					if isOwner {
						<span class="text-warm-faint mx-1">|</span>
						<form method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="inline">
							<input type="hidden" name="op" value="close_proposal"/>
							<input type="hidden" name="node_id" value={ p.ID }/>
							<input type="hidden" name="outcome" value="passed"/>
							<button type="submit" class="px-2 py-1 text-xs bg-emerald-500/15 text-emerald-400 rounded hover:bg-emerald-500/25 transition-colors" title="Close as passed">
								Pass
							</button>
						</form>
						<form method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="inline">
							<input type="hidden" name="op" value="close_proposal"/>
							<input type="hidden" name="node_id" value={ p.ID }/>
							<input type="hidden" name="outcome" value="rejected"/>
							<button type="submit" class="px-2 py-1 text-xs bg-red-500/15 text-red-400 rounded hover:bg-red-500/25 transition-colors" title="Close as rejected">
								Reject
							</button>
						</form>
					}
				}
			</div>
		</div>
	</div>
}

templ govStateTab(spaceSlug, value, label, active string) {
	<a
		href={ templ.SafeURL("/app/" + spaceSlug + "/governance?state=" + value) }
		class={ "text-xs px-3 py-1.5 rounded-lg transition-colors font-medium",
			templ.KV("bg-brand/15 text-brand", value == active),
			templ.KV("bg-elevated text-warm-muted hover:text-warm", value != active) }
	>
		{ label }
	</a>
}

templ proposalStateBadge(state string) {
	switch state {
		case ProposalOpen:
			<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-sky-500/15 text-sky-400">open</span>
		case ProposalPassed:
			<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-emerald-500/15 text-emerald-400">passed</span>
		case ProposalFailed:
			<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-red-500/15 text-red-400">rejected</span>
		default:
			<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-warm-faint/20 text-warm-muted">{ state }</span>
	}
}

// ── Node detail ─────────────────────────────────────────────────

templ NodeDetailView(space Space, node Node, children []Node, ops []Op, user ViewUser, isOwner bool, parents []Node, dependencies []Node, dependents []Node, spaceTasks []Node, endorseCount int, endorsed bool, repostCount int, reposted bool) {
	@appLayout(space, []Space{space}, "", user) {
		<div class="max-w-3xl mx-auto p-6 space-y-8">
			<!-- Breadcrumb -->
			<div class="text-sm flex flex-wrap items-center gap-1">
				<a href={ templ.SafeURL("/app/" + space.Slug) } class="text-warm-faint hover:text-brand transition-colors">
					{ space.Name }
				</a>
				for _, p := range parents {
					<span class="text-warm-faint">/</span>
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", space.Slug, p.ID)) } class="text-warm-faint hover:text-brand transition-colors truncate max-w-[150px]">
						if p.Title != "" {
							{ p.Title }
						} else {
							{ p.Kind }
						}
					</a>
				}
				<span class="text-warm-faint">/</span>
				<span class="text-warm-secondary">
					if node.Title != "" {
						{ node.Title }
					} else {
						{ node.Kind }
					}
				</span>
			</div>

			<!-- Title -->
			<div>
				if node.Title != "" {
					<div class="flex items-center gap-2">
						if node.Pinned {
							<span class="text-brand" title="Pinned">
								<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.828 3.414a2 2 0 012.828 0l1.93 1.93a2 2 0 010 2.828L13 9.758l1.414 1.414L16 9.586a4 4 0 00-5.656-5.656L8.758 5.516 10.172 6.93l1.656-1.656z"></path><path d="M6.343 8.828L4.93 10.242a4 4 0 005.656 5.656l1.586-1.586-1.414-1.414-1.586 1.586a2 2 0 01-2.828-2.828l1.414-1.414L6.343 8.828z"></path></svg>
							</span>
						}
						<h1 class="text-2xl font-light leading-tight text-warm">{ node.Title }</h1>
					</div>
				}
				<div class="flex items-center gap-3 mt-2 text-xs text-warm-faint">
					<span class={ "font-medium px-2 py-0.5 rounded-full", kindBadgeClass(node.Kind) }>{ node.Kind }</span>
					if node.Pinned {
						<span class="font-medium px-2 py-0.5 rounded-full bg-brand/15 text-brand">pinned</span>
					}
					<span>by { node.Author }</span>
					<span>{ node.CreatedAt.Format("Jan 2, 2006 3:04 PM") }</span>
					if isOwner {
						if node.Pinned {
							<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="inline">
								<input type="hidden" name="op" value="unpin"/>
								<input type="hidden" name="node_id" value={ node.ID }/>
								<button type="submit" class="text-brand hover:text-brand-dark transition-colors">unpin</button>
							</form>
						} else {
							<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="inline">
								<input type="hidden" name="op" value="pin"/>
								<input type="hidden" name="node_id" value={ node.ID }/>
								<button type="submit" class="text-warm-faint hover:text-brand transition-colors">pin</button>
							</form>
						}
					}
				</div>
			</div>

			<!-- Task metadata (only for tasks) -->
			if node.Kind == KindTask {
				<div class="flex flex-wrap gap-6">
					<!-- Status buttons -->
					<div class="space-y-1.5">
						<label class="text-[10px] font-semibold text-warm-faint uppercase tracking-wider">Status</label>
						if isOwner {
							<div class="flex gap-1">
								for _, s := range []string{StateOpen, StateActive, StateReview, StateDone} {
									<form method="POST" action={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s/state", space.Slug, node.ID)) }>
										<input type="hidden" name="state" value={ s }/>
										<button type="submit" class={ "px-2 py-1 rounded-md text-xs font-medium transition-colors cursor-pointer",
											templ.KV("ring-2 ring-offset-1 ring-brand ring-offset-void", s == node.State),
											stateBgClass(s) }>
											{ stateLabel(s) }
										</button>
									</form>
								}
							</div>
						} else {
							<span class={ "px-2 py-1 rounded-md text-xs font-medium", stateBgClass(node.State) }>{ stateLabel(node.State) }</span>
						}
					</div>
					<!-- Priority -->
					<div class="space-y-1.5">
						<label class="text-[10px] font-semibold text-warm-faint uppercase tracking-wider">Priority</label>
						<div class="flex items-center gap-1.5 text-sm text-warm-secondary">
							<span class="w-2 h-2 rounded-full" style={ fmt.Sprintf("background-color: %s", priorityDotHex(node.Priority)) }></span>
							<span class="capitalize">{ node.Priority }</span>
						</div>
					</div>
					<!-- Assignee -->
					<div class="space-y-1.5">
						<label class="text-[10px] font-semibold text-warm-faint uppercase tracking-wider">Assignee</label>
						<div class="text-sm">
							if node.Assignee != "" {
								<div class="flex items-center gap-1.5 text-warm-secondary">
									<span class="w-5 h-5 rounded-full bg-brand/10 text-brand text-[10px] font-bold flex items-center justify-center">{ initial(node.Assignee) }</span>
									{ node.Assignee }
								</div>
							} else if user.Name != "" && user.Name != "Anonymous" {
								<div class="flex items-center gap-2">
									<form method="POST" action={ templ.SafeURL(fmt.Sprintf("/app/%s/op", space.Slug)) } class="inline">
										<input type="hidden" name="op" value="claim"/>
										<input type="hidden" name="node_id" value={ node.ID }/>
										<button type="submit" class="px-3 py-1 bg-brand text-void rounded-md hover:bg-brand-dark transition-colors text-sm font-medium">Claim</button>
									</form>
									<form method="POST" action={ templ.SafeURL(fmt.Sprintf("/app/%s/op", space.Slug)) } class="inline">
										<input type="hidden" name="op" value="assign"/>
										<input type="hidden" name="node_id" value={ node.ID }/>
										<input type="hidden" name="assignee" value="hive"/>
										<button type="submit" class="px-3 py-1 bg-violet-500/10 text-violet-400 border border-violet-500/20 rounded-md hover:bg-violet-500/20 transition-colors text-sm font-medium">Assign to agent</button>
									</form>
								</div>
							} else {
								<span class="text-warm-faint text-sm">Unassigned</span>
							}
						</div>
					</div>
					if node.DueDate != nil {
						<div class="space-y-1.5">
							<label class="text-[10px] font-semibold text-warm-faint uppercase tracking-wider">Due</label>
							if node.DueDate.Before(time.Now()) && node.State != StateDone {
								<div class="text-sm text-red-400 font-medium">{ node.DueDate.Format("Jan 2, 2006") } (overdue)</div>
							} else {
								<div class="text-sm text-warm-secondary">{ node.DueDate.Format("Jan 2, 2006") }</div>
							}
						</div>
					}
				</div>
			}

			<!-- Dependencies -->
			if len(dependencies) > 0 || len(dependents) > 0 || len(spaceTasks) > 0 {
				<div class="space-y-3">
					if len(dependencies) > 0 {
						<div>
							<h2 class="text-xs font-semibold text-warm-faint uppercase tracking-wider mb-2">Depends on</h2>
							<div class="space-y-1">
								for _, dep := range dependencies {
									@depRow(dep, space.Slug, node.ID, true)
								}
							</div>
						</div>
					}
					if len(dependents) > 0 {
						<div>
							<h2 class="text-xs font-semibold text-warm-faint uppercase tracking-wider mb-2">Blocking</h2>
							<div class="space-y-1">
								for _, dep := range dependents {
									@depRow(dep, space.Slug, "", false)
								}
							</div>
						</div>
					}
					if len(spaceTasks) > 0 && user.Name != "" && user.Name != "Anonymous" {
						<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="flex items-center gap-2">
							<input type="hidden" name="op" value="depend"/>
							<input type="hidden" name="node_id" value={ node.ID }/>
							<select name="depends_on" required class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-sm text-warm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent">
								<option value="" disabled selected>Add dependency...</option>
								for _, t := range spaceTasks {
									<option value={ t.ID }>{ truncate(t.Title, 60) } ({ stateLabel(t.State) })</option>
								}
							</select>
							<button type="submit" class="px-3 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium flex-shrink-0">Add</button>
						</form>
					}
				</div>
			}

			<!-- Body -->
			if node.Body != "" {
				<div class="bg-surface rounded-lg border border-edge p-4">
					<div class="text-sm text-warm-secondary prose prose-invert prose-sm max-w-none">
			@renderMarkdown(node.Body)
		</div>
				</div>
			}

			<!-- Engagement bar -->
			if node.Kind == KindPost || node.Kind == KindThread {
				<div class="flex items-center gap-4 text-xs text-warm-faint">
					<span>{ fmt.Sprintf("%d replies", node.ChildCount) }</span>
					<div id={ "repost-" + node.ID }>
						@repostButton(node.ID, space.Slug, repostCount, reposted)
					</div>
					<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/feed?quote=%s", space.Slug, node.ID)) } class="hover:text-brand transition-colors">
						quote
					</a>
					<div id={ "endorse-" + node.ID }>
						@endorseButton(node.ID, space.Slug, endorseCount, endorsed)
					</div>
				</div>
			}

			<!-- Edit form -->
			if isOwner && node.Kind != KindComment && node.Kind != KindConversation {
				<div>
					<button onclick="document.getElementById('edit-form').classList.toggle('hidden')" class="text-sm text-brand hover:underline">Edit</button>
					<form id="edit-form" method="POST" action={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s/update", space.Slug, node.ID)) } class="hidden mt-3 bg-surface rounded-lg border border-edge p-4 space-y-3">
						<div>
							<label class="block text-xs font-medium text-warm-muted mb-1">Title</label>
							<input type="text" name="title" value={ node.Title } class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm"/>
						</div>
						<div>
							<label class="block text-xs font-medium text-warm-muted mb-1">
								if node.Kind == KindTask {
									Description
								} else {
									Body
								}
							</label>
							<textarea name="body" rows="4" class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm">{ node.Body }</textarea>
						</div>
						if node.Kind == KindTask {
							<div class="grid grid-cols-2 gap-3">
								<div>
									<label class="block text-xs font-medium text-warm-muted mb-1">Priority</label>
									<select name="priority" class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand text-warm-secondary">
										<option value="low" selected?={ node.Priority == PriorityLow }>Low</option>
										<option value="medium" selected?={ node.Priority == PriorityMedium }>Medium</option>
										<option value="high" selected?={ node.Priority == PriorityHigh }>High</option>
										<option value="urgent" selected?={ node.Priority == PriorityUrgent }>Urgent</option>
									</select>
								</div>
								<div>
									<label class="block text-xs font-medium text-warm-muted mb-1">Assignee</label>
									<input type="text" name="assignee" value={ node.Assignee } class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm" placeholder="Unassigned"/>
								</div>
							</div>
						}
						<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Save changes</button>
					</form>
				</div>
			}

			<!-- Children (subtasks / replies) -->
			if len(children) > 0 {
				<div class="space-y-3">
					<button onclick="var c=document.getElementById('children');c.classList.toggle('hidden');this.querySelector('svg').classList.toggle('rotate-90')" class="flex items-center gap-2 text-sm font-medium text-warm-muted hover:text-warm transition-colors cursor-pointer">
						<svg class="w-3 h-3 rotate-90 transition-transform duration-150" fill="currentColor" viewBox="0 0 20 20"><path d="M6 6L14 10L6 14V6Z"></path></svg>
						if node.Kind == KindTask {
							{ fmt.Sprintf("Subtasks (%d/%d)", countDone(children), len(children)) }
						} else {
							{ fmt.Sprintf("Replies (%d)", len(children)) }
						}
					</button>
					if node.Kind == KindTask {
						<div class="w-full bg-elevated rounded-full h-1.5">
							<div class="bg-brand rounded-full h-1.5 transition-all" style={ childProgressSlice(children) }></div>
						</div>
					}
					<div id="children" class="space-y-2"
					hx-get={ fmt.Sprintf("/app/%s/node/%s/children", space.Slug, node.ID) }
					hx-trigger="every 5s"
					hx-swap="innerHTML"
				>
						for _, child := range children {
							if child.Kind == KindComment {
								@CommentItem(child)
							} else {
								@childRow(child, space.Slug)
							}
						}
					</div>
				</div>
			}

			<!-- Add child -->
			if node.Kind == KindTask && isOwner {
				<div class="bg-elevated rounded-lg border border-edge p-4">
					<h3 class="text-xs font-semibold text-warm-faint uppercase tracking-wider mb-2">Add subtask</h3>
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="flex gap-2">
						<input type="hidden" name="op" value="decompose"/>
						<input type="hidden" name="parent_id" value={ node.ID }/>
						<input type="text" name="title" required placeholder="Subtask title..."
							class="flex-1 px-3 py-1.5 bg-surface border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm text-warm placeholder-warm-faint"/>
						<button type="submit" class="px-3 py-1.5 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">Add</button>
					</form>
				</div>
			}

			<!-- Reply form (for posts and threads) -->
			if node.Kind == KindPost || node.Kind == KindThread {
				<div class="space-y-3">
					<h2 class="text-sm font-medium text-warm-muted">
						{ fmt.Sprintf("Replies (%d)", len(children)) }
					</h2>
					<div id="children" class="space-y-2">
						for _, child := range children {
							@CommentItem(child)
						}
					</div>
					if user.Name != "" && user.Name != "Anonymous" {
						<form
							method="POST"
							action={ templ.SafeURL("/app/" + space.Slug + "/op") }
							hx-post={ "/app/" + space.Slug + "/op" }
							hx-target="#children"
							hx-swap="beforeend"
							hx-on::after-request="if(event.detail.successful) this.reset()"
							class="space-y-2"
						>
							<input type="hidden" name="op" value="respond"/>
							<input type="hidden" name="parent_id" value={ node.ID }/>
							<textarea name="body" placeholder="Write a reply..." required rows="3"
								class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
							<div class="flex justify-end">
								<button type="submit" class="px-3 py-1.5 bg-brand text-void rounded-md hover:bg-brand-dark transition-colors text-sm font-medium">Reply</button>
							</div>
						</form>
					}
				</div>
			}

			<!-- Task workflow: Submit for Review (active) -->
			if node.Kind == KindTask && node.State == StateActive && user.Name != "" && user.Name != "Anonymous" {
				<div id="task-workflow" class="bg-surface rounded-lg border border-edge p-4 space-y-3">
					<h2 class="text-xs font-semibold text-warm-faint uppercase tracking-wider">Submit for Review</h2>
					<p class="text-xs text-warm-muted">Done with this task? Submit your work for review. The task author will be notified.</p>
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="space-y-2">
						<input type="hidden" name="op" value="progress"/>
						<input type="hidden" name="node_id" value={ node.ID }/>
						<textarea name="body" rows="2" placeholder="What did you do? (optional summary of work completed)"
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
						<button type="submit" class="px-4 py-2 bg-amber-500/20 text-amber-400 border border-amber-500/30 rounded-lg hover:bg-amber-500/30 transition-colors text-sm font-medium">
							Submit for Review →
						</button>
					</form>
				</div>
			}

			<!-- Task workflow: Review verdict (review state) -->
			if node.Kind == KindTask && node.State == StateReview && user.Name != "" && user.Name != "Anonymous" {
				<div id="task-review" class="bg-surface rounded-lg border border-amber-500/30 p-4 space-y-3">
					<div class="flex items-center gap-2">
						<span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
						<h2 class="text-xs font-semibold text-amber-400 uppercase tracking-wider">Awaiting Review</h2>
					</div>
					<p class="text-xs text-warm-muted">This task is ready for review. Approve to mark it done, request revisions to send it back, or reject to close it.</p>
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="space-y-3">
						<input type="hidden" name="op" value="review"/>
						<input type="hidden" name="node_id" value={ node.ID }/>
						<textarea name="body" rows="2" placeholder="Feedback for the assignee (required for revisions/rejection)"
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none text-warm placeholder-warm-faint"></textarea>
						<div class="flex gap-2 flex-wrap">
							<button type="submit" name="verdict" value="approve"
								class="px-4 py-2 bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 rounded-lg hover:bg-emerald-500/30 transition-colors text-sm font-medium">
								✓ Approve
							</button>
							<button type="submit" name="verdict" value="revise"
								class="px-4 py-2 bg-amber-500/20 text-amber-400 border border-amber-500/30 rounded-lg hover:bg-amber-500/30 transition-colors text-sm font-medium">
								↩ Request Revisions
							</button>
							<button type="submit" name="verdict" value="reject"
								class="px-4 py-2 bg-red-500/10 text-red-400 border border-red-500/20 rounded-lg hover:bg-red-500/20 transition-colors text-sm font-medium">
								✕ Reject
							</button>
						</div>
					</form>
				</div>
			}

			<!-- Claim evidence actions -->
			if node.Kind == KindClaim && (node.State == ClaimClaimed || node.State == ClaimChallenged) && user.Name != "" && user.Name != "Anonymous" {
				<div class="space-y-3">
					<h2 class="text-sm font-medium text-warm-muted">Epistemic actions</h2>
					<div class="flex gap-2">
						<button type="button" onclick={ toggleForm("detail-challenge") } class="text-xs px-3 py-1.5 bg-amber-500/10 text-amber-400 rounded-lg hover:bg-amber-500/20 transition-colors">
							Challenge
						</button>
						<button type="button" onclick={ toggleForm("detail-verify") } class="text-xs px-3 py-1.5 bg-emerald-500/10 text-emerald-400 rounded-lg hover:bg-emerald-500/20 transition-colors">
							Verify
						</button>
						<button type="button" onclick={ toggleForm("detail-retract") } class="text-xs px-3 py-1.5 bg-red-500/10 text-red-400 rounded-lg hover:bg-red-500/20 transition-colors">
							Retract
						</button>
					</div>
					<form id="detail-challenge" method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="hidden bg-elevated rounded-lg border border-edge p-4 space-y-2">
						<input type="hidden" name="op" value="challenge"/>
						<input type="hidden" name="node_id" value={ node.ID }/>
						<label class="block text-xs font-medium text-amber-400">Why do you challenge this claim?</label>
						<textarea name="reason" required placeholder="Provide counter-evidence or reasoning..." rows="3"
							class="w-full px-3 py-2 bg-surface border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent resize-none"></textarea>
						<button type="submit" class="px-4 py-2 bg-amber-500/20 text-amber-400 rounded-lg hover:bg-amber-500/30 transition-colors text-sm font-medium">Submit challenge</button>
					</form>
					<form id="detail-verify" method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="hidden bg-elevated rounded-lg border border-edge p-4 space-y-2">
						<input type="hidden" name="op" value="verify"/>
						<input type="hidden" name="node_id" value={ node.ID }/>
						<label class="block text-xs font-medium text-emerald-400">Evidence supporting this claim</label>
						<textarea name="reason" placeholder="Provide supporting evidence or reasoning..." rows="3"
							class="w-full px-3 py-2 bg-surface border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent resize-none"></textarea>
						<button type="submit" class="px-4 py-2 bg-emerald-500/20 text-emerald-400 rounded-lg hover:bg-emerald-500/30 transition-colors text-sm font-medium">Confirm verification</button>
					</form>
					<form id="detail-retract" method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="hidden bg-elevated rounded-lg border border-edge p-4 space-y-2">
						<input type="hidden" name="op" value="retract"/>
						<input type="hidden" name="node_id" value={ node.ID }/>
						<label class="block text-xs font-medium text-red-400">Why is this claim being retracted?</label>
						<textarea name="reason" placeholder="Explain why this claim is no longer valid..." rows="3"
							class="w-full px-3 py-2 bg-surface border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent resize-none"></textarea>
						<button type="submit" class="px-4 py-2 bg-red-500/20 text-red-400 rounded-lg hover:bg-red-500/30 transition-colors text-sm font-medium">Confirm retraction</button>
					</form>
				</div>
			}

			<!-- Activity on this node -->
			if len(ops) > 0 {
				<div class="space-y-3">
					if node.Kind == KindClaim {
						<h2 class="text-sm font-medium text-warm-muted">Evidence trail</h2>
					} else {
						<h2 class="text-sm font-medium text-warm-muted">Activity</h2>
					}
					<div class="space-y-1">
						for _, o := range ops {
							<div class="py-1">
								<div class="flex items-center gap-2 text-xs text-warm-faint">
									<span class="font-medium text-warm-secondary">{ o.Actor }</span>
									if o.Op == "review" {
										<span class={ "font-medium px-1.5 py-0.5 rounded-full", reviewVerdictBadgeClass(opVerdict(o.Payload)) }>{ "review: " + opVerdict(o.Payload) }</span>
									} else {
										<span class={ "font-medium px-1.5 py-0.5 rounded-full", opBadgeClass(o.Op) }>{ o.Op }</span>
									}
									<span>{ o.CreatedAt.Format("Jan 2, 3:04 PM") }</span>
								</div>
								if isEvidenceOp(o.Op) && opReason(o.Payload) != "" && opReason(o.Payload) != "challenged" && opReason(o.Payload) != "disputed" {
									<p class="text-xs text-warm-muted mt-1 ml-4 pl-2 border-l-2 border-edge">{ opReason(o.Payload) }</p>
								}
								if o.Op == "review" && opReviewBody(o.Payload) != "" {
									<p class="text-xs text-warm-muted mt-1 ml-4 pl-2 border-l-2 border-edge">{ opReviewBody(o.Payload) }</p>
								}
								if o.Op == "progress" && opProgressBody(o.Payload) != "" {
									<p class="text-xs text-warm-muted mt-1 ml-4 pl-2 border-l-2 border-edge">{ opProgressBody(o.Payload) }</p>
								}
							</div>
						}
					</div>
				</div>
			}

			<!-- Actions -->
			if user.Name != "" && user.Name != "Anonymous" && node.Kind != KindConversation && node.Kind != KindComment {
				<div class="flex gap-2 border-t border-edge pt-4">
					<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") }>
						<input type="hidden" name="op" value="converse"/>
						<input type="hidden" name="title" value={ "Discuss: " + node.Title }/>
						<button type="submit" class="text-xs px-3 py-1.5 bg-sky-500/10 text-sky-400 rounded-lg hover:bg-sky-500/20 transition-colors">
							Discuss this
						</button>
					</form>
				</div>
			}
			<!-- Timestamps + delete -->
			<div class="flex items-center justify-between border-t border-edge pt-4">
				<div class="flex gap-4 text-xs text-warm-faint">
					<span>Created { node.CreatedAt.Format("Jan 2, 2006 3:04 PM") }</span>
					<span>Updated { node.UpdatedAt.Format("Jan 2, 2006 3:04 PM") }</span>
				</div>
				if isOwner {
					<button type="button"
						hx-delete={ fmt.Sprintf("/app/%s/node/%s", space.Slug, node.ID) }
						hx-confirm="Delete this? This cannot be undone."
						class="text-xs text-red-400 hover:text-red-300 transition-colors">
						Delete
					</button>
				}
			</div>
		</div>
	}
}

templ childRow(node Node, spaceSlug string) {
	<a
		href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.ID)) }
		class="flex items-center gap-2 px-3 py-2 rounded-md hover:bg-elevated transition-colors"
	>
		if node.State == StateDone {
			<svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
				<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
			</svg>
		} else {
			<div class="w-4 h-4 rounded-full border-2 border-edge-strong flex-shrink-0"></div>
		}
		<span class={ "text-sm flex-1", templ.KV("line-through text-warm-faint", node.State == StateDone), templ.KV("text-warm", node.State != StateDone) }>
			{ node.Title }
		</span>
		<span class={ "text-[10px] font-medium px-2 py-0.5 rounded-full", stateBgClass(node.State) }>
			{ stateLabel(node.State) }
		</span>
	</a>
}

templ depRow(node Node, spaceSlug string, parentNodeID string, canRemove bool) {
	<div class="flex items-center gap-2 px-3 py-2 rounded-md bg-surface border border-edge hover:border-brand/30 transition-colors">
		<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.ID)) } class="flex items-center gap-2 flex-1 min-w-0">
			if node.State == StateDone {
				<svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
					<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
				</svg>
			} else {
				<div class="w-4 h-4 rounded-full border-2 border-amber-500/50 flex-shrink-0"></div>
			}
			<span class={ "text-sm flex-1 truncate", templ.KV("line-through text-warm-faint", node.State == StateDone), templ.KV("text-warm", node.State != StateDone) }>
				{ node.Title }
			</span>
			<span class={ "text-[10px] font-medium px-2 py-0.5 rounded-full flex-shrink-0", stateBgClass(node.State) }>
				{ stateLabel(node.State) }
			</span>
			if node.Assignee != "" {
				<span class="text-[10px] text-warm-faint flex-shrink-0">{ node.Assignee }</span>
			}
		</a>
		if canRemove && parentNodeID != "" {
			<form method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="flex-shrink-0">
				<input type="hidden" name="op" value="undepend"/>
				<input type="hidden" name="node_id" value={ parentNodeID }/>
				<input type="hidden" name="depends_on" value={ node.ID }/>
				<button type="submit" class="text-[10px] text-warm-faint hover:text-red-400 transition-colors px-1" title="Remove dependency">✕</button>
			</form>
		}
	</div>
}

templ CommentItem(node Node) {
	<div class="bg-surface rounded-lg border border-edge p-4">
		<div class="flex items-center gap-2 mb-2">
			if node.AuthorKind == "agent" {
				<span class="w-6 h-6 rounded-full bg-violet-500/10 text-violet-400 text-xs font-bold flex items-center justify-center" title="Agent">
					{ initial(node.Author) }
				</span>
			} else {
				<span class="w-6 h-6 rounded-full bg-brand/10 text-brand text-xs font-bold flex items-center justify-center">
					{ initial(node.Author) }
				</span>
			}
			<span class="text-sm font-medium text-warm">{ node.Author }</span>
			if node.AuthorKind == "agent" {
				<span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
			}
			<span class="text-xs text-warm-faint">{ node.CreatedAt.Format("Jan 2, 3:04 PM") }</span>
		</div>
		<div class="text-sm text-warm-secondary prose prose-invert prose-sm max-w-none">
			@renderMarkdown(node.Body)
		</div>
	</div>
}

// ── API Keys ─────────────────────────────────────────────────────

templ APIKeysView(keys []ViewAPIKey, user ViewUser) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>API Keys — lovyou.ai</title>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			<script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
			@themeBlock()
		</head>
		<body class="bg-void text-warm-secondary min-h-screen flex flex-col">
			@simpleHeader(user)
			<main class="flex-1 max-w-2xl mx-auto px-4 md:px-6 py-12 w-full">
				<h1 class="text-2xl font-light text-warm mb-2">API Keys</h1>
				<p class="text-sm text-warm-muted mb-8">Authenticate agents and scripts to interact with lovyou.ai programmatically.</p>
				<!-- Create new key -->
				<div class="bg-surface rounded-lg border border-edge p-6 mb-8">
					<h2 class="text-sm font-medium text-warm mb-4">Create new key</h2>
					<form hx-post="/auth/api-keys" hx-target="#key-result" hx-swap="innerHTML" class="space-y-3">
						<div class="flex gap-3">
							<input
								type="text"
								name="name"
								placeholder="Key name (e.g. hive-agent)"
								class="flex-1 text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"
							/>
							<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium whitespace-nowrap">
								Create Key
							</button>
						</div>
						<input
							type="text"
							name="agent_name"
							placeholder="Agent identity (optional — posts appear as this name)"
							class="w-full text-sm px-3 py-2 bg-elevated border border-edge rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-warm placeholder-warm-faint"
						/>
					</form>
					<div id="key-result" class="mt-4"></div>
				</div>
				<!-- Existing keys -->
				if len(keys) > 0 {
					<div class="bg-surface rounded-lg border border-edge">
						<div class="px-6 py-4 border-b border-edge">
							<h2 class="text-sm font-medium text-warm">Your keys</h2>
						</div>
						for _, key := range keys {
							<div class="px-6 py-4 flex items-center justify-between border-b border-edge last:border-0">
								<div>
									<span class="text-sm font-medium text-warm">{ key.Name }</span>
									if key.AgentName != "" {
										<span class="text-xs text-brand ml-2">posts as { key.AgentName }</span>
									}
									<span class="text-xs text-warm-muted ml-3">Created { key.CreatedAt }</span>
								</div>
								<form method="POST" action={ templ.SafeURL("/auth/api-keys/" + key.ID + "/delete") }>
									<button type="submit" class="text-xs text-warm-faint hover:text-red-400 transition-colors">
										Revoke
									</button>
								</form>
							</div>
						}
					</div>
				} else {
					<div class="text-center py-8 text-warm-muted text-sm">
						<p>No API keys yet. Create one to get started.</p>
					</div>
				}
				<!-- Usage -->
				<div class="mt-8 bg-surface rounded-lg border border-edge p-6">
					<h2 class="text-sm font-medium text-warm mb-3">Usage</h2>
					<p class="text-sm text-warm-muted mb-3">Include your API key as a Bearer token in the Authorization header:</p>
					<pre class="text-xs bg-elevated rounded-lg p-4 text-warm-secondary overflow-x-auto"><code>curl -H "Authorization: Bearer lv_..." \
     -H "Accept: application/json" \
     https://lovyou.ai/app/your-space/feed</code></pre>
				</div>
			</main>
			@simpleFooter()
			@commandPalette()
		</body>
	</html>
}

// ── Shared components ───────────────────────────────────────────

templ simpleHeader(user ViewUser) {
	<header class="border-b border-edge bg-surface">
		<nav class="max-w-4xl mx-auto px-4 md:px-6 py-3.5 flex items-center justify-between">
			<a href="/" class="font-display text-xl font-normal text-brand brand-breathe italic">lovyou.ai</a>
			<div class="flex items-center gap-5 text-sm text-warm-muted">
				<a href="/discover" class="hover:text-brand transition-colors">Discover</a>
				<a href="/blog" class="hover:text-brand transition-colors hidden md:inline">Blog</a>
				if user.Name != "" && user.Name != "Anonymous" {
					<div class="flex items-center gap-2 md:ml-1 md:pl-3 md:border-l md:border-edge">
						<a href={ templ.SafeURL("/user/" + user.Name) } class="flex items-center gap-2 hover:opacity-80 transition-opacity">
							if user.Picture != "" {
								<img src={ user.Picture } class="w-6 h-6 rounded-full" alt={ user.Name } referrerpolicy="no-referrer"/>
							} else {
								<span class="w-6 h-6 rounded-full bg-brand/10 text-brand text-xs font-bold flex items-center justify-center">
									{ initial(user.Name) }
								</span>
							}
							<span class="text-warm-muted text-xs hidden md:inline">{ user.Name }</span>
						</a>
						<form method="POST" action="/auth/logout">
							<button type="submit" class="text-xs text-warm-faint hover:text-red-400 transition-colors hidden md:inline">Logout</button>
						</form>
					</div>
				} else {
					<a href="/app" class="px-3 py-1 bg-brand/10 text-brand rounded-md hover:bg-brand/20 transition-colors text-xs font-medium">My Work</a>
				}
			</div>
		</nav>
	</header>
}

templ simpleFooter() {
	<footer class="border-t border-edge bg-surface">
		<div class="max-w-4xl mx-auto px-4 md:px-6 py-8 flex flex-col md:flex-row items-start justify-between gap-6">
			<div>
				<span class="font-display text-sm text-warm-faint italic">lovyou.ai</span>
				<p class="text-[10px] text-warm-faint mt-1">Humans and agents, building together.</p>
			</div>
			<div class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-warm-faint">
				<a href="/discover" class="hover:text-brand transition-colors">Discover</a>
				<a href="/market" class="hover:text-brand transition-colors">Market</a>
				<a href="/knowledge" class="hover:text-brand transition-colors">Knowledge</a>
				<a href="/blog" class="hover:text-brand transition-colors">Blog</a>
				<a href="/reference" class="hover:text-brand transition-colors">Reference</a>
				<a href="https://github.com/lovyou-ai" class="hover:text-brand transition-colors" target="_blank" rel="noopener">GitHub</a>
			</div>
		</div>
	</footer>
}

// ── Helper functions ────────────────────────────────────────────

func stateLabel(state string) string {
	switch state {
	case StateOpen:
		return "Open"
	case StateActive:
		return "Active"
	case StateReview:
		return "Review"
	case StateDone:
		return "Done"
	case StateClosed:
		return "Closed"
	default:
		return state
	}
}

func stateBgClass(state string) string {
	switch state {
	case StateOpen:
		return "bg-warm-faint/20 text-warm-muted"
	case StateActive:
		return "bg-indigo-500/15 text-indigo-400"
	case StateReview:
		return "bg-amber-500/15 text-amber-400"
	case StateDone:
		return "bg-emerald-500/15 text-emerald-400"
	case StateClosed:
		return "bg-warm-faint/20 text-warm-faint"
	default:
		return "bg-warm-faint/20 text-warm-muted"
	}
}

func stateColorHex(state string) string {
	switch state {
	case StateOpen:
		return "#78756e"
	case StateActive:
		return "#818cf8"
	case StateReview:
		return "#fbbf24"
	case StateDone:
		return "#6ec89b"
	case StateClosed:
		return "#4a4844"
	default:
		return "#78756e"
	}
}

func priorityDotHex(priority string) string {
	switch priority {
	case PriorityUrgent:
		return "#e07070"
	case PriorityHigh:
		return "#fbbf24"
	case PriorityMedium:
		return "#e8a0b8"
	case PriorityLow:
		return "#78756e"
	default:
		return "#78756e"
	}
}

func boardEmpty(columns []BoardColumn) bool {
	for _, col := range columns {
		if len(col.Nodes) > 0 {
			return false
		}
	}
	return true
}

func dashboardStateClass(state string) string {
	switch state {
	case StateOpen:
		return "bg-warm-faint/20 text-warm-muted"
	case StateActive:
		return "bg-indigo-500/15 text-indigo-400"
	case StateReview:
		return "bg-amber-500/15 text-amber-400"
	default:
		return "bg-warm-faint/20 text-warm-muted"
	}
}

func dashRelativeTime(t time.Time) string {
	d := time.Since(t)
	switch {
	case d < time.Minute:
		return "now"
	case d < time.Hour:
		return fmt.Sprintf("%dm", int(d.Minutes()))
	case d < 24*time.Hour:
		return fmt.Sprintf("%dh", int(d.Hours()))
	case d < 30*24*time.Hour:
		return fmt.Sprintf("%dd", int(d.Hours()/24))
	default:
		return t.Format("Jan 2")
	}
}

func truncateBody(s string, maxLen int) string {
	if len(s) <= maxLen {
		return s
	}
	return s[:maxLen] + "..."
}

func kindBadgeClass(kind string) string {
	switch kind {
	case KindTask, SpaceProject:
		return "bg-indigo-500/15 text-indigo-400"
	case KindPost, SpaceCommunity:
		return "bg-emerald-500/15 text-emerald-400"
	case KindThread, SpaceTeam:
		return "bg-amber-500/15 text-amber-400"
	case KindComment:
		return "bg-warm-faint/20 text-warm-muted"
	default:
		return "bg-warm-faint/20 text-warm-muted"
	}
}

func opBadgeClass(op string) string {
	switch op {
	case "intend", "decompose":
		return "bg-indigo-500/15 text-indigo-400"
	case "express", "discuss":
		return "bg-emerald-500/15 text-emerald-400"
	case "respond":
		return "bg-warm-faint/20 text-warm-muted"
	case "complete":
		return "bg-emerald-500/15 text-emerald-400"
	case "claim", "assign":
		return "bg-amber-500/15 text-amber-400"
	case "prioritize":
		return "bg-purple-500/15 text-purple-400"
	case "review":
		return "bg-amber-500/15 text-amber-400"
	case "progress":
		return "bg-blue-500/15 text-blue-400"
	default:
		return "bg-warm-faint/20 text-warm-muted"
	}
}

func renderMarkdown(src string) templ.Component {
	var buf bytes.Buffer
	md := goldmark.New()
	if err := md.Convert([]byte(src), &buf); err != nil {
		return templ.Raw("<p>" + src + "</p>")
	}
	return templ.Raw(buf.String())
}

func resolveName(id string, nameMap map[string]string) string {
	if nameMap != nil {
		if name, ok := nameMap[id]; ok {
			return name
		}
	}
	return id
}

func initial(name string) string {
	if name == "" {
		return ""
	}
	runes := []rune(name)
	if len(runes) == 0 {
		return ""
	}
	return string(runes[0:1])
}

func childProgress(node Node) string {
	if node.ChildCount == 0 {
		return "width: 0%"
	}
	pct := (node.ChildDone * 100) / node.ChildCount
	return fmt.Sprintf("width: %d%%", pct)
}

func childProgressSlice(nodes []Node) string {
	if len(nodes) == 0 {
		return "width: 0%"
	}
	done := countDone(nodes)
	pct := (done * 100) / len(nodes)
	return fmt.Sprintf("width: %d%%", pct)
}

func countDone(nodes []Node) int {
	n := 0
	for _, nd := range nodes {
		if nd.State == StateDone {
			n++
		}
	}
	return n
}

func truncate(s string, max int) string {
	if len(s) <= max {
		return s
	}
	return s[:max] + "…"
}

func quotePostPlaceholder(q *Node) string {
	if q != nil {
		return "Add your thoughts..."
	}
	return "What's on your mind?"
}

func containsStr(ss []string, s string) bool {
	for _, v := range ss {
		if v == s {
			return true
		}
	}
	return false
}

func lastMessageTS(messages []Node) string {
	if len(messages) == 0 {
		return time.Now().UTC().Format(time.RFC3339Nano)
	}
	return messages[len(messages)-1].CreatedAt.Format(time.RFC3339Nano)
}

// ── Knowledge lens (Layer 6) ────────────────────────────────────

templ KnowledgeView(space Space, spaces []Space, claims []Node, challengeCounts map[string]int, user ViewUser, searchQuery string) {
	@appLayout(space, spaces, "knowledge", user) {
		<div class="p-6 md:p-8 space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="font-display text-2xl font-light text-warm">Knowledge</h1>
					<p class="text-sm text-warm-muted mt-1">Claims with epistemic status — assert what you know, challenge what you doubt</p>
				</div>
			</div>
			<form action={ templ.SafeURL("/app/" + space.Slug + "/knowledge") } method="GET" class="flex gap-2">
				<input type="text" name="q" value={ searchQuery } placeholder="Search claims..."
					class="flex-1 px-3 py-1.5 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-1 focus:ring-brand"/>
				if searchQuery != "" {
					<a href={ templ.SafeURL("/app/" + space.Slug + "/knowledge") } class="text-xs text-warm-faint hover:text-brand transition-colors flex items-center px-2">Clear</a>
				}
			</form>
			<!-- Create claim form -->
			<form method="POST" action={ templ.SafeURL("/app/" + space.Slug + "/op") } class="bg-surface border border-edge rounded-lg p-5 space-y-3">
				<input type="hidden" name="op" value="assert"/>
				<input
					type="text"
					name="title"
					placeholder="State a claim..."
					required
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent"
				/>
				<textarea
					name="body"
					placeholder="Evidence or reasoning (optional)"
					rows="2"
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-sm text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent resize-none"
				></textarea>
				<button type="submit" class="px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors text-sm font-medium">
					Assert claim
				</button>
			</form>
			if len(claims) == 0 {
				<div class="text-center py-12">
					<p class="text-warm-muted text-lg">No claims yet</p>
					<p class="text-warm-faint text-sm mt-2">Be the first to assert a knowledge claim in this space</p>
				</div>
			} else {
				<div class="space-y-3">
					for _, c := range claims {
						@KnowledgeCard(c, space.Slug, challengeCounts[c.ID])
					}
				</div>
			}
		</div>
	}
}

templ KnowledgeCard(node Node, spaceSlug string, challenges int) {
	<div class="p-5 bg-surface rounded-lg border border-edge hover:border-brand/30 transition-all">
		<div class="flex items-center gap-2 mb-1">
			@claimStatusBadge(node.State)
			<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", spaceSlug, node.ID)) } class="text-sm font-medium text-warm hover:text-brand transition-colors">
				{ node.Title }
			</a>
		</div>
		if node.Body != "" {
			<p class="text-xs text-warm-muted mt-1 line-clamp-2">{ truncate(node.Body, 200) }</p>
		}
		<div class="flex items-center gap-3 mt-2 text-xs text-warm-faint">
			if node.AuthorKind == "agent" {
				<span class="text-violet-400">{ node.Author }</span>
			} else {
				<span>{ node.Author }</span>
			}
			<span>{ node.CreatedAt.Format("Jan 2, 2006") }</span>
			if challenges > 0 {
				<span class="text-amber-400">{ fmt.Sprintf("%d challenge", challenges) }{ pluralS(challenges) }</span>
			}
		</div>
		if node.State == ClaimClaimed || node.State == ClaimChallenged {
			<div class="flex gap-1 mt-3">
				<button type="button" onclick={ toggleForm("challenge-" + node.ID) } class="text-xs px-2 py-1 bg-amber-500/10 text-amber-400 rounded hover:bg-amber-500/20 transition-colors">
					Challenge
				</button>
				<button type="button" onclick={ toggleForm("verify-" + node.ID) } class="text-xs px-2 py-1 bg-emerald-500/10 text-emerald-400 rounded hover:bg-emerald-500/20 transition-colors">
					Verify
				</button>
				<button type="button" onclick={ toggleForm("retract-" + node.ID) } class="text-xs px-2 py-1 bg-red-500/10 text-red-400 rounded hover:bg-red-500/20 transition-colors">
					Retract
				</button>
			</div>
			<form id={ "challenge-" + node.ID } method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="hidden mt-2 space-y-2">
				<input type="hidden" name="op" value="challenge"/>
				<input type="hidden" name="node_id" value={ node.ID }/>
				<textarea name="reason" required placeholder="Why do you challenge this claim?" rows="2"
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent resize-none"></textarea>
				<button type="submit" class="text-xs px-3 py-1.5 bg-amber-500/20 text-amber-400 rounded hover:bg-amber-500/30 transition-colors font-medium">
					Submit challenge
				</button>
			</form>
			<form id={ "verify-" + node.ID } method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="hidden mt-2 space-y-2">
				<input type="hidden" name="op" value="verify"/>
				<input type="hidden" name="node_id" value={ node.ID }/>
				<textarea name="reason" placeholder="Evidence or reasoning for verification (optional)" rows="2"
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent resize-none"></textarea>
				<button type="submit" class="text-xs px-3 py-1.5 bg-emerald-500/20 text-emerald-400 rounded hover:bg-emerald-500/30 transition-colors font-medium">
					Confirm verification
				</button>
			</form>
			<form id={ "retract-" + node.ID } method="POST" action={ templ.SafeURL("/app/" + spaceSlug + "/op") } class="hidden mt-2 space-y-2">
				<input type="hidden" name="op" value="retract"/>
				<input type="hidden" name="node_id" value={ node.ID }/>
				<textarea name="reason" placeholder="Why is this claim being retracted?" rows="2"
					class="w-full px-3 py-2 bg-elevated border border-edge rounded-lg text-xs text-warm placeholder-warm-faint focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent resize-none"></textarea>
				<button type="submit" class="text-xs px-3 py-1.5 bg-red-500/20 text-red-400 rounded hover:bg-red-500/30 transition-colors font-medium">
					Confirm retraction
				</button>
			</form>
		}
	</div>
}

templ claimStatusBadge(state string) {
	switch state {
		case "claimed":
			<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-sky-500/15 text-sky-400">claimed</span>
		case "challenged":
			<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-400">challenged</span>
		case "verified":
			<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-emerald-500/15 text-emerald-400">verified</span>
		case "retracted":
			<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-red-500/15 text-red-400">retracted</span>
		default:
			<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-warm-faint/20 text-warm-muted">{ state }</span>
	}
}

func pluralS(n int) string {
	if n == 1 {
		return ""
	}
	return "s"
}

// opReason extracts the "reason" field from an op's JSON payload.
func opReason(payload json.RawMessage) string {
	if len(payload) == 0 {
		return ""
	}
	var m map[string]string
	if err := json.Unmarshal(payload, &m); err != nil {
		return ""
	}
	return m["reason"]
}

// isEvidenceOp returns true if the op is a knowledge evidence operation.
func isEvidenceOp(op string) bool {
	return op == "challenge" || op == "verify" || op == "retract"
}

// opVerdict extracts the verdict field from a review op payload.
func opVerdict(payload json.RawMessage) string {
	if len(payload) == 0 {
		return ""
	}
	var m map[string]string
	if err := json.Unmarshal(payload, &m); err != nil {
		return ""
	}
	return m["verdict"]
}

// opReviewBody extracts the feedback body from a review op payload.
func opReviewBody(payload json.RawMessage) string {
	if len(payload) == 0 {
		return ""
	}
	var m map[string]string
	if err := json.Unmarshal(payload, &m); err != nil {
		return ""
	}
	return m["body"]
}

// opProgressBody extracts the progress note from a progress op payload.
func opProgressBody(payload json.RawMessage) string {
	if len(payload) == 0 {
		return ""
	}
	var m map[string]string
	if err := json.Unmarshal(payload, &m); err != nil {
		return ""
	}
	return m["body"]
}

// reviewVerdictBadgeClass returns a badge CSS class for a review verdict.
func reviewVerdictBadgeClass(verdict string) string {
	switch verdict {
	case "approve":
		return "bg-emerald-500/15 text-emerald-400"
	case "revise":
		return "bg-amber-500/15 text-amber-400"
	case "reject":
		return "bg-red-500/15 text-red-400"
	default:
		return "bg-amber-500/15 text-amber-400"
	}
}
