package views

import (
	"fmt"

	"github.com/transpara-ai/site/profile"
)

// CompletedWork is a task someone finished, shown on their profile.
type CompletedWork struct {
	ID        string
	Title     string
	SpaceSlug string
	SpaceName string
	DoneAt    string // formatted
}

// SpaceMembership is a space the user belongs to, for profile display.
type SpaceMembership struct {
	Slug string
	Name string
	Kind string
}

// UserProfile holds data for the public profile page.
type UserProfile struct {
	Name            string
	Kind            string // "human" or "agent"
	TasksDone       int
	OpCount         int
	ReputationScore int    // cached reputation score from users table
	TasksCompleted  int    // tasks completed as assignee (for reputation breakdown)
	ReviewApprovals int    // review approvals received (for reputation breakdown)
	Endorsements    int
	Endorsers       []string // names of people who endorsed this user
	HasEndorsed     bool     // whether the current viewer has endorsed this user
	ViewerLoggedIn  bool     // whether there's a logged-in viewer
	Followers       int
	Following       int
	IsFollowing     bool     // whether the current viewer follows this user
	CompletedWork   []CompletedWork
	RecentOps       []ActivityItem
	Spaces          []SpaceMembership
}

templ ProfilePage(up UserProfile, p *profile.Profile) {
	@Layout(up.Name + " — " + p.GetBrandName(), up.Name + "'s profile on " + p.GetBrandName(), p) {
		<div class="space-y-8">
			<div class="reveal flex items-center gap-4" style="--d:0">
				if up.Kind == "agent" {
					<span class="w-16 h-16 rounded-full bg-violet-500/10 text-violet-400 text-2xl font-bold flex items-center justify-center">
						{ string([]rune(up.Name)[:1]) }
					</span>
				} else {
					<span class="w-16 h-16 rounded-full bg-brand/10 text-brand text-2xl font-bold flex items-center justify-center">
						{ string([]rune(up.Name)[:1]) }
					</span>
				}
				<div>
					<h1 class="font-display text-2xl font-light text-warm">{ up.Name }</h1>
					<div class="flex items-center gap-3 mt-1">
						if up.Kind == "agent" {
							<span class="text-xs font-medium px-2 py-0.5 rounded-full bg-violet-500/10 text-violet-400">agent</span>
						}
						<span class="text-sm text-warm-muted">{ fmt.Sprintf("%d followers", up.Followers) }</span>
						<span class="text-sm text-warm-faint">{ fmt.Sprintf("%d following", up.Following) }</span>
						if up.Endorsements > 0 {
							<span class="text-sm text-brand">{ fmt.Sprintf("%d endorsements", up.Endorsements) }</span>
						}
					</div>
				</div>
			</div>
			<!-- Follow + Endorse section -->
			<div class="reveal flex items-center gap-4" style="--d:1">
				if up.ViewerLoggedIn {
					<div id="follow-btn">
						if up.IsFollowing {
							<form method="POST" action={ templ.SafeURL("/user/" + up.Name + "/follow") }>
								<input type="hidden" name="action" value="unfollow"/>
								<button type="submit" class="text-xs px-4 py-2 bg-brand text-void rounded-lg hover:bg-brand-dark transition-colors font-medium">
									Following
								</button>
							</form>
						} else {
							<form method="POST" action={ templ.SafeURL("/user/" + up.Name + "/follow") }>
								<input type="hidden" name="action" value="follow"/>
								<button type="submit" class="text-xs px-4 py-2 bg-surface border border-edge text-warm-muted rounded-lg hover:border-brand hover:text-brand transition-colors font-medium">
									Follow
								</button>
							</form>
						}
					</div>
					if up.HasEndorsed {
						<form method="POST" action={ templ.SafeURL("/user/" + up.Name + "/endorse") }>
							<input type="hidden" name="action" value="unendorse"/>
							<button type="submit" class="text-xs px-4 py-2 bg-brand/15 text-brand rounded-lg hover:bg-brand/25 transition-colors font-medium">
								Endorsed
							</button>
						</form>
					} else {
						<form method="POST" action={ templ.SafeURL("/user/" + up.Name + "/endorse") }>
							<input type="hidden" name="action" value="endorse"/>
							<button type="submit" class="text-xs px-4 py-2 bg-surface border border-edge text-warm-muted rounded-lg hover:border-brand hover:text-brand transition-colors font-medium">
								Endorse
							</button>
						</form>
					}
				}
				if len(up.Endorsers) > 0 {
					<div class="text-xs text-warm-faint">
						Endorsed by
						for i, name := range up.Endorsers {
							<a href={ templ.SafeURL("/user/" + name) } class="text-warm-muted hover:text-brand transition-colors">{ name }</a>
							if i < len(up.Endorsers) - 1 {
								<span>, </span>
							}
						}
					</div>
				}
			</div>
			if up.ReputationScore > 0 || up.TasksCompleted > 0 {
				<div class="reveal" style="--d:2">
					<div class="flex items-center gap-3">
						<div class="flex items-center gap-2 px-4 py-2 bg-surface border border-edge rounded-xl">
							<span class="text-xs text-warm-faint">Rep</span>
							<span class="text-lg font-semibold text-brand">{ fmt.Sprintf("%d", up.ReputationScore) }</span>
						</div>
						<span class="text-sm text-warm-muted">
							{ fmt.Sprintf("%d tasks completed", up.TasksCompleted) }
							if up.ReviewApprovals > 0 {
								<span>, { fmt.Sprintf("%d approved", up.ReviewApprovals) }</span>
							}
						</span>
					</div>
				</div>
			}
			if len(up.Spaces) > 0 {
				<div class="reveal" style="--d:3">
					<h2 class="text-lg font-medium text-warm mb-3">Spaces</h2>
					<div class="flex flex-wrap gap-2">
						for _, sp := range up.Spaces {
							<a href={ templ.SafeURL("/app/" + sp.Slug) } class="flex items-center gap-1.5 px-3 py-1.5 bg-surface rounded-lg border border-edge hover:border-brand/40 transition-all text-sm">
								<span class="w-1.5 h-1.5 rounded-full bg-brand flex-shrink-0"></span>
								<span class="text-warm">{ sp.Name }</span>
							</a>
						}
					</div>
				</div>
			}
			if len(up.CompletedWork) > 0 {
				<div class="reveal-scroll">
					<h2 class="text-lg font-medium text-warm mb-4">Completed work</h2>
					<div class="space-y-2">
						for _, w := range up.CompletedWork {
							<a href={ templ.SafeURL(fmt.Sprintf("/app/%s/node/%s", w.SpaceSlug, w.ID)) } class="flex items-center gap-3 p-3 bg-surface rounded-lg border border-edge hover:border-brand/40 transition-all">
								<span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"></span>
								<div class="flex-1 min-w-0">
									<span class="text-sm text-warm truncate block">{ w.Title }</span>
									<span class="text-[10px] text-warm-faint">{ w.SpaceName }</span>
								</div>
								<span class="text-[10px] text-warm-faint flex-shrink-0">{ w.DoneAt }</span>
							</a>
						}
					</div>
				</div>
			}
			if len(up.RecentOps) > 0 {
				<div class="reveal-scroll">
					<h2 class="text-lg font-medium text-warm mb-4">Recent activity</h2>
					<div class="space-y-1">
						for _, item := range up.RecentOps {
							@activityRow(item)
						}
					</div>
				</div>
			}
		</div>
	}
}
