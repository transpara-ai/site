package graph

import (
	"bytes"
	"encoding/json"
	"fmt"
	"time"

	"github.com/yuin/goldmark"
)

// ── Theme block (shared across app layouts) ─────────────────────

templ themeBlock() {
	<link rel="preconnect" href="https://fonts.googleapis.com"/>
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
	<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,400&display=swap" rel="stylesheet"/>
	<style type="text/tailwindcss">
		@theme {
			--color-brand: #e8a0b8;
			--color-brand-dark: #d4899f;
			--color-void: #09090b;
			--color-surface: #111113;
			--color-elevated: #18181b;
			--color-edge: #1e1e22;
			--color-edge-mid: #2a2a2e;
			--color-edge-strong: #3a3a3f;
			--color-warm: #f0ede8;
			--color-warm-secondary: #c8c4bc;
			--color-warm-muted: #78756e;
			--color-warm-faint: #4a4844;
		}
	</style>
	<style>
		.font-display { font-family: 'Source Serif 4', Georgia, 'Times New Roman', serif; }
		@keyframes breathe {
			0%, 100% { opacity: 0.8; transform: scale(1); }
			50% { opacity: 1; transform: scale(1.03); }
		}
		.brand-breathe { animation: breathe 4s ease-in-out infinite; }
		@keyframes skeleton-pulse { 0%,100%{opacity:0.4} 50%{opacity:0.7} }
		.skeleton { animation: skeleton-pulse 1.5s ease-in-out infinite; background-color: #18181b; border-radius: 0.375rem; }
		@media (prefers-reduced-motion: reduce) {
			.brand-breathe { animation: none; }
			.skeleton { animation: none; }
		}
	</style>
}

// ── AppLayout ───────────────────────────────────────────────────
//
// Two-column layout: sidebar (spaces + lens nav) + main content.

templ appLayout(space Space, spaces []Space, activeLens string, user ViewUser) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ space.Name } — lovyou.ai</title>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			<script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
			@themeBlock()
		</head>
		<body class="bg-void text-warm-secondary h-screen flex flex-col overflow-hidden">
			<header class="border-b border-edge bg-surface flex-shrink-0">
				<nav class="px-4 md:px-6 py-3 flex items-center justify-between">
					<div class="flex items-center gap-2 md:gap-3 min-w-0">
						<a href="/" class="font-display text-xl font-normal text-brand brand-breathe flex-shrink-0 italic">lovyou.ai</a>
						<span class="text-warm-faint/50">/</span>
						<a href="/app" class="text-xs font-medium hover:text-brand transition-colors text-warm-muted hidden md:inline">My Work</a>
						<span class="text-warm-faint/50 hidden md:inline">/</span>
						<span class="text-sm text-warm-secondary truncate">{ space.Name }</span>
					</div>
					<div class="flex items-center gap-5 text-sm text-warm-muted">
						<a href="/discover" class="hover:text-brand transition-colors hidden md:inline">Discover</a>
						<a href="/blog" class="hover:text-brand transition-colors hidden md:inline">Blog</a>
						if user.Name != "" && user.Name != "Anonymous" {
							<div class="flex items-center gap-2 md:ml-1 md:pl-3 md:border-l md:border-edge">
								<a href={ templ.SafeURL("/user/" + user.Name) } class="flex items-center gap-2 hover:opacity-80 transition-opacity">
									if user.Picture != "" {
										<img src={ user.Picture } class="w-6 h-6 rounded-full" alt={ user.Name } referrerpolicy="no-referrer"/>
									} else {
										<span class="w-6 h-6 rounded-full bg-brand/10 text-brand text-xs font-bold flex items-center justify-center">
											{ initial(user.Name) }
										</span>
									}
									<span class="text-warm-muted text-xs hidden md:inline">{ user.Name }</span>
								</a>
								<form method="POST" action="/auth/logout">
									<button type="submit" class="text-xs text-warm-faint hover:text-red-400 transition-colors hidden md:inline">Logout</button>
								</form>
							</div>
						}
					</div>
				</nav>
			</header>
			<!-- Mobile lens bar -->
			<nav class="md:hidden border-b border-edge bg-surface flex-shrink-0">
				<div class="flex px-2 py-1.5 gap-1 overflow-x-auto">
					<a href="/app" class="px-2.5 py-1 text-[11px] rounded-md bg-elevated text-warm-faint whitespace-nowrap">Home</a>
					@mobileLensTab(space.Slug, "board", "Board", activeLens)
					@mobileLensTab(space.Slug, "conversations", "Chat", activeLens)
					@mobileLensTab(space.Slug, "feed", "Feed", activeLens)
					@mobileLensTab(space.Slug, "people", "People", activeLens)
					<button
						onclick="var m=document.getElementById('mobile-more');m.classList.toggle('hidden');this.classList.toggle('bg-brand/10');this.classList.toggle('text-brand')"
						class={ "px-3 py-1.5 text-xs font-medium rounded-md whitespace-nowrap transition-colors",
							templ.KV("bg-brand/10 text-brand", activeLens != "" && activeLens != "board" && activeLens != "conversations" && activeLens != "feed" && activeLens != "people"),
							templ.KV("text-warm-muted hover:text-warm hover:bg-elevated", activeLens == "" || activeLens == "board" || activeLens == "conversations" || activeLens == "feed" || activeLens == "people") }
					>
						More
					</button>
				</div>
				<div
					id="mobile-more"
					class={ "px-2 pb-1.5 flex flex-wrap gap-1",
						templ.KV("hidden", activeLens == "" || activeLens == "board" || activeLens == "conversations" || activeLens == "feed" || activeLens == "people") }
				>
					@mobileLensTab(space.Slug, "projects", "Projects", activeLens)
					@mobileLensTab(space.Slug, "goals", "Goals", activeLens)
					@mobileLensTab(space.Slug, "threads", "Threads", activeLens)
					@mobileLensTab(space.Slug, "knowledge", "Knowledge", activeLens)
					@mobileLensTab(space.Slug, "governance", "Governance", activeLens)
					@mobileLensTab(space.Slug, "roles", "Roles", activeLens)
					@mobileLensTab(space.Slug, "teams", "Teams", activeLens)
					@mobileLensTab(space.Slug, "policies", "Policies", activeLens)
					@mobileLensTab(space.Slug, "changelog", "Build", activeLens)
					@mobileLensTab(space.Slug, "activity", "Activity", activeLens)
					@mobileLensTab(space.Slug, "settings", "Settings", activeLens)
				</div>
			</nav>
			<div class="flex flex-1 min-h-0 overflow-hidden">
				<!-- Sidebar -->
				<aside id="app-sidebar" class="w-60 border-r border-edge bg-surface flex-shrink-0 overflow-y-auto hidden md:block transition-[width] duration-200 ease-out">
					<div class="p-4 space-y-6 sidebar-content">
						<!-- Dashboard link -->
						<a href="/app" class="flex items-center gap-2 px-2.5 py-1.5 text-sm rounded-md hover:bg-elevated text-warm-muted transition-colors relative">
							<svg class="w-4 h-4 text-warm-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
							</svg>
							My Work
							if user.UnreadCount > 0 {
								<span class="ml-auto bg-brand text-void text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0">{ fmt.Sprintf("%d", user.UnreadCount) }</span>
							}
						</a>
						<!-- Core — what every user needs -->
						<div>
							<nav class="space-y-0.5">
								@lensLink(space.Slug, "board", "Board", activeLens, boardIcon())
								@lensLink(space.Slug, "conversations", "Chat", activeLens, conversationsIcon())
								@lensLink(space.Slug, "feed", "Feed", activeLens, feedIcon())
								@lensLink(space.Slug, "people", "People", activeLens, peopleIcon())
							</nav>
						</div>
						<!-- More — expanded on click -->
						<div>
							<button onclick="document.getElementById('sidebar-more').classList.toggle('hidden'); this.querySelector('svg').classList.toggle('rotate-90')" class="flex items-center gap-2 w-full px-3 py-1.5 text-xs text-warm-faint hover:text-brand transition-colors">
								<svg class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
								More
							</button>
							<nav id="sidebar-more" class="hidden space-y-0.5 mt-0.5">
								@lensLink(space.Slug, "projects", "Projects", activeLens, projectsIcon())
								@lensLink(space.Slug, "goals", "Goals", activeLens, goalsIcon())
								@lensLink(space.Slug, "threads", "Threads", activeLens, threadsIcon())
								@lensLink(space.Slug, "knowledge", "Knowledge", activeLens, knowledgeIcon())
								@lensLink(space.Slug, "governance", "Governance", activeLens, governanceIcon())
								@lensLink(space.Slug, "roles", "Roles", activeLens, rolesIcon())
								@lensLink(space.Slug, "teams", "Teams", activeLens, teamsIcon())
								@lensLink(space.Slug, "policies", "Policies", activeLens, policiesIcon())
								@lensLink(space.Slug, "changelog", "Build", activeLens, changelogIcon())
								@lensLink(space.Slug, "activity", "Activity", activeLens, activityIcon())
							</nav>
						</div>
						<div>
							<nav class="space-y-0.5">
								@lensLink(space.Slug, "settings", "Settings", activeLens, settingsIcon())
							</nav>
						</div>
						<!-- Spaces -->
						<div>
							<h2 class="text-[10px] font-semibold text-warm-faint uppercase tracking-wider mb-2">Spaces</h2>
							<nav class="space-y-0.5">
								for _, sp := range spaces {
									<a
										href={ templ.SafeURL("/app/" + sp.Slug) }
										class={ "flex items-center gap-2 px-2.5 py-1.5 text-sm rounded-md transition-colors",
											templ.KV("bg-brand/10 text-brand font-medium", sp.ID == space.ID),
											templ.KV("hover:bg-elevated text-warm-muted", sp.ID != space.ID) }
									>
										<span class="w-1.5 h-1.5 rounded-full bg-brand flex-shrink-0"></span>
										{ sp.Name }
									</a>
								}
							</nav>
							<a
								href="/app"
								class="flex items-center gap-2 px-2.5 py-1.5 mt-1 text-sm text-warm-faint hover:text-brand rounded-md hover:bg-elevated w-full transition-colors"
							>
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
								</svg>
								New space
							</a>
						</div>
					<!-- Collapse toggle -->
						<button onclick="toggleSidebar()" class="w-full flex items-center justify-center py-2 text-warm-faint hover:text-warm-muted transition-colors mt-2" title="Collapse sidebar">
							<svg id="sidebar-collapse-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path></svg>
						</button>
					</div>
				</aside>
				<script>
				function toggleSidebar(){
					var s=document.getElementById('app-sidebar');
					var collapsed=s.classList.toggle('sidebar-collapsed');
					localStorage.setItem('sidebar-collapsed',collapsed?'1':'');
				}
				(function(){if(localStorage.getItem('sidebar-collapsed')==='1'){var s=document.getElementById('app-sidebar');if(s)s.classList.add('sidebar-collapsed')}})();
				</script>
				<style>
				.sidebar-collapsed{width:3rem!important}
				.sidebar-collapsed .sidebar-content h2,
				.sidebar-collapsed .sidebar-content span:not(.w-1\.5):not(.w-4):not(.bg-brand):not(.rounded-full),
				.sidebar-collapsed .sidebar-content a>span.text-warm-muted,
				.sidebar-collapsed .sidebar-content a>svg+span:not(.w-1\.5){font-size:0;overflow:hidden;width:0;padding:0;margin:0}
				.sidebar-collapsed .sidebar-content a{justify-content:center;padding-left:0.5rem;padding-right:0.5rem}
				.sidebar-collapsed .sidebar-content nav a span.ml-auto{display:none}
				.sidebar-collapsed #sidebar-collapse-icon{transform:rotate(180deg)}
				</style>
				<!-- Main content -->
				<main class="flex-1 overflow-y-auto">
					{ children... }
				</main>
			</div>
			@commandPalette()
		</body>
	</html>
}

templ commandPalette() {
	<!-- Toast container -->
	<div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"></div>
	<script>
	function showToast(msg){
		var c=document.getElementById('toast-container');if(!c)return;
		var t=document.createElement('div');
		t.className='pointer-events-auto bg-surface border border-edge rounded-lg shadow-lg px-4 py-2.5 text-sm text-warm flex items-center gap-3 animate-[fadeUp_0.3s_ease]';
		t.innerHTML=msg+'<div class="w-full absolute bottom-0 left-0 h-0.5 bg-brand/30 rounded-b-lg" style="animation:shrink 4s linear forwards"></div>';
		t.style.position='relative';t.style.overflow='hidden';
		c.appendChild(t);
		setTimeout(function(){t.style.opacity='0';t.style.transition='opacity 0.3s';setTimeout(function(){t.remove()},300)},4000);
	}
	document.body.addEventListener('htmx:afterRequest',function(e){
		var xhr=e.detail.xhr;if(!xhr)return;
		var trigger=xhr.getResponseHeader('HX-Trigger');
		if(trigger){try{var j=JSON.parse(trigger);if(j.toast)showToast(j.toast)}catch(e){}}
	});
	</script>
	<style>@keyframes shrink{from{width:100%}to{width:0}}</style>
	<!-- Relative time auto-update -->
	<script>
	(function(){
		function relTime(d){var s=Math.floor((Date.now()-d)/1000);if(s<60)return'now';if(s<3600)return Math.floor(s/60)+'m';if(s<86400)return Math.floor(s/3600)+'h';return Math.floor(s/86400)+'d'}
		setInterval(function(){
			document.querySelectorAll('[data-ts]').forEach(function(el){
				var ts=el.getAttribute('data-ts');if(!ts)return;
				var d=new Date(ts).getTime();if(isNaN(d))return;
				var span=el.querySelector('.rel-time');
				if(span)span.textContent=relTime(d);
			});
		},60000);
	})();
	</script>
	<!-- @mention autocomplete -->
	<div id="mention-dropdown" class="hidden fixed z-50 bg-surface border border-edge rounded-lg shadow-lg overflow-hidden max-h-48 overflow-y-auto"></div>
	<script>
	(function(){
		var dd=document.getElementById('mention-dropdown');
		var activeEl=null, mentionStart=-1;
		function hideMention(){dd.classList.add('hidden');activeEl=null;mentionStart=-1}
		window.insertMention=function(name){
			if(!activeEl)return;
			var v=activeEl.value;
			activeEl.value=v.substring(0,mentionStart)+'@'+name+' '+v.substring(activeEl.selectionStart);
			activeEl.focus();
			activeEl.selectionStart=activeEl.selectionEnd=mentionStart+name.length+2;
			hideMention();
		};
		document.addEventListener('input',function(e){
			var el=e.target;
			if(el.tagName!=='TEXTAREA'&&el.tagName!=='INPUT')return;
			var v=el.value, pos=el.selectionStart;
			// Find @ before cursor
			var i=pos-1;
			while(i>=0&&v[i]!==' '&&v[i]!=='\n')i--;
			if(i+1<pos&&v[i+1]==='@'){
				var q=v.substring(i+2,pos);
				if(q.length>0){
					mentionStart=i+1;activeEl=el;
					fetch('/api/members?q='+encodeURIComponent(q)).then(function(r){return r.text()}).then(function(html){
						if(!html.trim()){hideMention();return}
						dd.innerHTML=html;dd.classList.remove('hidden');
						var rect=el.getBoundingClientRect();
						dd.style.left=rect.left+'px';dd.style.top=(rect.top-dd.offsetHeight-4)+'px';dd.style.minWidth='200px';
					});
					return;
				}
			}
			hideMention();
		});
		document.addEventListener('keydown',function(e){if(e.key==='Escape')hideMention()});
		document.addEventListener('click',function(e){if(!dd.contains(e.target))hideMention()});
	})();
	</script>
	<!-- Keyboard shortcuts -->
	<dialog id="shortcuts-help" class="bg-transparent backdrop:bg-void/60 backdrop:backdrop-blur-sm p-0 m-0 fixed inset-0 w-full h-full z-50">
		<div class="flex items-center justify-center min-h-full" onclick="document.getElementById('shortcuts-help').close()">
			<div class="bg-surface border border-edge rounded-xl shadow-2xl p-6 max-w-sm" onclick="event.stopPropagation()">
				<h2 class="font-display text-lg text-warm mb-4">Keyboard shortcuts</h2>
				<div class="grid grid-cols-2 gap-y-2 gap-x-6 text-sm">
					<kbd class="text-warm-faint">Ctrl+K</kbd><span class="text-warm-muted">Command palette</span>
					<kbd class="text-warm-faint">?</kbd><span class="text-warm-muted">This help</span>
					<kbd class="text-warm-faint">G then B</kbd><span class="text-warm-muted">Go to Board</span>
					<kbd class="text-warm-faint">G then F</kbd><span class="text-warm-muted">Go to Feed</span>
					<kbd class="text-warm-faint">G then C</kbd><span class="text-warm-muted">Go to Chat</span>
					<kbd class="text-warm-faint">G then A</kbd><span class="text-warm-muted">Go to Activity</span>
					<kbd class="text-warm-faint">G then K</kbd><span class="text-warm-muted">Go to Knowledge</span>
					<kbd class="text-warm-faint">G then H</kbd><span class="text-warm-muted">Go Home</span>
				</div>
				<p class="text-[10px] text-warm-faint mt-4">Press Esc to close</p>
			</div>
		</div>
	</dialog>
	<script>
	(function(){
		var gPending=false;
		document.addEventListener('keydown',function(e){
			var t=e.target.tagName;if(t==='INPUT'||t==='TEXTAREA'||t==='SELECT')return;
			if(e.key==='?'&&!e.ctrlKey&&!e.metaKey){e.preventDefault();document.getElementById('shortcuts-help').showModal();return}
			if(e.key==='g'&&!e.ctrlKey&&!e.metaKey){gPending=true;setTimeout(function(){gPending=false},1000);return}
			if(gPending){
				gPending=false;
				var m=window.location.pathname.match(/^\/app\/([^/]+)/);
				var slug=m?m[1]:'';
				var map={b:'board',f:'feed',c:'conversations',a:'activity',k:'knowledge',h:''};
				var lens=map[e.key];
				if(lens!==undefined){
					e.preventDefault();
					if(e.key==='h')window.location='/app';
					else if(slug)window.location='/app/'+slug+'/'+lens;
				}
			}
		});
	})();
	</script>
	<dialog id="cmd-palette" class="bg-transparent backdrop:bg-void/60 backdrop:backdrop-blur-sm p-0 m-0 fixed inset-0 w-full h-full z-50">
		<div class="flex items-start justify-center pt-[20vh] min-h-full" onclick="document.getElementById('cmd-palette').close()">
			<div class="w-full max-w-lg bg-surface border border-edge rounded-xl shadow-2xl shadow-brand/10 overflow-hidden" onclick="event.stopPropagation()">
				<div class="flex items-center gap-2 px-4 py-3 border-b border-edge">
					<svg class="w-4 h-4 text-warm-faint flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
					</svg>
					<input
						id="cmd-palette-input"
						type="text"
						placeholder="Search spaces, tasks, people..."
						class="flex-1 bg-transparent text-sm text-warm placeholder-warm-faint outline-none"
						hx-get="/api/palette"
						hx-trigger="keyup changed delay:150ms"
						hx-target="#cmd-palette-results"
						name="q"
						autocomplete="off"
					/>
					<kbd class="text-[10px] text-warm-faint bg-elevated px-1.5 py-0.5 rounded border border-edge">esc</kbd>
				</div>
				<div id="cmd-palette-results" class="max-h-80 overflow-y-auto py-1">
					<div class="p-4 text-center text-warm-faint text-sm">Type to search...</div>
				</div>
			</div>
		</div>
	</dialog>
	<script>
		(function(){
			var d=document.getElementById('cmd-palette'),inp=document.getElementById('cmd-palette-input');
			document.addEventListener('keydown',function(e){
				if((e.metaKey||e.ctrlKey)&&e.key==='k'){e.preventDefault();d.showModal();inp.value='';inp.focus();return}
				if(e.key==='Escape'&&d.open){d.close();return}
			});
			d.addEventListener('close',function(){inp.value='';document.getElementById('cmd-palette-results').innerHTML='<div class="p-4 text-center text-warm-faint text-sm">Type to search...</div>'});
			// Navigate results with arrow keys and enter
			document.getElementById('cmd-palette-results').addEventListener('keydown',function(e){
				if(e.key==='ArrowDown'||e.key==='ArrowUp'){
					e.preventDefault();
					var links=this.querySelectorAll('a');if(!links.length)return;
					var cur=this.querySelector('a.bg-elevated');
					var idx=cur?Array.from(links).indexOf(cur):-1;
					if(cur)cur.classList.remove('bg-elevated');
					idx=e.key==='ArrowDown'?Math.min(idx+1,links.length-1):Math.max(idx-1,0);
					links[idx].classList.add('bg-elevated');links[idx].scrollIntoView({block:'nearest'});
				}
				if(e.key==='Enter'){var sel=this.querySelector('a.bg-elevated');if(sel)window.location=sel.href;}
			});
			inp.addEventListener('keydown',function(e){
				if(e.key==='ArrowDown'){e.preventDefault();var r=document.getElementById('cmd-palette-results');r.dispatchEvent(new KeyboardEvent('keydown',{key:'ArrowDown'}));}
			});
		})();
	</script>
}

templ lensLink(spaceSlug, lens, label, activeLens string, icon templ.Component) {
	<a
		href={ templ.SafeURL("/app/" + spaceSlug + "/" + lens) }
		class={ "flex items-center gap-2 px-2.5 py-1.5 text-sm rounded-md transition-all duration-200",
			templ.KV("bg-brand/10 text-brand font-medium border-l-2 border-brand", lens == activeLens),
			templ.KV("hover:bg-elevated text-warm-muted hover:text-warm border-l-2 border-transparent", lens != activeLens) }
	>
		@icon
		{ label }
	</a>
}

templ mobileLensTab(spaceSlug, lens, label, activeLens string) {
	<a
		href={ templ.SafeURL("/app/" + spaceSlug + "/" + lens) }
		class={ "px-3 py-1.5 text-xs font-medium rounded-md whitespace-nowrap transition-colors",
			templ.KV("bg-brand/10 text-brand", lens == activeLens),
			templ.KV("text-warm-muted hover:text-warm hover:bg-elevated", lens != activeLens) }
	>
		{ label }
	</a>
}

